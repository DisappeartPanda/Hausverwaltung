# Supabase Konfiguration
# Diese Werte findest du in deinem Supabase Dashboard unter Project Settings > API

PUBLIC_SUPABASE_URL=https://dein-projekt.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# Optional: Für Admin-Operationen (niemals im Browser verwenden!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# Storage Bucket für Dokumente
SUPABASE_DOCUMENTS_BUCKET=documents