---
import BaseLayout from "./BaseLayout.astro";
import { ROUTES } from "../lib/constants/routes";

interface Props {
  title?: string;
  description?: string;
  organizationName?: string | null;
  userEmail?: string | null;
}

const {
  title = "Dashboard | ImmobilienPro",
  description = "Verwaltungsdashboard für ImmobilienPro.",
  organizationName = "ImmobilienPro",
  userEmail = null,
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <main class="page-shell">
    <section class="section">
      <div class="container">
        <div class="row row--between">
          <div class="stack">
            <p class="section__eyebrow">Dashboard</p>
            <h1>{organizationName}</h1>
            {userEmail && <p>Angemeldet als {userEmail}</p>}
          </div>

          <div class="row">
            <a href={ROUTES.APP_DASHBOARD} class="button button--secondary">
              Dashboard
            </a>
            <a href={ROUTES.APP_OBJECTS} class="button button--secondary">
              Objekte
            </a>
            <a href={ROUTES.APP_TENANTS} class="button button--secondary">
              Mieter
            </a>
            <a href={ROUTES.APP_MAINTENANCE} class="button button--secondary">
              Wartungen
            </a>
            <a href={ROUTES.API_LOGOUT} class="button button--ghost">
              Abmelden
            </a>
          </div>
        </div>

        <slot />
      </div>
    </section>
  </main>
</BaseLayout>