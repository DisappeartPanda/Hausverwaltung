---
import '../styles/global.css';
import Navigation from '../components/index/Navigation.astro';

interface Props {
  title: string;
  fullWidth?: boolean;
}

const { title, fullWidth = false } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body class:list={["layout", fullWidth && "full-width"]}>
    <Navigation />

    <div class="dashboard-surface">
      <div class="ui-grid-surface">
        <main class="main-content">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>

<style>
  /* -------------------------------------------------------
     Surface / Background
  ------------------------------------------------------- */
  .dashboard-surface{
    min-height: 100vh;
    background: var(--dark);
    position: relative;
    isolation: isolate; /* eigener stacking context */
  }

  /* ✅ WICHTIG: Overlays dürfen NIE klicken blockieren */
  .dashboard-surface::before,
  .dashboard-surface::after{
    pointer-events: none !important;
    z-index: 0;
  }

  .dashboard-surface::before{
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      var(--dark) 0%,
      var(--dark-light) 50%,
      #064e3b 100%
    );
    opacity: 0.8;
  }

  .dashboard-surface::after{
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 4rem 4rem;
  }

  /* -------------------------------------------------------
     Content Layer (muss über allem liegen + klickbar)
  ------------------------------------------------------- */
  .ui-grid-surface{
    position: relative;
    z-index: 2;
    pointer-events: auto; /* ✅ explizit klickbar */
  }

  /* Falls global.css auf ui-grid-surface Overlays nutzt: kill them */
  .ui-grid-surface::before,
  .ui-grid-surface::after{
    pointer-events: none !important;
  }

  .main-content{
    position: relative;
    z-index: 3;
    pointer-events: auto; /* ✅ explizit klickbar */

    flex: 1;
    overflow-y: auto;

    /* Platz unter sticky/fixed Navbar */
    padding-top: calc(var(--nav-height, 72px) + 16px);

    /* du hattest 100vh — das lassen wir, aber sicher */
    height: 100vh;
  }

  /* Sicherheitsnetz: wenn irgendwo in global.css pointer-events:none gesetzt wurde */
  .main-content *,
  .ui-grid-surface *{
    pointer-events: auto;
  }
</style>