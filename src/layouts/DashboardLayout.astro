---
import Layout from './Layout.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<Layout title={title}>
  <!-- Loading State -->
  <div id="loading" class="flex items-center justify-center min-h-screen bg-gray-50">
    <div class="text-center">
      <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mx-auto"></div>
      <p class="mt-4 text-gray-600">Wird geladen...</p>
    </div>
  </div>

  <!-- Geschützter Content -->
  <div id="app" class="hidden">
    <div class="flex h-screen bg-gray-100">
      <!-- Sidebar -->
      <aside class="w-64 bg-white shadow-md flex flex-col">
        <div class="p-6 border-b">
          <h1 class="text-xl font-bold text-gray-800">🏠 Hausverwaltung</h1>
          <p id="user-name" class="text-sm text-gray-600 mt-1">Laden...</p>
        </div>
        
        <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
          <a href="/dashboard" class="nav-link block px-4 py-2 rounded hover:bg-gray-100 text-gray-700 text-sm" data-path="/dashboard">📊 Dashboard</a>
          <a href="/objekte" class="nav-link block px-4 py-2 rounded hover:bg-gray-100 text-gray-700 text-sm" data-path="/objekte">🏢 Objekte</a>
          <a href="/wohneinheiten" class="nav-link block px-4 py-2 rounded hover:bg-gray-100 text-gray-700 text-sm" data-path="/wohneinheiten">🚪 Wohneinheiten</a>
          <a href="/mieter" class="nav-link block px-4 py-2 rounded hover:bg-gray-100 text-gray-700 text-sm" data-path="/mieter">👥 Mieter</a>
          <a href="/mietvertraege" class="nav-link block px-4 py-2 rounded hover:bg-gray-100 text-gray-700 text-sm" data-path="/mietvertraege">📄 Verträge</a>
          <a href="/zahlungen" class="nav-link block px-4 py-2 rounded hover:bg-gray-100 text-gray-700 text-sm" data-path="/zahlungen">💰 Zahlungen</a>
          <a href="/maengel" class="nav-link block px-4 py-2 rounded hover:bg-gray-100 text-gray-700 text-sm" data-path="/maengel">⚠️ Mängel</a>
          
          <!-- NEU: Instandhaltung -->
          <div class="pt-2 mt-2 border-t">
            <a href="/instandhaltung" class="nav-link block px-4 py-2 rounded hover:bg-gray-100 text-gray-700 text-sm" data-path="/instandhaltung">🔧 Instandhaltung</a>
          </div>
          
          <!-- NEU: Nebenkosten -->
          <div class="pt-2 mt-2 border-t">
            <a href="/nebenkosten" class="nav-link block px-4 py-2 rounded hover:bg-gray-100 text-gray-700 text-sm" data-path="/nebenkosten">📋 Nebenkosten</a>
          </div>
        </nav>
        
        <div class="p-4 border-t">
          <button id="logout" class="w-full px-4 py-2 bg-red-500 text-white rounded hover:bg-red-600 text-sm transition">
            Abmelden
          </button>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 overflow-auto p-6">
        <slot />
      </main>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabase';
  
  const init = async () => {
    const { data: { session } } = await supabase.auth.getSession();
    
    if (!session) {
      window.location.href = '/login';
      return;
    }
    
    // Vermieter-Daten laden
    const { data: vermieter } = await supabase
      .from('vermieter')
      .select('vorname, nachname')
      .eq('user_id', session.user.id)
      .single();
    
    document.getElementById('user-name')!.textContent = 
      vermieter ? `${vermieter.vorname} ${vermieter.nachname}` : 'Unbekannt';
    
    // Aktiven Link markieren
    const currentPath = window.location.pathname;
    document.querySelectorAll('.nav-link').forEach(link => {
      const linkPath = link.getAttribute('data-path');
      if (linkPath && currentPath.startsWith(linkPath)) {
        link.classList.add('bg-blue-100', 'text-blue-800', 'font-medium');
      }
    });
    
    // Loading ausblenden, App einblenden
    document.getElementById('loading')!.classList.add('hidden');
    document.getElementById('app')!.classList.remove('hidden');
  };
  
  document.getElementById('logout')?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.href = '/login';
  });
  
  supabase.auth.onAuthStateChange((event, session) => {
    if (event === 'SIGNED_OUT' || !session) {
      window.location.href = '/login';
    }
  });
  
  init();
</script>