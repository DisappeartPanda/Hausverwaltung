---
import "../styles/tokens.css";
import "../styles/base.css";
import "../styles/components.css";
import "../styles/themes.css";
import "../styles/typography.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "ImmobilienPro",
  description = "Moderne Hausverwaltung für Vermieter, Verwalter und Mieter.",
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <slot />
  </body>
</html>