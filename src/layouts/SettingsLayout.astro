---
import BaseLayout from "./BaseLayout.astro";
import { ROUTES } from "../lib/constants/routes";

interface Props {
  title?: string;
  description?: string;
  userEmail?: string | null;
  organizationName?: string | null;
  activeModules?: string[];
  theme?: string;
}

const {
  title = "Einstellungen | ImmobilienPro",
  description = "Verwalte deine Einstellungen und Kontodaten.",
  userEmail = null,
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <main class="page-shell">
    <section class="section">
      <div class="container">
        <div class="row row--between">
          <div class="stack">
            <p class="section__eyebrow">Einstellungen</p>
            <h1>Kontoeinstellungen</h1>
            {userEmail && <p>Angemeldet als {userEmail}</p>}
          </div>

          <div class="row">
            <a href={ROUTES.APP_DASHBOARD} class="button button--secondary">
              Zurück zum Dashboard
            </a>
            <a href={ROUTES.API_LOGOUT} class="button button--ghost">
              Abmelden
            </a>
          </div>
        </div>

        <slot />
      </div>
    </section>
  </main>
</BaseLayout>