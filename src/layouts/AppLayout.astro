---
import DashboardLayout from "./DashboardLayout.astro";

interface Props {
  title?: string;
  description?: string;
  organizationName?: string | null;
  userEmail?: string | null;
  activeModules?: string[];
  theme?: string;
  tenantName?: string;
}

const {
  title = "ImmobilienPro App",
  description = "Verwaltung von Immobilien, Wohneinheiten, Mietern und Prozessen.",
  organizationName = "ImmobilienPro",
  userEmail = null,
} = Astro.props;
---

<DashboardLayout
  title={title}
  description={description}
  organizationName={organizationName}
  userEmail={userEmail}
>
  <slot />
</DashboardLayout>