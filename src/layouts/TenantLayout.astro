---
import BaseLayout from "./BaseLayout.astro";
import TenantSidebar from "../components/shared/TenantSidebar.astro";

interface Props {
  title?: string;
  description?: string;
  theme?: "dark-green" | "dark-blue" | "light";
  tenantName?: string;
  currentPath?: string;
}

const {
  title = "Mieterportal | ImmobilienPro",
  description = "Dokumente, Mängel und Nachrichten zentral im Mieterportal.",
  theme = "dark-green",
  tenantName = "Max Mustermann",
  currentPath = Astro.url.pathname,
} = Astro.props;
---

<BaseLayout title={title} description={description} theme={theme}>
  <div class="tenant-shell">
    <aside class="tenant-shell__sidebar">
      <TenantSidebar tenantName={tenantName} currentPath={currentPath} />
    </aside>

    <main class="tenant-shell__content">
      <slot />
    </main>
  </div>
</BaseLayout>

<style>
  .tenant-shell {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 18rem 1fr;
  }

  .tenant-shell__sidebar {
    position: sticky;
    top: 0;
    height: 100vh;
    border-right: 1px solid var(--border);
    background: var(--surface-glass);
    backdrop-filter: blur(var(--blur-md));
    -webkit-backdrop-filter: blur(var(--blur-md));
  }

  .tenant-shell__content {
    padding: var(--space-8);
  }

  @media (max-width: 960px) {
    .tenant-shell {
      grid-template-columns: 1fr;
    }

    .tenant-shell__sidebar {
      position: static;
      height: auto;
    }

    .tenant-shell__content {
      padding: var(--space-5);
    }
  }
</style>