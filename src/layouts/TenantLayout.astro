---
import BaseLayout from "./BaseLayout.astro";
import { ROUTES } from "../lib/constants/routes";

interface Props {
  title?: string;
  description?: string;
  userEmail?: string | null;

  // Legacy-Kompatibilität
  tenantName?: string;
  activeModules?: string[];
  theme?: string;
  organizationName?: string;
}

const {
  title = "Mieterbereich | ImmobilienPro",
  description = "Mieterportal für Dokumente, Informationen und Meldungen.",
  userEmail = null,
  tenantName = "Mieterbereich",
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <main class="page-shell">
    <section class="section">
      <div class="container">
        <div class="row row--between">
          <div class="stack">
            <p class="section__eyebrow">Tenant</p>
            <h1>{tenantName}</h1>
            {userEmail && <p>Angemeldet als {userEmail}</p>}
          </div>

          <div class="row">
            <a href={ROUTES.APP_TENANT_HOME} class="button button--secondary">
              Start
            </a>
            <a href={ROUTES.APP_DOCUMENTS} class="button button--secondary">
              Dokumente
            </a>
            <a href={ROUTES.APP_DEFECTS} class="button button--secondary">
              Mängel
            </a>
            <a href={ROUTES.API_LOGOUT} class="button button--ghost">
              Abmelden
            </a>
          </div>
        </div>

        <slot />
      </div>
    </section>
  </main>
</BaseLayout>