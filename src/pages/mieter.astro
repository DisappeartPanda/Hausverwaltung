---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Mieter">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Mieter</h1>
    <a href="/mieter/neu" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm">
      + Neuer Mieter
    </a>
  </div>
  
  <div id="loading" class="text-center py-8">Laden...</div>
  
  <div id="mieter-liste" class="bg-white rounded-lg shadow overflow-hidden hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Kontakt</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Aktueller Vertrag</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Aktionen</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200" id="mieter-tbody">
        <!-- Wird via JS gefüllt -->
      </tbody>
    </table>
  </div>
  
  <div id="keine-mieter" class="hidden text-center py-8 text-gray-500 bg-white rounded-lg shadow">
    <p class="mb-4">Noch keine Mieter vorhanden.</p>
    <a href="/mieter/neu" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm">
      Ersten Mieter anlegen
    </a>
  </div>
</DashboardLayout>

<script>
  import { supabase } from '../lib/supabase';
  
  const loadMieter = async () => {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return;
    
    const { data: vermieter } = await supabase
      .from('vermieter')
      .select('id')
      .eq('user_id', session.user.id)
      .single();
    
    if (!vermieter) return;
    
    // Mieter mit aktiven Verträgen laden
    const { data: mieter } = await supabase
      .from('mieter')
      .select(`
        *,
        mietvertraege (
          id,
          status,
          mietbeginn,
          wohneinheiten (
            bezeichnung,
            objekte (
              bezeichnung
            )
          )
        )
      `)
      .order('nachname');
    
    document.getElementById('loading')!.classList.add('hidden');
    
    if (!mieter || mieter.length === 0) {
      document.getElementById('keine-mieter')!.classList.remove('hidden');
      return;
    }
    
    const tbody = document.getElementById('mieter-tbody')!;
    document.getElementById('mieter-liste')!.classList.remove('hidden');
    
    mieter.forEach(m => {
      const aktiverVertrag = m.mietvertraege?.find((v: any) => v.status === 'aktiv');
      
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td class="px-6 py-4 whitespace-nowrap">
          <div class="text-sm font-medium text-gray-900">${m.nachname}, ${m.vorname}</div>
          <div class="text-sm text-gray-500">${m.geburtsdatum ? new Date(m.geburtsdatum).toLocaleDateString('de-DE') : ''}</div>
        </td>
        <td class="px-6 py-4 whitespace-nowrap">
          <div class="text-sm text-gray-900">${m.email || '-'}</div>
          <div class="text-sm text-gray-500">${m.telefon || '-'}</div>
        </td>
        <td class="px-6 py-4 whitespace-nowrap">
          ${aktiverVertrag 
            ? `<div class="text-sm text-gray-900">${aktiverVertrag.wohneinheiten.objekte.bezeichnung}</div>
               <div class="text-sm text-gray-500">${aktiverVertrag.wohneinheiten.bezeichnung}</div>
               <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Aktiv</span>`
            : `<span class="text-sm text-gray-500">Kein aktiver Vertrag</span>`
          }
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
          <a href="/mieter/${m.id}" class="text-blue-600 hover:text-blue-900 mr-3">Details</a>
          ${!aktiverVertrag ? `<a href="/mietvertraege/neu?mieter=${m.id}" class="text-green-600 hover:text-green-900">Vertrag</a>` : ''}
        </td>
      `;
      tbody.appendChild(tr);
    });
  };
  
  loadMieter();
</script>