---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Objekte">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Meine Objekte</h1>
    <a href="/objekte/neu" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm">
      + Neues Objekt
    </a>
  </div>
  
  <div id="loading" class="text-center py-8">Laden...</div>
  
  <div id="objekte-liste" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 hidden">
    <!-- Wird via JS gefüllt -->
  </div>
  
  <div id="keine-objekte" class="hidden text-center py-8 text-gray-500 bg-white rounded-lg shadow">
    <p class="mb-4">Noch keine Objekte vorhanden.</p>
    <a href="/objekte/neu" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm">
      Erstes Objekt anlegen
    </a>
  </div>
</DashboardLayout>

<script>
  import { supabase } from '../lib/supabase';
  
  const loadObjekte = async () => {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return;
    
    const { data: vermieter } = await supabase
      .from('vermieter')
      .select('id')
      .eq('user_id', session.user.id)
      .single();
    
    if (!vermieter) return;
    
    const { data: objekte } = await supabase
      .from('objekte')
      .select('*')
      .eq('vermieter_id', vermieter.id)
      .order('bezeichnung');
    
    document.getElementById('loading')!.classList.add('hidden');
    
    if (!objekte || objekte.length === 0) {
      document.getElementById('keine-objekte')!.classList.remove('hidden');
      return;
    }
    
    const container = document.getElementById('objekte-liste')!;
    container.classList.remove('hidden');
    
    objekte.forEach(objekt => {
      const card = document.createElement('div');
      card.className = 'bg-white rounded-lg shadow p-6 hover:shadow-md transition';
      card.innerHTML = `
        <h3 class="text-lg font-semibold text-gray-900 mb-2">${objekt.bezeichnung}</h3>
        <p class="text-gray-600 text-sm">${objekt.strasse} ${objekt.hausnummer || ''}</p>
        <p class="text-gray-600 text-sm">${objekt.plz} ${objekt.stadt}</p>
        <div class="mt-3 flex gap-2">
          <span class="px-2 py-1 bg-blue-100 text-blue-800 text-xs rounded-full">${objekt.objekt_typ || 'Wohnhaus'}</span>
          ${objekt.baujahr ? `<span class="px-2 py-1 bg-gray-100 text-gray-800 text-xs rounded-full">Baujahr ${objekt.baujahr}</span>` : ''}
        </div>
        <div class="mt-4 pt-4 border-t flex justify-between items-center">
          <a href="/objekte/${objekt.id}" class="text-blue-600 hover:text-blue-800 text-sm font-medium">Details →</a>
          <a href="/objekte/${objekt.id}/wohneinheiten" class="text-gray-500 hover:text-gray-700 text-sm">Wohneinheiten</a>
        </div>
      `;
      container.appendChild(card);
    });
  };
  
  loadObjekte();
</script>