---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import { BILLING_MODULES, getMergedLimitsForModules } from "../lib/billing/modules";
import { MODULE_KEYS } from "../lib/constants/module-keys";
import { ROUTES } from "../lib/constants/routes";

const combinations = [
  {
    title: "Gebäude + Vermietung",
    description: "Für Verwaltungen, die Haus- und Einheitenebene gemeinsam steuern wollen.",
    modules: [MODULE_KEYS.HAUSVERWALTUNG, MODULE_KEYS.SONDEREIGENTUM],
    priceMonthly: 49,
    comparePrice: 58,
  },
  {
    title: "Vermietung + Mietpool",
    description: "Für Modelle mit Mieterverwaltung und zusätzlicher Ausschüttungslogik.",
    modules: [MODULE_KEYS.SONDEREIGENTUM, MODULE_KEYS.MIETPOOL],
    priceMonthly: 59,
    comparePrice: 68,
  },
  {
    title: "Komplettlösung",
    description: "Für professionelle Verwaltungen mit Gebäude-, Wohnungs- und Poolverwaltung.",
    modules: [
      MODULE_KEYS.HAUSVERWALTUNG,
      MODULE_KEYS.SONDEREIGENTUM,
      MODULE_KEYS.MIETPOOL,
    ],
    priceMonthly: 79,
    comparePrice: 87,
  },
];

type ModuleKey =
  | typeof MODULE_KEYS.HAUSVERWALTUNG
  | typeof MODULE_KEYS.SONDEREIGENTUM
  | typeof MODULE_KEYS.MIETPOOL;

type ComparisonRow = {
  label: string;
  includedIn: ModuleKey[];
};

const comparisonRows: ComparisonRow[] = [
  {
    label: "Objektübersicht",
    includedIn: [MODULE_KEYS.HAUSVERWALTUNG, MODULE_KEYS.SONDEREIGENTUM],
  },
  {
    label: "Eigentümerverwaltung",
    includedIn: [MODULE_KEYS.HAUSVERWALTUNG],
  },
  {
    label: "Wartungen",
    includedIn: [MODULE_KEYS.HAUSVERWALTUNG],
  },
  {
    label: "Rücklagen",
    includedIn: [MODULE_KEYS.HAUSVERWALTUNG, MODULE_KEYS.SONDEREIGENTUM],
  },
  {
    label: "Gebäudemängel",
    includedIn: [MODULE_KEYS.HAUSVERWALTUNG, MODULE_KEYS.SONDEREIGENTUM],
  },
  {
    label: "Wohneinheiten",
    includedIn: [MODULE_KEYS.SONDEREIGENTUM],
  },
  {
    label: "Mieter",
    includedIn: [MODULE_KEYS.SONDEREIGENTUM],
  },
  {
    label: "Dokumente",
    includedIn: [MODULE_KEYS.SONDEREIGENTUM],
  },
  {
    label: "Kommunikation",
    includedIn: [MODULE_KEYS.SONDEREIGENTUM],
  },
  {
    label: "Mietpool-Dashboard",
    includedIn: [MODULE_KEYS.MIETPOOL],
  },
  {
    label: "Auszahlungen",
    includedIn: [MODULE_KEYS.MIETPOOL],
  },
  {
    label: "Poolrücklagen",
    includedIn: [MODULE_KEYS.MIETPOOL],
  },
];

function hasModule(includedIn: string[], moduleKey: string): boolean {
  return includedIn.includes(moduleKey);
}

const addons = [
  "Zusätzliches Objekt",
  "Zusätzliche Wohneinheiten",
  "Zusätzliche Benutzer",
  "Dokumentenspeicher",
  "KI-Assistent",
  "Export & Buchhaltung",
];
---

<MarketingLayout
  title="Preise | ImmobilienPro"
  description="Modulare Preise für moderne Immobilienverwaltung mit flexibel kombinierbaren Modulen."
>
  <section class="section">
    <div class="container">
      <header class="section__header">
        <p class="section__eyebrow">Pricing</p>
        <h1>Modulare Preise für moderne Immobilienverwaltung</h1>
        <p>
          Buche nur die Module, die du wirklich brauchst. Alle Bereiche sind
          unabhängig nutzbar und lassen sich später flexibel kombinieren.
        </p>
      </header>

      <div class="row">
        <span class="badge">Monatlich kündbar</span>
        <span class="badge">Frei kombinierbar</span>
        <span class="badge badge--accent">Später erweiterbar</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section__header">
        <p class="section__eyebrow">Module</p>
        <h2>Wähle die Bausteine, die zu deiner Verwaltung passen</h2>
      </header>

      <div class="grid-auto">
        {
          BILLING_MODULES.map((module) => (
            <article class="card card--glass card--glow">
              <div class="card__body stack">
                <div class="stack">
                  <div class="row row--between">
                    <h3>{module.name}</h3>
                    {module.highlight && (
                      <span class="badge badge--accent">{module.highlight}</span>
                    )}
                  </div>

                  <p>{module.shortDescription}</p>
                  <p><strong>{module.priceMonthly} € / Monat</strong></p>
                </div>

                <div class="stack">
                  <h4>Enthalten</h4>
                  <ul>
                    {module.features.map((feature) => <li>{feature}</li>)}
                  </ul>
                </div>

                <div class="stack">
                  <h4>Limits</h4>
                  <ul>
                    {module.limits.maxObjects !== undefined && (
                      <li>
                        Objekte:{" "}
                        {module.limits.maxObjects === null
                          ? "unbegrenzt"
                          : module.limits.maxObjects}
                      </li>
                    )}
                    {module.limits.maxOwners !== undefined && (
                      <li>
                        Eigentümer:{" "}
                        {module.limits.maxOwners === null
                          ? "unbegrenzt"
                          : module.limits.maxOwners}
                      </li>
                    )}
                    {module.limits.maxUnits !== undefined && (
                      <li>
                        Wohneinheiten:{" "}
                        {module.limits.maxUnits === null
                          ? "unbegrenzt"
                          : module.limits.maxUnits}
                      </li>
                    )}
                    {module.limits.maxTenants !== undefined && (
                      <li>
                        Mieter:{" "}
                        {module.limits.maxTenants === null
                          ? "unbegrenzt"
                          : module.limits.maxTenants}
                      </li>
                    )}
                  </ul>
                </div>

                <div class="row">
                  <a href={ROUTES.AUTH_REGISTER} class="button button--primary">
                    Modul wählen
                  </a>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section__header">
        <p class="section__eyebrow">Kombinationen</p>
        <h2>Beliebte Modul-Kombinationen</h2>
        <p>
          Manche Verwaltungen brauchen mehr als einen Bereich. Dafür sind
          Kombinationen direkt mitgedacht.
        </p>
      </header>

      <div class="grid-auto">
        {
          combinations.map((combo) => {
            const limits = getMergedLimitsForModules(combo.modules);

            return (
              <article class="card card--glass card--glow">
                <div class="card__body stack">
                  <div class="stack">
                    <h3>{combo.title}</h3>
                    <p>{combo.description}</p>
                    <div class="row">
                      {combo.modules.map((module) => <span class="badge">{module}</span>)}
                    </div>
                  </div>

                  <div class="stack">
                    <p><strong>{combo.priceMonthly} € / Monat</strong></p>
                    <p>Statt {combo.comparePrice} € bei Einzelbuchung</p>
                  </div>

                  <div class="stack">
                    <h4>Kombinierte Limits</h4>
                    <ul>
                      {limits.maxObjects !== undefined && (
                        <li>
                          Objekte:{" "}
                          {limits.maxObjects === null ? "unbegrenzt" : limits.maxObjects}
                        </li>
                      )}
                      {limits.maxUnits !== undefined && (
                        <li>
                          Wohneinheiten:{" "}
                          {limits.maxUnits === null ? "unbegrenzt" : limits.maxUnits}
                        </li>
                      )}
                      {limits.maxTenants !== undefined && (
                        <li>
                          Mieter:{" "}
                          {limits.maxTenants === null ? "unbegrenzt" : limits.maxTenants}
                        </li>
                      )}
                    </ul>
                  </div>

                  <div class="row">
                    <a href={ROUTES.AUTH_REGISTER} class="button button--primary">
                      Kombination wählen
                    </a>
                  </div>
                </div>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section__header">
        <p class="section__eyebrow">Vergleich</p>
        <h2>Welche Funktionen in welchem Modul enthalten sind</h2>
      </header>

      <div class="panel">
        <div class="panel__body">
          <div style="overflow-x: auto;">
            <table>
              <thead>
                <tr>
                  <th align="left">Funktion</th>
                  <th align="left">Hausverwaltung</th>
                  <th align="left">Sondereigentum</th>
                  <th align="left">Mietpool</th>
                </tr>
              </thead>
              <tbody>
               {
  comparisonRows.map((row) => (
    <tr>
      <td>{row.label}</td>
      <td>{hasModule(row.includedIn, MODULE_KEYS.HAUSVERWALTUNG) ? "✓" : "—"}</td>
      <td>{hasModule(row.includedIn, MODULE_KEYS.SONDEREIGENTUM) ? "✓" : "—"}</td>
      <td>{hasModule(row.includedIn, MODULE_KEYS.MIETPOOL) ? "✓" : "—"}</td>
    </tr>
  ))
}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section__header">
        <p class="section__eyebrow">Add-ons</p>
        <h2>Erweitere dein Setup bei Bedarf</h2>
        <p>
          Du musst nicht sofort alles buchen. Zusätzliche Funktionen können
          später ergänzt werden.
        </p>
      </header>

      <div class="grid-auto">
        {
          addons.map((addon) => (
            <article class="card card--glass">
              <div class="card__body stack">
                <h3>{addon}</h3>
                <p>
                  Später zubuchbar, wenn deine Verwaltung wächst oder du weitere
                  Anforderungen abdecken willst.
                </p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</MarketingLayout>