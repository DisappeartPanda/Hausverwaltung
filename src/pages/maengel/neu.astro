---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Mangel melden">
  <div class="mb-6">
    <a href="/maengel" class="text-gray-600 hover:text-gray-800 text-sm">← Zurück zu Mängeln</a>
  </div>
  
  <h1 class="text-2xl font-bold mb-6">Neuen Mangel melden</h1>
  
  <form id="mangel-form" class="max-w-2xl bg-white rounded-lg shadow p-6 space-y-6">
    <div>
      <label class="block text-sm font-medium text-gray-700">Wohneinheit *</label>
      <select name="wohneinheit_id" required class="mt-1 block w-full px-3 py-2 border rounded-md">
        <option value="">Bitte wählen...</option>
      </select>
    </div>
    
    <div>
      <label class="block text-sm font-medium text-gray-700">Kategorie *</label>
      <select name="kategorie" required class="mt-1 block w-full px-3 py-2 border rounded-md">
        <option value="sanitaer">Sanitär</option>
        <option value="elektro">Elektro</option>
        <option value="heizung">Heizung</option>
        <option value="fenster_tueren">Fenster/Türen</option>
        <option value="boden_wand">Boden/Wand</option>
        <option value="schimmel">Schimmel</option>
        <option value="laerm">Lärm</option>
        <option value="sonstiges">Sonstiges</option>
      </select>
    </div>
    
    <div>
      <label class="block text-sm font-medium text-gray-700">Titel *</label>
      <input name="titel" type="text" required placeholder="Kurze Beschreibung des Mangels"
        class="mt-1 block w-full px-3 py-2 border rounded-md" />
    </div>
    
    <div>
      <label class="block text-sm font-medium text-gray-700">Detaillierte Beschreibung *</label>
      <textarea name="beschreibung" rows="4" required placeholder="Beschreiben Sie den Mangel genau..."
        class="mt-1 block w-full px-3 py-2 border rounded-md"></textarea>
    </div>
    
    <div>
      <label class="block text-sm font-medium text-gray-700">Ort im Objekt</label>
      <input name="ort_im_objekt" type="text" placeholder="z.B. Badezimmer, Küche links"
        class="mt-1 block w-full px-3 py-2 border rounded-md" />
    </div>
    
    <div class="flex items-center gap-4">
      <label class="flex items-center gap-2">
        <input type="checkbox" name="dringend" class="rounded" />
        <span class="text-sm font-medium text-red-700">Dringend (z.B. Heizungsausfall, Wasserschaden)</span>
      </label>
      
      <label class="flex items-center gap-2">
        <input type="checkbox" name="sicherheitsrelevant" class="rounded" />
        <span class="text-sm font-medium text-orange-700">Sicherheitsrelevant</span>
      </label>
    </div>
    
    <div class="flex gap-4 pt-4">
      <button type="submit" class="px-6 py-2 bg-red-600 text-white rounded hover:bg-red-700">
        Mangel melden
      </button>
      <a href="/maengel" class="px-6 py-2 bg-gray-300 text-gray-700 rounded hover:bg-gray-400">
        Abbrechen
      </a>
    </div>
    
    <div id="error-message" class="hidden p-3 bg-red-100 border border-red-400 text-red-700 rounded text-sm"></div>
  </form>
</DashboardLayout>

<script>
  import { supabase } from '../../lib/supabase';
  
  // Wohneinheiten laden
  const loadEinheiten = async () => {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return;
    
    const { data: einheiten } = await supabase
      .from('wohneinheiten')
      .select(`
        id,
        bezeichnung,
        objekte (bezeichnung)
      `)
      .order('bezeichnung');
    
    const select = document.querySelector('select[name="wohneinheit_id"]') as HTMLSelectElement;
    einheiten?.forEach(e => {
      const option = document.createElement('option');
      option.value = e.id;
      option.textContent = `${e.objekte?.[0]?.bezeichnung || 'Unbekannt'} - ${e.bezeichnung}`;
      select.appendChild(option);
    });
  };
  
  const form = document.getElementById('mangel-form');
  const errorMsg = document.getElementById('error-message');
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg!.classList.add('hidden');
    
    const formData = new FormData(e.target as HTMLFormElement);
    
    const { error } = await supabase
      .from('maengel')
      .insert({
        wohneinheit_id: formData.get('wohneinheit_id'),
        kategorie: formData.get('kategorie'),
        titel: formData.get('titel'),
        beschreibung: formData.get('beschreibung'),
        ort_im_objekt: formData.get('ort_im_objekt') || null,
        dringend: formData.get('dringend') === 'on',
        sicherheitsrelevant: formData.get('sicherheitsrelevant') === 'on',
        status: 'offen',
        gemeldet_am: new Date().toISOString().split('T')[0],
      });
    
    if (error) {
      errorMsg!.textContent = 'Fehler: ' + error.message;
      errorMsg!.classList.remove('hidden');
    } else {
      window.location.href = '/maengel';
    }
  });
  
  loadEinheiten();
</script>