---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Zahlung erfassen">
  <div class="mb-6">
    <a href="/zahlungen" class="text-gray-600 hover:text-gray-800 text-sm">← Zurück zu Zahlungen</a>
  </div>
  
  <h1 class="text-2xl font-bold mb-6">Zahlung erfassen</h1>
  
  <form id="zahlung-form" class="max-w-2xl bg-white rounded-lg shadow p-6 space-y-6">
    <div>
      <label class="block text-sm font-medium text-gray-700">Mietvertrag *</label>
      <select name="mietvertrag_id" required class="mt-1 block w-full px-3 py-2 border rounded-md">
        <option value="">Bitte wählen...</option>
      </select>
    </div>
    
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700">Zahlungsdatum *</label>
        <input name="zahlungsdatum" type="date" required
          class="mt-1 block w-full px-3 py-2 border rounded-md" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Zahlungsmonat *</label>
        <input name="zahlungsmonat" type="month" required
          class="mt-1 block w-full px-3 py-2 border rounded-md" />
      </div>
    </div>
    
    <div>
      <label class="block text-sm font-medium text-gray-700">Betrag (€) *</label>
      <input name="betrag" type="number" step="0.01" required
        class="mt-1 block w-full px-3 py-2 border rounded-md" />
    </div>
    
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700">Zahlungsart</label>
        <select name="zahlungsart" class="mt-1 block w-full px-3 py-2 border rounded-md">
          <option value="ueberweisung">Überweisung</option>
          <option value="lastschrift">Lastschrift</option>
          <option value="bar">Bar</option>
          <option value="scheck">Scheck</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Referenz/Buchungstext</label>
        <input name="referenz" type="text" placeholder="z.B. Miete Januar 2024"
          class="mt-1 block w-full px-3 py-2 border rounded-md" />
      </div>
    </div>
    
    <div class="flex gap-4 pt-4">
      <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
        Zahlung speichern
      </button>
      <a href="/zahlungen" class="px-6 py-2 bg-gray-300 text-gray-700 rounded hover:bg-gray-400">
        Abbrechen
      </a>
    </div>
    
    <div id="error-message" class="hidden p-3 bg-red-100 border border-red-400 text-red-700 rounded text-sm"></div>
  </form>
</DashboardLayout>

<script>
  import { supabase } from '../../lib/supabase';
  
  // Aktive Verträge laden
  const loadVertraege = async () => {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return;
    
    const { data: vertraege } = await supabase
      .from('mietvertraege')
      .select(`
        id,
        gesamtmiete,
        mieter (vorname, nachname),
        wohneinheiten (bezeichnung, objekte (bezeichnung))
      `)
      .eq('status', 'aktiv')
      .order('mietbeginn', { ascending: false });
    
    const select = document.querySelector('select[name="mietvertrag_id"]') as HTMLSelectElement;
    vertraege?.forEach(v => {
      const option = document.createElement('option');
      option.value = v.id;
      // KORRIGIERT: Alle Relationen sind Arrays
      const mieter = v.mieter?.[0];
      const einheit = v.wohneinheiten?.[0];
      const objekt = einheit?.objekte?.[0];
      
      option.textContent = `${mieter?.nachname || 'Unbekannt'}, ${mieter?.vorname || ''} - ${objekt?.bezeichnung || 'Unbekannt'} (${v.gesamtmiete} €)`;
      option.dataset.betrag = String(v.gesamtmiete);
      select.appendChild(option);
    });
    
    // Betrag automatisch füllen
    select.addEventListener('change', (e) => {
      const selected = (e.target as HTMLSelectElement).selectedOptions[0];
      const betrag = selected.dataset.betrag;
      if (betrag) {
        (document.querySelector('input[name="betrag"]') as HTMLInputElement).value = betrag;
      }
    });
    
    // Heute als Default
    (document.querySelector('input[name="zahlungsdatum"]') as HTMLInputElement).valueAsDate = new Date();
  };
  
  const form = document.getElementById('zahlung-form');
  const errorMsg = document.getElementById('error-message');
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg!.classList.add('hidden');
    
    const formData = new FormData(e.target as HTMLFormElement);
    
    const { error } = await supabase
      .from('mietzahlungen')
      .insert({
        mietvertrag_id: formData.get('mietvertrag_id'),
        zahlungsdatum: formData.get('zahlungsdatum'),
        zahlungsmonat: formData.get('zahlungsmonat') + '-01',
        betrag: parseFloat(formData.get('betrag') as string),
        zahlungsart: formData.get('zahlungsart'),
        referenz: formData.get('referenz') || null,
        status: 'eingegangen',
      });
    
    if (error) {
      errorMsg!.textContent = 'Fehler: ' + error.message;
      errorMsg!.classList.remove('hidden');
    } else {
      window.location.href = '/zahlungen';
    }
  });
  
  loadVertraege();
</script>