---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Wohneinheiten">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Wohneinheiten</h1>
    <a href="/wohneinheiten/neu" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm">
      + Neue Einheit
    </a>
  </div>
  
  <!-- Filter nach Objekt -->
  <div class="mb-6">
    <select id="objekt-filter" class="px-4 py-2 border rounded-md bg-white">
      <option value="">Alle Objekte</option>
    </select>
  </div>
  
  <div id="loading" class="text-center py-8">Laden...</div>
  
  <div id="einheiten-liste" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 hidden">
    <!-- Wird via JS gefüllt -->
  </div>
  
  <div id="keine-einheiten" class="hidden text-center py-8 text-gray-500 bg-white rounded-lg shadow">
    <p class="mb-4">Noch keine Wohneinheiten vorhanden.</p>
    <a href="/wohneinheiten/neu" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm">
      Erste Einheit anlegen
    </a>
  </div>
</DashboardLayout>

<script>
  import { supabase } from '../lib/supabase';
  
  let alleEinheiten: any[] = [];
  
  const loadData = async () => {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return;
    
    // Objekte für Filter laden
    const { data: objekte } = await supabase
      .from('objekte')
      .select('id, bezeichnung')
      .order('bezeichnung');
    
    const filterSelect = document.getElementById('objekt-filter') as HTMLSelectElement;
    objekte?.forEach(obj => {
      const option = document.createElement('option');
      option.value = obj.id;
      option.textContent = obj.bezeichnung;
      filterSelect.appendChild(option);
    });
    
    filterSelect.addEventListener('change', (e) => {
      const objektId = (e.target as HTMLSelectElement).value;
      filterEinheiten(objektId);
    });
    
    // Wohneinheiten laden
    const { data: einheiten } = await supabase
      .from('wohneinheiten')
      .select(`
        *,
        objekte (
          id,
          bezeichnung,
          strasse,
          hausnummer
        )
      `)
      .order('bezeichnung');
    
    alleEinheiten = einheiten || [];
    
    document.getElementById('loading')!.classList.add('hidden');
    
    if (alleEinheiten.length === 0) {
      document.getElementById('keine-einheiten')!.classList.remove('hidden');
      return;
    }
    
    renderEinheiten(alleEinheiten);
  };
  
  const renderEinheiten = (einheiten: any[]) => {
    const container = document.getElementById('einheiten-liste')!;
    container.classList.remove('hidden');
    container.innerHTML = '';
    
    einheiten.forEach(einheit => {
      const statusColors = {
        frei: 'bg-green-100 text-green-800',
        vermietet: 'bg-blue-100 text-blue-800',
        reserviert: 'bg-yellow-100 text-yellow-800',
        renovierung: 'bg-gray-100 text-gray-800'
      };
      
      const card = document.createElement('div');
      card.className = 'bg-white rounded-lg shadow p-6 hover:shadow-md transition';
      card.innerHTML = `
        <div class="flex justify-between items-start mb-2">
          <h3 class="text-lg font-semibold text-gray-900">${einheit.bezeichnung}</h3>
          <span class="px-2 py-1 rounded-full text-xs ${statusColors[einheit.status as keyof typeof statusColors] || 'bg-gray-100'}">
            ${einheit.status}
          </span>
        </div>
        <p class="text-sm text-gray-600 mb-1">${einheit.objekte.bezeichnung}</p>
        <p class="text-sm text-gray-500 mb-3">${einheit.objekte.strasse} ${einheit.objekte.hausnummer || ''}</p>
        
        <div class="grid grid-cols-2 gap-2 text-sm mb-3">
          <div><span class="text-gray-500">Fläche:</span> ${einheit.wohnflaeche_m2 || '-'} m²</div>
          <div><span class="text-gray-500">Zimmer:</span> ${einheit.zimmeranzahl || '-'}</div>
        </div>
        
        <div class="pt-3 border-t">
          <p class="text-lg font-bold text-gray-900">${einheit.kaltmiete?.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</p>
          <p class="text-xs text-gray-500">Kaltmiete</p>
        </div>
        
        <div class="mt-4 pt-3 border-t flex justify-between">
          <a href="/wohneinheiten/${einheit.id}" class="text-blue-600 hover:text-blue-800 text-sm">Details →</a>
          ${einheit.status === 'frei' 
            ? `<a href="/mietvertraege/neu?einheit=${einheit.id}" class="text-green-600 hover:text-green-800 text-sm">Vermieten</a>`
            : `<a href="/mietvertraege?einheit=${einheit.id}" class="text-gray-600 hover:text-gray-800 text-sm">Vertrag</a>`
          }
        </div>
      `;
      container.appendChild(card);
    });
  };
  
  const filterEinheiten = (objektId: string) => {
    if (!objektId) {
      renderEinheiten(alleEinheiten);
      return;
    }
    const filtered = alleEinheiten.filter(e => e.objekte.id === objektId);
    renderEinheiten(filtered);
  };
  
  loadData();
</script>