---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Neuer Mieter">
  <div class="mb-6">
    <a href="/mieter" class="text-gray-600 hover:text-gray-800 text-sm">← Zurück zu Mieter</a>
  </div>
  
  <h1 class="text-2xl font-bold mb-6">Neuen Mieter anlegen</h1>
  
  <form id="mieter-form" class="max-w-3xl bg-white rounded-lg shadow p-6 space-y-6">
    <div class="grid grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700">Anrede</label>
        <select name="anrede" class="mt-1 block w-full px-3 py-2 border rounded-md">
          <option value="herr">Herr</option>
          <option value="frau">Frau</option>
          <option value="divers">Divers</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Vorname *</label>
        <input name="vorname" type="text" required class="mt-1 block w-full px-3 py-2 border rounded-md" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Nachname *</label>
        <input name="nachname" type="text" required class="mt-1 block w-full px-3 py-2 border rounded-md" />
      </div>
    </div>
    
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700">Geburtsdatum</label>
        <input name="geburtsdatum" type="date" class="mt-1 block w-full px-3 py-2 border rounded-md" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Geburtsort</label>
        <input name="geburtsort" type="text" class="mt-1 block w-full px-3 py-2 border rounded-md" />
      </div>
    </div>
    
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700">E-Mail</label>
        <input name="email" type="email" class="mt-1 block w-full px-3 py-2 border rounded-md" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Telefon</label>
        <input name="telefon" type="tel" class="mt-1 block w-full px-3 py-2 border rounded-md" />
      </div>
    </div>
    
    <div>
      <label class="block text-sm font-medium text-gray-700">Mobil</label>
      <input name="telefon_mobil" type="tel" class="mt-1 block w-full px-3 py-2 border rounded-md" />
    </div>
    
    <div class="border-t pt-4">
      <h3 class="text-sm font-medium text-gray-900 mb-3">Aktuelle Anschrift (vor Einzug)</h3>
      <div class="grid grid-cols-3 gap-4">
        <div class="col-span-2">
          <input name="aktuelle_strasse" type="text" placeholder="Straße" class="w-full px-3 py-2 border rounded-md" />
        </div>
        <div>
          <input name="aktuelle_plz" type="text" placeholder="PLZ" class="w-full px-3 py-2 border rounded-md" />
        </div>
      </div>
      <input name="aktuelle_stadt" type="text" placeholder="Stadt" class="mt-2 w-full px-3 py-2 border rounded-md" />
    </div>
    
    <div class="border-t pt-4">
      <h3 class="text-sm font-medium text-gray-900 mb-3">Bankverbindung</h3>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <input name="iban" type="text" placeholder="IBAN" class="w-full px-3 py-2 border rounded-md" />
        </div>
        <div>
          <input name="bic" type="text" placeholder="BIC" class="w-full px-3 py-2 border rounded-md" />
        </div>
      </div>
    </div>
    
    <div class="border-t pt-4">
      <h3 class="text-sm font-medium text-gray-900 mb-3">Notfallkontakt</h3>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <input name="notfall_name" type="text" placeholder="Name" class="w-full px-3 py-2 border rounded-md" />
        </div>
        <div>
          <input name="notfall_telefon" type="tel" placeholder="Telefon" class="w-full px-3 py-2 border rounded-md" />
        </div>
      </div>
    </div>
    
    <div>
      <label class="block text-sm font-medium text-gray-700">Notizen</label>
      <textarea name="notizen" rows="3" class="mt-1 block w-full px-3 py-2 border rounded-md"></textarea>
    </div>
    
    <div class="flex gap-4 pt-4">
      <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
        Speichern
      </button>
      <a href="/mieter" class="px-6 py-2 bg-gray-300 text-gray-700 rounded hover:bg-gray-400">
        Abbrechen
      </a>
    </div>
    
    <div id="error-message" class="hidden p-3 bg-red-100 border border-red-400 text-red-700 rounded text-sm"></div>
  </form>
</DashboardLayout>

<script>
  import { supabase } from '../../lib/supabase';
  
  const form = document.getElementById('mieter-form');
  const errorMsg = document.getElementById('error-message');
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg!.classList.add('hidden');
    
    const formData = new FormData(e.target as HTMLFormElement);
    
    const { data, error } = await supabase
      .from('mieter')
      .insert({
        anrede: formData.get('anrede'),
        vorname: formData.get('vorname'),
        nachname: formData.get('nachname'),
        geburtsdatum: formData.get('geburtsdatum') || null,
        geburtsort: formData.get('geburtsort') || null,
        email: formData.get('email') || null,
        telefon: formData.get('telefon') || null,
        telefon_mobil: formData.get('telefon_mobil') || null,
        aktuelle_strasse: formData.get('aktuelle_strasse') || null,
        aktuelle_plz: formData.get('aktuelle_plz') || null,
        aktuelle_stadt: formData.get('aktuelle_stadt') || null,
        iban: formData.get('iban') || null,
        bic: formData.get('bic') || null,
        notfall_name: formData.get('notfall_name') || null,
        notfall_telefon: formData.get('notfall_telefon') || null,
        notizen: formData.get('notizen') || null,
      })
      .select()
      .single();
    
    if (error) {
      errorMsg!.textContent = 'Fehler: ' + error.message;
      errorMsg!.classList.remove('hidden');
    } else {
      // Optional: Direkt zu Vertragserstellung
      const urlParams = new URLSearchParams(window.location.search);
      const redirectTo = urlParams.get('redirect');
      
      if (redirectTo === 'vertrag') {
        window.location.href = `/mietvertraege/neu?mieter=${data.id}`;
      } else {
        window.location.href = '/mieter';
      }
    }
  });
</script>