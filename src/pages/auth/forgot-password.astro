---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { createServerSupabaseClient } from "../../lib/supabase/server";
import { ROUTES } from "../../lib/constants/routes";

let error = "";
let success = "";
let email = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  email = String(formData.get("email") ?? "").trim();

  if (!email) {
    error = "Bitte gib deine E-Mail-Adresse ein.";
  } else {
    const supabase = createServerSupabaseClient(Astro.cookies);

    const { error: resetError } = await supabase.auth.resetPasswordForEmail(
      email,
      {
        redirectTo: new URL(ROUTES.AUTH_RESET_PASSWORD, Astro.url).toString(),
      }
    );

    if (resetError) {
      error = "Passwort-Reset konnte nicht gestartet werden.";
    } else {
      success =
        "Wir haben dir einen Link zum Zurücksetzen deines Passworts geschickt.";
    }
  }
}
---

<BaseLayout title="Passwort vergessen | ImmobilienPro">
  <section class="auth-shell">
    <div class="auth-card">
      <div class="auth-header">
        <p class="eyebrow">Passwort vergessen</p>
        <h1>Passwort zurücksetzen</h1>
        <p class="auth-copy">
          Gib deine E-Mail-Adresse ein. Du erhältst einen Link zum Zurücksetzen
          deines Passworts.
        </p>
      </div>

      {
        error && (
          <div class="auth-alert auth-alert-error" role="alert">
            {error}
          </div>
        )
      }

      {
        success && (
          <div class="auth-alert auth-alert-success" role="status">
            {success}
          </div>
        )
      }

      <form method="POST" class="auth-form">
        <label for="email">E-Mail</label>
        <input
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          required
          value={email}
        />

        <button type="submit">Reset-Link senden</button>
      </form>

      <div class="auth-links">
        <a href={ROUTES.AUTH_LOGIN}>Zurück zum Login</a>
      </div>
    </div>
  </section>
</BaseLayout>