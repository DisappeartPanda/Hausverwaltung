---
import AuthLayout from "../../layouts/AuthLayout.astro";
import { createServerSupabaseClient } from "../../lib/supabase/server";
import { ROUTES } from "../../lib/constants/routes";

let error = "";
let success = "";
let email = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  email = String(formData.get("email") ?? "").trim();

  if (!email) {
    error = "Bitte gib deine E-Mail-Adresse ein.";
    success = "";
  } else {
    const supabase = createServerSupabaseClient(Astro.cookies);

    const { error: resetError } = await supabase.auth.resetPasswordForEmail(
      email,
      {
        redirectTo: new URL(ROUTES.AUTH_RESET_PASSWORD, Astro.url).toString(),
      }
    );

    if (resetError) {
      error = "Passwort-Reset konnte nicht gestartet werden.";
      success = "";
    } else {
      error = "";
      success =
        "Wir haben dir einen Link zum Zurücksetzen deines Passworts geschickt.";
    }
  }
}
---

<AuthLayout title="Passwort vergessen | ImmobilienPro">
  <section class="section">
    <div class="container--md">
      <div class="card card--glass">
        <div class="card__body stack">
          <header class="section__header">
            <p class="section__eyebrow">Passwort vergessen</p>
            <h1>Passwort zurücksetzen</h1>
            <p>
              Gib deine E-Mail-Adresse ein. Du erhältst einen Link zum
              Zurücksetzen deines Passworts.
            </p>
          </header>

          {
            error && (
              <div class="panel">
                <div class="panel__body">
                  <p>{error}</p>
                </div>
              </div>
            )
          }

          {
            success && (
              <div class="panel">
                <div class="panel__body">
                  <p>{success}</p>
                </div>
              </div>
            )
          }

          <form method="POST" class="stack">
            <div class="input-group">
              <label for="email" class="input-label">E-Mail</label>
              <input
                id="email"
                name="email"
                type="email"
                autocomplete="email"
                required
                value={email}
              />
            </div>

            <div class="row">
              <button type="submit" class="button button--primary">
                Reset-Link senden
              </button>
              <a href={ROUTES.AUTH_LOGIN} class="button button--secondary">
                Zurück zum Login
              </a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</AuthLayout>