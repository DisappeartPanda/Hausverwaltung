---
import AuthLayout from "../../layouts/AuthLayout.astro";
import { createServerSupabaseClient } from "../../lib/supabase/server";
import { ROUTES } from "../../lib/constants/routes";
import { ROLES } from "../../lib/constants/roles";

let error = "";
let success = "";

let firstName = "";
let lastName = "";
let email = "";
let role: typeof ROLES.LANDLORD | typeof ROLES.TENANT = ROLES.LANDLORD;
let organizationName = "";
let organizationId = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();

  firstName = String(formData.get("firstName") ?? "").trim();
  lastName = String(formData.get("lastName") ?? "").trim();
  email = String(formData.get("email") ?? "").trim();
  const password = String(formData.get("password") ?? "");
  const confirmPassword = String(formData.get("confirmPassword") ?? "");
  role = String(formData.get("role") ?? ROLES.LANDLORD) as
    | typeof ROLES.LANDLORD
    | typeof ROLES.TENANT;
  organizationName = String(formData.get("organizationName") ?? "").trim();
  organizationId = String(formData.get("organizationId") ?? "").trim();

  if (!firstName || !lastName || !email || !password || !confirmPassword) {
    error = "Bitte fülle alle Pflichtfelder aus.";
    success = "";
  } else if (password !== confirmPassword) {
    error = "Die Passwörter stimmen nicht überein.";
    success = "";
  } else if (password.length < 8) {
    error = "Das Passwort muss mindestens 8 Zeichen lang sein.";
    success = "";
  } else if (role === ROLES.LANDLORD && !organizationName) {
    error = "Bitte gib einen Organisationsnamen an.";
    success = "";
  } else {
    const supabase = createServerSupabaseClient(Astro.cookies);

    const { error: signUpError } = await supabase.auth.signUp({
      email,
      password,
      options: {
        emailRedirectTo: new URL(ROUTES.AUTH_LOGIN, Astro.url).toString(),
        data: {
          first_name: firstName,
          last_name: lastName,
          role,
          organization_name: organizationName || null,
          organization_id: organizationId || null,
        },
      },
    });

    if (signUpError) {
      error = "Registrierung fehlgeschlagen. Bitte versuche es erneut.";
      success = "";
    } else {
      error = "";
      success =
        "Registrierung erfolgreich. Bitte prüfe deine E-Mails für die Bestätigung.";
    }
  }
}
---

<AuthLayout title="Registrierung | ImmobilienPro">
  <section class="section">
    <div class="container--md">
      <div class="card card--glass">
        <div class="card__body stack">
          <header class="section__header">
            <p class="section__eyebrow">Registrierung</p>
            <h1>Neues Konto erstellen</h1>
            <p>
              Registriere dich als Verwalter oder Mieter und starte mit
              ImmobilienPro.
            </p>
          </header>

          {
            error && (
              <div class="panel">
                <div class="panel__body">
                  <p>{error}</p>
                </div>
              </div>
            )
          }

          {
            success && (
              <div class="panel">
                <div class="panel__body">
                  <p>{success}</p>
                </div>
              </div>
            )
          }

          <form method="POST" class="stack">
            <div class="grid-auto">
              <div class="input-group">
                <label for="firstName" class="input-label">Vorname</label>
                <input
                  id="firstName"
                  name="firstName"
                  type="text"
                  autocomplete="given-name"
                  required
                  value={firstName}
                />
              </div>

              <div class="input-group">
                <label for="lastName" class="input-label">Nachname</label>
                <input
                  id="lastName"
                  name="lastName"
                  type="text"
                  autocomplete="family-name"
                  required
                  value={lastName}
                />
              </div>
            </div>

            <div class="input-group">
              <label for="email" class="input-label">E-Mail</label>
              <input
                id="email"
                name="email"
                type="email"
                autocomplete="email"
                required
                value={email}
              />
            </div>

            <div class="grid-auto">
              <div class="input-group">
                <label for="password" class="input-label">Passwort</label>
                <input
                  id="password"
                  name="password"
                  type="password"
                  autocomplete="new-password"
                  required
                />
              </div>

              <div class="input-group">
                <label for="confirmPassword" class="input-label">
                  Passwort bestätigen
                </label>
                <input
                  id="confirmPassword"
                  name="confirmPassword"
                  type="password"
                  autocomplete="new-password"
                  required
                />
              </div>
            </div>

            <div class="input-group">
              <label for="role" class="input-label">Rolle</label>
              <select id="role" name="role">
                <option value={ROLES.LANDLORD} selected={role === ROLES.LANDLORD}>
                  Verwalter / Vermieter
                </option>
                <option value={ROLES.TENANT} selected={role === ROLES.TENANT}>
                  Mieter
                </option>
              </select>
            </div>

            <div class="grid-auto">
              <div class="input-group">
                <label for="organizationName" class="input-label">
                  Organisationsname
                </label>
                <input
                  id="organizationName"
                  name="organizationName"
                  type="text"
                  value={organizationName}
                />
              </div>

              <div class="input-group">
                <label for="organizationId" class="input-label">
                  Organisations-ID
                </label>
                <input
                  id="organizationId"
                  name="organizationId"
                  type="text"
                  value={organizationId}
                />
              </div>
            </div>

            <div class="row">
              <button type="submit" class="button button--primary">
                Konto erstellen
              </button>
              <a href={ROUTES.AUTH_LOGIN} class="button button--secondary">
                Zum Login
              </a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</AuthLayout>