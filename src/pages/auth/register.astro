---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { createServerSupabaseClient } from "../../lib/supabase/server";
import { ROUTES } from "../../lib/constants/routes";
import { ROLES } from "../../lib/constants/roles";

let error = "";
let success = "";

let firstName = "";
let lastName = "";
let email = "";
let role = ROLES.LANDLORD;
let organizationName = "";
let organizationId = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();

  firstName = String(formData.get("firstName") ?? "").trim();
  lastName = String(formData.get("lastName") ?? "").trim();
  email = String(formData.get("email") ?? "").trim();
  const password = String(formData.get("password") ?? "");
  const confirmPassword = String(formData.get("confirmPassword") ?? "");
  role = String(formData.get("role") ?? ROLES.LANDLORD) as
    | typeof ROLES.LANDLORD
    | typeof ROLES.TENANT;
  organizationName = String(formData.get("organizationName") ?? "").trim();
  organizationId = String(formData.get("organizationId") ?? "").trim();

  if (!firstName || !lastName || !email || !password || !confirmPassword) {
    error = "Bitte fülle alle Pflichtfelder aus.";
  } else if (password !== confirmPassword) {
    error = "Die Passwörter stimmen nicht überein.";
  } else if (password.length < 8) {
    error = "Das Passwort muss mindestens 8 Zeichen lang sein.";
  } else if (role === ROLES.LANDLORD && !organizationName) {
    error = "Bitte gib einen Organisationsnamen an.";
  } else {
    const supabase = createServerSupabaseClient(Astro.cookies);

    const { error: signUpError } = await supabase.auth.signUp({
      email,
      password,
      options: {
        emailRedirectTo: new URL(ROUTES.AUTH_LOGIN, Astro.url).toString(),
        data: {
          first_name: firstName,
          last_name: lastName,
          role,
          organization_name: organizationName || null,
          organization_id: organizationId || null,
        },
      },
    });

    if (signUpError) {
      error = "Registrierung fehlgeschlagen. Bitte versuche es erneut.";
    } else {
      success =
        "Registrierung erfolgreich. Bitte prüfe deine E-Mails für die Bestätigung.";
    }
  }
}
---

<BaseLayout title="Registrierung | ImmobilienPro">
  <section class="auth-shell">
    <div class="auth-card">
      <div class="auth-header">
        <p class="eyebrow">Registrierung</p>
        <h1>Neues Konto erstellen</h1>
        <p class="auth-copy">
          Registriere dich als Verwalter oder Mieter und starte mit
          ImmobilienPro.
        </p>
      </div>

      {
        error && (
          <div class="auth-alert auth-alert-error" role="alert">
            {error}
          </div>
        )
      }

      {
        success && (
          <div class="auth-alert auth-alert-success" role="status">
            {success}
          </div>
        )
      }

      <form method="POST" class="auth-form">
        <label for="firstName">Vorname</label>
        <input
          id="firstName"
          name="firstName"
          type="text"
          autocomplete="given-name"
          required
          value={firstName}
        />

        <label for="lastName">Nachname</label>
        <input
          id="lastName"
          name="lastName"
          type="text"
          autocomplete="family-name"
          required
          value={lastName}
        />

        <label for="email">E-Mail</label>
        <input
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          required
          value={email}
        />

        <label for="password">Passwort</label>
        <input
          id="password"
          name="password"
          type="password"
          autocomplete="new-password"
          required
        />

        <label for="confirmPassword">Passwort bestätigen</label>
        <input
          id="confirmPassword"
          name="confirmPassword"
          type="password"
          autocomplete="new-password"
          required
        />

        <label for="role">Rolle</label>
        <select id="role" name="role">
          <option value={ROLES.LANDLORD} selected={role === ROLES.LANDLORD}>
            Verwalter / Vermieter
          </option>
          <option value={ROLES.TENANT} selected={role === ROLES.TENANT}>
            Mieter
          </option>
        </select>

        <label for="organizationName">Organisationsname</label>
        <input
          id="organizationName"
          name="organizationName"
          type="text"
          value={organizationName}
        />

        <label for="organizationId">Organisations-ID</label>
        <input
          id="organizationId"
          name="organizationId"
          type="text"
          value={organizationId}
        />

        <button type="submit">Konto erstellen</button>
      </form>

      <div class="auth-links">
        <a href={ROUTES.AUTH_LOGIN}>Zum Login</a>
      </div>
    </div>
  </section>
</BaseLayout>