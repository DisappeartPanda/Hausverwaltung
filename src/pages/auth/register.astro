---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Registrieren | ImmobilienPro"
  description="Erstelle dein ImmobilienPro-Konto."
>
  <main class="page-shell">
    <div class="container--md">
      <section class="card card--glass">
        <div class="card__body stack">
          <div class="section__header">
            <span class="section__eyebrow">Registrierung</span>
            <h1>Neues Konto erstellen</h1>
            <p>
              Registriere dich als Verwalter oder Mieter und starte mit
              ImmobilienPro.
            </p>
          </div>

          <form id="register-form" class="stack">
            <div class="grid-auto">
              <div class="input-group">
                <label class="input-label" for="firstName">Vorname</label>
                <input id="firstName" name="firstName" required />
              </div>

              <div class="input-group">
                <label class="input-label" for="lastName">Nachname</label>
                <input id="lastName" name="lastName" required />
              </div>
            </div>

            <div class="input-group">
              <label class="input-label" for="email">E-Mail</label>
              <input id="email" name="email" type="email" required />
            </div>

            <div class="input-group">
              <label class="input-label" for="password">Passwort</label>
              <input id="password" name="password" type="password" required />
            </div>

            <div class="input-group">
              <label class="input-label" for="role">Rolle</label>
              <select id="role" name="role">
                <option value="landlord">Verwalter / Vermieter</option>
                <option value="tenant">Mieter</option>
              </select>
            </div>

            <div class="input-group" id="organizationName-group">
              <label class="input-label" for="organizationName">
                Organisationsname
              </label>
              <input
                id="organizationName"
                name="organizationName"
                placeholder="z. B. Musterverwaltung GmbH"
              />
            </div>

            <div class="input-group" id="organizationId-group" style="display: none;">
              <label class="input-label" for="organizationId">
                Organisations-ID
              </label>
              <input
                id="organizationId"
                name="organizationId"
                placeholder="UUID deiner Organisation"
              />
            </div>

            <div class="row">
              <button class="button button--primary" type="submit">
                Konto erstellen
              </button>
              <a class="button button--secondary" href="/auth/login">
                Zum Login
              </a>
            </div>

            <p id="register-status" class="form-status" aria-live="polite"></p>
          </form>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>

<script>
  const form = document.querySelector("#register-form");
  const statusEl = document.querySelector("#register-status");
  const roleSelect = document.querySelector("#role");
  const organizationNameGroup = document.querySelector("#organizationName-group");
  const organizationIdGroup = document.querySelector("#organizationId-group");

  function updateRoleFields() {
    const role = roleSelect?.value;

    if (role === "tenant") {
      if (organizationNameGroup) organizationNameGroup.style.display = "none";
      if (organizationIdGroup) organizationIdGroup.style.display = "";
    } else {
      if (organizationNameGroup) organizationNameGroup.style.display = "";
      if (organizationIdGroup) organizationIdGroup.style.display = "none";
    }
  }

  roleSelect?.addEventListener("change", updateRoleFields);
  updateRoleFields();

  async function bootstrapAccount(role, values) {
    if (role === "tenant") {
      const response = await fetch("/api/auth/bootstrap-tenant", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          organizationId: values.organizationId
        })
      });

      return response.json();
    }

    const response = await fetch("/api/auth/bootstrap-landlord", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        organizationName: values.organizationName
      })
    });

    return response.json();
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const formData = new FormData(form);
    const payload = Object.fromEntries(formData.entries());

    try {
      const registerResponse = await fetch("/api/auth/register", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify(payload)
      });

      const registerResult = await registerResponse.json();

      if (!registerResponse.ok || !registerResult.success) {
        statusEl.textContent =
          registerResult?.errors?.form ||
          Object.values(registerResult?.errors || {})[0] ||
          "Registrierung fehlgeschlagen.";
        return;
      }

      if (registerResult.data.requiresEmailConfirmation) {
        statusEl.textContent =
          "Registrierung erfolgreich. Bitte bestätige zuerst deine E-Mail-Adresse.";
        form.reset();
        updateRoleFields();
        return;
      }

      const bootstrapResult = await bootstrapAccount(payload.role, payload);

      if (!bootstrapResult.success) {
        statusEl.textContent =
          bootstrapResult?.errors?.form ||
          Object.values(bootstrapResult?.errors || {})[0] ||
          "Konto wurde erstellt, aber das Setup konnte nicht abgeschlossen werden.";
        return;
      }

      statusEl.textContent = "Registrierung erfolgreich. Du wirst weitergeleitet.";
      window.location.href =
        payload.role === "tenant" ? "/tenant" : "/app/dashboard";
    } catch {
      statusEl.textContent = "Bei der Registrierung ist ein Fehler aufgetreten.";
    }
  });
</script>

<style>
  .form-status {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }
</style>