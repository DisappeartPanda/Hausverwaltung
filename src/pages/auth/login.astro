---
import AuthLayout from "../../layouts/AuthLayout.astro";
import { createServerSupabaseClient } from "../../lib/supabase/server";
import { ROUTES } from "../../lib/constants/routes";
import { getPostLoginRoute } from "../../lib/auth/redirects";
import { getUserRole } from "../../lib/auth/user-role";

let error = "";
let email = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();

  email = String(formData.get("email") ?? "").trim();
  const password = String(formData.get("password") ?? "");

  if (!email || !password) {
    error = "Bitte gib E-Mail und Passwort ein.";
  } else {
    const supabase = createServerSupabaseClient(Astro.cookies);

    const { error: signInError } = await supabase.auth.signInWithPassword({
      email,
      password,
    });

    if (signInError) {
      error = "Anmeldung fehlgeschlagen. Bitte prüfe deine Zugangsdaten.";
    } else {
      const {
        data: { user },
      } = await supabase.auth.getUser();

      const role = getUserRole(user);

      return Astro.redirect(getPostLoginRoute(role));
    }
  }
}
---

<AuthLayout title="Login | ImmobilienPro">
  <section class="section">
    <div class="container--md">
      <div class="card card--glass">
        <div class="card__body stack">
          <header class="section__header">
            <p class="section__eyebrow">Login</p>
            <h1>Bei ImmobilienPro anmelden</h1>
            <p>
              Melde dich mit deinem Konto an, um auf Verwaltung oder
              Mieterportal zuzugreifen.
            </p>
          </header>

          {
            error && (
              <div class="panel">
                <div class="panel__body">
                  <p>{error}</p>
                </div>
              </div>
            )
          }

          <form method="POST" class="stack">
            <div class="input-group">
              <label for="email" class="input-label">E-Mail</label>
              <input
                id="email"
                name="email"
                type="email"
                autocomplete="email"
                required
                value={email}
              />
            </div>

            <div class="input-group">
              <label for="password" class="input-label">Passwort</label>
              <input
                id="password"
                name="password"
                type="password"
                autocomplete="current-password"
                required
              />
            </div>

            <div class="row">
              <button type="submit" class="button button--primary">
                Anmelden
              </button>
              <a href={ROUTES.AUTH_REGISTER} class="button button--secondary">
                Registrieren
              </a>
            </div>
          </form>

          <div class="row">
            <a href={ROUTES.AUTH_FORGOT_PASSWORD}>Passwort vergessen?</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</AuthLayout>