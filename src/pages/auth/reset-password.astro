---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ROUTES } from "../../lib/constants/routes";

let error = "";
let success = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const password = String(formData.get("password") ?? "");
  const confirmPassword = String(formData.get("confirmPassword") ?? "");

  if (!password || !confirmPassword) {
    error = "Bitte fülle beide Passwortfelder aus.";
  } else if (password !== confirmPassword) {
    error = "Die Passwörter stimmen nicht überein.";
  } else if (password.length < 8) {
    error = "Das Passwort muss mindestens 8 Zeichen lang sein.";
  } else {
    const supabase = Astro.locals.supabase;

    const { error: updateError } = await supabase.auth.updateUser({
      password,
    });

    if (updateError) {
      error = "Das Passwort konnte nicht aktualisiert werden.";
    } else {
      success = "Dein Passwort wurde erfolgreich aktualisiert.";
    }
  }
}
---

<BaseLayout title="Neues Passwort | ImmobilienPro">
  <section class="auth-shell">
    <div class="auth-card">
      <div class="auth-header">
        <p class="eyebrow">Neues Passwort</p>
        <h1>Passwort neu setzen</h1>
        <p class="auth-copy">
          Vergib jetzt ein neues Passwort für dein Konto.
        </p>
      </div>

      {
        error && (
          <div class="auth-alert auth-alert-error" role="alert">
            {error}
          </div>
        )
      }

      {
        success && (
          <div class="auth-alert auth-alert-success" role="status">
            {success}
          </div>
        )
      }

      <form method="POST" class="auth-form">
        <label for="password">Neues Passwort</label>
        <input
          id="password"
          name="password"
          type="password"
          autocomplete="new-password"
          required
        />

        <label for="confirmPassword">Neues Passwort bestätigen</label>
        <input
          id="confirmPassword"
          name="confirmPassword"
          type="password"
          autocomplete="new-password"
          required
        />

        <button type="submit">Passwort speichern</button>
      </form>

      <div class="auth-links">
        <a href={ROUTES.AUTH_LOGIN}>Zum Login</a>
      </div>
    </div>
  </section>
</BaseLayout>