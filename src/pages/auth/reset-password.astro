---
import AuthLayout from "../../layouts/AuthLayout.astro";
import { ROUTES } from "../../lib/constants/routes";

let error = "";
let success = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const password = String(formData.get("password") ?? "");
  const confirmPassword = String(formData.get("confirmPassword") ?? "");

  if (!Astro.locals.session) {
    error = "Dein Reset-Link ist ungültig oder abgelaufen.";
    success = "";
  } else if (!password || !confirmPassword) {
    error = "Bitte fülle beide Passwortfelder aus.";
    success = "";
  } else if (password !== confirmPassword) {
    error = "Die Passwörter stimmen nicht überein.";
    success = "";
  } else if (password.length < 8) {
    error = "Das Passwort muss mindestens 8 Zeichen lang sein.";
    success = "";
  } else {
    const supabase = Astro.locals.supabase;

    const { error: updateError } = await supabase.auth.updateUser({
      password,
    });

    if (updateError) {
      error = "Das Passwort konnte nicht aktualisiert werden.";
      success = "";
    } else {
      error = "";
      success = "Dein Passwort wurde erfolgreich aktualisiert.";
    }
  }
}
---

<AuthLayout title="Neues Passwort | ImmobilienPro">
  <section class="section">
    <div class="container--md">
      <div class="card card--glass">
        <div class="card__body stack">
          <header class="section__header">
            <p class="section__eyebrow">Neues Passwort</p>
            <h1>Passwort neu setzen</h1>
            <p>Vergib jetzt ein neues Passwort für dein Konto.</p>
          </header>

          {
            error && (
              <div class="panel">
                <div class="panel__body">
                  <p>{error}</p>
                </div>
              </div>
            )
          }

          {
            success && (
              <div class="panel">
                <div class="panel__body stack">
                  <p>{success}</p>
                  <div class="row">
                    <a href={ROUTES.AUTH_LOGIN} class="button button--primary">
                      Zum Login
                    </a>
                  </div>
                </div>
              </div>
            )
          }

          <form method="POST" class="stack">
            <div class="input-group">
              <label for="password" class="input-label">Neues Passwort</label>
              <input
                id="password"
                name="password"
                type="password"
                autocomplete="new-password"
                required
              />
            </div>

            <div class="input-group">
              <label for="confirmPassword" class="input-label">
                Neues Passwort bestätigen
              </label>
              <input
                id="confirmPassword"
                name="confirmPassword"
                type="password"
                autocomplete="new-password"
                required
              />
            </div>

            <div class="row">
              <button type="submit" class="button button--primary">
                Passwort speichern
              </button>
              <a href={ROUTES.AUTH_LOGIN} class="button button--secondary">
                Zum Login
              </a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</AuthLayout>