---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { supabase } from '../../lib/supabase';

const { id } = Astro.params;

// Auth
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

// Wartung mit Belegen laden
const { data: wartung, error } = await supabase
  .from('instandhaltung')
  .select(`
    *,
    objekte(bezeichnung, adresse),
    instandhaltung_belege(*)
  `)
  .eq('id', id)
  .single();

if (error || !wartung) return Astro.redirect('/instandhaltung');

// Prüfen ob Vermieter berechtigt ist
const { data: objektCheck } = await supabase
  .from('objekte')
  .select('vermieter_id')
  .eq('id', wartung.objekt_id)
  .single();

if (objektCheck?.vermieter_id !== session.user.id) {
  return Astro.redirect('/instandhaltung');
}

const gesamtkosten = wartung.kosten_material + wartung.kosten_lohn + wartung.kosten_sonstige;
const istUeberfaellig = wartung.naechste_wartung && new Date(wartung.naechste_wartung) < new Date() && wartung.status === 'Geplant';
---

<DashboardLayout title={`Wartung: ${wartung.kategorie}`}>
  <div class="max-w-4xl mx-auto space-y-6">
    <!-- Header mit Status -->
    <div class="flex justify-between items-start">
      <div>
        <a href="/instandhaltung" class="text-sm text-gray-600 hover:text-gray-900">← Zurück zur Übersicht</a>
        <h1 class="text-2xl font-bold text-gray-900 mt-2">{wartung.kategorie}</h1>
        <p class="text-gray-600">{wartung.objekte.bezeichnung} • {wartung.position}</p>
      </div>
      <div class="flex gap-2">
        <span class={`px-3 py-1 rounded-full text-sm font-medium ${
          wartung.status === 'Erledigt' ? 'bg-green-100 text-green-800' :
          wartung.status === 'Überfällig' || istUeberfaellig ? 'bg-red-100 text-red-800' :
          wartung.status === 'In Bearbeitung' ? 'bg-yellow-100 text-yellow-800' :
          'bg-blue-100 text-blue-800'
        }`}>
          {istUeberfaellig ? 'Überfällig' : wartung.status}
        </span>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Hauptinfo -->
      <div class="md:col-span-2 space-y-6">
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="font-semibold text-gray-900 mb-4">Beschreibung</h2>
          <p class="text-gray-700 whitespace-pre-wrap">{wartung.beschreibung}</p>
        </div>

        <!-- Kosten -->
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="font-semibold text-gray-900 mb-4">Kostenaufstellung</h2>
          <div class="space-y-2">
            <div class="flex justify-between">
              <span class="text-gray-600">Materialkosten:</span>
              <span>{wartung.kosten_material.toLocaleString('de-DE')} €</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600">Lohnkosten:</span>
              <span>{wartung.kosten_lohn.toLocaleString('de-DE')} €</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600">Sonstige:</span>
              <span>{wartung.kosten_sonstige.toLocaleString('de-DE')} €</span>
            </div>
            <div class="border-t pt-2 flex justify-between font-bold">
              <span>Gesamt:</span>
              <span>{gesamtkosten.toLocaleString('de-DE')} €</span>
            </div>
          </div>
          {wartung.rechnungsnummer && (
            <p class="text-sm text-gray-600 mt-4">Rechnungsnr.: {wartung.rechnungsnummer}</p>
          )}
        </div>

        <!-- Belege -->
        {wartung.instandhaltung_belege && wartung.instandhaltung_belege.length > 0 && (
          <div class="bg-white rounded-lg shadow p-6">
            <h2 class="font-semibold text-gray-900 mb-4">Belege & Dokumente</h2>
            <div class="grid grid-cols-2 gap-4">
              {wartung.instandhaltung_belege.map(beleg => (
                <a href={beleg.url} target="_blank" class="flex items-center gap-3 p-3 border rounded-lg hover:bg-gray-50">
                  <div class="w-10 h-10 bg-gray-100 rounded flex items-center justify-center">
                    📎
                  </div>
                  <div class="overflow-hidden">
                    <p class="text-sm font-medium truncate">{beleg.dateiname}</p>
                    <p class="text-xs text-gray-500">{beleg.typ || 'Dokument'}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="font-semibold text-gray-900 mb-4">Details</h2>
          <div class="space-y-3 text-sm">
            <div>
              <span class="text-gray-600 block">Durchgeführt am:</span>
              <span class="font-medium">{new Date(wartung.datum).toLocaleDateString('de-DE')}</span>
            </div>
            {wartung.naechste_wartung && (
              <div>
                <span class="text-gray-600 block">Nächste Wartung:</span>
                <span class={`font-medium ${istUeberfaellig ? 'text-red-600' : ''}`}>
                  {new Date(wartung.naechste_wartung).toLocaleDateString('de-DE')}
                </span>
              </div>
            )}
            {wartung.durchgefuehrt_von && (
              <div>
                <span class="text-gray-600 block">Durchgeführt von:</span>
                <span class="font-medium">{wartung.durchgefuehrt_von}</span>
              </div>
            )}
            {wartung.kontakt && (
              <div>
                <span class="text-gray-600 block">Kontakt:</span>
                <span class="font-medium">{wartung.kontakt}</span>
              </div>
            )}
            {wartung.erinnerung_aktiv && (
              <div class="bg-blue-50 p-3 rounded">
                <span class="text-blue-800 block font-medium">🔔 Erinnerung aktiv</span>
                <span class="text-blue-600 text-xs">{wartung.erinnerung_tage} Tage vorher</span>
              </div>
            )}
          </div>
        </div>

        <!-- Aktionen -->
        <div class="bg-white rounded-lg shadow p-6 space-y-3">
          <a href={`/instandhaltung/${id}/bearbeiten`} class="block w-full text-center bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700">
            Bearbeiten
          </a>
          {wartung.status !== 'Erledigt' && (
            <form action={`/api/instandhaltung/${id}/status`} method="POST" class="contents">
              <input type="hidden" name="status" value="Erledigt" />
              <button type="submit" class="block w-full bg-green-600 text-white py-2 rounded-lg hover:bg-green-700">
                Als erledigt markieren
              </button>
            </form>
          )}
          <form action={`/api/instandhaltung/${id}/loeschen`} method="POST" 
                onsubmit="return confirm('Wirklich löschen?')" class="contents">
            <button type="submit" class="block w-full bg-red-100 text-red-700 py-2 rounded-lg hover:bg-red-200">
              Löschen
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>