---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { supabase, getAnstehendeWartungen, getWartungsStatistiken } from '../../lib/supabase';

// Auth Check
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

// Alle Objekte des Vermieters laden
const { data: objekte } = await supabase
  .from('objekte')
  .select('id, bezeichnung, adresse, baujahr')
  .eq('vermieter_id', session.user.id);

// Dashboard-Daten laden
const anstehendeWartungen = await getAnstehendeWartungen(session.user.id, 30);

// Statistiken pro Objekt
const objektStats = await Promise.all(
  (objekte || []).map(async (obj) => ({
    ...obj,
    stats: await getWartungsStatistiken(obj.id)
  }))
);

// Rücklagen-Übersicht
const { data: ruecklagen } = await supabase
  .from('ruecklagen')
  .select('*, objekte(bezeichnung)')
  .in('objekt_id', objekte?.map(o => o.id) || [])
  .order('jahr', { ascending: false });

const gesamtRuecklage = ruecklagen?.reduce((sum, r) => sum + (r.stand || 0), 0) || 0;
---

<DashboardLayout title="Instandhaltung">
  <div class="space-y-6">
    <!-- Header -->
    <div class="flex justify-between items-center">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Instandhaltung</h1>
        <p class="text-gray-600">Wartung, Reparaturen & Rücklagen</p>
      </div>
      <div class="flex gap-3">
        <a href="/instandhaltung/ruecklagen" class="bg-gray-100 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-200">
          Rücklagen
        </a>
        <a href="/instandhaltung/neu" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
          + Neue Wartung
        </a>
      </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <div class="bg-white p-6 rounded-lg shadow border-l-4 border-blue-500">
        <p class="text-sm text-gray-600">Anstehend (30 Tage)</p>
        <p class="text-2xl font-bold text-blue-600">{anstehendeWartungen.length}</p>
      </div>
      <div class="bg-white p-6 rounded-lg shadow border-l-4 border-green-500">
        <p class="text-sm text-gray-600">Gesamte Rücklagen</p>
        <p class="text-2xl font-bold text-green-600">{gesamtRuecklage.toLocaleString('de-DE')} €</p>
      </div>
      <div class="bg-white p-6 rounded-lg shadow border-l-4 border-yellow-500">
        <p class="text-sm text-gray-600">Diese Jahr erledigt</p>
        <p class="text-2xl font-bold text-yellow-600">
          {objektStats.reduce((sum, o) => sum + (o.stats.nachStatus['Erledigt'] || 0), 0)}
        </p>
      </div>
      <div class="bg-white p-6 rounded-lg shadow border-l-4 border-red-500">
        <p class="text-sm text-gray-600">Überfällig</p>
        <p class="text-2xl font-bold text-red-600">
          {objektStats.reduce((sum, o) => sum + (o.stats.nachStatus['Überfällig'] || 0), 0)}
        </p>
      </div>
    </div>

    <!-- Anstehende Wartungen -->
    {anstehendeWartungen.length > 0 && (
      <div class="bg-white rounded-lg shadow overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 bg-yellow-50">
          <h2 class="text-lg font-semibold text-yellow-800">⚠️ Anstehende Wartungen</h2>
        </div>
        <div class="divide-y divide-gray-200">
          {anstehendeWartungen.map(wartung => (
            <div class="p-6 flex items-center justify-between hover:bg-gray-50">
              <div class="flex items-center gap-4">
                <div class={`w-3 h-3 rounded-full ${
                  new Date(wartung.naechste_wartung!) < new Date() ? 'bg-red-500' : 'bg-yellow-500'
                }`} />
                <div>
                  <p class="font-medium text-gray-900">{wartung.kategorie}</p>
                  <p class="text-sm text-gray-600">{wartung.objekte?.bezeichnung} • {wartung.position}</p>
                  <p class="text-xs text-gray-500">Fällig: {new Date(wartung.naechste_wartung!).toLocaleDateString('de-DE')}</p>
                </div>
              </div>
              <a href={`/instandhaltung/${wartung.id}`} class="text-blue-600 hover:text-blue-800">
                Details →
              </a>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Objekt-Übersicht -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      {objektStats.map(obj => (
        <div class="bg-white rounded-lg shadow p-6">
          <div class="flex justify-between items-start mb-4">
            <div>
              <h3 class="font-semibold text-gray-900">{obj.bezeichnung}</h3>
              <p class="text-sm text-gray-600">{obj.adresse}</p>
            </div>
            <span class="text-xs bg-gray-100 text-gray-700 px-2 py-1 rounded">Baujahr {obj.baujahr}</span>
          </div>
          
          <div class="space-y-3">
            <div class="flex justify-between text-sm">
              <span class="text-gray-600">Gesamtwartungen:</span>
              <span class="font-medium">{obj.stats.total}</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-600">Kosten gesamt:</span>
              <span class="font-medium">{obj.stats.gesamtkosten.toLocaleString('de-DE')} €</span>
            </div>
            
            <!-- Status-Balken -->
            <div class="flex gap-1 h-2 rounded-full overflow-hidden bg-gray-200">
              {obj.stats.nachStatus['Erledigt'] > 0 && (
                <div class="bg-green-500" style={`width: ${(obj.stats.nachStatus['Erledigt'] / obj.stats.total) * 100}%`} />
              )}
              {obj.stats.nachStatus['In Bearbeitung'] > 0 && (
                <div class="bg-yellow-500" style={`width: ${(obj.stats.nachStatus['In Bearbeitung'] / obj.stats.total) * 100}%`} />
              )}
              {obj.stats.nachStatus['Geplant'] > 0 && (
                <div class="bg-blue-500" style={`width: ${(obj.stats.nachStatus['Geplant'] / obj.stats.total) * 100}%`} />
              )}
            </div>
            
            <a href={`/instandhaltung?objekt=${obj.id}`} class="block text-center text-sm text-blue-600 hover:text-blue-800 mt-4">
              Alle Wartungen anzeigen
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</DashboardLayout>