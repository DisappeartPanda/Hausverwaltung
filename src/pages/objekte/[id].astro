---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Nebenkosten Übersicht">
  <div class="mb-6">
    <a href="/dashboard" class="text-gray-600 hover:text-gray-800 text-sm">← Zurück zum Dashboard</a>
  </div>
  
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Nebenkostenabrechnungen</h1>
    <a href="/nebenkosten/neu" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm">
      + Neue Abrechnung
    </a>
  </div>

  <!-- Filter -->
  <div class="bg-white rounded-lg shadow p-4 mb-6">
    <div class="flex gap-4">
      <div class="flex-1">
        <label class="block text-sm font-medium text-gray-700 mb-1">Jahr</label>
        <select id="filter-jahr" class="w-full px-3 py-2 border rounded-md">
          <option value="">Alle Jahre</option>
          <option value="2024">2024</option>
          <option value="2023">2023</option>
          <option value="2022">2022</option>
        </select>
      </div>
      <div class="flex-1">
        <label class="block text-sm font-medium text-gray-700 mb-1">Objekt</label>
        <select id="filter-objekt" class="w-full px-3 py-2 border rounded-md">
          <option value="">Alle Objekte</option>
        </select>
      </div>
      <div class="flex-1">
        <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
        <select id="filter-status" class="w-full px-3 py-2 border rounded-md">
          <option value="">Alle Status</option>
          <option value="entwurf">Entwurf</option>
          <option value="versendet">Versendet</option>
          <option value="abgeschlossen">Abgeschlossen</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Liste -->
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-gray-600">
        <tr>
          <th class="px-6 py-3 text-left">Abrechnungsjahr</th>
          <th class="px-6 py-3 text-left">Objekt</th>
          <th class="px-6 py-3 text-left">Zeitraum</th>
          <th class="px-6 py-3 text-left">Gesamtkosten</th>
          <th class="px-6 py-3 text-left">Status</th>
          <th class="px-6 py-3 text-left">Aktionen</th>
        </tr>
      </thead>
      <tbody id="abrechnungen-liste" class="divide-y divide-gray-200">
        <tr>
          <td colspan="6" class="px-6 py-8 text-center text-gray-500">Laden...</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Hinweis -->
  <div class="mt-6 bg-yellow-50 border border-yellow-200 rounded-lg p-4 text-sm text-yellow-800">
    <h3 class="font-bold mb-2">⚠️ Wichtige Fristen:</h3>
    <ul class="list-disc pl-5 space-y-1">
      <li>Abrechnung muss spätestens 12 Monate nach Ende des Abrechnungsjahres vorliegen (§ 556 BGB)</li>
      <li>Mieter hat 1 Jahr Zeit für Widerspruch</li>
      <li>Heizkosten: Mindestens 50% nach Verbrauch umlegen (HeizkostenV)</li>
    </ul>
  </div>
</DashboardLayout>

<script>
  import { supabase } from '../../lib/supabase';
  
  const loadAbrechnungen = async () => {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return;
    
    const { data: vermieter } = await supabase
      .from('vermieter')
      .select('id')
      .eq('user_id', session.user.id)
      .single();
    
    if (!vermieter) return;
    
    // Demo-Daten (später aus DB)
    const demoAbrechnungen = [
      {
        id: 1,
        jahr: 2024,
        objekt: { bezeichnung: 'Musterstraße 1' },
        von: '2024-01-01',
        bis: '2024-12-31',
        gesamtkosten: 12500.00,
        status: 'entwurf'
      },
      {
        id: 2,
        jahr: 2023,
        objekt: { bezeichnung: 'Beispielweg 5' },
        von: '2023-01-01',
        bis: '2023-12-31',
        gesamtkosten: 8900.50,
        status: 'abgeschlossen'
      }
    ];
    
    const statusColors = {
      entwurf: 'bg-gray-100 text-gray-800',
      versendet: 'bg-blue-100 text-blue-800',
      abgeschlossen: 'bg-green-100 text-green-800'
    };
    
    const liste = document.getElementById('abrechnungen-liste')!;
    if (demoAbrechnungen.length === 0) {
      liste.innerHTML = '<tr><td colspan="6" class="px-6 py-8 text-center text-gray-500">Keine Abrechnungen vorhanden</td></tr>';
      return;
    }
    
    liste.innerHTML = demoAbrechnungen.map(a => `
      <tr class="hover:bg-gray-50">
        <td class="px-6 py-4 font-medium">${a.jahr}</td>
        <td class="px-6 py-4">${a.objekt.bezeichnung}</td>
        <td class="px-6 py-4 text-gray-600">${new Date(a.von).toLocaleDateString('de-DE')} - ${new Date(a.bis).toLocaleDateString('de-DE')}</td>
        <td class="px-6 py-4 font-medium">${a.gesamtkosten.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</td>
        <td class="px-6 py-4">
          <span class="px-2 py-1 rounded-full text-xs ${statusColors[a.status as keyof typeof statusColors]}">${a.status}</span>
        </td>
        <td class="px-6 py-4">
          <a href="/nebenkosten/${a.id}" class="text-blue-600 hover:text-blue-800 text-sm">Details</a>
        </td>
      </tr>
    `).join('');
  };
  
  loadAbrechnungen();
</script>