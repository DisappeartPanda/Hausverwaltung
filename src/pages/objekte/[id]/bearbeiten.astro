---
export const prerender = false;

import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { requireLandlordSession } from '../../../lib/supabase/serverAuth';

type OBJ = { id: string; bezeichnung: string | null };
type WE = { id: string; bezeichnung: string | null; status: string | null; kaltmiete: number | null };

const auth = await requireLandlordSession(Astro as any);
if (auth instanceof Response) return auth;

const { supabase } = auth as any;

const objektId = String(Astro.params.id ?? '');
if (!objektId) return new Response('Missing id', { status: 400 });

const { data: objekt, error: objErr } = await supabase
  .from('objekte')
  .select('id, bezeichnung')
  .eq('id', objektId)
  .maybeSingle<OBJ>();

if (objErr) return new Response(objErr.message, { status: 400 });
if (!objekt) return new Response('Not found', { status: 404 });

const { data: units, error: weErr } = await supabase
  .from('wohneinheiten')
  .select('id, bezeichnung, status, kaltmiete')
  .eq('objekt_id', objektId)
  .order('bezeichnung', { ascending: true });

if (weErr) return new Response(weErr.message, { status: 400 });

const einheiten: WE[] = (units ?? []) as WE[];
---

<DashboardLayout title={`Bearbeiten | ${objekt.bezeichnung ?? 'Objekt'}`} fullWidth>
  <div class="wrap">
    <header class="head">
      <div>
        <h1>Bearbeiten</h1>
        <p class="muted">{objekt.bezeichnung ?? 'Objekt'} · {einheiten.length} Wohneinheiten</p>
      </div>

      <div class="actions">
        <a class="btn ghost" href={`/objekte/${objekt.id}`}>Fertig</a>
      </div>
    </header>

    <section class="panel">
      <div class="panel-head">
        <h2>Wohneinheiten</h2>
        <p class="muted small">
          Klick auf „Löschen“ startet einen 5-Sekunden-Countdown. In der Zeit kannst du „Undo“ drücken.
          (Mieter werden beim Löschen automatisch mit entfernt.)
        </p>
      </div>

      {einheiten.length === 0 ? (
        <p class="muted">Keine Wohneinheiten vorhanden.</p>
      ) : (
        <div class="list">
          {einheiten.map((u) => (
            <div class="row" data-unit-row data-unit-id={u.id} data-unit-name={u.bezeichnung ?? 'Wohneinheit'}>
              <div class="left">
                <div class="title">{u.bezeichnung ?? 'Wohneinheit'}</div>
                <div class="meta">
                  <span>{u.status ?? '—'}</span>
                  <span>·</span>
                  <span>{(u.kaltmiete ?? 0).toLocaleString('de-DE')}€</span>
                </div>
              </div>

              <div class="right">
                <button class="btn danger" type="button" data-delete>
                  Löschen
                </button>

                <button class="btn ghost" type="button" data-undo hidden>
                  Undo
                </button>

                <span class="countdown" data-countdown hidden>5</span>
              </div>
            </div>
          ))}
        </div>
      )}

      <div class="foot">
        <a class="btn ghost" href={`/objekte/${objekt.id}`}>Zurück</a>
      </div>
    </section>
  </div>

  <div class="toast" data-toast hidden></div>

  <script is:inline>
    function init() {
      const toast = document.querySelector('[data-toast]');
      const timers = new Map(); // unitId -> {t, iv}

      function showToast(msg, type) {
        if (!toast) return;
        toast.textContent = msg;
        toast.classList.remove('show', 'ok', 'err', 'warn');
        toast.classList.add(type || 'warn');
        toast.hidden = false;
        void toast.offsetWidth;
        toast.classList.add('show');
        setTimeout(() => {
          toast.classList.remove('show');
          setTimeout(() => (toast.hidden = true), 180);
        }, 2400);
      }

      async function commitDelete(id, row) {
        let res;
        try {
          res = await fetch(`/api/wohneinheit/${id}`, { method: 'DELETE' });
        } catch {
          showToast('Netzwerkfehler beim Löschen.', 'err');
          return false;
        }

        if (!res.ok) {
          const msg = (await res.text()).slice(0, 180) || 'Löschen fehlgeschlagen.';
          showToast(msg, 'err');
          return false;
        }

        row.classList.add('removing');
        setTimeout(() => row.remove(), 180);
        showToast('Gelöscht.', 'ok');
        return true;
      }

      function startCountdown(row) {
        const id = row.getAttribute('data-unit-id');
        const name = row.getAttribute('data-unit-name') || 'Wohneinheit';
        if (!id) return;

        // falls schon läuft -> ignorieren
        if (timers.has(id)) return;

        const btnDelete = row.querySelector('[data-delete]');
        const btnUndo = row.querySelector('[data-undo]');
        const countdown = row.querySelector('[data-countdown]');

        if (!btnDelete || !btnUndo || !countdown) return;

        btnDelete.disabled = true;
        btnUndo.hidden = false;
        countdown.hidden = false;

        let n = 5;
        countdown.textContent = String(n);
        showToast(`„${name}“ wird gelöscht…`, 'warn');

        const iv = setInterval(() => {
          n -= 1;
          countdown.textContent = String(n);
        }, 1000);

        const t = setTimeout(async () => {
          clearInterval(iv);
          timers.delete(id);

          btnUndo.hidden = true;
          countdown.hidden = true;

          // commit
          await commitDelete(id, row);
        }, 5000);

        timers.set(id, { t, iv });
      }

      function undo(row) {
        const id = row.getAttribute('data-unit-id');
        if (!id) return;

        const item = timers.get(id);
        if (!item) return;

        clearTimeout(item.t);
        clearInterval(item.iv);
        timers.delete(id);

        const btnDelete = row.querySelector('[data-delete]');
        const btnUndo = row.querySelector('[data-undo]');
        const countdown = row.querySelector('[data-countdown]');

        if (btnDelete) btnDelete.disabled = false;
        if (btnUndo) btnUndo.hidden = true;
        if (countdown) countdown.hidden = true;

        showToast('Abgebrochen.', 'ok');
      }

      document.addEventListener('click', (e) => {
        const t = e.target;
        if (!(t instanceof Element)) return;

        const delBtn = t.closest('[data-delete]');
        if (delBtn) {
          const row = delBtn.closest('[data-unit-row]');
          if (row) startCountdown(row);
          return;
        }

        const undoBtn = t.closest('[data-undo]');
        if (undoBtn) {
          const row = undoBtn.closest('[data-unit-row]');
          if (row) undo(row);
          return;
        }
      });

      console.log('[bearbeiten] delete ready');
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  </script>
</DashboardLayout>

<style>
  .wrap{
    width: 100%;
    box-sizing: border-box;
    padding-top: calc(var(--nav-gap, 16px) + clamp(0.75rem, 1.4vw, 1.25rem));
    padding-left: clamp(0.75rem, 1.4vw, 1.25rem);
    padding-right: clamp(0.75rem, 1.4vw, 1.25rem);
    padding-bottom: clamp(0.75rem, 1.4vw, 1.25rem);
    display: grid;
    gap: 1rem;
  }

  .head{
    display:flex;
    align-items:flex-end;
    justify-content:space-between;
    gap: 1rem;
  }

  h1{ margin:0; color: var(--white); font-size: 1.6rem; }
  .muted{ margin: .25rem 0 0; color: var(--gray-400); }
  .muted.small{ font-size: .85rem; }

  .actions{ display:flex; gap:.6rem; flex-wrap: wrap; }

  .panel{
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(20px);
    border: 2px solid var(--dark-lighter);
    border-radius: 1.25rem;
    padding: 1rem;
  }

  .panel-head{
    display:grid;
    gap: .25rem;
    margin-bottom: .75rem;
  }

  .panel h2{
    margin: 0;
    color: var(--white);
    font-size: 1.05rem;
  }

  .list{
    display:grid;
    gap: .65rem;
  }

  .row{
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap: 1rem;
    padding: .9rem 1rem;
    border-radius: 1rem;
    border: 2px solid var(--dark-lighter);
    background: rgba(255,255,255,0.04);
    transition: opacity .18s ease, transform .18s ease;
  }

  .row.removing{
    opacity: 0;
    transform: translateY(-2px);
  }

  .title{ color: var(--white); font-weight: 750; }
  .meta{ color: var(--gray-400); font-size: .85rem; display:flex; gap:.4rem; align-items:center; }

  .right{
    display:flex;
    align-items:center;
    gap:.55rem;
    flex-wrap: wrap;
    justify-content: flex-end;
    min-width: 160px;
  }

  .btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding: .55rem .9rem;
    border-radius: 999px;
    border: 2px solid var(--dark-lighter);
    background: rgba(255,255,255,0.06);
    color: var(--white);
    text-decoration:none;
    transition: all .2s ease;
    white-space: nowrap;
  }

  .btn:hover{
    border-color: var(--primary);
    background: rgba(255,255,255,0.09);
  }

  .btn.ghost{
    background: transparent;
    color: var(--gray-400);
  }

  .btn.danger{
    border-color: rgba(239, 68, 68, 0.35);
    background: rgba(239, 68, 68, 0.10);
    color: rgba(255,255,255,0.92);
  }

  .btn.danger:hover{
    border-color: rgba(239, 68, 68, 0.65);
    background: rgba(239, 68, 68, 0.14);
  }

  .btn:disabled{
    opacity: .6;
    cursor: not-allowed;
  }

  .countdown{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.10);
    background: rgba(0,0,0,0.28);
    color: rgba(255,255,255,0.82);
    font-weight: 800;
    font-size: .85rem;
  }

  .foot{
    margin-top: 1rem;
    display:flex;
    justify-content:flex-end;
  }

  /* Toast */
  .toast{
    position: fixed;
    left: 50%;
    bottom: 22px;
    transform: translateX(-50%);
    z-index: 120;
    padding: .6rem .85rem;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.92);
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(10px);
    box-shadow: 0 18px 45px rgba(0,0,0,0.5);
    opacity: 0;
    transition: opacity .2s ease, transform .2s ease;
  }
  .toast.show{
    opacity: 1;
    transform: translateX(-50%) translateY(-2px);
  }
  .toast.ok{
    border-color: rgba(34,197,94,0.25);
    background: rgba(34,197,94,0.12);
  }
  .toast.err{
    border-color: rgba(239,68,68,0.25);
    background: rgba(239,68,68,0.12);
  }
  .toast.warn{
    border-color: rgba(253,224,71,0.22);
    background: rgba(253,224,71,0.10);
  }
</style>