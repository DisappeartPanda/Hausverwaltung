---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

const { id } = Astro.params;
---

<DashboardLayout title="Mietvertrag Details">
  <div class="mb-6">
    <a href="/mietvertraege" class="text-gray-600 hover:text-gray-800 text-sm">← Zurück zu Verträgen</a>
  </div>
  
  <div id="loading" class="text-center py-8">Laden...</div>
  
  <div id="vertrag-content" class="hidden space-y-6">
    <!-- Header -->
    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex justify-between items-start">
        <div>
          <h1 class="text-2xl font-bold text-gray-900" id="vertragsnummer">-</h1>
          <p class="text-gray-600 mt-1" id="mieter-name">-</p>
        </div>
        <span id="status-badge" class="px-3 py-1 rounded-full text-sm font-medium">-</span>
      </div>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Vertragsdetails -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-lg font-semibold mb-4">Vertragsdetails</h2>
        <dl class="space-y-3">
          <div class="flex justify-between">
            <dt class="text-gray-600">Mietbeginn:</dt>
            <dd class="font-medium" id="mietbeginn">-</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-gray-600">Mietende:</dt>
            <dd class="font-medium" id="mietende">-</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-gray-600">Kündigungsfrist:</dt>
            <dd class="font-medium" id="kuendigungsfrist">-</dd>
          </div>
          <div class="flex justify-between border-t pt-3">
            <dt class="text-gray-600">Kaltmiete:</dt>
            <dd class="font-medium" id="kaltmiete">-</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-gray-600">Nebenkosten:</dt>
            <dd class="font-medium" id="nebenkosten">-</dd>
          </div>
          <div class="flex justify-between text-lg font-bold border-t pt-3">
            <dt>Gesamtmiete:</dt>
            <dd id="gesamtmiete">-</dd>
          </div>
          <div class="flex justify-between border-t pt-3">
            <dt class="text-gray-600">Kaution:</dt>
            <dd class="font-medium" id="kaution">-</dd>
          </div>
        </dl>
      </div>
      
      <!-- Wohneinheit -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-lg font-semibold mb-4">Wohneinheit</h2>
        <div id="wohneinheit-info">
          <h3 class="font-medium text-gray-900" id="einheit-bezeichnung">-</h3>
          <p class="text-gray-600" id="objekt-bezeichnung">-</p>
          <p class="text-gray-500 text-sm mt-1" id="objekt-adresse">-</p>
        </div>
        
        <h3 class="font-semibold mt-6 mb-3">Mieter</h3>
        <div id="mieter-info">
          <p class="font-medium" id="mieter-detail-name">-</p>
          <p class="text-gray-600 text-sm" id="mieter-kontakt">-</p>
          <p class="text-gray-500 text-sm" id="mieter-adresse">-</p>
        </div>
      </div>
    </div>
    
    <!-- Aktionen -->
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold mb-4">Aktionen</h2>
      <div class="flex gap-3 flex-wrap">
        <button id="btn-kuendigen" class="px-4 py-2 bg-yellow-500 text-white rounded hover:bg-yellow-600 text-sm hidden">
          Vertrag kündigen
        </button>
        <button id="btn-beenden" class="px-4 py-2 bg-red-500 text-white rounded hover:bg-red-600 text-sm hidden">
          Vertrag beenden
        </button>
        <a id="link-zahlungen" href="#" class="px-4 py-2 bg-blue-100 text-blue-700 rounded hover:bg-blue-200 text-sm">
          Zahlungen anzeigen
        </a>
        <button id="btn-vertrag-upload" class="px-4 py-2 bg-gray-100 text-gray-700 rounded hover:bg-gray-200 text-sm">
          Vertrag hochladen
        </button>
      </div>
    </div>
    
    <!-- Zahlungsübersicht -->
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold mb-4">Zahlungsübersicht</h2>
      <div id="zahlungen-liste" class="space-y-2">
        <p class="text-gray-500">Laden...</p>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  import { supabase } from '../../lib/supabase';
  
  const vertragId = '${id}';
  
  const loadVertrag = async () => {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return;
    
    const { data: vertrag, error } = await supabase
      .from('mietvertraege')
      .select(`
        *,
        mieter (*),
        wohneinheiten (
          *,
          objekte (*)
        )
      `)
      .eq('id', vertragId)
      .single();
    
    if (error || !vertrag) {
      window.location.href = '/mietvertraege';
      return;
    }
    
    // Arrays extrahieren
    const mieter = vertrag.mieter?.[0];
    const wohneinheit = vertrag.wohneinheiten?.[0];
    const objekt = wohneinheit?.objekte?.[0];
    
    if (!mieter || !wohneinheit || !objekt) {
      console.error('Fehlende Daten:', { mieter, wohneinheit, objekt });
      return;
    }
    
    document.getElementById('loading')!.classList.add('hidden');
    document.getElementById('vertrag-content')!.classList.remove('hidden');
    
    // Header
    document.getElementById('vertragsnummer')!.textContent = vertrag.vertragsnummer || `Vertrag #${vertrag.id.slice(0, 8)}`;
    document.getElementById('mieter-name')!.textContent = `${mieter.nachname}, ${mieter.vorname}`;
    
    const statusColors = {
      aktiv: 'bg-green-100 text-green-800',
      gekuendigt: 'bg-yellow-100 text-yellow-800',
      beendet: 'bg-gray-100 text-gray-800',
      vorzeitig_beendet: 'bg-red-100 text-red-800'
    };
    const statusBadge = document.getElementById('status-badge')!;
    statusBadge.textContent = vertrag.status;
    statusBadge.className = `px-3 py-1 rounded-full text-sm font-medium ${statusColors[vertrag.status as keyof typeof statusColors]}`;
    
    // Details
    document.getElementById('mietbeginn')!.textContent = new Date(vertrag.mietbeginn).toLocaleDateString('de-DE');
    document.getElementById('mietende')!.textContent = vertrag.mietende 
      ? new Date(vertrag.mietende).toLocaleDateString('de-DE') 
      : (vertrag.unbefristet ? 'Unbefristet' : '-');
    document.getElementById('kuendigungsfrist')!.textContent = `${vertrag.kuendigungsfrist_monate || 3} Monate`;
    
    document.getElementById('kaltmiete')!.textContent = vertrag.kaltmiete.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'});
    document.getElementById('nebenkosten')!.textContent = (vertrag.nebenkosten_vorauszahlung || 0).toLocaleString('de-DE', {style: 'currency', currency: 'EUR'});
    document.getElementById('gesamtmiete')!.textContent = (vertrag.gesamtmiete || vertrag.kaltmiete + (vertrag.nebenkosten_vorauszahlung || 0)).toLocaleString('de-DE', {style: 'currency', currency: 'EUR'});
    document.getElementById('kaution')!.textContent = vertrag.kaution_betrag 
      ? `${vertrag.kaution_betrag.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})} (${vertrag.kaution_hinterlegt_am ? 'hinterlegt am ' + new Date(vertrag.kaution_hinterlegt_am).toLocaleDateString('de-DE') : 'noch nicht hinterlegt'})`
      : '-';
    
    // Wohneinheit
    document.getElementById('einheit-bezeichnung')!.textContent = wohneinheit.bezeichnung;
    document.getElementById('objekt-bezeichnung')!.textContent = objekt.bezeichnung;
    document.getElementById('objekt-adresse')!.textContent = `${objekt.strasse} ${objekt.hausnummer || ''}, ${objekt.plz} ${objekt.stadt}`;
    
    // Mieter
    document.getElementById('mieter-detail-name')!.textContent = `${mieter.anrede || ''} ${mieter.vorname} ${mieter.nachname}`.trim();
    document.getElementById('mieter-kontakt')!.textContent = [mieter.email, mieter.telefon].filter(Boolean).join(' | ') || '-';
    document.getElementById('mieter-adresse')!.textContent = mieter.aktuelle_strasse 
      ? `${mieter.aktuelle_strasse}, ${mieter.aktuelle_plz} ${mieter.aktuelle_stadt}`
      : '-';
    
    // Aktionen
    document.getElementById('link-zahlungen')!.setAttribute('href', `/zahlungen?vertrag=${vertragId}`);
    
    if (vertrag.status === 'aktiv') {
      document.getElementById('btn-kuendigen')!.classList.remove('hidden');
      document.getElementById('btn-beenden')!.classList.remove('hidden');
    }
    
    // Zahlungen laden
    loadZahlungen(vertragId);
  };
  
  const loadZahlungen = async (vertragId: string) => {
    const { data: zahlungen } = await supabase
      .from('mietzahlungen')
      .select('*')
      .eq('mietvertrag_id', vertragId)
      .order('zahlungsmonat', { ascending: false })
      .limit(12);
    
    const container = document.getElementById('zahlungen-liste')!;
    
    if (!zahlungen || zahlungen.length === 0) {
      container.innerHTML = '<p class="text-gray-500">Keine Zahlungen vorhanden.</p>';
      return;
    }
    
    const statusColors = {
      offen: 'bg-yellow-100 text-yellow-800',
      eingegangen: 'bg-green-100 text-green-800',
      ueberfaellig: 'bg-red-100 text-red-800',
      storniert: 'bg-gray-100 text-gray-800'
    };
    
    container.innerHTML = zahlungen.map(z => `
      <div class="flex justify-between items-center p-3 bg-gray-50 rounded">
        <div>
          <p class="font-medium">${new Date(z.zahlungsmonat).toLocaleDateString('de-DE', {month: 'long', year: 'numeric'})}</p>
          <p class="text-sm text-gray-600">Fällig: ${new Date(z.zahlungsdatum).toLocaleDateString('de-DE')}</p>
        </div>
        <div class="text-right">
          <p class="font-bold">${z.betrag.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</p>
          <span class="px-2 py-1 rounded text-xs ${statusColors[z.status as keyof typeof statusColors] || 'bg-gray-100'}">${z.status}</span>
        </div>
      </div>
    `).join('');
  };
  
  // Kündigen
  document.getElementById('btn-kuendigen')?.addEventListener('click', async () => {
    if (!confirm('Möchten Sie diesen Vertrag wirklich kündigen?')) return;
    
    const { error } = await supabase
      .from('mietvertraege')
      .update({ 
        status: 'gekuendigt',
        gekuendigt_am: new Date().toISOString().split('T')[0]
      })
      .eq('id', vertragId);
    
    if (!error) window.location.reload();
  });
  
  // Beenden
  document.getElementById('btn-beenden')?.addEventListener('click', async () => {
    if (!confirm('Möchten Sie diesen Vertrag wirklich beenden?')) return;
    
    const { error } = await supabase
      .from('mietvertraege')
      .update({ status: 'vorzeitig_beendet' })
      .eq('id', vertragId);
    
    if (!error) window.location.reload();
  });
  
  loadVertrag();
</script>