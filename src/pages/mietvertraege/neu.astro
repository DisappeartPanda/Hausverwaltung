---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Neuer Mietvertrag">
  <div class="mb-6">
    <a href="/mietvertraege" class="text-gray-600 hover:text-gray-800 text-sm">← Zurück zu Verträgen</a>
  </div>
  
  <h1 class="text-2xl font-bold mb-6">Neuen Mietvertrag anlegen</h1>
  
  <form id="vertrag-form" class="max-w-3xl bg-white rounded-lg shadow p-6 space-y-6">
    <!-- Mieter Auswahl -->
    <div>
      <label class="block text-sm font-medium text-gray-700">Mieter *</label>
      <select name="mieter_id" required class="mt-1 block w-full px-3 py-2 border rounded-md">
        <option value="">Bitte wählen...</option>
      </select>
      <p class="mt-1 text-sm text-gray-500">
        Mieter nicht vorhanden? <a href="/mieter/neu?redirect=vertrag" class="text-blue-600">Neuen Mieter anlegen</a>
      </p>
    </div>
    
    <!-- Wohneinheit Auswahl -->
    <div>
      <label class="block text-sm font-medium text-gray-700">Wohneinheit *</label>
      <select name="wohneinheit_id" required class="mt-1 block w-full px-3 py-2 border rounded-md">
        <option value="">Bitte wählen...</option>
      </select>
    </div>
    
    <!-- Vertragsdaten -->
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700">Vertragsnummer</label>
        <input name="vertragsnummer" type="text" placeholder="z.B. MV-2024-001"
          class="mt-1 block w-full px-3 py-2 border rounded-md" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Mietbeginn *</label>
        <input name="mietbeginn" type="date" required
          class="mt-1 block w-full px-3 py-2 border rounded-md" />
      </div>
    </div>
    
    <div class="flex items-center gap-2">
      <input type="checkbox" name="unbefristet" id="unbefristet" checked class="rounded" />
      <label for="unbefristet" class="text-sm font-medium text-gray-700">Unbefristeter Vertrag</label>
    </div>
    
    <div id="mietende-container" class="hidden">
      <label class="block text-sm font-medium text-gray-700">Mietende</label>
      <input name="mietende" type="date"
        class="mt-1 block w-full px-3 py-2 border rounded-md" />
    </div>
    
    <!-- Mietkonditionen -->
    <div class="border-t pt-4">
      <h3 class="text-sm font-medium text-gray-900 mb-3">Mietkonditionen</h3>
      
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700">Kaltmiete (€) *</label>
          <input name="kaltmiete" type="number" step="0.01" required
            class="mt-1 block w-full px-3 py-2 border rounded-md" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700">Nebenkosten Vorauszahlung (€)</label>
          <input name="nebenkosten_vorauszahlung" type="number" step="0.01" value="0"
            class="mt-1 block w-full px-3 py-2 border rounded-md" />
        </div>
      </div>
      
      <div class="mt-4 p-3 bg-gray-50 rounded">
        <p class="text-sm text-gray-600">Gesamtmiete: <span id="gesamtmiete-anzeige" class="font-bold">0,00 €</span></p>
      </div>
    </div>
    
    <!-- Kaution -->
    <div class="border-t pt-4">
      <h3 class="text-sm font-medium text-gray-900 mb-3">Kaution</h3>
      
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700">Kaution (Monatsmieten)</label>
          <input name="kaution_monate" type="number" value="3" min="0" max="6"
            class="mt-1 block w-full px-3 py-2 border rounded-md" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700">Kaution hinterlegt am</label>
          <input name="kaution_hinterlegt_am" type="date"
            class="mt-1 block w-full px-3 py-2 border rounded-md" />
        </div>
      </div>
    </div>
    
    <div class="flex gap-4 pt-4">
      <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
        Vertrag speichern
      </button>
      <a href="/mietvertraege" class="px-6 py-2 bg-gray-300 text-gray-700 rounded hover:bg-gray-400">
        Abbrechen
      </a>
    </div>
    
    <div id="error-message" class="hidden p-3 bg-red-100 border border-red-400 text-red-700 rounded text-sm"></div>
  </form>
</DashboardLayout>

<script>
  import { supabase } from '../../lib/supabase';
  
  // Mieter und Wohneinheiten laden
  const loadData = async () => {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return;
    
    // Mieter laden
    const { data: mieter } = await supabase
      .from('mieter')
      .select('id, vorname, nachname')
      .order('nachname');
    
    const mieterSelect = document.querySelector('select[name="mieter_id"]') as HTMLSelectElement;
    mieter?.forEach(m => {
      const option = document.createElement('option');
      option.value = m.id;
      option.textContent = `${m.nachname}, ${m.vorname}`;
      mieterSelect.appendChild(option);
    });
    
    // Freie Wohneinheiten laden
    const { data: einheiten } = await supabase
      .from('wohneinheiten')
      .select(`
        id,
        bezeichnung,
        kaltmiete,
        objekte (bezeichnung)
      `)
      .eq('status', 'frei')
      .order('bezeichnung');

    const einheitSelect = document.querySelector('select[name="wohneinheit_id"]') as HTMLSelectElement;
    einheiten?.forEach(e => {
      const option = document.createElement('option');
      option.value = e.id;
      // KORRIGIERT: objekte ist ein Array, daher [0]
      option.textContent = `${e.objekte?.[0]?.bezeichnung || 'Unbekannt'} - ${e.bezeichnung} (${e.kaltmiete} €)`;
      option.dataset.kaltmiete = String(e.kaltmiete);
      einheitSelect.appendChild(option);
    });
    
    // URL Parameter prüfen (vorbelegung)
    const urlParams = new URLSearchParams(window.location.search);
    const preselectedMieter = urlParams.get('mieter');
    const preselectedEinheit = urlParams.get('einheit');
    
    if (preselectedMieter) mieterSelect.value = preselectedMieter;
    if (preselectedEinheit) {
      einheitSelect.value = preselectedEinheit;
      updateGesamtmiete();
    }
  };  // ← HIER WAR DIE KLAMMER ZU FRÜH!
  
  // Unbefristet Toggle
  document.getElementById('unbefristet')?.addEventListener('change', (e) => {
    const container = document.getElementById('mietende-container')!;
    if ((e.target as HTMLInputElement).checked) {
      container.classList.add('hidden');
    } else {
      container.classList.remove('hidden');
    }
  });
  
  // Gesamtmiete berechnen
  const updateGesamtmiete = () => {
    const kaltmiete = parseFloat((document.querySelector('input[name="kaltmiete"]') as HTMLInputElement)?.value) || 0;
    const nebenkosten = parseFloat((document.querySelector('input[name="nebenkosten_vorauszahlung"]') as HTMLInputElement)?.value) || 0;
    const gesamt = kaltmiete + nebenkosten;
    document.getElementById('gesamtmiete-anzeige')!.textContent = 
      gesamt.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'});
  };
  
  document.querySelector('input[name="kaltmiete"]')?.addEventListener('input', updateGesamtmiete);
  document.querySelector('input[name="nebenkosten_vorauszahlung"]')?.addEventListener('input', updateGesamtmiete);
  
  // Wohneinheit auswahl -> Kaltmiete übernehmen
  document.querySelector('select[name="wohneinheit_id"]')?.addEventListener('change', (e) => {
    const selected = (e.target as HTMLSelectElement).selectedOptions[0];
    const kaltmiete = selected.dataset.kaltmiete;
    if (kaltmiete) {
      (document.querySelector('input[name="kaltmiete"]') as HTMLInputElement).value = kaltmiete;
      updateGesamtmiete();
    }
  });
  
  // Formular absenden
  const form = document.getElementById('vertrag-form');
  const errorMsg = document.getElementById('error-message');
  
form?.addEventListener('submit', async (e) => {
  e.preventDefault();
  errorMsg!.classList.add('hidden');
  
  const formData = new FormData(e.target as HTMLFormElement);
  
  const kaltmiete = parseFloat(formData.get('kaltmiete') as string);
  const nebenkosten = parseFloat(formData.get('nebenkosten_vorauszahlung') as string) || 0;
  const kautionMonate = parseInt(formData.get('kaution_monate') as string) || 3;
  const mietbeginn = formData.get('mietbeginn') as string;
  const wohneinheitId = formData.get('wohneinheit_id') as string;
  
  // 1. Vertrag erstellen
  const { data: vertrag, error: vertragError } = await supabase
    .from('mietvertraege')
    .insert({
      mieter_id: formData.get('mieter_id'),
      wohneinheit_id: wohneinheitId,
      vertragsnummer: formData.get('vertragsnummer') || null,
      mietbeginn: mietbeginn,
      mietende: formData.get('mietende') || null,
      unbefristet: formData.get('unbefristet') === 'on',
      kaltmiete: kaltmiete,
      nebenkosten_vorauszahlung: nebenkosten,
      gesamtmiete: kaltmiete + nebenkosten,
      kaution_betrag: kaltmiete * kautionMonate,
      kaution_hinterlegt_am: formData.get('kaution_hinterlegt_am') || null,
      status: 'aktiv',
    })
    .select()
    .single();
  
  if (vertragError) {
    errorMsg!.textContent = 'Fehler: ' + vertragError.message;
    errorMsg!.classList.remove('hidden');
    return;
  }
  
  // 2. Zahlungen für die nächsten 12 Monate generieren
  const zahlungen = [];
  const startDatum = new Date(mietbeginn);
  
  for (let i = 0; i < 12; i++) {
    const zahlungsMonat = new Date(startDatum.getFullYear(), startDatum.getMonth() + i, 1);
    zahlungen.push({
      mietvertrag_id: vertrag.id,
      zahlungsmonat: zahlungsMonat.toISOString().split('T')[0],
      zahlungsdatum: zahlungsMonat.toISOString().split('T')[0], // Fälligkeitsdatum
      betrag: kaltmiete + nebenkosten,
      kaltmiete_antell: kaltmiete,
      nebenkosten_antell: nebenkosten,
      status: 'offen',
    });
  }
  
  const { error: zahlungError } = await supabase
    .from('mietzahlungen')
    .insert(zahlungen);
  
  if (zahlungError) {
    console.error('Fehler beim Erstellen der Zahlungen:', zahlungError);
    // Vertrag bleibt bestehen, Zahlungen können später manuell erstellt werden
  }
  
  window.location.href = '/mietvertraege';
});
  
  loadData();
</script>