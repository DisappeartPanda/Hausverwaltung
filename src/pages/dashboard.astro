---
export const prerender = false;

import DashboardLayout from '../layouts/DashboardLayout.astro';
import Tacho from '../components/dashboard/Tacho.astro';
import Sidebar from '../components/dashboard/Sidebar.astro';
import { getDashboardData } from '../lib/dashboard/dashboardStats';
import { requireLandlordSession } from '../lib/supabase/serverAuth';

const { accessToken } = await requireLandlordSession(Astro);
const result = await getDashboardData(accessToken);
const stats = result.stats;

const units = stats.einheiten;

const level =
  units === 0 ? 'setup' :
  units <= 3  ? 'small' :
  units <= 15 ? 'medium' :
  units <= 50 ? 'large' :
                'xl';

const leer = Math.max(0, stats.einheiten - stats.vermietet);
const leerstandPct = stats.einheiten ? Math.round((leer / stats.einheiten) * 100) : 0;
const vollVermietet = stats.einheiten > 0 && leer === 0;

// Cashflow delta
const deltaTxt =
  stats.zahlungen30Delta > 0 ? `Δ +${stats.zahlungen30Delta.toLocaleString('de-DE')}€ (30T)` :
  stats.zahlungen30Delta < 0 ? `Δ ${stats.zahlungen30Delta.toLocaleString('de-DE')}€ (30T)` :
  `Δ 0€ (30T)`;

// ---------- “Manual Widgets” (Server Side) ----------
// Wenn du dashboard_widgets noch nicht setzt: Default Reihenfolge
type WidgetSize = 'sm' | 'md' | 'lg';
type WidgetCfg = { id: 'tacho' | 'health' | 'next' | 'chips' | 'kpis'; enabled: boolean; size?: WidgetSize };

const defaultWidgets: WidgetCfg[] = [
  { id: 'tacho', enabled: true, size: 'lg' },
  { id: 'health', enabled: true, size: 'md' },
  { id: 'next', enabled: true, size: 'md' },
  { id: 'chips', enabled: true, size: 'sm' },
  { id: 'kpis', enabled: true, size: 'md' },
];

// ⚠️ Wir lesen serverseitig NICHT profile_settings hier (weil getDashboardData aktuell nur mode liefert).
// Sobald du willst, erweitere ich getDashboardData um dashboard_widgets.
// Für jetzt: “manual” wird über dashboardMode in profile_settings gesteuert,
// aber die Reihenfolge ist defaultWidgets.
const widgets = defaultWidgets;

// ---------- Chips ----------
type ChipType = 'success' | 'warning' | 'danger' | 'neutral';
type Chip = { type: ChipType; text: string; href?: string };

const chips: Chip[] = (() => {
  const arr: Chip[] = [];

  if (level === 'setup') {
    arr.push({ type: 'warning', text: '🏁 Starte: erstes Objekt anlegen', href: '/objekte/neu' });
    arr.push({ type: 'neutral', text: '⚙️ Profil & Setup prüfen', href: '/profil' });
    return arr;
  }

  if (leer > 0) arr.push({ type: 'warning', text: `📉 Leerstand: ${leer} (${leerstandPct}%)`, href: '/wohneinheiten?status=frei' });
  else arr.push({ type: 'success', text: `✅ Voll vermietet: ${stats.vermietet}/${stats.einheiten}`, href: '/wohneinheiten?status=vermietet' });

  if (stats.wartungenUeberfaellig > 0) arr.push({ type: 'danger', text: `⏰ Überfällig: ${stats.wartungenUeberfaellig}`, href: '/maengel?status=ueberfaellig' });
  else if (stats.wartungenOffen > 0) arr.push({ type: 'warning', text: `🔧 Offen: ${stats.wartungenOffen}`, href: '/maengel?status=offen' });
  else arr.push({ type: 'neutral', text: '🔧 Wartungen: ok', href: '/maengel' });

  if (stats.zahlungenUeberfaellig > 0) arr.push({ type: 'danger', text: `💶 Überfällig: ${stats.zahlungenUeberfaellig}`, href: '/zahlungen?status=ueberfaellig' });
  else if (stats.zahlungenOffen > 0) arr.push({ type: 'warning', text: `💶 Offen: ${stats.zahlungenOffen}`, href: '/zahlungen?status=offen' });
  else if (stats.zahlungen30Summe > 0) arr.push({ type: 'success', text: `💶 Cashflow 30T: ${stats.zahlungen30Summe.toLocaleString('de-DE')}€`, href: '/zahlungen' });

  return arr.slice(0, 5);
})();

// ---------- KPIs ----------
type KPI = { title: string; value: string; sub?: string; href?: string };

const kpis: KPI[] = (() => {
  if (level === 'setup') {
    return [
      { title: 'Objekte', value: '0', href: '/objekte' },
      { title: 'Einheiten', value: '0', href: '/wohneinheiten' },
      { title: 'Start', value: 'Objekt anlegen', sub: 'für KPIs & Score', href: '/objekte/neu' },
      { title: 'Nächster Schritt', value: 'Einheit anlegen', sub: 'macht Miete & Status sichtbar', href: '/wohneinheiten/neu' },
    ];
  }

  const action: KPI =
    stats.wartungenUeberfaellig > 0
      ? { title: 'Überfällig', value: String(stats.wartungenUeberfaellig), sub: 'Vorgänge', href: '/maengel?status=ueberfaellig' }
      : leer > 0
        ? { title: 'Leerstand', value: String(leer), sub: `${leerstandPct}% frei`, href: '/wohneinheiten?status=frei' }
        : stats.zahlungenUeberfaellig > 0
          ? { title: 'Zahlungen', value: String(stats.zahlungenUeberfaellig), sub: 'überfällig', href: '/zahlungen?status=ueberfaellig' }
          : { title: 'Status', value: 'OK', sub: 'Keine Alarme' };

  return [
    { title: 'Einheiten', value: String(stats.einheiten), sub: `${stats.objekte} Objekte`, href: '/wohneinheiten' },
    { title: 'Soll-Miete', value: `${stats.mieteGesamt.toLocaleString('de-DE')}€`, sub: 'pro Monat', href: '/wohneinheiten' },
    { title: 'Cashflow', value: `${stats.zahlungen30Summe.toLocaleString('de-DE')}€`, sub: `letzte 30 Tage · ${deltaTxt}`, href: '/zahlungen' },
    action,
  ];
})();

// ---------- Next Steps ----------
type ActionTone = 'primary' | 'success' | 'warning' | 'danger' | 'neutral';
type NextAction = { title: string; desc?: string; href: string; tone?: ActionTone; icon?: string };

const nextActions: NextAction[] = (() => {
  const a: NextAction[] = [];

  if (level === 'setup') {
    a.push({ title: 'Erstes Objekt anlegen', desc: 'Basis für Einheiten, Mieter und Zahlungen.', href: '/objekte/neu', tone: 'primary', icon: '🏢' });
    a.push({ title: 'Erste Einheit anlegen', desc: 'Damit Soll-Miete & Status sichtbar werden.', href: '/wohneinheiten/neu', tone: 'neutral', icon: '🧩' });
    a.push({ title: 'Ersten Vertrag anlegen', desc: 'Verknüpft Mieter, Einheit und Zahlungen.', href: '/mietvertraege/neu', tone: 'neutral', icon: '📄' });
    a.push({ title: 'Erste Zahlung erfassen', desc: 'Dann wird Cashflow/Delta aktiv.', href: '/zahlungen/neu', tone: 'neutral', icon: '💶' });
    return a;
  }

  if (leer > 0) a.push({ title: 'Leerstand prüfen', desc: `Aktuell ${leer} frei – Vermietung priorisieren.`, href: '/wohneinheiten?status=frei', tone: 'warning', icon: '📉' });

  if (stats.wartungenUeberfaellig > 0) a.push({ title: 'Überfällige Vorgänge abarbeiten', desc: `${stats.wartungenUeberfaellig} überfällig – Kostenrisiko.`, href: '/maengel?status=ueberfaellig', tone: 'danger', icon: '⏰' });
  else if (stats.wartungenOffen > 0) a.push({ title: 'Offene Vorgänge bearbeiten', desc: `${stats.wartungenOffen} offen – Status updaten/terminieren.`, href: '/maengel?status=offen', tone: 'warning', icon: '🔧' });

  if (stats.zahlungenUeberfaellig > 0) a.push({ title: 'Überfällige Zahlungen klären', desc: `${stats.zahlungenUeberfaellig} überfällig – sofort prüfen.`, href: '/zahlungen?status=ueberfaellig', tone: 'danger', icon: '💥' });
  else if (stats.zahlungenOffen > 0) a.push({ title: 'Offene Zahlungen prüfen', desc: `${stats.zahlungenOffen} offen – Mahnung/Reminder.`, href: '/zahlungen?status=offen', tone: 'warning', icon: '💶' });

  a.push({ title: 'Objekte vervollständigen', desc: 'Datenqualität verbessert Score & Reports.', href: '/objekte?edit=1', tone: 'neutral', icon: '🧾' });

  return a.slice(0, 4);
})();

const toneClass = (t: ActionTone) => {
  switch (t) {
    case 'primary': return 'tone-primary';
    case 'success': return 'tone-success';
    case 'warning': return 'tone-warning';
    case 'danger':  return 'tone-danger';
    default:        return 'tone-neutral';
  }
};

const { buckets, reasons, nextGains } = stats.scoreBreakdown;
---

<DashboardLayout title="Dashboard | ImmobilienPro" fullWidth>
  <section class="dash" aria-label="Dashboard">
    <aside class="dash-left">
      <Sidebar einheiten={stats.einheiten} mode={result.resolvedMode} />
    </aside>

    <main class="dash-right">
      {widgets.filter(w => w.enabled).map((w) => (
        w.id === 'tacho' ? (
          <section class="panel panel-big" aria-label="Portfolio Zustand">
            <Tacho stats={stats} />
          </section>
        ) : w.id === 'health' ? (
          <section class="panel panel-health" aria-label="Score Erklärung">
            <header class="health-head">
              <div>
                <h2>Health Score – Warum?</h2>
                <p>Transparent, fair und direkt umsetzbar.</p>
              </div>
              <div class="health-total" style={`--accent:${stats.scoreFarbe}`}>
                <span class="health-num">{stats.score}</span>
                <span class="health-max">/100</span>
              </div>
            </header>

            <div class="health-grid">
              <div class="health-card">
                <div class="hc-title">Datenqualität</div>
                <div class="hc-points">{buckets.daten}/25</div>
                <ul class="hc-list">
                  {reasons.daten.map((x) => <li>{x}</li>)}
                </ul>
              </div>

              <div class="health-card">
                <div class="hc-title">Vermietung</div>
                <div class="hc-points">{buckets.vermietung}/25</div>
                <ul class="hc-list">
                  {reasons.vermietung.map((x) => <li>{x}</li>)}
                </ul>
              </div>

              <div class="health-card">
                <div class="hc-title">Wartungen</div>
                <div class="hc-points">{buckets.wartung}/25</div>
                <ul class="hc-list">
                  {reasons.wartung.map((x) => <li>{x}</li>)}
                </ul>
              </div>

              <div class="health-card">
                <div class="hc-title">Zahlungen</div>
                <div class="hc-points">{buckets.zahlungen}/25</div>
                <ul class="hc-list">
                  {reasons.zahlungen.map((x) => <li>{x}</li>)}
                </ul>
              </div>
            </div>

            {nextGains.length > 0 && (
              <div class="gains">
                <div class="gains-title">Schnelle Gewinne</div>
                <div class="gains-list">
                  {nextGains.map((g) => (
                    g.href ? (
                      <a class="gain" href={g.href}>
                        <span class="gain-p">{g.points > 0 ? `+${g.points}` : g.points}</span>
                        <span class="gain-t">{g.text}</span>
                        <span class="gain-a" aria-hidden="true">→</span>
                      </a>
                    ) : (
                      <div class="gain">
                        <span class="gain-p">{g.points > 0 ? `+${g.points}` : g.points}</span>
                        <span class="gain-t">{g.text}</span>
                      </div>
                    )
                  ))}
                </div>
              </div>
            )}
          </section>
        ) : w.id === 'next' ? (
          <section class="panel panel-actions" aria-label="Next Steps">
            <header class="nba-head">
              <h2>Next Steps</h2>
              <p>1-Klick Aktionen, die dein Portfolio sofort verbessern.</p>
            </header>

            <div class="nba-grid">
              {nextActions.map((x) => (
                <a class={`nba-card ${toneClass(x.tone ?? 'neutral')}`} href={x.href}>
                  <div class="nba-top">
                    <div class="nba-icon" aria-hidden="true">{x.icon ?? '✨'}</div>
                    <div class="nba-title">{x.title}</div>
                  </div>
                  {x.desc && <div class="nba-desc">{x.desc}</div>}
                  <div class="nba-cta">
                    <span>Öffnen</span>
                    <span aria-hidden="true">→</span>
                  </div>
                </a>
              ))}
            </div>
          </section>
        ) : w.id === 'chips' ? (
          <section class="chips" aria-label="Status">
            {chips.map((c) => (
              c.href
                ? <a class:list={['chip', c.type]} href={c.href}>{c.text}</a>
                : <span class:list={['chip', c.type]}>{c.text}</span>
            ))}
          </section>
        ) : (
          <section class="kpis" aria-label="Kennzahlen">
            {kpis.map((k) => (
              k.href ? (
                <a class="kpi kpi-link" href={k.href} aria-label={`Öffne ${k.title}`}>
                  <div class="kpi-title">{k.title}</div>
                  <div class="kpi-value">{k.value}</div>
                  {k.sub && <div class="kpi-sub">{k.sub}</div>}
                </a>
              ) : (
                <div class="kpi">
                  <div class="kpi-title">{k.title}</div>
                  <div class="kpi-value">{k.value}</div>
                  {k.sub && <div class="kpi-sub">{k.sub}</div>}
                </div>
              )
            ))}
          </section>
        )
      ))}
    </main>
  </section>
</DashboardLayout>

<style>
  .dash{
    width: min(1400px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: clamp(0.75rem, 1.4vw, 1.25rem);
    align-items: stretch;
    padding: 0 clamp(0.75rem, 1.4vw, 1.25rem);
    box-sizing: border-box;
  }

  .dash-left,
  .dash-right{ min-width: 0; }

  .dash-right{
    display: grid;
    grid-template-rows: auto;
    gap: clamp(0.6rem, 1vw, 0.9rem);
    min-width: 0;
  }

  .panel,
  .kpi{
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(20px);
    border: 2px solid var(--dark-lighter);
    border-radius: 1.5rem;
  }

  .panel-big{
    padding: clamp(0.75rem, 1.2vw, 1.1rem);
    overflow: hidden;
  }

  .panel-big :global(.tacho-card),
  .panel-big :global(.tacho-stats-card){
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    padding: 0 !important;
    margin: 0 !important;
    max-width: none !important;
  }

  /* Health */
  .panel-health{ padding: clamp(0.75rem, 1.2vw, 1.1rem); }
  .health-head{
    display:flex;
    justify-content:space-between;
    align-items:flex-start;
    gap: 12px;
  }
  .health-head h2{
    margin:0;
    font-size: 1.05rem;
    font-weight: 950;
    letter-spacing: -0.01em;
    color: rgba(255,255,255,0.96);
  }
  .health-head p{
    margin: 4px 0 0;
    color: var(--gray-400);
    font-weight: 650;
    font-size: 0.9rem;
    line-height: 1.35;
  }
  .health-total{
    display:flex;
    align-items:baseline;
    gap: 6px;
    padding: 10px 14px;
    border-radius: 999px;
    background: rgba(0,0,0,0.28);
    border: 1px solid rgba(255,255,255,0.10);
    box-shadow: 0 15px 40px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.06);
  }
  .health-num{
    font-size: 1.55rem;
    font-weight: 950;
    color: var(--accent);
    text-shadow: 0 0 18px color-mix(in srgb, var(--accent) 55%, transparent);
  }
  .health-max{
    color: rgba(255,255,255,0.65);
    font-weight: 800;
  }

  .health-grid{
    margin-top: 12px;
    display:grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(0.6rem, 1vw, 0.9rem);
  }

  .health-card{
    border-radius: 1.1rem;
    border: 1px solid rgba(255,255,255,0.10);
    background: rgba(255,255,255,0.04);
    padding: 12px 12px 10px;
  }

  .hc-title{
    font-weight: 950;
    color: rgba(255,255,255,0.92);
    letter-spacing: -0.01em;
  }
  .hc-points{
    margin-top: 4px;
    font-weight: 950;
    color: rgba(255,255,255,0.82);
  }
  .hc-list{
    margin: 8px 0 0;
    padding-left: 16px;
    color: var(--gray-400);
    font-weight: 650;
    font-size: .9rem;
    line-height: 1.35;
  }

  .gains{
    margin-top: 12px;
    border-top: 1px solid rgba(255,255,255,0.10);
    padding-top: 12px;
  }
  .gains-title{
    font-weight: 950;
    color: rgba(255,255,255,0.92);
  }
  .gains-list{
    margin-top: 8px;
    display:flex;
    flex-direction:column;
    gap: 8px;
  }
  .gain{
    display:flex;
    align-items:center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 1rem;
    border: 1px solid rgba(255,255,255,0.10);
    background: rgba(255,255,255,0.04);
    text-decoration:none;
    color: inherit;
    transition: transform .18s ease, background .18s ease, border-color .18s ease;
  }
  .gain:hover{
    transform: translateY(-1px);
    background: rgba(255,255,255,0.08);
    border-color: rgba(134,239,172,0.35);
  }
  .gain-p{
    min-width: 52px;
    text-align:center;
    font-weight: 950;
    color: rgba(134,239,172,0.92);
    background: rgba(134,239,172,0.10);
    border: 1px solid rgba(134,239,172,0.18);
    padding: 6px 10px;
    border-radius: 999px;
  }
  .gain-t{
    flex: 1;
    color: rgba(255,255,255,0.86);
    font-weight: 750;
  }
  .gain-a{
    opacity: .75;
    font-weight: 950;
  }

  /* Next Steps */
  .panel-actions{ padding: clamp(0.75rem, 1.2vw, 1.1rem); }

  .nba-head h2{
    margin:0;
    font-size: 1.05rem;
    font-weight: 950;
    letter-spacing: -0.01em;
    color: rgba(255,255,255,0.96);
  }
  .nba-head p{
    margin: 4px 0 0;
    color: var(--gray-400);
    font-weight: 650;
    font-size: 0.9rem;
    line-height: 1.35;
  }

  .nba-grid{
    margin-top: 10px;
    display:grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(0.6rem, 1vw, 0.9rem);
  }

  .nba-card{
    display:flex;
    flex-direction:column;
    gap: 8px;
    padding: clamp(0.75rem, 1.1vw, 0.95rem);
    border-radius: 1.1rem;
    text-decoration:none;
    border: 2px solid var(--dark-lighter);
    background: rgba(255,255,255,0.04);
    transition: transform .18s ease, background .18s ease, border-color .18s ease, box-shadow .18s ease;
  }
  .nba-card:hover{
    transform: translateY(-2px);
    background: rgba(255,255,255,0.08);
    border-color: rgba(134,239,172,0.40);
    box-shadow: 0 20px 60px rgba(0,0,0,0.35);
  }

  .nba-top{ display:flex; align-items:center; gap: 10px; }
  .nba-icon{
    width: 34px;
    height: 34px;
    border-radius: 12px;
    display:grid;
    place-items:center;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.10);
  }
  .nba-title{
    font-weight: 950;
    color: rgba(255,255,255,0.95);
    letter-spacing: -0.01em;
    line-height: 1.15;
  }
  .nba-desc{
    color: var(--gray-400);
    font-weight: 650;
    font-size: 0.88rem;
    line-height: 1.35;
  }
  .nba-cta{
    margin-top: 2px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    color: rgba(255,255,255,0.84);
    font-weight: 900;
    font-size: 0.92rem;
  }

  .tone-primary{ border-color: rgba(34,197,94,0.28); }
  .tone-success{ border-color: rgba(134,239,172,0.22); }
  .tone-warning{ border-color: rgba(253,224,71,0.18); }
  .tone-danger{  border-color: rgba(239,68,68,0.20); }
  .tone-neutral{ border-color: var(--dark-lighter); }

  /* Chips */
  .chips{
    display: flex;
    justify-content: center;
    gap: .6rem;
    flex-wrap: wrap;
  }

  .chip{
    display: inline-flex;
    align-items: center;
    gap: .45rem;
    padding: .38rem .75rem;
    border-radius: 2rem;
    font-size: .78rem;
    font-weight: 700;
    border: 1px solid rgba(255,255,255,0.10);
    background: rgba(255,255,255,0.05);
    color: var(--gray-400);
    white-space: nowrap;
    text-decoration: none;
    cursor: pointer;
    transition: transform .18s ease, background .18s ease, border-color .18s ease;
  }

  .chip:hover{
    transform: translateY(-1px);
    background: rgba(255,255,255,0.08);
    border-color: rgba(134,239,172,0.35);
  }

  .chip.success{
    background: rgba(134, 239, 172, 0.10);
    color: var(--primary);
    border: 1px solid rgba(134, 239, 172, 0.20);
  }
  .chip.warning{
    background: rgba(253, 224, 71, 0.08);
    color: var(--warning);
    border: 1px solid rgba(253, 224, 71, 0.18);
  }
  .chip.danger{
    background: rgba(239, 68, 68, 0.10);
    color: rgba(255,255,255,0.92);
    border: 1px solid rgba(239, 68, 68, 0.22);
  }
  .chip.neutral{
    background: rgba(255,255,255,0.04);
    color: var(--gray-400);
    border: 1px solid rgba(255,255,255,0.10);
  }

  /* KPIs */
  .kpis{
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(0.6rem, 1vw, 0.9rem);
  }

  .kpi{
    padding: clamp(0.75rem, 1.1vw, 1rem);
    display: grid;
    align-content: center;
    gap: .25rem;
    min-height: 92px;
    transition: all .25s ease;
  }

  .kpi:hover{
    border-color: rgba(134,239,172,0.45);
    background: rgba(255,255,255,0.08);
    transform: translateY(-2px);
  }

  .kpi-link{ text-decoration: none; color: inherit; cursor: pointer; }

  .kpi-title{
    font-size: .82rem;
    font-weight: 750;
    color: var(--gray-400);
  }

  .kpi-value{
    font-size: clamp(1.35rem, 1.8vw, 1.8rem);
    font-weight: 900;
    color: var(--white);
