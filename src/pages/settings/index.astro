---
import SettingsLayout from "../../layouts/SettingsLayout.astro";
import { ROUTES } from "../../lib/constants/routes";

const userEmail = Astro.locals.user?.email ?? null;
---

<SettingsLayout
  title="Einstellungen | ImmobilienPro"
  description="Übersicht über Konto- und Sicherheitseinstellungen."
  userEmail={userEmail}
>
  <div class="stack">
    <header class="section__header">
      <p class="section__eyebrow">Settings</p>
      <h2>Einstellungen im Überblick</h2>
      <p>
        Verwalte dein Profil, deine Sicherheitsoptionen und wichtige
        Kontobereiche an einem Ort.
      </p>
    </header>

    <section class="grid-auto">
      <article class="card card--glass card--glow">
        <div class="card__body stack">
          <h3>Profil</h3>
          <p>
            Bearbeite persönliche Angaben, Kontaktinformationen und
            organisationsbezogene Daten.
          </p>
          <div class="row">
            <a href={ROUTES.SETTINGS_PROFILE} class="button button--primary">
              Profil öffnen
            </a>
          </div>
        </div>
      </article>

      <article class="card card--glass card--glow">
        <div class="card__body stack">
          <h3>Sicherheit</h3>
          <p>
            Behalte Passwort, Login-Sicherheit und den Schutz deines Kontos im
            Blick.
          </p>
          <div class="row">
            <a href={ROUTES.SETTINGS_SECURITY} class="button button--secondary">
              Sicherheit öffnen
            </a>
          </div>
        </div>
      </article>
    </section>
  </div>
</SettingsLayout>