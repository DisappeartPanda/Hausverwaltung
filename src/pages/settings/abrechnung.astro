---
import SettingsLayout from "../../layouts/SettingsLayout.astro";
import { getAppSession } from "../../lib/auth/session";
import { getAppContext } from "../../lib/utils/app-context";
import { listObjectsByOrganization } from "../../lib/domain/objects/object-list-service";
import { listUnitsByOrganization } from "../../lib/domain/units/unit-list-service";
import { listTenantsByOrganization } from "../../lib/domain/tenants/tenant-list-service";

const session = await getAppSession(Astro);

if (session instanceof Response) {
  return session;
}

const appContext = await getAppContext(session);

if (!appContext.organizationId) {
  throw new Error("Keine organizationId verfügbar.");
}

const [objects, units, tenants] = await Promise.all([
  listObjectsByOrganization(appContext.organizationId),
  listUnitsByOrganization(appContext.organizationId),
  listTenantsByOrganization(appContext.organizationId),
]);
---

<SettingsLayout
  title="Abrechnungseinstellungen | ImmobilienPro"
  description="Grundlagen und Bezugsdaten für Abrechnungen."
  userEmail={session.email}
  organizationName={appContext.organizationName}
>
  <div class="stack">
    <header class="section__header">
      <p class="section__eyebrow">Abrechnung</p>
      <h2>Abrechnungsrelevante Basisdaten</h2>
      <p>
        Hier siehst du die aktuelle Datenbasis für Objekte, Einheiten und
        Mieter, die für spätere Abrechnungen relevant ist.
      </p>
    </header>

    <section class="grid-auto">
      <article class="card card--glass">
        <div class="card__body stack">
          <h3>Objekte</h3>
          <p><strong>Anzahl:</strong> {objects.length}</p>
        </div>
      </article>

      <article class="card card--glass">
        <div class="card__body stack">
          <h3>Wohneinheiten</h3>
          <p><strong>Anzahl:</strong> {units.length}</p>
        </div>
      </article>

      <article class="card card--glass">
        <div class="card__body stack">
          <h3>Mieter</h3>
          <p><strong>Anzahl:</strong> {tenants.length}</p>
        </div>
      </article>
    </section>
  </div>
</SettingsLayout>