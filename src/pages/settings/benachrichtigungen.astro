---
import SettingsLayout from "../../layouts/SettingsLayout.astro";
import { MODULE_KEYS } from "../../lib/constants/module-keys";

const activeModules = [
  MODULE_KEYS.HAUSVERWALTUNG,
  MODULE_KEYS.SONDEREIGENTUM,
];
---

<SettingsLayout
  title="Benachrichtigungen | ImmobilienPro"
  organizationName="Musterverwaltung GmbH"
  activeModules={activeModules}
>
  <div class="stack">
    <div class="section__header">
      <span class="section__eyebrow">Benachrichtigungen</span>
      <h1>Benachrichtigungen verwalten</h1>
      <p>
        Lege fest, zu welchen Ereignissen du informiert werden möchtest.
      </p>
    </div>

    <section class="card card--glass">
      <div class="card__body stack">
        <h3>E-Mail-Benachrichtigungen</h3>

        <label class="notification-row">
          <div>
            <strong>Neue Mängelmeldungen</strong>
            <p>Benachrichtigung bei neuen Schäden oder Störungen.</p>
          </div>
          <input type="checkbox" checked />
        </label>

        <label class="notification-row">
          <div>
            <strong>Neue Mieternachrichten</strong>
            <p>Benachrichtigung bei eingehenden Nachrichten im Portal.</p>
          </div>
          <input type="checkbox" checked />
        </label>

        <label class="notification-row">
          <div>
            <strong>Wartungserinnerungen</strong>
            <p>Hinweise auf anstehende Wartungstermine.</p>
          </div>
          <input type="checkbox" checked />
        </label>

        <label class="notification-row">
          <div>
            <strong>Abrechnungsupdates</strong>
            <p>Informationen bei neuen oder geänderten Abrechnungen.</p>
          </div>
          <input type="checkbox" />
        </label>

        <div class="row">
          <button class="button button--primary" type="button">
            Einstellungen speichern
          </button>
        </div>
      </div>
    </section>
  </div>
</SettingsLayout>

<style>
  .notification-row {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.02);
  }

  .notification-row p {
    margin-bottom: 0;
  }

  .notification-row input[type="checkbox"] {
    width: 1.1rem;
    height: 1.1rem;
    margin-top: 0.2rem;
  }

  @media (max-width: 720px) {
    .notification-row {
      flex-direction: column;
    }
  }
</style>