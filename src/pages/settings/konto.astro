---
import SettingsLayout from "../../layouts/SettingsLayout.astro";
import { MODULE_KEYS } from "../../lib/constants/module-keys";
import { getAppContext } from "../../lib/utils/app-context";
import { requireLandlordSession } from "../../lib/auth/guards";

const activeModules = [
  MODULE_KEYS.HAUSVERWALTUNG,
  MODULE_KEYS.SONDEREIGENTUM,
];

const session = await requireLandlordSession(Astro);

if (session instanceof Response) {
  return session;
}

const appContext = await getAppContext(session);

const firstName = session.firstName ?? "";
const lastName = session.lastName ?? "";
const email = session.email ?? "";
---

<SettingsLayout
  title="Konto | ImmobilienPro"
  organizationName={appContext.organizationName}
  activeModules={activeModules}
  theme={appContext.theme}
>
  <div class="stack">
    <div class="section__header">
      <span class="section__eyebrow">Konto</span>
      <h1>Kontoeinstellungen</h1>
      <p>
        Pflege die wichtigsten Angaben für dein Benutzerkonto und deine
        Organisation.
      </p>
    </div>

    <section class="card card--glass">
      <div class="card__body stack">
        <h3>Persönliche Angaben</h3>

        <form id="profile-update-form" class="stack">
          <div class="grid-auto">
            <div class="input-group">
              <label class="input-label" for="firstName">Vorname</label>
              <input id="firstName" name="firstName" value={firstName} />
            </div>

            <div class="input-group">
              <label class="input-label" for="lastName">Nachname</label>
              <input id="lastName" name="lastName" value={lastName} />
            </div>
          </div>

          <div class="input-group">
            <label class="input-label" for="email">E-Mail</label>
            <input id="email" name="email" value={email} />
          </div>

          <div class="input-group">
            <label class="input-label">Rolle</label>
            <input value={session.role} disabled />
          </div>

          <div class="row">
            <button class="button button--primary" type="submit">
              Änderungen speichern
            </button>
          </div>

          <p id="profile-form-status" class="form-status" aria-live="polite"></p>
        </form>
      </div>
    </section>

    <section class="card card--glass">
      <div class="card__body stack">
        <h3>Organisation</h3>

        <div class="grid-auto">
          <div class="input-group">
            <label class="input-label">Organisationsname</label>
            <input value={appContext.organizationName} disabled />
          </div>

          <div class="input-group">
            <label class="input-label">Organisations-ID</label>
            <input value={appContext.organizationId ?? ""} disabled />
          </div>
        </div>
      </div>
    </section>
  </div>
</SettingsLayout>

<script>
  const form = document.querySelector("#profile-update-form");
  const statusEl = document.querySelector("#profile-form-status");

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const formData = new FormData(form);
    const payload = Object.fromEntries(formData.entries());

    try {
      const response = await fetch("/api/profile/update", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify(payload)
      });

      const result = await response.json();

      if (!response.ok || !result.success) {
        statusEl.textContent =
          result?.errors?.form ||
          Object.values(result?.errors || {})[0] ||
          "Profil konnte nicht gespeichert werden.";
        return;
      }

      statusEl.textContent = "Profil erfolgreich aktualisiert.";
      window.location.reload();
    } catch {
      statusEl.textContent = "Beim Speichern ist ein Fehler aufgetreten.";
    }
  });
</script>

<style>
  .form-status {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }
</style>