---
export const prerender = false;

import DashboardLayout from '../layouts/DashboardLayout.astro';
import { requireLandlordSession } from '../lib/serverAuth';

const { supabase, user } = await requireLandlordSession(Astro);

const { data: settings } = await supabase
  .from('profile_settings')
  .select('user_id, dashboard_mode, theme, dashboard_layout')
  .eq('user_id', user.id)
  .maybeSingle();

const s = settings ?? {};
---

<DashboardLayout title="Einstellungen | ImmobilienPro">
  <section class="wrap">
    <header class="top">
      <div>
        <h1>Einstellungen</h1>
        <p>Design & Dashboard-Verhalten. (Hier kommt später auch „Dashboard manuell anpassen“ rein.)</p>
      </div>
    </header>

    <div class="panel">
      <form id="settingsForm" class="form">
        <div class="row">
          <div class="card">
            <h2>Dashboard</h2>
            <p>Steuert, ob dein Dashboard automatisch nach Einheiten skaliert oder manuell.</p>

            <label>
              <span>Dashboard Modus</span>
              <select name="dashboard_mode">
                <option value="auto" selected={(s.dashboard_mode ?? 'auto') === 'auto'}>Automatisch</option>
                <option value="manual" selected={s.dashboard_mode === 'manual'}>Manuell</option>
              </select>
            </label>

            <label>
              <span>Dashboard Layout</span>
              <select name="dashboard_layout">
                <option value="auto" selected={(s.dashboard_layout ?? 'auto') === 'auto'}>Auto</option>
                <option value="compact" selected={s.dashboard_layout === 'compact'}>Kompakt</option>
                <option value="detailed" selected={s.dashboard_layout === 'detailed'}>Detailliert</option>
              </select>
            </label>
          </div>

          <div class="card">
            <h2>Design</h2>
            <p>Theme-Auswahl (später können wir Design-Presets hinzufügen).</p>

            <label>
              <span>Theme</span>
              <select name="theme">
                <option value="dark" selected={(s.theme ?? 'dark') === 'dark'}>Dark</option>
                <option value="light" selected={s.theme === 'light'}>Light</option>
                <option value="system" selected={s.theme === 'system'}>System</option>
              </select>
            </label>

            <div class="hint">
              Tipp: „System“ kann später automatisch Dark/Light wählen.
            </div>
          </div>
        </div>

        <div class="actions">
          <button class="btn primary" type="submit">Speichern</button>
        </div>
      </form>
    </div>

    <div class="toast" id="toast" hidden></div>
  </section>
</DashboardLayout>

<script>
  const form = document.getElementById('settingsForm');
  const toast = document.getElementById('toast');

  const showToast = (msg, type = 'ok') => {
    if (!toast) return;
    toast.textContent = msg;
    toast.classList.remove('ok', 'err', 'show');
    toast.classList.add(type);
    toast.hidden = false;
    void toast.offsetWidth;
    toast.classList.add('show');
    setTimeout(() => {
      toast.classList.remove('show');
      setTimeout(() => (toast.hidden = true), 160);
    }, 2200);
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);

    let res;
    try {
      res = await fetch('/api/profile-settings', { method: 'POST', body: fd });
    } catch {
      showToast('Netzwerkfehler.', 'err');
      return;
    }

    if (!res.ok) {
      const msg = (await res.text()).slice(0, 180) || 'Speichern fehlgeschlagen.';
      showToast(msg, 'err');
      return;
    }

    showToast('Einstellungen gespeichert.', 'ok');
  });
</script>

<style>
  .wrap{
    width: min(1100px, 100%);
    margin: 0 auto;
    padding: 0 clamp(0.75rem, 1.4vw, 1.25rem);
    display:flex;
    flex-direction:column;
    gap: 14px;
  }

  .top h1{
    margin:0;
    font-size: 1.75rem;
    font-weight: 950;
    color: rgba(255,255,255,0.96);
    letter-spacing: -0.02em;
  }
  .top p{
    margin: 6px 0 0;
    color: rgba(190,201,197,0.75);
    font-weight: 650;
  }

  .panel{
    background: rgba(255,255,255,0.05);
    border: 2px solid var(--dark-lighter);
    border-radius: 1.25rem;
    padding: clamp(0.75rem, 1.2vw, 1.1rem);
  }

  .form{ display:flex; flex-direction:column; gap: 12px; }

  .row{
    display:grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .card{
    border-radius: 1.25rem;
    padding: 1rem;
    background: linear-gradient(180deg, rgba(16,22,19,0.78), rgba(10,14,12,0.78));
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 22px 70px rgba(0,0,0,0.30);
    display:flex;
    flex-direction:column;
    gap: 10px;
  }

  .card h2{
    margin:0;
    font-size: 1.12rem;
    font-weight: 950;
    color: rgba(255,255,255,0.95);
  }
  .card p{
    margin:0;
    color: rgba(190,201,197,0.72);
    font-weight: 650;
    font-size: .92rem;
  }

  label{
    display:flex;
    flex-direction:column;
    gap: .5rem;
    margin-top: .35rem;
  }

  label span{
    color: rgba(190,201,197,0.74);
    font-weight: 850;
    font-size: .92rem;
  }

  select{
    border-radius: 1rem;
    border: 1px solid rgba(255,255,255,0.10);
    background: rgba(0,0,0,0.28);
    color: rgba(255,255,255,0.92);
    padding: .85rem .9rem;
    font-weight: 800;
    outline: none;
  }

  .hint{
    margin-top: 6px;
    border-radius: 1rem;
    border: 1px solid rgba(34,197,94,0.18);
    background: rgba(34,197,94,0.08);
    padding: .75rem .85rem;
    color: rgba(190,201,197,0.78);
    font-weight: 650;
  }

  .actions{
    display:flex;
    justify-content:flex-end;
    padding-top: 4px;
  }

  .btn{
    padding: .85rem 1.05rem;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.10);
    background: rgba(255,255,255,0.06);
    color: rgba(236,242,239,0.92);
    font-weight: 950;
    cursor:pointer;
    transition: all .2s ease;
  }
  .btn:hover{
    transform: translateY(-1px);
    background: rgba(255,255,255,0.08);
    border-color: rgba(34,197,94,0.30);
  }
  .btn.primary{
    border-color: rgba(34,197,94,0.32);
    background: rgba(34,197,94,0.14);
  }

  .toast{
    position: fixed;
    left: 50%;
    bottom: 22px;
    transform: translateX(-50%);
    z-index: 120;
    padding: .6rem .85rem;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.92);
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(10px);
    box-shadow: 0 18px 45px rgba(0,0,0,0.5);
    opacity: 0;
    transition: opacity .2s ease, transform .2s ease;
  }
  .toast.show{
    opacity: 1;
    transform: translateX(-50%) translateY(-2px);
  }
  .toast.ok{
    border-color: rgba(34,197,94,0.25);
    background: rgba(34,197,94,0.12);
  }
  .toast.err{
    border-color: rgba(239,68,68,0.25);
    background: rgba(239,68,68,0.12);
  }

  @media (max-width: 980px){
    .row{ grid-template-columns: 1fr; }
    .actions{ justify-content:stretch; }
    .btn{ width:100%; justify-content:center; }
  }
</style>