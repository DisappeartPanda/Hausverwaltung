---
export const prerender = false;

import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { requireLandlordSession } from '../../lib/supabase/serverAuth';

const { supabase, user } = await requireLandlordSession(Astro);

type Mode = 'finance' | 'hybrid' | 'management';
type ModeOrAuto = Mode | 'auto';

type ProfileSettingsRow = {
  user_id: string;
  dashboard_mode: Mode | null;
  updated_at?: string;
};

let loadError = false;
let errorMessage = '';

let currentMode: ModeOrAuto = 'auto';

try {
  const { data, error } = await supabase
    .from('profile_settings')
    .select('user_id, dashboard_mode, updated_at')
    .eq('user_id', user.id)
    .maybeSingle();

  if (error) throw error;

  currentMode = (data?.dashboard_mode ?? null) === null ? 'auto' : (data!.dashboard_mode as Mode);
} catch (e: any) {
  loadError = true;
  errorMessage = e?.message ?? 'DB Fehler';
}
---

<DashboardLayout title="Profil & Einstellungen">
  <section class="page">
    <header class="header">
      <div class="header-left">
        <h1 class="title">Profil</h1>
        <p class="subtitle">Passe dein Dashboard an. Standardmäßig ist es automatisch und passt sich deinem Portfolio an.</p>
      </div>
    </header>

    {loadError && (
      <div class="state">
        <div class="state-text">
          <div class="state-title">Konnte Einstellungen nicht laden</div>
          <div class="state-subtitle">{errorMessage}</div>
        </div>
        <div class="state-actions">
          <a class="btn btn-ghost" href="/profil">Neu laden</a>
        </div>
      </div>
    )}

    {!loadError && (
      <form id="settingsForm" class="card">
        <div class="card-head">
          <div>
            <div class="card-title">Dashboard Ansicht</div>
            <div class="card-subtitle">
              <strong>Automatisch</strong> wählt die Ansicht je nach Anzahl deiner Einheiten.
              Sobald du manuell auswählst, bleibt es fix – bis du wieder auf <strong>Automatisch</strong> stellst.
            </div>
          </div>
          <div class="pill" id="modePill" data-mode={currentMode}>
            {currentMode === 'auto' ? 'Automatisch' : currentMode === 'finance' ? 'Finanzen' : currentMode === 'management' ? 'Verwaltung' : 'Hybrid'}
          </div>
        </div>

        <div class="options" role="radiogroup" aria-label="Dashboard Modus">
          <label class={`opt ${currentMode === 'auto' ? 'opt-active' : ''}`}>
            <input type="radio" name="dashboard_mode" value="auto" checked={currentMode === 'auto'} />
            <div class="opt-main">
              <div class="opt-title">✨ Automatisch</div>
              <div class="opt-desc">Passt sich an dein Portfolio an (empfohlen).</div>
            </div>
            <div class="opt-badge">Smart</div>
          </label>

          <label class={`opt ${currentMode === 'finance' ? 'opt-active' : ''}`}>
            <input type="radio" name="dashboard_mode" value="finance" checked={currentMode === 'finance'} />
            <div class="opt-main">
              <div class="opt-title">💰 Finanzen</div>
              <div class="opt-desc">Einnahmen, offene Zahlungen, Rendite & Kennzahlen.</div>
            </div>
            <div class="opt-badge">Cashflow</div>
          </label>

          <label class={`opt ${currentMode === 'hybrid' ? 'opt-active' : ''}`}>
            <input type="radio" name="dashboard_mode" value="hybrid" checked={currentMode === 'hybrid'} />
            <div class="opt-main">
              <div class="opt-title">🧠 Hybrid</div>
              <div class="opt-desc">Finanzen + Verwaltung in Balance (SaaS Default).</div>
            </div>
            <div class="opt-badge">Allround</div>
          </label>

          <label class={`opt ${currentMode === 'management' ? 'opt-active' : ''}`}>
            <input type="radio" name="dashboard_mode" value="management" checked={currentMode === 'management'} />
            <div class="opt-main">
              <div class="opt-title">🏢 Verwaltung</div>
              <div class="opt-desc">Mängel, Verträge, Aufgaben & Operatives im Fokus.</div>
            </div>
            <div class="opt-badge">Ops</div>
          </label>
        </div>

        <div class="actions">
          <button type="submit" class="btn btn-primary" id="saveBtn">Speichern</button>
          <a class="btn btn-ghost" href="/dashboard">Zum Dashboard</a>
          <span class="hint" id="saveHint">Änderungen werden sofort aktiv.</span>
        </div>

        <div id="toast" class="toast hidden" role="status" aria-live="polite"></div>
        <div id="error" class="error hidden" role="alert"></div>
      </form>
    )}
  </section>
</DashboardLayout>

<script type="module">
  import { supabase } from '../../lib/supabase';

  const form = document.getElementById('settingsForm');
  const toast = document.getElementById('toast');
  const error = document.getElementById('error');
  const saveBtn = document.getElementById('saveBtn');
  const pill = document.getElementById('modePill');

  const showToast = (msg) => {
    if (!toast) return;
    toast.textContent = msg;
    toast.classList.remove('hidden');
    setTimeout(() => toast.classList.add('hidden'), 1400);
  };

  const showError = (msg) => {
    if (!error) return;
    error.textContent = msg;
    error.classList.remove('hidden');
  };

  const clearError = () => {
    if (!error) return;
    error.textContent = '';
    error.classList.add('hidden');
  };

  const labelFor = (mode) => {
    if (mode === 'auto') return 'Automatisch';
    if (mode === 'finance') return 'Finanzen';
    if (mode === 'management') return 'Verwaltung';
    return 'Hybrid';
  };

  const updatePill = (mode) => {
    if (!pill) return;
    pill.textContent = labelFor(mode);
    pill.dataset.mode = mode;
  };

  const updateActive = (mode) => {
    document.querySelectorAll('.opt').forEach((el) => {
      const input = el.querySelector('input[type="radio"]');
      const isActive = input && input.value === mode;
      el.classList.toggle('opt-active', Boolean(isActive));
    });
  };

  form?.addEventListener('change', () => {
    const checked = form.querySelector('input[name="dashboard_mode"]:checked');
    const mode = checked ? checked.value : 'auto';
    updatePill(mode);
    updateActive(mode);
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearError();

    if (saveBtn) {
      saveBtn.disabled = true;
      saveBtn.textContent = 'Speichere…';
    }

    try {
      const { data: { session }, error: sErr } = await supabase.auth.getSession();
      if (sErr) throw sErr;
      if (!session) {
        window.location.href = '/login';
        return;
      }

      const checked = form.querySelector('input[name="dashboard_mode"]:checked');
      const mode = checked ? checked.value : 'auto';

      // null = automatisch
      const dashboard_mode = mode === 'auto' ? null : mode;

      const { error: upErr } = await supabase
        .from('profile_settings')
        .upsert({
          user_id: session.user.id,
          dashboard_mode,
          updated_at: new Date().toISOString()
        }, { onConflict: 'user_id' });

      if (upErr) throw upErr;

      showToast('Gespeichert ✓');
      updatePill(mode);
      updateActive(mode);
    } catch (err) {
      showError('Fehler: ' + (err?.message ?? String(err)));
    } finally {
      if (saveBtn) {
        saveBtn.disabled = false;
        saveBtn.textContent = 'Speichern';
      }
    }
  });
</script>

<style>
  :global(:root) {
    --ip-card: rgba(16, 22, 19, 0.72);
    --ip-card-2: rgba(12, 17, 14, 0.72);
    --ip-border: rgba(255,255,255,0.10);
    --ip-text: rgba(236, 242, 239, 0.92);
    --ip-muted: rgba(190, 201, 197, 0.74);
    --ip-accent: #22c55e;
    --ip-shadow: 0 24px 70px rgba(0,0,0,0.45);
  }

  .page { display:flex; flex-direction:column; gap:16px; }

  .header { display:flex; align-items:flex-start; justify-content:space-between; gap:14px; }
  .title { margin:0; font-size:1.65rem; font-weight:950; letter-spacing:-0.02em; color:var(--ip-text); }
  .subtitle { margin:6px 0 0; color:var(--ip-muted); font-weight:650; font-size:0.95rem; max-width: 72ch; }

  .card{
    border-radius:20px;
    background: linear-gradient(180deg, rgba(16, 22, 19, 0.74), rgba(10, 14, 12, 0.74));
    border: 1px solid rgba(255,255,255,0.10);
    box-shadow: 0 22px 70px rgba(0,0,0,0.30), inset 0 1px 0 rgba(255,255,255,0.06);
    padding:16px;
  }

  .card-head{
    display:flex;
    align-items:flex-start;
    justify-content:space-between;
    gap:12px;
    padding-bottom:12px;
    margin-bottom:12px;
    border-bottom:1px solid rgba(255,255,255,0.08);
  }

  .card-title{
    color: rgba(236,242,239,0.94);
    font-weight:950;
    letter-spacing:-0.01em;
    font-size:1.05rem;
  }

  .card-subtitle{
    margin-top:6px;
    color: rgba(190,201,197,0.78);
    font-weight:650;
    line-height:1.45;
    max-width: 80ch;
  }

  .pill{
    padding:8px 12px;
    border-radius:999px;
    border:1px solid rgba(34,197,94,0.22);
    background: rgba(34,197,94,0.10);
    color: rgba(207,255,225,0.92);
    font-weight:900;
    font-size:0.9rem;
    white-space:nowrap;
  }
  .pill[data-mode="finance"]{
    border-color: rgba(34,197,94,0.22);
    background: rgba(34,197,94,0.10);
  }
  .pill[data-mode="hybrid"]{
    border-color: rgba(34,197,94,0.22);
    background: rgba(34,197,94,0.10);
  }
  .pill[data-mode="management"]{
    border-color: rgba(250,204,21,0.22);
    background: rgba(250,204,21,0.10);
    color: rgba(255,244,204,0.92);
  }
  .pill[data-mode="auto"]{
    border-color: rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.06);
    color: rgba(236,242,239,0.90);
  }

  .options{
    display:grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap:12px;
  }
  @media (max-width: 900px){
    .options{ grid-template-columns: 1fr; }
  }

  .opt{
    position:relative;
    display:flex;
    gap:12px;
    align-items:flex-start;
    padding:14px;
    border-radius:18px;
    border:1px solid rgba(255,255,255,0.10);
    background: rgba(255,255,255,0.04);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
    cursor:pointer;
    user-select:none;
  }

  .opt:hover{
    transform: translateY(-2px);
    border-color: rgba(34,197,94,0.20);
    background: rgba(255,255,255,0.06);
  }

  .opt input{
    position:absolute;
    opacity:0;
    pointer-events:none;
  }

  .opt-active{
    border-color: rgba(34,197,94,0.28);
    background: rgba(34,197,94,0.10);
    box-shadow: 0 22px 70px rgba(0,0,0,0.20), inset 0 1px 0 rgba(255,255,255,0.06);
  }

  .opt-main{ display:flex; flex-direction:column; gap:4px; }
  .opt-title{ color: rgba(236,242,239,0.94); font-weight:950; }
  .opt-desc{ color: rgba(190,201,197,0.78); font-weight:650; }

  .opt-badge{
    margin-left:auto;
    padding:6px 10px;
    border-radius:999px;
    border:1px solid rgba(255,255,255,0.10);
    background: rgba(0,0,0,0.20);
    color: rgba(236,242,239,0.88);
    font-weight:900;
    font-size:0.82rem;
    white-space:nowrap;
  }

  .actions{
    display:flex;
    align-items:center;
    gap:10px;
    padding-top:14px;
    margin-top:14px;
    border-top:1px solid rgba(255,255,255,0.08);
    flex-wrap:wrap;
  }

  .btn{
    display:inline-flex; align-items:center; justify-content:center; gap:10px;
    padding:10px 14px; border-radius:12px;
    border:1px solid var(--ip-border);
    background: rgba(255,255,255,0.06);
    color:var(--ip-text); text-decoration:none;
    font-weight:900; font-size:0.95rem;
    transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease, border-color 160ms ease;
    cursor:pointer;
  }
  .btn:hover{ transform:translateY(-1px); background:rgba(255,255,255,0.08); box-shadow:0 18px 50px rgba(0,0,0,0.35); }

  .btn-primary{
    border-color: rgba(34, 197, 94, 0.35);
    background: linear-gradient(180deg, rgba(34,197,94,0.18), rgba(34,197,94,0.08));
    box-shadow: 0 18px 60px rgba(34,197,94,0.12);
  }
  .btn-primary:hover{
    border-color: rgba(34, 197, 94, 0.55);
    box-shadow: 0 22px 70px rgba(34,197,94,0.16);
  }
  .btn-ghost{ background: rgba(255,255,255,0.04); }

  .hint{
    color: rgba(190,201,197,0.70);
    font-weight:650;
    font-size:0.9rem;
  }

  .toast{
    margin-top:12px;
    padding:12px;
    border-radius:14px;
    border:1px solid rgba(34,197,94,0.22);
    background: rgba(34,197,94,0.12);
    color: rgba(207,255,225,0.92);
    font-weight:900;
  }

  .error{
    margin-top:12px;
    padding:12px;
    border-radius:14px;
    border:1px solid rgba(239,68,68,0.22);
    background: rgba(239,68,68,0.10);
    color: rgba(255,220,220,0.95);
    font-weight:800;
  }
  .hidden{ display:none !important; }

  .state{
    display:flex; align-items:center; justify-content:space-between; gap:14px;
    padding:22px; border-radius:18px;
    background: linear-gradient(180deg, rgba(16, 22, 19, 0.74), rgba(10, 14, 12, 0.74));
    border:1px solid rgba(255,255,255,0.10);
    box-shadow: 0 22px 70px rgba(0,0,0,0.30), inset 0 1px 0 rgba(255,255,255,0.05);
    color: var(--ip-text);
  }
  .state-title{ font-weight:950; }
  .state-subtitle{ color: var(--ip-muted); font-weight:650; font-size:0.92rem; margin-top:2px; }
</style>