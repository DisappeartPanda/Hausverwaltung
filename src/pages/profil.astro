---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Mein Profil">
  <h1 class="text-2xl font-bold mb-6">Mein Profil</h1>
  
  <div class="max-w-2xl space-y-6">
    <!-- Persönliche Daten -->
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold mb-4">Persönliche Daten</h2>
      <form id="profil-form" class="space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700">Vorname *</label>
            <input name="vorname" type="text" required class="mt-1 block w-full px-3 py-2 border rounded-md" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Nachname *</label>
            <input name="nachname" type="text" required class="mt-1 block w-full px-3 py-2 border rounded-md" />
          </div>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700">E-Mail *</label>
          <input name="email" type="email" required class="mt-1 block w-full px-3 py-2 border rounded-md" />
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700">Telefon</label>
          <input name="telefon" type="tel" class="mt-1 block w-full px-3 py-2 border rounded-md" />
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700">Steuer-ID</label>
          <input name="steuer_id" type="text" class="mt-1 block w-full px-3 py-2 border rounded-md" />
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700">Firma (optional)</label>
          <input name="firma" type="text" class="mt-1 block w-full px-3 py-2 border rounded-md" />
        </div>
        
        <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
          Speichern
        </button>
      </form>
    </div>
    
    <!-- Adresse -->
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold mb-4">Adresse</h2>
      <form id="adresse-form" class="space-y-4">
        <div class="grid grid-cols-3 gap-4">
          <div class="col-span-2">
            <label class="block text-sm font-medium text-gray-700">Straße</label>
            <input name="strasse" type="text" class="mt-1 block w-full px-3 py-2 border rounded-md" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Hausnummer</label>
            <input name="hausnummer" type="text" class="mt-1 block w-full px-3 py-2 border rounded-md" />
          </div>
        </div>
        
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700">PLZ</label>
            <input name="plz" type="text" class="mt-1 block w-full px-3 py-2 border rounded-md" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Stadt</label>
            <input name="stadt" type="text" class="mt-1 block w-full px-3 py-2 border rounded-md" />
          </div>
        </div>
        
        <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
          Speichern
        </button>
      </form>
    </div>
    
    <!-- Bankverbindung -->
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold mb-4">Bankverbindung (für Mietauszahlungen)</h2>
      <form id="bank-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700">IBAN</label>
          <input name="iban" type="text" class="mt-1 block w-full px-3 py-2 border rounded-md" />
        </div>
        
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700">BIC</label>
            <input name="bic" type="text" class="mt-1 block w-full px-3 py-2 border rounded-md" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Kontoinhaber</label>
            <input name="kontoinhaber" type="text" class="mt-1 block w-full px-3 py-2 border rounded-md" />
          </div>
        </div>
        
        <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
          Speichern
        </button>
      </form>
    </div>
    
    <!-- Passwort ändern -->
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold mb-4">Passwort ändern</h2>
      <form id="passwort-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700">Neues Passwort</label>
          <input name="neues_passwort" type="password" minlength="6" class="mt-1 block w-full px-3 py-2 border rounded-md" />
        </div>
        
        <button type="submit" class="px-6 py-2 bg-gray-600 text-white rounded hover:bg-gray-700">
          Passwort aktualisieren
        </button>
      </form>
    </div>
  </div>
</DashboardLayout>

<script>
  import { supabase } from '../lib/supabase';
  
  let vermieterId: string;
  
  const loadProfil = async () => {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return;
    
    const { data: vermieter } = await supabase
      .from('vermieter')
      .select('*')
      .eq('user_id', session.user.id)
      .single();
    
    if (!vermieter) return;
    
    vermieterId = vermieter.id;
    
    // Formulare füllen
    const profilForm = document.getElementById('profil-form') as HTMLFormElement;
    profilForm.vorname.value = vermieter.vorname;
    profilForm.nachname.value = vermieter.nachname;
    profilForm.email.value = vermieter.email;
    profilForm.telefon.value = vermieter.telefon || '';
    profilForm.steuer_id.value = vermieter.steuer_id || '';
    profilForm.firma.value = vermieter.firma || '';
    
    const adresseForm = document.getElementById('adresse-form') as HTMLFormElement;
    adresseForm.strasse.value = vermieter.strasse || '';
    adresseForm.hausnummer.value = vermieter.hausnummer || '';
    adresseForm.plz.value = vermieter.plz || '';
    adresseForm.stadt.value = vermieter.stadt || '';
    
    const bankForm = document.getElementById('bank-form') as HTMLFormElement;
    bankForm.iban.value = vermieter.iban || '';
    bankForm.bic.value = vermieter.bic || '';
    bankForm.kontoinhaber.value = vermieter.kontoinhaber || '';
  };
  
  // Profil speichern
  document.getElementById('profil-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target as HTMLFormElement);
    
    await supabase
      .from('vermieter')
      .update({
        vorname: formData.get('vorname'),
        nachname: formData.get('nachname'),
        email: formData.get('email'),
        telefon: formData.get('telefon') || null,
        steuer_id: formData.get('steuer_id') || null,
        firma: formData.get('firma') || null,
      })
      .eq('id', vermieterId);
    
    alert('Profil gespeichert!');
  });
  
  // Adresse speichern
  document.getElementById('adresse-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target as HTMLFormElement);
    
    await supabase
      .from('vermieter')
      .update({
        strasse: formData.get('strasse') || null,
        hausnummer: formData.get('hausnummer') || null,
        plz: formData.get('plz') || null,
        stadt: formData.get('stadt') || null,
      })
      .eq('id', vermieterId);
    
    alert('Adresse gespeichert!');
  });
  
  // Bank speichern
  document.getElementById('bank-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target as HTMLFormElement);
    
    await supabase
      .from('vermieter')
      .update({
        iban: formData.get('iban') || null,
        bic: formData.get('bic') || null,
        kontoinhaber: formData.get('kontoinhaber') || null,
      })
      .eq('id', vermieterId);
    
    alert('Bankverbindung gespeichert!');
  });
  
  // Passwort ändern
  document.getElementById('passwort-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target as HTMLFormElement);
    const neuesPasswort = formData.get('neues_passwort') as string;
    
    const { error } = await supabase.auth.updateUser({
      password: neuesPasswort
    });
    
    if (error) {
      alert('Fehler: ' + error.message);
    } else {
      alert('Passwort erfolgreich geändert!');
      (e.target as HTMLFormElement).reset();
    }
  });
  
  loadProfil();
</script>