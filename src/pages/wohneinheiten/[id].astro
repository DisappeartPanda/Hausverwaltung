---
export const prerender = false;

import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { requireLandlordSession } from '../../lib/supabase/serverAuth';

const { supabase, user } = await requireLandlordSession(Astro);

const { id } = Astro.params;
if (!id) throw new Error('Keine Wohneinheit-ID in der Route.');

const uuidRegex =
  /^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i;
if (!uuidRegex.test(id)) throw new Error('Ungültige Wohneinheit-ID.');

type WohneinheitRow = {
  id: string;
  objekt_id: string;
  eigentuemer_id: string | null;
  bezeichnung: string | null;
  wohnflaeche_qm: number | null;
  zimmer_anzahl: number | null;
  kaltmiete: number | null;
  nebenkosten_vorauszahlung: number | null;
  kaution: number | null;
  verfuegbar_ab: string | null;
  status: string | null;
  notizen: string | null;
  created_at: string | null;
};

type ObjektRow = {
  id: string;
  bezeichnung: string | null;
  adresse: string | null;
  plz: string | null;
  stadt: string | null;
};

type MietvertragRow = {
  id: string;
  wohnheinheit_id?: string; // falls typo irgendwo auftaucht (defensiv)
  wohneinheit_id: string;
  mieter_id: string;
  vertragsnummer: string | null;
  mietbeginn: string | null;
  mietende: string | null;
  unbefristet: boolean | null;
  kaltmiete: number | null;
  nebenkosten_vorauszahlung: number | null;
  gesamtmiete: number | null;
  status: string | null;
  vertrag_pdf_url: string | null;
};

type MieterRow = {
  id: string;
  profil_id: string | null;
  wohneinheit_id: string | null;
  mietvertrag_von: string | null;
  mietvertrag_bis: string | null;
  anzahl_bewohner: number | null;
};

type ProfileRow = {
  id: string;
  name: string | null;
  telefon: string | null;
  role: string | null;
};

type ZahlungRow = {
  id: string;
  mieter_id: string;
  typ: string | null;
  betrag: number | null;
  zahlungsdatum: string | null;
  status: string | null;
  referenz_monat: number | null;
  referenz_jahr: number | null;
  zahlungsmethode: string | null;
  notizen: string | null;
};

type MaengelRow = {
  id: string;
  wohneinheit_id: string | null;
  titel: string | null;
  status: string | null;
  dringend: boolean | null;
  gemeldet_am: string | null;
  behoben_am: string | null;
  ort_im_objekt: string | null;
  beschreibung: string | null;
};

const safeText = (v: unknown, fallback = '—') => {
  const s = String(v ?? '').trim();
  return s.length ? s : fallback;
};
const norm = (v: unknown) => String(v ?? '').trim().toLowerCase();
const safeNum = (v: unknown) => {
  const n = Number(v);
  return Number.isFinite(n) ? n : null;
};
const fmtEUR = (n: number | null | undefined) =>
  (safeNum(n) ?? 0).toLocaleString('de-DE', { style: 'currency', currency: 'EUR' });
const fmtM2 = (n: number | null | undefined) =>
  n == null ? '—' : n.toLocaleString('de-DE', { maximumFractionDigits: 2 }) + ' m²';
const fmtDate = (d: string | null | undefined) =>
  d ? new Date(d).toLocaleDateString('de-DE') : '—';

const statusPill = (s: string | null | undefined) => {
  const k = norm(s);
  if (!k) return { cls: 'pill', text: '—' };
  if (k.includes('vermietet')) return { cls: 'pill pill-ok', text: 'Vermietet' };
  if (k.includes('frei')) return { cls: 'pill pill-warn', text: 'Frei' };
  if (k.includes('reserv')) return { cls: 'pill pill-amber', text: 'Reserviert' };
  if (k.includes('reno')) return { cls: 'pill pill-dim', text: 'Renovierung' };
  return { cls: 'pill', text: safeText(s) };
};

// --------------------------
// Modular: Loader
// --------------------------
async function loadWohneinheit(weId: string) {
  const { data, error } = await supabase
    .from('wohneinheiten')
    .select(
      'id, objekt_id, eigentuemer_id, bezeichnung, wohnflaeche_qm, zimmer_anzahl, kaltmiete, nebenkosten_vorauszahlung, kaution, verfuegbar_ab, status, notizen, created_at'
    )
    .eq('id', weId)
    .maybeSingle<WohneinheitRow>();

  if (error) throw error;
  if (!data) return null;

  // Ownership (wie du es überall machst)
  if (data.eigentuemer_id && data.eigentuemer_id !== user.id) return null;

  return data;
}

async function loadObjekt(objektId: string) {
  const { data, error } = await supabase
    .from('objekte')
    .select('id, bezeichnung, adresse, plz, stadt')
    .eq('id', objektId)
    .maybeSingle<ObjektRow>();

  if (error) throw error;
  return data ?? null;
}

async function loadAktiverMietvertrag(weId: string) {
  // Aktiv: mietende IS NULL oder status enthält "aktiv"
  const { data, error } = await supabase
    .from('mietvertraege')
    .select(
      'id, wohneinheit_id, mieter_id, vertragsnummer, mietbeginn, mietende, unbefristet, kaltmiete, nebenkosten_vorauszahlung, gesamtmiete, status, vertrag_pdf_url'
    )
    .eq('wohneinheit_id', weId)
    .order('mietbeginn', { ascending: false })
    .limit(1)
    .maybeSingle<MietvertragRow>();

  if (error) throw error;
  if (!data) return null;

  // Falls der letzte Vertrag schon beendet ist, aber es gibt noch "aktiv" nicht -> prüfen:
  if (data.mietende) {
    const st = norm(data.status);
    if (!st.includes('aktiv') && !st.includes('lauf')) return null;
  }

  return data;
}

async function loadMieterUndProfil(mieterId: string) {
  const { data: m, error: mErr } = await supabase
    .from('mieter')
    .select('id, profil_id, wohneinheit_id, mietvertrag_von, mietvertrag_bis, anzahl_bewohner')
    .eq('id', mieterId)
    .maybeSingle<MieterRow>();

  if (mErr) throw mErr;
  if (!m) return { mieter: null, profil: null };

  let profil: ProfileRow | null = null;
  if (m.profil_id) {
    const { data: p, error: pErr } = await supabase
      .from('profiles')
      .select('id, name, telefon, role')
      .eq('id', m.profil_id)
      .maybeSingle<ProfileRow>();

    if (pErr) throw pErr;
    profil = p ?? null;
  }

  return { mieter: m, profil };
}

async function loadLetzteZahlungen(mieterId: string) {
  const { data, error } = await supabase
    .from('zahlungen')
    .select('id, mieter_id, typ, betrag, zahlungsdatum, status, referenz_monat, referenz_jahr, zahlungsmethode, notizen')
    .eq('mieter_id', mieterId)
    .order('zahlungsdatum', { ascending: false })
    .limit(6)
    .returns<ZahlungRow[]>();

  if (error) throw error;
  return data ?? [];
}

async function loadOffeneMaengel(weId: string) {
  const { data, error } = await supabase
    .from('maengel')
    .select('id, wohneinheit_id, titel, status, dringend, gemeldet_am, behoben_am, ort_im_objekt, beschreibung')
    .eq('wohneinheit_id', weId)
    .order('gemeldet_am', { ascending: false })
    .limit(8)
    .returns<MaengelRow[]>();

  if (error) throw error;
  // offen = status != behoben/geschlossen
  const open = (data ?? []).filter((m) => {
    const s = norm(m.status);
    return !s.includes('behob') && !s.includes('geschloss') && !s.includes('erled');
  });
  return open;
}

// --------------------------
// Load all
// --------------------------
let loadError = false;
let errorMessage = '';

let wohneinheit: WohneinheitRow | null = null;
let objekt: ObjektRow | null = null;
let mietvertrag: MietvertragRow | null = null;
let mieter: MieterRow | null = null;
let profil: ProfileRow | null = null;
let zahlungen: ZahlungRow[] = [];
let maengel: MaengelRow[] = [];

try {
  wohneinheit = await loadWohneinheit(id);

  if (wohneinheit) {
    objekt = await loadObjekt(wohneinheit.objekt_id);
    mietvertrag = await loadAktiverMietvertrag(wohneinheit.id);

    if (mietvertrag?.mieter_id) {
      const mp = await loadMieterUndProfil(mietvertrag.mieter_id);
      mieter = mp.mieter;
      profil = mp.profil;

      // Zahlungen hängen an mieter_id (laut Screenshot)
      zahlungen = await loadLetzteZahlungen(mietvertrag.mieter_id);
    }

    // Mängel hängen an wohneinheit_id (laut Screenshot)
    maengel = await loadOffeneMaengel(wohneinheit.id);
  }
} catch (e: any) {
  loadError = true;
  errorMessage = e?.message ?? 'DB Fehler';
}

const pageTitle = wohneinheit ? safeText(wohneinheit.bezeichnung, 'Wohneinheit') : 'Wohneinheit';
const addr = objekt
  ? [objekt.adresse, [objekt.plz, objekt.stadt].filter(Boolean).join(' ')].filter(Boolean).join(', ') || '—'
  : '—';

const pill = statusPill(wohneinheit?.status);

const cold = safeNum(mietvertrag?.kaltmiete) ?? safeNum(wohneinheit?.kaltmiete) ?? 0;
const nk = safeNum(mietvertrag?.nebenkosten_vorauszahlung) ?? safeNum(wohneinheit?.nebenkosten_vorauszahlung) ?? 0;
const totalRent = safeNum(mietvertrag?.gesamtmiete) ?? (cold + nk);

const occupied = Boolean(mietvertrag && (norm(wohneinheit?.status).includes('vermietet') || norm(mietvertrag?.status).includes('aktiv')));
---

<DashboardLayout title={pageTitle}>
  <section class="page">
    <div class="topbar">
      <a class="back" href={objekt?.id ? `/objekte/${objekt.id}` : '/objekte'}>← Zurück zum Objekt</a>

      <div class="top-actions">
        <a class="btn" href={`/wohneinheiten/${id}/bearbeiten`}>✏️ Bearbeiten</a>
        {mietvertrag?.vertrag_pdf_url && (
          <a class="btn btn-soft" href={mietvertrag.vertrag_pdf_url} target="_blank" rel="noreferrer">📄 Vertrag</a>
        )}
      </div>
    </div>

    {loadError && (
      <div class="state">
        <div class="state-text">
          <div class="state-title">Konnte Wohneinheit nicht laden</div>
          <div class="state-subtitle">{errorMessage}</div>
        </div>
        <div class="state-actions">
          <a class="btn btn-ghost" href={`/wohneinheiten/${id}`}>Neu laden</a>
        </div>
      </div>
    )}

    {!loadError && !wohneinheit && (
      <div class="empty">
        <div class="empty-card">
          <div class="empty-icon">🏠</div>
          <h2>Wohneinheit nicht gefunden</h2>
          <p>Entweder existiert sie nicht oder du hast keinen Zugriff darauf.</p>
          <a class="btn btn-primary" href="/objekte">Zurück</a>
        </div>
      </div>
    )}

    {!loadError && wohneinheit && (
      <>
        <!-- HERO -->
        <header class="hero">
          <div class="hero-top">
            <div class="hero-left">
              <h1 class="title">{safeText(wohneinheit.bezeichnung, 'Wohneinheit')}</h1>

              <div class="hero-meta">
                <div class="meta-row">
                  <span class="meta-label">Objekt</span>
                  <a class="meta-link" href={objekt?.id ? `/objekte/${objekt.id}` : '/objekte'}>
                    {safeText(objekt?.bezeichnung, '—')}
                  </a>
                </div>

                <div class="meta-row">
                  <span class="meta-label">Adresse</span>
                  <span class="meta-value address">
                    <span>{safeText(objekt?.adresse, '—')}</span>
                    <span>{[objekt?.plz, objekt?.stadt].filter(Boolean).join(' ') || '—'}</span>
                  </span>
                </div>
              </div>
            </div>

            <div class="hero-right">
              <span class={pill.cls}>{pill.text}</span>

              <div class="statline">
                <span class={`badge ${occupied ? '' : 'badge-dim'}`}>
                  {occupied ? 'Vermietet' : 'Frei'}
                </span>
                <span class={`badge ${maengel.length ? 'badge-warn' : 'badge-ok'}`}>
                  {maengel.length ? `${maengel.length} Mängel offen` : 'Keine offenen Mängel'}
                </span>
              </div>
            </div>
          </div>

          <div class="kpis" aria-label="Stammdaten">
            <article class="kpi kpi-accent">
              <div class="kpi-top">
                <div class="kpi-icon">📐</div>
                <div class="kpi-label">Wohnfläche</div>
              </div>
              <div class="kpi-value">{fmtM2(wohneinheit.wohnflaeche_qm)}</div>
              <div class="kpi-hint">Einheit</div>
            </article>

            <article class="kpi">
              <div class="kpi-top">
                <div class="kpi-icon">🚪</div>
                <div class="kpi-label">Zimmer</div>
              </div>
              <div class="kpi-value">{wohneinheit.zimmer_anzahl ?? '—'}</div>
              <div class="kpi-hint">Anzahl</div>
            </article>

            <article class="kpi">
              <div class="kpi-top">
                <div class="kpi-icon">💶</div>
                <div class="kpi-label">Kaltmiete</div>
              </div>
              <div class="kpi-value">{fmtEUR(cold)}</div>
              <div class="kpi-hint">Monat</div>
            </article>

            <article class="kpi">
              <div class="kpi-top">
                <div class="kpi-icon">🧾</div>
                <div class="kpi-label">Gesamt</div>
              </div>
              <div class="kpi-value">{fmtEUR(totalRent)}</div>
              <div class="kpi-hint">Kalt + NK</div>
            </article>
          </div>

          {wohneinheit.notizen && (
            <div class="note">
              <div class="note-title">Notizen</div>
              <div class="note-text">{wohneinheit.notizen}</div>
            </div>
          )}
        </header>

        <div class="layout">
          <!-- MAIN -->
          <div class="main">
            <!-- MIETER -->
            <section class="panel">
              <div class="panel-head">
                <h2>👤 Aktueller Mieter</h2>
                {mietvertrag?.id ? (
                  <a class="link" href={`/mietvertraege/${mietvertrag.id}`}>Mietvertrag →</a>
                ) : (
                  <a class="link" href={`/mietvertraege/neu?wohneinheit=${id}`}>+ Vertrag anlegen</a>
                )}
              </div>

              {mietvertrag && mieter ? (
                <div class="info-grid">
                  <div>
                    <div class="muted">Name</div>
                    <div class="strong">{safeText(profil?.name, '—')}</div>
                  </div>

                  <div>
                    <div class="muted">Mietbeginn</div>
                    <div class="strong">{fmtDate(mietvertrag.mietbeginn)}</div>
                  </div>

                  <div>
                    <div class="muted">Telefon</div>
                    {profil?.telefon ? (
                      <a class="link" href={`tel:${profil.telefon}`}>{profil.telefon}</a>
                    ) : (
                      <div class="strong">—</div>
                    )}
                  </div>

                  <div>
                    <div class="muted">Bewohner</div>
                    <div class="strong">{mieter.anzahl_bewohner ?? '—'}</div>
                  </div>

                  <div class="span2">
                    <div class="muted">Vertragsstatus</div>
                    <div class="strong">
                      {safeText(mietvertrag.status, mietvertrag.mietende ? 'Beendet' : 'Aktiv')}
                      {mietvertrag.unbefristet ? ' · unbefristet' : ''}
                      {mietvertrag.mietende ? ` · Ende: ${fmtDate(mietvertrag.mietende)}` : ''}
                    </div>
                  </div>
                </div>
              ) : (
                <div class="empty-inline">
                  <div class="muted">Kein aktiver Mietvertrag / Mieter verknüpft.</div>
                  <div class="inline-actions">
                    <a class="btn btn-primary" href={`/mietvertraege/neu?wohneinheit=${id}`}>+ Mietvertrag erstellen</a>
                  </div>
                </div>
              )}
            </section>

            <!-- ZAHLUNGEN -->
            <section class="panel">
              <div class="panel-head">
                <h2>💰 Letzte Zahlungen</h2>
                <a class="link" href="/zahlungen">Alle →</a>
              </div>

              {zahlungen.length > 0 ? (
                <div class="table-wrap">
                  <table class="table">
                    <thead>
                      <tr>
                        <th>Datum</th>
                        <th>Typ</th>
                        <th>Referenz</th>
                        <th class="right">Betrag</th>
                        <th>Status</th>
                      </tr>
                    </thead>
                    <tbody>
                      {zahlungen.map((z) => {
                        const ref =
                          z.referenz_monat && z.referenz_jahr
                            ? `${String(z.referenz_monat).padStart(2, '0')}/${z.referenz_jahr}`
                            : '—';

                        const st = norm(z.status);
                        const cls =
                          st.includes('eing') || st.includes('bez') ? 'tag tag-ok'
                          : st.includes('off') ? 'tag tag-warn'
                          : 'tag';

                        return (
                          <tr>
                            <td>{fmtDate(z.zahlungsdatum)}</td>
                            <td>{safeText(z.typ, '—')}</td>
                            <td class="muted">{ref}</td>
                            <td class="right strong">{fmtEUR(z.betrag)}</td>
                            <td><span class={cls}>{safeText(z.status, '—')}</span></td>
                          </tr>
                        );
                      })}
                    </tbody>
                  </table>
                </div>
              ) : (
                <div class="muted">Keine Zahlungen gefunden (Zahlungen hängen bei dir an <code>mieter_id</code>).</div>
              )}
            </section>

            <!-- MÄNGEL -->
            <section class="panel">
              <div class="panel-head">
                <h2>⚠️ Offene Mängel</h2>
                <a class="link" href={`/maengel/neu?wohneinheit=${id}`}>+ Mangel melden</a>
              </div>

              {maengel.length > 0 ? (
                <div class="cards">
                  {maengel.map((m) => (
                    <a class={`mcard ${m.dringend ? 'mcard-hot' : ''}`} href={`/maengel/${m.id}`}>
                      <div class="mcard-top">
                        <div class="mcard-title">{safeText(m.titel, 'Mangel')}</div>
                        {m.dringend ? <span class="tag tag-hot">DRINGEND</span> : <span class="tag">{safeText(m.status, '—')}</span>}
                      </div>
                      <div class="mcard-sub">
                        <span>{m.ort_im_objekt ? `📍 ${m.ort_im_objekt}` : '📍 —'}</span>
                        <span>{m.gemeldet_am ? `🗓️ ${fmtDate(m.gemeldet_am)}` : ''}</span>
                      </div>
                      {m.beschreibung ? <div class="mcard-desc">{m.beschreibung}</div> : null}
                    </a>
                  ))}
                </div>
              ) : (
                <div class="muted">Keine offenen Mängel 🎉</div>
              )}
            </section>
          </div>

          <!-- SIDE -->
          <aside class="side">
            <section class="panel">
              <div class="panel-head">
                <h2>Aktionen</h2>
              </div>
              <div class="actions">
                <a class="btn btn-soft" href={`/wohneinheiten/${id}/bearbeiten`}>✏️ Bearbeiten</a>
                <a class="btn btn-soft" href={`/mietvertraege/neu?wohneinheit=${id}`}>📄 Mietvertrag</a>
                <button class="btn btn-soft" type="button" id="btnRaise">📈 Mieterhöhung vorschlagen</button>
              </div>
            </section>

            <section class="panel">
              <div class="panel-head">
                <h2>🧠 Quick Facts</h2>
              </div>

              <div class="facts">
                <div class="fact">
                  <div class="muted">Nebenkosten (VZ)</div>
                  <div class="strong">{fmtEUR(nk)}</div>
                </div>
                <div class="fact">
                  <div class="muted">Kaution</div>
                  <div class="strong">{fmtEUR(wohneinheit.kaution)}</div>
                </div>
                <div class="fact">
                  <div class="muted">Verfügbar ab</div>
                  <div class="strong">{fmtDate(wohneinheit.verfuegbar_ab)}</div>
                </div>
                <div class="fact">
                  <div class="muted">Erstellt</div>
                  <div class="strong">{fmtDate(wohneinheit.created_at)}</div>
                </div>
              </div>
            </section>
          </aside>
        </div>
      </>
    )}
  </section>

  {/* ✅ Werte für Browser */}
  <html data-kaltmiete={String(cold)} />
</DashboardLayout>

<script>
  const KALTMIETE = Number(document.documentElement.dataset.kaltmiete || '0');

  const btn = document.getElementById('btnRaise');
  btn?.addEventListener('click', () => {
    const neueMiete = KALTMIETE * 1.03;
    alert(`Vorschlag: Neue Kaltmiete ${neueMiete.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}`);
  });
</script>

<style>
  :global(:root) {
    --ip-card: rgba(16, 22, 19, 0.72);
    --ip-card-2: rgba(12, 17, 14, 0.72);
    --ip-border: rgba(255,255,255,0.10);
    --ip-text: rgba(236, 242, 239, 0.92);
    --ip-muted: rgba(190, 201, 197, 0.74);
    --ip-accent: #22c55e;
    --ip-shadow: 0 24px 70px rgba(0,0,0,0.45);
  }

  .page { display:flex; flex-direction:column; gap:16px; }

  .topbar{ display:flex; align-items:center; justify-content:space-between; gap:12px; }
  .back{ color: rgba(190,201,197,0.85); text-decoration:none; font-weight:850; }
  .back:hover{ color: rgba(236,242,239,0.92); }

  .top-actions{ display:flex; gap:10px; align-items:center; flex-wrap:wrap; }

  .btn{
    display:inline-flex; align-items:center; justify-content:center; gap:10px;
    padding:10px 14px; border-radius:12px;
    border:1px solid var(--ip-border);
    background: rgba(255,255,255,0.06);
    color:var(--ip-text); text-decoration:none;
    font-weight:900; font-size:0.95rem;
    transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease, border-color 160ms ease;
    cursor:pointer;
  }
  .btn:hover{ transform:translateY(-1px); background:rgba(255,255,255,0.08); box-shadow:0 18px 50px rgba(0,0,0,0.35); }
  .btn-soft{ width:100%; background: rgba(255,255,255,0.05); }
  .btn-ghost{ background: rgba(255,255,255,0.04); }
