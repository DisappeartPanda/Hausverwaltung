---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Neue Wohneinheit">
  <div class="mb-6">
    <a href="/wohneinheiten" class="text-gray-600 hover:text-gray-800 text-sm">← Zurück zu Wohneinheiten</a>
  </div>
  
  <h1 class="text-2xl font-bold mb-6">Neue Wohneinheit anlegen</h1>
  
  <form id="einheit-form" class="max-w-2xl bg-white rounded-lg shadow p-6 space-y-6">
    <div>
      <label class="block text-sm font-medium text-gray-700">Objekt *</label>
      <select name="objekt_id" required class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md">
        <option value="">Bitte wählen...</option>
      </select>
    </div>
    
    <div>
      <label class="block text-sm font-medium text-gray-700">Bezeichnung *</label>
      <input name="bezeichnung" type="text" required placeholder="z.B. 1. OG links"
        class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md" />
    </div>
    
    <div>
      <label class="block text-sm font-medium text-gray-700">Türbezeichnung</label>
      <input name="tuerbezeichnung" type="text" placeholder="z.B. Wohnung 3"
        class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md" />
    </div>
    
    <div class="grid grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700">Wohnfläche (m²)</label>
        <input name="wohnflaeche_m2" type="number" step="0.01"
          class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Nutzfläche (m²)</label>
        <input name="nutzflaeche_m2" type="number" step="0.01"
          class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Zimmer</label>
        <input name="zimmeranzahl" type="number"
          class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md" />
      </div>
    </div>
    
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700">Kaltmiete (€) *</label>
        <input name="kaltmiete" type="number" step="0.01" required
          class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Nebenkosten Vorauszahlung (€)</label>
        <input name="nebenkosten_vorauszahlung" type="number" step="0.01" value="0"
          class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md" />
      </div>
    </div>
    
    <div>
      <label class="block text-sm font-medium text-gray-700">Kaution (Monate)</label>
      <input name="kaution_monate" type="number" value="3" min="0" max="6"
        class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md" />
    </div>
    
    <div>
      <label class="block text-sm font-medium text-gray-700">Status</label>
      <select name="status" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md">
        <option value="frei">Frei</option>
        <option value="vermietet">Vermietet</option>
        <option value="reserviert">Reserviert</option>
        <option value="renovierung">In Renovierung</option>
      </select>
    </div>
    
    <div>
      <label class="block text-sm font-medium text-gray-700">Ausstattung (komma-getrennt)</label>
      <input name="ausstattung" type="text" placeholder="z.B. Balkon, Einbauküche, Badewanne"
        class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md" />
    </div>
    
    <div>
      <label class="block text-sm font-medium text-gray-700">Notizen</label>
      <textarea name="notizen" rows="3"
        class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md"></textarea>
    </div>
    
    <div class="flex gap-4 pt-4">
      <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
        Speichern
      </button>
      <a href="/wohneinheiten" class="px-6 py-2 bg-gray-300 text-gray-700 rounded hover:bg-gray-400">
        Abbrechen
      </a>
    </div>
    
    <div id="error-message" class="hidden p-3 bg-red-100 border border-red-400 text-red-700 rounded text-sm"></div>
  </form>
</DashboardLayout>

<script>
  import { supabase } from '../../lib/supabase';
  
  // Objekte laden für Dropdown
  const loadObjekte = async () => {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return;
    
    const { data: vermieter } = await supabase
      .from('vermieter')
      .select('id')
      .eq('user_id', session.user.id)
      .single();
    
    if (!vermieter) return;
    
    const { data: objekte } = await supabase
      .from('objekte')
      .select('id, bezeichnung')
      .eq('vermieter_id', vermieter.id)
      .order('bezeichnung');
    
    const select = document.querySelector('select[name="objekt_id"]') as HTMLSelectElement;
    objekte?.forEach(obj => {
      const option = document.createElement('option');
      option.value = obj.id;
      option.textContent = obj.bezeichnung;
      select.appendChild(option);
    });
  };
  
  loadObjekte();
  
  // Formular-Handler
  const form = document.getElementById('einheit-form');
  const errorMsg = document.getElementById('error-message');
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg!.classList.add('hidden');
    
    const formData = new FormData(e.target as HTMLFormElement);
    
    const ausstattungStr = formData.get('ausstattung') as string;
    const ausstattung = ausstattungStr ? ausstattungStr.split(',').map(s => s.trim()).filter(s => s) : [];
    
    const { error } = await supabase
      .from('wohneinheiten')
      .insert({
        objekt_id: formData.get('objekt_id'),
        bezeichnung: formData.get('bezeichnung'),
        tuerbezeichnung: formData.get('tuerbezeichnung') || null,
        wohnflaeche_m2: formData.get('wohnflaeche_m2') ? parseFloat(formData.get('wohnflaeche_m2') as string) : null,
        nutzflaeche_m2: formData.get('nutzflaeche_m2') ? parseFloat(formData.get('nutzflaeche_m2') as string) : null,
        zimmeranzahl: formData.get('zimmeranzahl') ? parseInt(formData.get('zimmeranzahl') as string) : null,
        kaltmiete: parseFloat(formData.get('kaltmiete') as string),
        nebenkosten_vorauszahlung: parseFloat(formData.get('nebenkosten_vorauszahlung') as string) || 0,
        kaution_monate: parseInt(formData.get('kaution_monate') as string) || 3,
        status: formData.get('status'),
        ausstattung: ausstattung.length > 0 ? ausstattung : null,
        notizen: formData.get('notizen') || null,
      });
    
    if (error) {
      errorMsg!.textContent = 'Fehler: ' + error.message;
      errorMsg!.classList.remove('hidden');
    } else {
      window.location.href = '/wohneinheiten';
    }
  });
</script>