---
export const prerender = false;

import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { requireLandlordSession } from '../../lib/supabase/serverAuth';

// ✅ Script wird von Vite gebundelt und als URL verfügbar gemacht
import einheitNeuScript from '../../scripts/wohneinheit-neu.client.ts?url';

const auth = await requireLandlordSession(Astro);
if (auth instanceof Response) return auth;

const { user } = auth;

const preObjekt = Astro.url.searchParams.get('objekt') ?? '';
---

<DashboardLayout title="Neue Wohneinheit">

<section class="page">

<header class="header">

<a href={preObjekt ? `/objekte/${preObjekt}` : '/wohneinheiten'} class="back">
← Zurück
</a>

<h1 class="title">Neue Wohneinheit</h1>

<p class="subtitle">
Lege eine neue Einheit an und verknüpfe sie mit einem Objekt.
</p>

</header>


<form id="einheit-form" class="card form">

<div class="grid">

<!-- Objekt -->

<div class="field full">

{preObjekt ? (

<div class="lockedRow">

<div class="lockedPill" id="lockedObjektPill">

<span class="dot"></span>

<span class="lockedText">
Objekt wird geladen…
</span>

</div>

<input
type="hidden"
id="objektLocked"
name="objekt_id_locked"
value={preObjekt}
/>

</div>

) : (

<select name="objekt_id" id="objekt_id" required>
<option value="">Bitte wählen…</option>
</select>

)}

</div>


<!-- Bezeichnung -->

<div class="field full">

<label>Bezeichnung *</label>

<input
name="bezeichnung"
type="text"
required
placeholder="z.B. 1. OG links"
/>

</div>


<!-- Typ -->

<div class="field">

<label>Typ</label>

<select name="typ">

<option value="wohnung">Wohnung</option>

<option value="gewerbe">Gewerbe</option>

<option value="garage">Garage</option>

<option value="stellplatz">Stellplatz</option>

</select>

</div>


<!-- Tür -->

<div class="field">

<label>Türbezeichnung</label>

<input
name="tuerbezeichnung"
type="text"
placeholder="z.B. Wohnung 3"
/>

</div>


<!-- Wohnfläche -->

<div class="field">

<label>Wohnfläche (m²)</label>

<input
name="wohnflaeche_qm"
type="number"
step="0.01"
placeholder="z.B. 85"
/>

</div>


<!-- Zimmer -->

<div class="field">

<label>Zimmer</label>

<input
name="zimmer_anzahl"
type="number"
placeholder="z.B. 3"
/>

</div>


<!-- Kaltmiete -->

<div class="field">

<label>Kaltmiete (€) *</label>

<input
name="kaltmiete"
type="number"
step="0.01"
required
placeholder="z.B. 850"
/>

</div>


<!-- Nebenkosten -->

<div class="field">

<label>Nebenkosten (€)</label>

<input
name="nebenkosten_vorauszahlung"
type="number"
step="0.01"
placeholder="z.B. 150"
/>

</div>


<!-- Status -->

<div class="field full">

<label>Status</label>

<select name="status">

<option value="frei">Frei</option>

<option value="vermietet">Vermietet</option>

<option value="reserviert">Reserviert</option>

<option value="renovierung">In Renovierung</option>

</select>

</div>


</div>


<div class="actions">

<button type="submit" class="btn primary">
Speichern
</button>

</div>


<div id="error-message" class="error hidden"></div>

</form>

</section>

</DashboardLayout>


<script type="module" src={einheitNeuScript}></script>

<style>

.page{
display:flex;
flex-direction:column;
gap:20px;
}

.header{
display:flex;
flex-direction:column;
gap:6px;
}

.title{
font-size:1.6rem;
font-weight:800;
}

.subtitle{
color:#9ca3af;
}

.back{
color:#9ca3af;
text-decoration:none;
font-weight:700;
}

.card{
padding:20px;
border-radius:20px;
background:rgba(15,20,18,.8);
border:1px solid rgba(255,255,255,.08);
}

.grid{
display:grid;
grid-template-columns:1fr 1fr;
gap:14px;
}

.full{
grid-column:1 / -1;
}

.field{
display:flex;
flex-direction:column;
gap:6px;
}

label{
font-weight:700;
color:#d1d5db;
}

input,select{
padding:10px;
border-radius:12px;
border:1px solid rgba(255,255,255,.1);
background:rgba(0,0,0,.2);
color:white;
}

.actions{
margin-top:16px;
}

.btn{
padding:10px 16px;
border-radius:10px;
font-weight:700;
}

.primary{
background:#22c55e;
color:black;
}

.error{
margin-top:10px;
padding:10px;
background:#7f1d1d;
border-radius:8px;
}

.hidden{
display:none;
}

.lockedRow{
display:flex;
align-items:center;
gap:10px;
}

/* ---- Locked Objekt Pill: mehr Kontrast & Lesbarkeit ---- */

.lockedPill{
  background: rgba(34,197,94,.18);           /* etwas satter */
  border: 1px solid rgba(34,197,94,.55);      /* stärkere Kontur */
  box-shadow:
    0 0 0 1px rgba(0,0,0,.35) inset,
    0 10px 30px rgba(0,0,0,.35),
    0 0 18px rgba(34,197,94,.22);             /* leichter Glow */
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.lockedText{
  color: rgba(236,253,245,.98);               /* fast-white mit grünem Touch */
  font-weight: 800;
  letter-spacing: .2px;
  text-shadow:
    0 1px 0 rgba(0,0,0,.55),
    0 0 10px rgba(34,197,94,.18);
}

.dot{
  width: 10px;
  height: 10px;
  background: #22c55e;
  box-shadow: 0 0 10px rgba(34,197,94,.55);
}

/* Optional: bessere Pill-Form/Spacing */
.lockedPill{
  padding: 10px 14px;
  gap: 10px;
}

</style>