---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
---

<Layout title="Passwort vergessen | ImmobilienPro">
  <style>
    .forgot-page{
      min-height: 100vh;
      background: var(--dark);
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .forgot-page::before{
      content:'';
      position:absolute;
      inset:0;
      background: linear-gradient(135deg, var(--dark) 0%, var(--dark-light) 50%, #064e3b 100%);
      opacity: 0.85;
    }

    .forgot-page::after{
      content:'';
      position:absolute;
      inset:0;
      background-image:
        linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: 4rem 4rem;
      pointer-events:none;
    }

    .wrap{
      position: relative;
      z-index: 10;
      width: 100%;
      max-width: 480px;
    }

    .logo-section{
      text-align:center;
      margin-bottom: 2rem;
    }

    .logo-link{
      display:inline-flex;
      align-items:center;
      gap:.75rem;
      text-decoration:none;
    }

    .logo-icon{
      width: 3rem;
      height: 3rem;
      background: var(--primary);
      border-radius: .75rem;
      display:flex;
      align-items:center;
      justify-content:center;
      box-shadow: 0 10px 25px -5px rgba(134, 239, 172, 0.3);
      color: var(--dark);
      font-size: 1.5rem;
    }

    .logo-text{
      text-align:left;
      display:flex;
      flex-direction:column;
    }

    .logo-title{
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--white);
      line-height: 1;
      letter-spacing: -0.02em;
    }

    .logo-subtitle{
      font-size: .75rem;
      color: var(--primary);
      letter-spacing: .12em;
      font-weight: 600;
      text-transform: uppercase;
      margin-top: .1rem;
    }

    .card{
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(20px);
      border: 1px solid var(--dark-lighter);
      border-radius: 1.5rem;
      padding: 2rem;
    }

    .back-btn{
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      color: var(--gray-400);
      font-size: .875rem;
      cursor: pointer;
      background: none;
      border: none;
      padding: 0;
      transition: color .2s;
      margin-bottom: 1.25rem;
      text-decoration: none;
      font-weight: 600;
    }

    .back-btn:hover{ color: var(--white); }

    .back-btn svg{
      width: 1rem;
      height: 1rem;
    }

    .head{
      margin-bottom: 1.25rem;
      text-align: left;
    }

    .title{
      font-size: 1.55rem;
      font-weight: 900;
      color: var(--white);
      margin: 0 0 .35rem 0;
      letter-spacing: -0.02em;
    }

    .sub{
      color: var(--gray-400);
      font-size: .95rem;
      margin: 0;
      line-height: 1.5;
    }

    .form-group{
      margin-top: 1.25rem;
      margin-bottom: 1rem;
    }

    .label{
      display:block;
      font-size: .75rem;
      font-weight: 600;
      color: var(--gray-400);
      text-transform: uppercase;
      letter-spacing: .05em;
      margin-bottom: .5rem;
    }

    .input{
      width: 100%;
      padding: .9rem 1rem;
      background: rgba(0, 0, 0, 0.30);
      border: 1px solid var(--dark-lighter);
      border-radius: .75rem;
      color: var(--white);
      font-size: 1rem;
      transition: all .2s ease;
    }

    .input::placeholder{ color: var(--gray-600); }

    .input:focus{
      outline:none;
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(134,239,172,0.12);
    }

    .btn{
      width: 100%;
      padding: 1rem;
      background: var(--primary);
      color: var(--dark);
      font-weight: 900;
      font-size: 1rem;
      border: none;
      border-radius: .75rem;
      cursor: pointer;
      transition: all .2s ease;
      display:flex;
      align-items:center;
      justify-content:center;
      gap: .6rem;
      margin-top: .25rem;
    }

    .btn:hover:not(:disabled){
      background: var(--primary-hover);
      transform: translateY(-1px);
      box-shadow: 0 10px 25px -5px rgba(134,239,172,0.25);
    }

    .btn:disabled{
      opacity: .6;
      cursor: not-allowed;
    }

    .spinner{
      width: 1.25rem;
      height: 1.25rem;
      border: 2px solid var(--dark);
      border-top-color: transparent;
      border-radius: 50%;
      animation: spin 1s linear infinite;
      display: none;
    }

    .btn.loading .spinner{ display:block; }
    .btn.loading .btn-text{ display:none; }

    @keyframes spin { to { transform: rotate(360deg); } }

    .msg{
      margin-top: 1rem;
      font-size: .875rem;
      text-align: center;
      display: none;
      padding: .85rem;
      border-radius: .9rem;
      border: 1px solid transparent;
    }

    .msg.error{
      color: #fecaca;
      background: rgba(220, 38, 38, 0.12);
      border-color: rgba(220, 38, 38, 0.25);
    }

    .msg.success{
      color: rgba(255,255,255,0.92);
      background: rgba(134,239,172,0.10);
      border-color: rgba(134,239,172,0.22);
    }

    .msg.visible{ display:block; }

    .footer{
      margin-top: 1.1rem;
      text-align:center;
      color: var(--gray-400);
      font-size: .875rem;
    }

    .footer a{
      color: var(--primary);
      font-weight: 800;
      text-decoration:none;
    }

    .footer a:hover{ text-decoration: underline; }

    @media (max-width: 640px){
      .card{ padding: 1.5rem; }
    }
  </style>

  <div class="forgot-page">
    <div class="wrap">
      <div class="logo-section">
        <a href="/" class="logo-link">
          <div class="logo-icon" aria-hidden="true">🏢</div>
          <div class="logo-text">
            <div class="logo-title">ImmobilienPro</div>
            <div class="logo-subtitle">HAUSVERWALTUNG</div>
          </div>
        </a>
      </div>

      <div class="card">
        <a class="back-btn" href="/login">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          Zurück zum Login
        </a>

        <div class="head">
          <h1 class="title">Passwort vergessen?</h1>
          <p class="sub">
            Geben Sie Ihre E-Mail ein. Wir senden Ihnen einen Link zum Zurücksetzen.
          </p>
        </div>

        <form id="forgotForm">
          <div class="form-group">
            <label class="label" for="email">E-Mail</label>
            <input
              class="input"
              type="email"
              id="email"
              name="email"
              required
              placeholder="ihre@email.de"
              autocomplete="email"
              autofocus
            />
          </div>

          <button type="submit" class="btn" id="submitBtn">
            <div class="spinner" aria-hidden="true"></div>
            <span class="btn-text">Reset-Link senden</span>
          </button>

          <div id="msgError" class="msg error"></div>
          <div id="msgSuccess" class="msg success"></div>
        </form>

        <div class="footer">
          Noch kein Konto? <a href="/registrieren">Jetzt registrieren →</a>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('forgotForm')?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const form = e.target;
      const submitBtn = document.getElementById('submitBtn');
      const msgError = document.getElementById('msgError');
      const msgSuccess = document.getElementById('msgSuccess');

      if (!submitBtn || !msgError || !msgSuccess || !(form instanceof HTMLFormElement)) return;

      msgError.classList.remove('visible');
      msgSuccess.classList.remove('visible');
      msgError.textContent = '';
      msgSuccess.textContent = '';

      submitBtn.setAttribute('disabled', 'true');
      submitBtn.classList.add('loading');

      try {
        const formData = new FormData(form);
        const email = formData.get('email');

        const res = await fetch('/api/passwort-vergessen', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email })
        });

        const data = await res.json().catch(() => ({}));

        if (res.ok && (data.success === true || data.ok === true)) {
          msgSuccess.textContent =
            'Wenn die E-Mail existiert, erhalten Sie in Kürze einen Reset-Link. Bitte prüfen Sie auch den Spam-Ordner.';
          msgSuccess.classList.add('visible');
          form.reset();
          return;
        }

        throw new Error(data.error || 'Konnte keinen Link senden. Bitte versuchen Sie es erneut.');

      } catch (err) {
        msgError.textContent = err instanceof Error ? err.message : 'Ein Fehler ist aufgetreten';
        msgError.classList.add('visible');
      } finally {
        submitBtn.removeAttribute('disabled');
        submitBtn.classList.remove('loading');
      }
    });
  </script>
</Layout>