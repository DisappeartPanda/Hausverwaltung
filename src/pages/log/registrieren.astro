---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
---

<Layout title="Registrieren | ImmobilienPro">
  <style>
    /* ... deine bestehenden Styles bleiben gleich ... */
    .register-page {
      min-height: 100vh;
      background: var(--dark);
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .register-page::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, var(--dark) 0%, var(--dark-light) 50%, #064e3b 100%);
      opacity: 0.8;
    }

    .register-page::after {
      content: '';
      position: absolute;
      inset: 0;
      background-image: 
        linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: 4rem 4rem;
    }

    .register-container {
      position: relative;
      z-index: 10;
      width: 100%;
      max-width: 480px;
    }

    .logo-section {
      text-align: center;
      margin-bottom: 2rem;
    }

    .logo-link {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
    }

    .logo-icon {
      width: 3rem;
      height: 3rem;
      background: var(--primary);
      border-radius: 0.75rem;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 10px 25px -5px rgba(134, 239, 172, 0.3);
    }

    .logo-icon svg {
      width: 1.75rem;
      height: 1.75rem;
      color: var(--dark);
    }

    .logo-text {
      text-align: left;
    }

    .logo-title {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--white);
      line-height: 1;
    }

    .logo-subtitle {
      font-size: 0.75rem;
      color: var(--primary);
      letter-spacing: 0.1em;
      font-weight: 500;
    }

    .step-role {
      text-align: center;
    }

    .step-title {
      font-size: 1.875rem;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 0.5rem;
    }

    .step-subtitle {
      color: var(--gray-400);
      margin-bottom: 2rem;
    }

    .role-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .role-card {
      background: rgba(255, 255, 255, 0.05);
      border: 2px solid var(--dark-lighter);
      border-radius: 1rem;
      padding: 1.5rem;
      text-align: left;
      cursor: pointer;
      transition: all 0.3s ease;
      position: relative;
    }

    .role-card:hover {
      border-color: var(--primary);
      background: rgba(255, 255, 255, 0.08);
      transform: translateY(-2px);
    }

    .role-icon {
      width: 3rem;
      height: 3rem;
      border-radius: 0.75rem;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
    }

    .role-icon svg {
      width: 1.5rem;
      height: 1.5rem;
    }

    .role-card.vermieter .role-icon {
      background: rgba(134, 239, 172, 0.1);
    }

    .role-card.vermieter .role-icon svg {
      color: var(--primary);
    }

    .role-card.mieter .role-icon {
      background: rgba(147, 197, 253, 0.1);
    }

    .role-card.mieter .role-icon svg {
      color: var(--info);
    }

    .role-title {
      font-size: 1.125rem;
      font-weight: 600;
      color: var(--white);
      margin-bottom: 0.25rem;
    }

    .role-desc {
      font-size: 0.875rem;
      color: var(--gray-400);
      line-height: 1.4;
    }

    .role-radio {
      position: absolute;
      top: 1rem;
      right: 1rem;
      width: 1.25rem;
      height: 1.25rem;
      border: 2px solid var(--gray-600);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .role-card:hover .role-radio {
      border-color: var(--primary);
    }

    .role-radio::after {
      content: '';
      width: 0.625rem;
      height: 0.625rem;
      background: var(--primary);
      border-radius: 50%;
      opacity: 0;
      transition: opacity 0.2s;
    }

    .role-card:hover .role-radio::after {
      opacity: 1;
    }

    .login-link {
      color: var(--gray-400);
      font-size: 0.875rem;
    }

    .login-link a {
      color: var(--primary);
      text-decoration: none;
      font-weight: 500;
    }

    .login-link a:hover {
      text-decoration: underline;
    }

    .step-form {
      display: none;
    }

    .step-form.active {
      display: block;
    }

    .form-card {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(20px);
      border: 1px solid var(--dark-lighter);
      border-radius: 1.5rem;
      padding: 2rem;
    }

    .back-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--gray-400);
      font-size: 0.875rem;
      margin-bottom: 1.5rem;
      cursor: pointer;
      background: none;
      border: none;
      padding: 0;
      transition: color 0.2s;
    }

    .back-btn:hover {
      color: var(--white);
    }

    .back-btn svg {
      width: 1rem;
      height: 1rem;
    }

    .form-header {
      margin-bottom: 1.5rem;
    }

    .role-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      padding: 0.375rem 0.875rem;
      border-radius: 2rem;
      font-size: 0.75rem;
      font-weight: 500;
      margin-bottom: 0.75rem;
    }

    .role-badge.vermieter {
      background: rgba(134, 239, 172, 0.1);
      color: var(--primary);
      border: 1px solid rgba(134, 239, 172, 0.2);
    }

    .role-badge.mieter {
      background: rgba(147, 197, 253, 0.1);
      color: var(--info);
      border: 1px solid rgba(147, 197, 253, 0.2);
    }

    .role-badge svg {
      width: 0.875rem;
      height: 0.875rem;
    }

    .form-title {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 0.25rem;
    }

    .form-subtitle {
      color: var(--gray-400);
      font-size: 0.875rem;
    }

    .form-group {
      margin-bottom: 1.25rem;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .form-label {
      display: block;
      font-size: 0.75rem;
      font-weight: 500;
      color: var(--gray-400);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.5rem;
    }

    .form-input {
      width: 100%;
      padding: 0.875rem 1rem;
      background: rgba(0, 0, 0, 0.3);
      border: 1px solid var(--dark-lighter);
      border-radius: 0.75rem;
      color: var(--white);
      font-size: 1rem;
      transition: all 0.2s;
    }

    .form-input::placeholder {
      color: var(--gray-600);
    }

    .form-input:focus {
      outline: none;
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(134, 239, 172, 0.1);
    }

    .input-hint {
      font-size: 0.75rem;
      color: var(--gray-600);
      margin-top: 0.375rem;
    }

    .mieter-section {
      display: none;
      margin-top: 1.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--dark-lighter);
    }

    .mieter-section.active {
      display: block;
    }

    .section-label {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--primary);
      font-size: 0.875rem;
      font-weight: 500;
      margin-bottom: 1rem;
    }

    .section-label svg {
      width: 1rem;
      height: 1rem;
    }

    .submit-btn {
      width: 100%;
      padding: 1rem;
      background: var(--primary);
      color: var(--dark);
      font-weight: 700;
      font-size: 1rem;
      border: none;
      border-radius: 0.75rem;
      cursor: pointer;
      transition: all 0.2s;
      margin-top: 0.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
    }

    .submit-btn:hover:not(:disabled) {
      background: var(--primary-hover);
      transform: translateY(-1px);
      box-shadow: 0 10px 25px -5px rgba(134, 239, 172, 0.3);
    }

    .submit-btn:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    .submit-btn svg {
      width: 1.25rem;
      height: 1.25rem;
    }

    .step-form {
  display: none;
}

.step-form.active {
  display: block;
}

.mieter-section {
  display: none;
}

/* Für JavaScript-Steuerung */
.mieter-section[style*="block"] {
  display: block !important;
}

.error-message {
  color: #dc2626;
  margin-top: 1rem;
  font-size: 0.875rem;
  text-align: center;
  display: none;
  padding: 0.75rem;
  background: #fef2f2;
  border-radius: 0.5rem;
}

    .spinner {
      width: 1.25rem;
      height: 1.25rem;
      border: 2px solid var(--dark);
      border-top-color: transparent;
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .error-message {
      color: #dc2626;
      margin-top: 1rem;
      font-size: 0.875rem;
      text-align: center;
      display: none;
      padding: 0.75rem;
      background: #fef2f2;
      border-radius: 0.5rem;
    }

    .error-message.visible {
      display: block;
    }

    .trust-badges {
      display: flex;
      justify-content: center;
      gap: 2rem;
      margin-top: 2rem;
      color: var(--gray-600);
      font-size: 0.75rem;
    }

    .trust-badge {
      display: flex;
      align-items: center;
      gap: 0.375rem;
    }

    .trust-badge svg {
      width: 1rem;
      height: 1rem;
      color: var(--primary);
    }

    @media (max-width: 640px) {
      .role-grid {
        grid-template-columns: 1fr;
      }
      
      .form-row {
        grid-template-columns: 1fr;
      }
      
      .form-card {
        padding: 1.5rem;
      }
    }
  </style>

  <div class="register-page">
    <div class="register-container">
      
      <!-- Logo -->
      <div class="logo-section">
        <a href="/" class="logo-link">
          <div class="logo-icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <div class="logo-text">
            <div class="logo-title">ImmobilienPro</div>
            <div class="logo-subtitle">HAUSVERWALTUNG</div>
          </div>
        </a>
      </div>

      <!-- Schritt 1: Rollen-Auswahl -->
      <div id="step-role" class="step-role">
        <h1 class="step-title">Wer sind Sie?</h1>
        <p class="step-subtitle">Wählen Sie Ihre Rolle für den passenden Service</p>

        <div class="role-grid">
          <div class="role-card vermieter" data-role="landlord">
            <div class="role-icon">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
              </svg>
            </div>
            <div class="role-title">Eigentümer</div>
            <div class="role-desc">Ich verwalte Immobilien und suche eine Hausverwaltung</div>
            <div class="role-radio"></div>
          </div>

          <div class="role-card mieter" data-role="tenant">
            <div class="role-icon">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path>
              </svg>
            </div>
            <div class="role-title">Mieter</div>
            <div class="role-desc">Ich wohne zur Miete und möchte meine Daten einsehen</div>
            <div class="role-radio"></div>
          </div>
        </div>

        <p class="login-link">
          Bereits registriert? <a href="/login">Anmelden →</a>
        </p>
      </div>

      <!-- Schritt 2: Formular -->
      <div id="step-form" class="step-form">
        <div class="form-card">
          <button class="back-btn" type="button" id="back-btn">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Zurück zur Auswahl
          </button>

          <div class="form-header">
            <div id="role-badge" class="role-badge"></div>
            <h2 class="form-title">Konto erstellen</h2>
            <p id="form-subtitle" class="form-subtitle"></p>
          </div>

          <form id="register-form">
            <input type="hidden" name="role" id="role-input" />

            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Vorname *</label>
                <input type="text" name="vorname" class="form-input" required placeholder="Max" />
              </div>
              <div class="form-group">
                <label class="form-label">Nachname *</label>
                <input type="text" name="nachname" class="form-input" required placeholder="Mustermann" />
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">E-Mail *</label>
              <input type="email" name="email" class="form-input" required placeholder="max@beispiel.de" />
            </div>

            <div class="form-group">
              <label class="form-label">Passwort *</label>
              <input type="password" name="password" class="form-input" required minlength="6" placeholder="••••••••" />
              <p class="input-hint">Mindestens 6 Zeichen</p>
            </div>

            <!-- Mieter-spezifische Felder -->
            <div id="mieter-section" class="mieter-section">
              <div class="section-label">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                </svg>
                Wohnungsdaten
              </div>

              <div class="form-group">
                <label class="form-label">Straße & Hausnummer *</label>
                <input type="text" name="strasse" class="form-input mieter-required" placeholder="Musterstraße 123" />
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label class="form-label">PLZ *</label>
                  <input type="text" name="plz" class="form-input mieter-required" placeholder="12345" />
                </div>
                <div class="form-group">
                  <label class="form-label">Stadt *</label>
                  <input type="text" name="stadt" class="form-input mieter-required" placeholder="Berlin" />
                </div>
              </div>

              <div class="form-group">
                <label class="form-label">Wohnungs-ID (falls vorhanden)</label>
                <input type="text" name="wohnung_id" class="form-input" placeholder="Wird von Ihrem Vermieter bereitgestellt" />
              </div>
            </div>

            <button type="submit" id="submit-btn" class="submit-btn">
              <span id="btn-text">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="width: 1.25rem; height: 1.25rem;">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
                Kostenlos registrieren
              </span>
              <span id="btn-loading" style="display: none;">
                <div class="spinner"></div>
                Wird erstellt...
              </span>
            </button>
          </form>

          <div id="error-message" class="error-message"></div>
        </div>
      </div>

      <!-- Trust Badges -->
      <div class="trust-badges">
        <div class="trust-badge">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
          </svg>
          SSL-verschlüsselt
        </div>
        <div class="trust-badge">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
          </svg>
          DSGVO-konform
        </div>
      </div>

    </div>
  </div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    let selectedRole = null;

    // DOM Elemente mit null-Checks
    const stepRole = document.getElementById('step-role');
    const stepForm = document.getElementById('step-form');
    const roleInput = document.getElementById('role-input');
    const roleBadge = document.getElementById('role-badge');
    const formSubtitle = document.getElementById('form-subtitle');
    const mieterSection = document.getElementById('mieter-section');
    const form = document.getElementById('register-form');
    const submitBtn = document.getElementById('submit-btn');
    const btnText = document.getElementById('btn-text');
    const btnLoading = document.getElementById('btn-loading');
    const errorMsg = document.getElementById('error-message');
    const backBtn = document.getElementById('back-btn');

    if (!stepRole || !stepForm) {
      console.error('Wichtige Elemente nicht gefunden!');
      return;
    }

    // Rollen-Auswahl
    document.querySelectorAll('.role-card').forEach(function(card) {
      card.addEventListener('click', function() {
        const role = card.getAttribute('data-role');
        selectRole(role);
      });
    });

    // Zurück-Button
    backBtn?.addEventListener('click', goBack);

    function selectRole(role) {
      selectedRole = role;
      
      stepRole.style.display = 'none';
      stepForm.classList.add('active');
      
      if (roleInput) roleInput.value = role;
      
      const mieterInputs = document.querySelectorAll('.mieter-required');
      
      if (role === 'landlord') {
        if (roleBadge) {
          roleBadge.className = 'role-badge vermieter';
          roleBadge.innerHTML = `
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="width: 0.875rem; height: 0.875rem;">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
            Eigentümer
          `;
        }
        if (formSubtitle) formSubtitle.textContent = 'Erstellen Sie Ihr Konto. Weitere Daten können Sie später ergänzen.';
        if (mieterSection) mieterSection.style.display = 'none';
        mieterInputs.forEach(function(input) { input.required = false; });
      } else {
        if (roleBadge) {
          roleBadge.className = 'role-badge mieter';
          roleBadge.innerHTML = `
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="width: 0.875rem; height: 0.875rem;">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path>
            </svg>
            Mieter
          `;
        }
        if (formSubtitle) formSubtitle.textContent = 'Erstellen Sie Ihr Konto mit Ihren Wohnungsdaten.';
        if (mieterSection) mieterSection.style.display = 'block';
        mieterInputs.forEach(function(input) { input.required = true; });
      }
      
      console.log('Rolle ausgewählt:', role);
    }

    function goBack() {
      selectedRole = null;
      stepRole.style.display = 'block';
      stepForm.classList.remove('active');
      if (form) form.reset();
      if (errorMsg) errorMsg.style.display = 'none';
    }

    // Formular absenden
    form?.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      if (!submitBtn || !btnText || !btnLoading) {
        console.error('Button-Elemente nicht gefunden');
        return;
      }
      
      // Loading State
      submitBtn.disabled = true;
      btnText.style.display = 'none';
      btnLoading.style.display = 'flex';
      if (errorMsg) errorMsg.style.display = 'none';

      try {
        const formData = new FormData(form);
        const data = {
          email: formData.get('email'),
          password: formData.get('password'),
          vorname: formData.get('vorname'),
          nachname: formData.get('nachname'),
          role: formData.get('role'),
          strasse: formData.get('strasse'),
          plz: formData.get('plz'),
          stadt: formData.get('stadt'),
          wohnung_id: formData.get('wohnung_id')
        };

        console.log('Registriere:', data);

        // An API senden
        const res = await fetch('/api/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        const result = await res.json();
        console.log('API Antwort:', result);

        if (result.success) {
          alert('✓ Registrierung erfolgreich! Sie können sich jetzt anmelden.');
          window.location.href = '/login';
        } else {
          throw new Error(result.error || 'Registrierung fehlgeschlagen');
        }

      } catch (err) {
        console.error('Fehler:', err);
        if (errorMsg) {
          errorMsg.textContent = err instanceof Error ? err.message : 'Ein Fehler ist aufgetreten';
          errorMsg.style.display = 'block';
        }
        
        submitBtn.disabled = false;
        btnText.style.display = 'flex';
        btnLoading.style.display = 'none';
      }
    });
  });
</script>
</Layout>