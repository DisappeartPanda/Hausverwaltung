---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Mietverträge">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Mietverträge</h1>
    <a href="/mietvertraege/neu" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm">
      + Neuer Vertrag
    </a>
  </div>
  
  <div id="loading" class="text-center py-8">Laden...</div>
  
  <div id="vertraege-liste" class="bg-white rounded-lg shadow overflow-hidden hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Vertragsnr.</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Mieter</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Wohneinheit</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Miete</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Aktionen</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200" id="vertraege-tbody"></tbody>
    </table>
  </div>
</DashboardLayout>

<script>
  import { supabase } from '../lib/supabase';
  
  const loadVertraege = async () => {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return;
    
    const { data: vermieter } = await supabase
      .from('vermieter')
      .select('id')
      .eq('user_id', session.user.id)
      .single();
    
    if (!vermieter) return;
    
    const { data: vertraege } = await supabase
      .from('mietvertraege')
      .select(`
        *,
        mieter (vorname, nachname),
        wohneinheiten (
          bezeichnung,
          objekte (bezeichnung)
        )
      `)
      .order('mietbeginn', { ascending: false });
    
    document.getElementById('loading')!.classList.add('hidden');
    
    if (!vertraege || vertraege.length === 0) {
      document.getElementById('vertraege-liste')!.innerHTML = 
        '<div class="p-8 text-center text-gray-500">Keine Verträge vorhanden.</div>';
      document.getElementById('vertraege-liste')!.classList.remove('hidden');
      return;
    }
    
    const tbody = document.getElementById('vertraege-tbody')!;
    document.getElementById('vertraege-liste')!.classList.remove('hidden');
    
    vertraege.forEach(v => {
      const statusColors = {
        aktiv: 'bg-green-100 text-green-800',
        gekuendigt: 'bg-yellow-100 text-yellow-800',
        beendet: 'bg-gray-100 text-gray-800',
        vorzeitig_beendet: 'bg-red-100 text-red-800'
      };
      
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
          ${v.vertragsnummer || '-'}
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
          ${v.mieter.nachname}, ${v.mieter.vorname}
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
          <div>${v.wohneinheiten.objekte.bezeichnung}</div>
          <div class="text-xs">${v.wohneinheiten.bezeichnung}</div>
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
          ${v.gesamtmiete?.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}
        </td>
        <td class="px-6 py-4 whitespace-nowrap">
          <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full ${statusColors[v.status as keyof typeof statusColors]}">
            ${v.status.replace('_', ' ')}
          </span>
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
          <a href="/mietvertraege/${v.id}" class="text-blue-600 hover:text-blue-900">Details</a>
        </td>
      `;
      tbody.appendChild(tr);
    });
  };
  
  loadVertraege();
</script>