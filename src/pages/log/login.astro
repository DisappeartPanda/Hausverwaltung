---
export const prerender = false;

import Layout from '../layouts/Layout.astro';

// Wenn bereits eingeloggt: zurück zur Homepage (statt Dashboard)
const existingRole = Astro.cookies.get('userRole')?.value;
if (existingRole && existingRole !== 'guest') {
  throw Astro.redirect('/');
}
---

<Layout title="Login | ImmobilienPro">
  <style>
    /* (Dein CSS unverändert gelassen – hier komplett wie bei dir) */
    .login-page{min-height:100vh;background:var(--dark);position:relative;overflow:hidden;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2rem}
    .login-page::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,var(--dark) 0%,var(--dark-light) 50%,#064e3b 100%);opacity:.85}
    .login-page::after{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.03) 1px,transparent 1px);background-size:4rem 4rem;pointer-events:none}
    .login-container{position:relative;z-index:10;width:100%;max-width:480px}
    .logo-section{text-align:center;margin-bottom:2rem}
    .logo-link{display:inline-flex;align-items:center;gap:.75rem;text-decoration:none}
    .logo-icon{width:3rem;height:3rem;background:var(--primary);border-radius:.75rem;display:flex;align-items:center;justify-content:center;box-shadow:0 10px 25px -5px rgba(134,239,172,0.3);color:var(--dark);font-size:1.5rem}
    .logo-text{text-align:left;display:flex;flex-direction:column}
    .logo-title{font-size:1.5rem;font-weight:800;color:var(--white);line-height:1;letter-spacing:-0.02em}
    .logo-subtitle{font-size:.75rem;color:var(--primary);letter-spacing:.12em;font-weight:600;text-transform:uppercase;margin-top:.1rem}
    .form-card{background:rgba(255,255,255,0.05);backdrop-filter:blur(20px);border:1px solid var(--dark-lighter);border-radius:1.5rem;padding:2rem}
    .header{text-align:center;margin-bottom:1.5rem}
    .header h1{font-size:1.65rem;font-weight:800;color:var(--white);margin:0 0 .35rem 0}
    .header p{color:var(--gray-400);font-size:.9rem;margin:0}
    .form-group{margin-bottom:1.1rem}
    .form-label{display:block;font-size:.75rem;font-weight:600;color:var(--gray-400);text-transform:uppercase;letter-spacing:.05em;margin-bottom:.5rem}
    .form-input{width:100%;padding:.9rem 1rem;background:rgba(0,0,0,0.30);border:1px solid var(--dark-lighter);border-radius:.75rem;color:var(--white);font-size:1rem;transition:all .2s ease}
    .form-input::placeholder{color:var(--gray-600)}
    .form-input:focus{outline:none;border-color:var(--primary);box-shadow:0 0 0 3px rgba(134,239,172,0.12)}
    .submit-btn{width:100%;padding:1rem;background:var(--primary);color:var(--dark);font-weight:900;font-size:1rem;border:none;border-radius:.75rem;cursor:pointer;transition:all .2s ease;margin-top:.25rem;display:flex;align-items:center;justify-content:center;gap:.6rem}
    .submit-btn:hover:not(:disabled){background:var(--primary-hover);transform:translateY(-1px);box-shadow:0 10px 25px -5px rgba(134,239,172,0.25)}
    .submit-btn:disabled{opacity:.6;cursor:not-allowed}
    .spinner{width:1.25rem;height:1.25rem;border:2px solid var(--dark);border-top-color:transparent;border-radius:50%;animation:spin 1s linear infinite;display:none}
    .submit-btn.loading .spinner{display:block}
    .submit-btn.loading .btn-text{display:none}
    @keyframes spin{to{transform:rotate(360deg)}}
    .error-message{margin-top:1rem;font-size:.875rem;text-align:center;display:none;padding:.75rem;border-radius:.75rem;color:#fecaca;background:rgba(220,38,38,0.12);border:1px solid rgba(220,38,38,0.25)}
    .error-message.visible{display:block}
    .links{margin-top:1.25rem;text-align:center;font-size:.875rem;color:var(--gray-400)}
    .links a{color:var(--primary);font-weight:700;text-decoration:none}
    .links a:hover{text-decoration:underline}
    .trust-badges{display:flex;justify-content:center;gap:2rem;margin-top:1.75rem;color:var(--gray-600);font-size:.75rem;position:relative;z-index:10}
    .trust-badge{display:flex;align-items:center;gap:.4rem}
    .trust-badge span:first-child{color:var(--primary)}
    .meta-row{display:flex;align-items:center;justify-content:space-between;gap:1rem;margin:.25rem 0 1.1rem}
    .remember{display:flex;align-items:center;gap:.55rem;color:var(--gray-400);font-size:.875rem;user-select:none}
    .remember input{appearance:none;width:1.05rem;height:1.05rem;border-radius:.35rem;border:1px solid var(--dark-lighter);background:rgba(0,0,0,0.25);display:grid;place-items:center;cursor:pointer;transition:all .15s ease}
    .remember input:focus{outline:none;box-shadow:0 0 0 3px rgba(134,239,172,0.12);border-color:rgba(134,239,172,0.45)}
    .remember input::after{content:'';width:.55rem;height:.55rem;border-radius:.2rem;transform:scale(0.2);opacity:0;transition:all .15s ease;background:var(--primary)}
    .remember input:checked{border-color:rgba(134,239,172,0.55);background:rgba(134,239,172,0.08)}
    .remember input:checked::after{transform:scale(1);opacity:1}
    .forgot{color:var(--primary);font-weight:800;font-size:.875rem;text-decoration:none}
    .forgot:hover{text-decoration:underline}
    @media (max-width:640px){.form-card{padding:1.5rem}}
  </style>

  <div class="login-page">
    <div class="login-container">
      <div class="logo-section">
        <a href="/" class="logo-link">
          <div class="logo-icon" aria-hidden="true">🏢</div>
          <div class="logo-text">
            <div class="logo-title">ImmobilienPro</div>
            <div class="logo-subtitle">HAUSVERWALTUNG</div>
          </div>
        </a>
      </div>

      <div class="form-card">
        <div class="header">
          <h1>Anmelden</h1>
          <p>Willkommen zurück bei ImmobilienPro</p>
        </div>

        <!-- ✅ IDs so lassen wie in deinem HTML -->
        <form id="loginForm" novalidate>
          <div class="form-group">
            <label class="form-label" for="email">E-Mail</label>
            <input class="form-input" type="email" id="email" name="email" required placeholder="ihre@email.de" autocomplete="email" autofocus />
          </div>

          <div class="form-group">
            <label class="form-label" for="password">Passwort</label>
            <input class="form-input" type="password" id="password" name="password" required placeholder="••••••••" autocomplete="current-password" />
          </div>

          <div class="meta-row">
            <label class="remember">
              <input type="checkbox" id="rememberMe" name="rememberMe" />
              <span>Angemeldet bleiben</span>
            </label>

            <a class="forgot" href="/passwort-vergessen">Passwort vergessen?</a>
          </div>

          <button type="submit" class="submit-btn" id="submitBtn">
            <div class="spinner" aria-hidden="true"></div>
            <span class="btn-text">Anmelden</span>
          </button>

          <div id="errorMsg" class="error-message" role="alert"></div>
        </form>

        <div class="links">
          Noch kein Konto? <a href="/registrieren">Jetzt registrieren →</a>
        </div>
      </div>

      <div class="trust-badges" aria-hidden="true">
        <div class="trust-badge"><span>🔒</span><span>SSL-verschlüsselt</span></div>
        <div class="trust-badge"><span>🛡️</span><span>DSGVO-konform</span></div>
      </div>
    </div>
  </div>

  <script type="module">
    const form = document.getElementById('loginForm');
    const submitBtn = document.getElementById('submitBtn');
    const errorMsg = document.getElementById('errorMsg');

    const showError = (msg) => {
      if (!errorMsg) return;
      errorMsg.textContent = msg;
      errorMsg.classList.add('visible');
    };

    const clearError = () => {
      if (!errorMsg) return;
      errorMsg.textContent = '';
      errorMsg.classList.remove('visible');
    };

    const setLoading = (on) => {
      if (!submitBtn) return;
      submitBtn.disabled = on;
      submitBtn.classList.toggle('loading', on);
    };

    form?.addEventListener('submit', async (e) => {
      e.preventDefault(); // ✅ verhindert Page-Reload
      clearError();
      setLoading(true);

      try {
        const fd = new FormData(form);

        const email = String(fd.get('email') ?? '').trim();
        const password = String(fd.get('password') ?? '').trim();
        const rememberMe = fd.get('rememberMe') === 'on';

        if (!email || !password) {
          showError('Bitte E-Mail und Passwort eingeben.');
          return;
        }

        const res = await fetch('/api/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password, rememberMe }),
        });

        const raw = await res.text(); // ✅ body nur 1x lesen
        let json = null;
        try { json = JSON.parse(raw); } catch {}

        if (!res.ok || !json?.success) {
          showError(json?.error ?? raw ?? 'Login fehlgeschlagen');
          return;
        }

        // ✅ Rollen-Redirect
        const role = json.role ?? 'tenant';

        // optional: ?next=... unterstützen
        const next = new URLSearchParams(window.location.search).get('next') ?? '/';

        window.location.href = role === 'landlord' ? (next || '/') : '/mieterbereich';
      } catch (err) {
        showError('Server-Fehler: ' + String(err));
      } finally {
        setLoading(false);
      }
    });
  </script>
</Layout>