---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Mängel">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Mängelverwaltung</h1>
    <a href="/maengel/neu" class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700 text-sm">
      + Mangel melden
    </a>
  </div>
  
  <!-- Filter -->
  <div class="flex gap-4 mb-6">
    <select id="status-filter" class="px-4 py-2 border rounded-md bg-white">
      <option value="">Alle Status</option>
      <option value="offen">Offen</option>
      <option value="in_pruefung">In Prüfung</option>
      <option value="behoben">Behoben</option>
    </select>
    <label class="flex items-center gap-2">
      <input type="checkbox" id="dringend-filter" class="rounded" />
      <span class="text-sm">Nur dringend</span>
    </label>
  </div>
  
  <div id="loading" class="text-center py-8">Laden...</div>
  
  <div id="maengel-liste" class="space-y-4 hidden">
    <!-- Wird via JS gefüllt -->
  </div>
  
  <div id="keine-maengel" class="hidden text-center py-8 text-gray-500 bg-white rounded-lg shadow">
    Keine Mängel vorhanden.
  </div>
</DashboardLayout>

<script>
  import { supabase } from '../lib/supabase';
  
  let alleMaengel: any[] = [];
  
  const loadMaengel = async () => {
    const { data: maengel } = await supabase
      .from('view_offene_maengel')
      .select('*')
      .order('dringend', { ascending: false })
      .order('gemeldet_am', { ascending: true });
    
    alleMaengel = maengel || [];
    
    document.getElementById('loading')!.classList.add('hidden');
    
    if (alleMaengel.length === 0) {
      document.getElementById('keine-maengel')!.classList.remove('hidden');
      return;
    }
    
    renderMaengel(alleMaengel);
    
    // Filter-Handler
    document.getElementById('status-filter')?.addEventListener('change', (e) => {
      applyFilters();
    });
    
    document.getElementById('dringend-filter')?.addEventListener('change', () => {
      applyFilters();
    });
  };
  
  const renderMaengel = (maengel: any[]) => {
    const container = document.getElementById('maengel-liste')!;
    container.classList.remove('hidden');
    container.innerHTML = '';
    
    maengel.forEach(m => {
      const statusColors = {
        offen: 'bg-red-100 text-red-800',
        in_pruefung: 'bg-yellow-100 text-yellow-800',
        bestaetigt: 'bg-blue-100 text-blue-800',
        behoben: 'bg-green-100 text-green-800',
        abgelehnt: 'bg-gray-100 text-gray-800'
      };
      
      const card = document.createElement('div');
      card.className = `bg-white rounded-lg shadow p-6 ${m.dringend ? 'border-l-4 border-red-500' : ''}`;
      card.innerHTML = `
        <div class="flex justify-between items-start mb-4">
          <div>
            <h3 class="text-lg font-semibold text-gray-900">${m.titel}</h3>
            <p class="text-sm text-gray-600">${m.objekt} - ${m.wohneinheit}</p>
          </div>
          <div class="flex gap-2">
            ${m.dringend ? '<span class="px-2 py-1 bg-red-100 text-red-800 text-xs rounded-full font-bold">DRINGEND</span>' : ''}
            <span class="px-2 py-1 ${statusColors[m.status as keyof typeof statusColors]} text-xs rounded-full">
              ${m.status.replace('_', ' ')}
            </span>
          </div>
        </div>
        
        <p class="text-gray-700 mb-4">${m.beschreibung}</p>
        
        <div class="grid grid-cols-2 gap-4 text-sm text-gray-500 mb-4">
          <div>
            <span class="font-medium">Gemeldet von:</span> ${m.mieter_name || 'Unbekannt'}
          </div>
          <div>
            <span class="font-medium">Datum:</span> ${new Date(m.gemeldet_am).toLocaleDateString('de-DE')}
          </div>
          <div>
            <span class="font-medium">Ort:</span> ${m.ort_im_objekt || '-'}
          </div>
          <div>
            <span class="font-medium">Kategorie:</span> ${m.kategorie}
          </div>
        </div>
        
        <div class="flex gap-3 pt-4 border-t">
          <a href="/maengel/${m.id}" class="text-blue-600 hover:text-blue-800 text-sm font-medium">Bearbeiten</a>
          ${m.status === 'offen' ? `
            <button onclick="updateStatus('${m.id}', 'in_pruefung')" class="text-yellow-600 hover:text-yellow-800 text-sm">In Prüfung</button>
            <button onclick="updateStatus('${m.id}', 'behoben')" class="text-green-600 hover:text-green-800 text-sm">Als behoben markieren</button>
          ` : ''}
        </div>
      `;
      container.appendChild(card);
    });
  };
  
  const applyFilters = () => {
    const statusFilter = (document.getElementById('status-filter') as HTMLSelectElement).value;
    const dringendFilter = (document.getElementById('dringend-filter') as HTMLInputElement).checked;
    
    let filtered = alleMaengel;
    
    if (statusFilter) {
      filtered = filtered.filter(m => m.status === statusFilter);
    }
    
    if (dringendFilter) {
      filtered = filtered.filter(m => m.dringend);
    }
    
    renderMaengel(filtered);
  };
  
  // @ts-ignore
  window.updateStatus = async (id: string, status: string) => {
    const { error } = await supabase
      .from('maengel')
      .update({ status, behoben_am: status === 'behoben' ? new Date().toISOString() : null })
      .eq('id', id);
    
    if (!error) {
      loadMaengel();
    }
  };
  
  loadMaengel();
</script>