---
import TenantLayout from "../../../layouts/TenantLayout.astro";
import { requireTenantSession } from "../../../lib/auth/guards";

const session = await requireTenantSession(Astro);

if (session instanceof Response) {
  return session;
}

const defects = [
  {
    title: "Heizung wird nicht richtig warm",
    status: "In Bearbeitung",
    date: "05.03.2026",
  },
  {
    title: "Fenster im Schlafzimmer zieht",
    status: "Gemeldet",
    date: "02.03.2026",
  },
];
---

<TenantLayout
  title="Mängel | Mieterportal"
  tenantName={session.email ?? "Mieter"}
>
  <div class="stack">
    <div class="section__header">
      <span class="section__eyebrow">Mängel</span>
      <h1>Mängel melden und verfolgen</h1>
      <p>
        Reiche neue Schäden ein und behalte den Bearbeitungsstatus im Blick.
      </p>
    </div>

    <section class="card card--glass">
      <div class="card__body stack">
        <h3>Neuen Mangel melden</h3>

        <div class="input-group">
          <label class="input-label">Titel</label>
          <input placeholder="z. B. Wasserhahn tropft" />
        </div>

        <div class="input-group">
          <label class="input-label">Beschreibung</label>
          <textarea placeholder="Beschreibe das Problem möglichst genau"></textarea>
        </div>

        <button class="button button--primary" type="button">
          Mangel absenden
        </button>
      </div>
    </section>

    <div class="stack">
      {
        defects.map((defect) => (
          <article class="card card--glass card--glow">
            <div class="card__body stack">
              <div class="row row--between">
                <span class="badge badge--accent">{defect.status}</span>
                <span class="badge">{defect.date}</span>
              </div>

              <h3>{defect.title}</h3>
              <p>
                Der aktuelle Bearbeitungsstand wird hier für dich transparent
                angezeigt.
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</TenantLayout>