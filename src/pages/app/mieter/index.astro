---
import AppLayout from "../../../layouts/AppLayout.astro";
import { requireLandlordSession } from "../../../lib/auth/guards";

const session = await requireLandlordSession(Astro);

if (session instanceof Response) {
  return session;
}

const userEmail = Astro.locals.user?.email ?? null;
---

<AppLayout
  title="Mieter | ImmobilienPro"
  organizationName="Mieterverwaltung"
  userEmail={userEmail}
>
  <div class="stack">
    <header class="section__header">
      <p class="section__eyebrow">Mieter</p>
      <h2>Mieter und Kontakte verwalten</h2>
      <p>
        Behalte Kontakte, laufende Mietverhältnisse und zentrale Informationen
        zur Kommunikation im Blick.
      </p>
    </header>

    <section class="panel">
      <div class="panel__body stack">
        <div class="row row--between">
          <h3>Mieterstatus</h3>
          <span class="badge">Kommunikation</span>
        </div>

        <div class="kpi-grid">
          <article class="kpi-card">
            <div class="kpi-card__label">Aktive Mieter</div>
            <div class="kpi-card__value">0</div>
          </article>

          <article class="kpi-card">
            <div class="kpi-card__label">Offene Anfragen</div>
            <div class="kpi-card__value">0</div>
          </article>

          <article class="kpi-card">
            <div class="kpi-card__label">Dokumente</div>
            <div class="kpi-card__value">0</div>
          </article>
        </div>
      </div>
    </section>

    <section class="grid-auto">
      <article class="card card--glass card--glow">
        <div class="card__body stack">
          <h3>Mieterverzeichnis</h3>
          <p>
            Sieh alle zugeordneten Mieter und ihre wichtigsten Stammdaten auf
            einen Blick.
          </p>
        </div>
      </article>

      <article class="card card--glass card--glow">
        <div class="card__body stack">
          <h3>Kommunikation</h3>
          <p>
            Organisiere Anfragen, Rückfragen und relevante Verwaltungsprozesse
            strukturiert.
          </p>
        </div>
      </article>

      <article class="card card--glass card--glow">
        <div class="card__body stack">
          <h3>Vertragsbezug</h3>
          <p>
            Verknüpfe Mieter mit Einheiten, Dokumenten und laufenden Vorgängen.
          </p>
        </div>
      </article>
    </section>
  </div>
</AppLayout>