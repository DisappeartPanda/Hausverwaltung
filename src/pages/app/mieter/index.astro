---
import AppLayout from "../../../layouts/AppLayout.astro";
import { MODULE_KEYS } from "../../../lib/constants/module-keys";
import { getAppContext } from "../../../lib/utils/app-context";
import { getTenantListViewModel } from "../../../lib/domain/tenants/tenant-service";
import { requireLandlordSession } from "../../../lib/auth/guards";

const activeModules = [MODULE_KEYS.SONDEREIGENTUM];

const session = await requireLandlordSession(Astro);

if (session instanceof Response) {
  return session;
}

const appContext = await getAppContext(session);

let tenants = [];

try {
  tenants = await getTenantListViewModel(appContext.organizationId);
} catch (error) {
  console.error("Fehler beim Laden der Mieter:", error);
}
---

<AppLayout
  title="Mieter | ImmobilienPro"
  organizationName={appContext.organizationName}
  activeModules={activeModules}
  theme={appContext.theme}
  userEmail={session.email}
>
  <div class="stack">
    <div class="row row--between">
      <div class="section__header">
        <span class="section__eyebrow">Mieter</span>
        <h1>Mieter verwalten</h1>
        <p>
          Behalte Mieter, Zuordnungen und Statusänderungen zentral im Blick.
        </p>
      </div>

      <a class="button button--primary" href="/app/mieter/neu">
        Mieter anlegen
      </a>
    </div>

    {
      tenants.length === 0 ? (
        <section class="card card--glass">
          <div class="card__body stack">
            <span class="badge">Noch keine Mieter</span>
            <h3>Lege deinen ersten Mieter an</h3>
            <p>
              Neue Mieter erscheinen hier automatisch, sobald sie gespeichert wurden.
            </p>
            <a class="button button--primary" href="/app/mieter/neu">
              Ersten Mieter anlegen
            </a>
          </div>
        </section>
      ) : (
        <div class="stack">
          {
            tenants.map((tenant) => (
              <article class="card card--glass card--glow">
                <div class="card__body row row--between">
                  <div class="stack" style="gap: 0.4rem;">
                    <div class="row">
                      <span class="badge badge--accent">{tenant.statusLabel}</span>
                      <span class="badge">{tenant.unitLabel}</span>
                    </div>

                    <h3>{tenant.fullName}</h3>
                    <p>{tenant.email}</p>
                    <p>{tenant.phoneLabel}</p>
                    <p>Einzug: {tenant.moveInDateLabel}</p>
                  </div>

                  <div class="row">
                    <a class="button button--secondary" href={`/app/mieter/${tenant.id}`}>
                      Details
                    </a>
                    <a class="button button--ghost" href={`/app/mieter/${tenant.id}/bearbeiten`}>
                      Bearbeiten
                    </a>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      )
    }
  </div>
</AppLayout>