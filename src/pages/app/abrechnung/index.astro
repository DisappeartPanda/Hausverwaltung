---
import AppLayout from "../../../layouts/AppLayout.astro";
import { MODULE_KEYS } from "../../../lib/constants/module-keys";

const activeModules = [
  MODULE_KEYS.HAUSVERWALTUNG,
  MODULE_KEYS.SONDEREIGENTUM,
];

const statements = [
  {
    title: "Hausabrechnung 2025",
    type: "Hausverwaltung",
    period: "01.01.2025 – 31.12.2025",
    status: "Abgeschlossen",
  },
  {
    title: "Nebenkosten WE 3.2",
    type: "Sondereigentum",
    period: "01.01.2025 – 31.12.2025",
    status: "In Prüfung",
  },
  {
    title: "Rücklagenübersicht Q1 2026",
    type: "Hausverwaltung",
    period: "Q1 2026",
    status: "Aktuell",
  },
];
---

<AppLayout
  title="Abrechnungen | ImmobilienPro"
  organizationName="Musterverwaltung GmbH"
  activeModules={activeModules}
>
  <div class="stack">
    <div class="row row--between">
      <div class="section__header">
        <span class="section__eyebrow">Abrechnungen</span>
        <h1>Abrechnungen und Auswertungen</h1>
        <p>
          Hausabrechnungen, einheitenbezogene Auswertungen und Rücklagenberichte
          gesammelt an einem Ort.
        </p>
      </div>

      <a class="button button--primary" href="/app/abrechnungen/export">
        Export starten
      </a>
    </div>

    <div class="stack">
      {
        statements.map((statement) => (
          <article class="card card--glass card--glow">
            <div class="card__body row row--between">
              <div class="stack" style="gap: 0.35rem;">
                <div class="row">
                  <span class="badge badge--accent">{statement.status}</span>
                  <span class="badge">{statement.type}</span>
                </div>

                <h3>{statement.title}</h3>
                <p>{statement.period}</p>
              </div>

              <div class="row">
                <a class="button button--secondary" href="#">
                  Öffnen
                </a>
                <a class="button button--ghost" href="#">
                  Exportieren
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</AppLayout>