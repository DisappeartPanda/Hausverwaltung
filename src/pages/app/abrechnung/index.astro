---
import AppLayout from "../../../layouts/AppLayout.astro";
import { requireLandlordSession } from "../../../lib/auth/guards";

const session = await requireLandlordSession(Astro);

if (session instanceof Response) {
  return session;
}

const userEmail = Astro.locals.user?.email ?? null;
---

<AppLayout
  title="Abrechnung | ImmobilienPro"
  organizationName="Abrechnungen"
  userEmail={userEmail}
>
  <div class="stack">
    <header class="section__header">
      <p class="section__eyebrow">Abrechnung</p>
      <h2>Abrechnungen und finanzielle Übersichten</h2>
      <p>
        Verwalte Abrechnungsprozesse, behalte offene Themen im Blick und schaffe
        eine klare Grundlage für wiederkehrende finanzielle Abläufe.
      </p>
    </header>

    <section class="panel">
      <div class="panel__body stack">
        <div class="row row--between">
          <h3>Finanzstatus</h3>
          <span class="badge badge--accent">Übersicht</span>
        </div>

        <div class="kpi-grid">
          <article class="kpi-card">
            <div class="kpi-card__label">Offene Abrechnungen</div>
            <div class="kpi-card__value">0</div>
          </article>

          <article class="kpi-card">
            <div class="kpi-card__label">Abgeschlossene Perioden</div>
            <div class="kpi-card__value">0</div>
          </article>

          <article class="kpi-card">
            <div class="kpi-card__label">Prüfbedarf</div>
            <div class="kpi-card__value">0</div>
          </article>
        </div>
      </div>
    </section>

    <section class="grid-auto">
      <article class="card card--glass card--glow">
        <div class="card__body stack">
          <h3>Laufende Abrechnungen</h3>
          <p>
            Behalte offene Abrechnungszyklen und vorbereitende Schritte in einer
            zentralen Übersicht.
          </p>
        </div>
      </article>

      <article class="card card--glass card--glow">
        <div class="card__body stack">
          <h3>Dokumente & Nachweise</h3>
          <p>
            Verknüpfe Belege, Unterlagen und relevante Dokumente direkt mit
            deinen finanziellen Vorgängen.
          </p>
          <div class="row">
            <a href="/app/dokumente" class="button button--secondary">
              Zu den Dokumenten
            </a>
          </div>
        </div>
      </article>

      <article class="card card--glass card--glow">
        <div class="card__body stack">
          <h3>Objektbezug</h3>
          <p>
            Ordne Abrechnungen sauber den passenden Objekten und Einheiten zu.
          </p>
          <div class="row">
            <a href="/app/objekte" class="button button--secondary">
              Zu den Objekten
            </a>
          </div>
        </div>
      </article>
    </section>
  </div>
</AppLayout>