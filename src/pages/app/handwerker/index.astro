---
import AppLayout from "../../../layouts/AppLayout.astro";
import { requireLandlordSession } from "../../../lib/auth/guards";

const session = await requireLandlordSession(Astro);

if (session instanceof Response) {
  return session;
}

const userEmail = Astro.locals.user?.email ?? null;
---

<AppLayout
  title="Handwerker | ImmobilienPro"
  organizationName="Handwerker & Dienstleister"
  userEmail={userEmail}
>
  <div class="stack">
    <header class="section__header">
      <p class="section__eyebrow">Handwerker</p>
      <h2>Externe Dienstleister und Handwerker organisieren</h2>
      <p>
        Behalte Kontakte, Zuständigkeiten und Einsätze von externen Partnern
        übersichtlich und strukturiert im Blick.
      </p>
    </header>

    <section class="panel">
      <div class="panel__body stack">
        <div class="row row--between">
          <h3>Dienstleisterstatus</h3>
          <span class="badge">Partner</span>
        </div>

        <div class="kpi-grid">
          <article class="kpi-card">
            <div class="kpi-card__label">Aktive Partner</div>
            <div class="kpi-card__value">0</div>
          </article>

          <article class="kpi-card">
            <div class="kpi-card__label">Offene Einsätze</div>
            <div class="kpi-card__value">0</div>
          </article>

          <article class="kpi-card">
            <div class="kpi-card__label">Zugeordnete Vorgänge</div>
            <div class="kpi-card__value">0</div>
          </article>
        </div>
      </div>
    </section>

    <section class="grid-auto">
      <article class="card card--glass card--glow">
        <div class="card__body stack">
          <h3>Kontakte verwalten</h3>
          <p>
            Halte Ansprechpartner, Gewerke und Zuständigkeiten zentral an einem
            Ort fest.
          </p>
        </div>
      </article>

      <article class="card card--glass card--glow">
        <div class="card__body stack">
          <h3>Einsätze & Vorgänge</h3>
          <p>
            Verknüpfe Handwerker mit Wartungen, Mängeln und technischen
            Aufgaben.
          </p>
          <div class="row">
            <a href="/app/wartungen" class="button button--secondary">
              Zu den Wartungen
            </a>
            <a href="/app/maengel" class="button button--secondary">
              Zu den Mängeln
            </a>
          </div>
        </div>
      </article>

      <article class="card card--glass card--glow">
        <div class="card__body stack">
          <h3>Dokumentation</h3>
          <p>
            Dokumentiere Leistungen, Nachweise und wichtige Unterlagen
            nachvollziehbar.
          </p>
          <div class="row">
            <a href="/app/dokumente" class="button button--secondary">
              Zu den Dokumenten
            </a>
          </div>
        </div>
      </article>
    </section>
  </div>
</AppLayout>