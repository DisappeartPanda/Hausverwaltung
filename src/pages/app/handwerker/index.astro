---
import AppLayout from "../../../layouts/AppLayout.astro";
import { MODULE_KEYS } from "../../../lib/constants/module-keys";

const activeModules = [MODULE_KEYS.HAUSVERWALTUNG];

const contractors = [
  {
    name: "Schmidt Haustechnik",
    trade: "Heizung / Sanitär",
    status: "Aktiv",
    contact: "info@schmidt-haustechnik.de",
  },
  {
    name: "Elektro Weber",
    trade: "Elektro",
    status: "Bevorzugt",
    contact: "kontakt@elektro-weber.de",
  },
  {
    name: "Malerbetrieb König",
    trade: "Malerarbeiten",
    status: "Verfügbar",
    contact: "mail@koenig-maler.de",
  },
];
---

<AppLayout
  title="Handwerker | ImmobilienPro"
  organizationName="Musterverwaltung GmbH"
  activeModules={activeModules}
>
  <div class="stack">
    <div class="row row--between">
      <div class="section__header">
        <span class="section__eyebrow">Handwerker</span>
        <h1>Handwerker und Dienstleister</h1>
        <p>
          Verwalte Kontakte, Zuständigkeiten und bevorzugte Partner für deine
          Objekte.
        </p>
      </div>

      <a class="button button--primary" href="/app/handwerker/neu">
        Handwerker hinzufügen
      </a>
    </div>

    <div class="grid-auto">
      {
        contractors.map((contractor) => (
          <article class="card card--glass card--glow">
            <div class="card__body stack">
              <div class="row row--between">
                <span class="badge badge--accent">{contractor.status}</span>
                <span class="badge">{contractor.trade}</span>
              </div>

              <h3>{contractor.name}</h3>
              <p>{contractor.contact}</p>

              <div class="row">
                <a class="button button--secondary" href="/app/handwerker/1">
                  Details
                </a>
                <a class="button button--ghost" href="/app/handwerker/1/bearbeiten">
                  Bearbeiten
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</AppLayout>