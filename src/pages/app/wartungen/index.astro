---
import AppLayout from "../../../layouts/AppLayout.astro";
import { MODULE_KEYS } from "../../../lib/constants/module-keys";
import { getAppContext } from "../../../lib/utils/app-context";
import { getMaintenanceListViewModel } from "../../../lib/domain/maintenance/maintenance-service";
import { requireLandlordSession } from "../../../lib/auth/guards";

const activeModules = [MODULE_KEYS.HAUSVERWALTUNG];

const session = await requireLandlordSession(Astro);

if (session instanceof Response) {
  return session;
}

const appContext = await getAppContext(session);

let maintenanceItems = [];

try {
  maintenanceItems = await getMaintenanceListViewModel(appContext.organizationId);
} catch (error) {
  console.error("Fehler beim Laden der Wartungen:", error);
}
---

<AppLayout
  title="Wartungen | ImmobilienPro"
  organizationName={appContext.organizationName}
  activeModules={activeModules}
  theme={appContext.theme}
  userEmail={session.email}
>
  <div class="stack">
    <div class="row row--between">
      <div class="section__header">
        <span class="section__eyebrow">Wartungen</span>
        <h1>Wartungen und Termine im Blick</h1>
        <p>
          Plane, dokumentiere und verfolge alle wiederkehrenden Maßnahmen für
          deine Objekte.
        </p>
      </div>

      <a class="button button--primary" href="/app/wartungen/neu">
        Wartung anlegen
      </a>
    </div>

    {
      maintenanceItems.length === 0 ? (
        <section class="card card--glass">
          <div class="card__body stack">
            <span class="badge">Noch keine Wartungen</span>
            <h3>Plane deine erste Wartung</h3>
            <p>
              Neue Wartungen werden hier nach dem Speichern automatisch angezeigt.
            </p>
            <a class="button button--primary" href="/app/wartungen/neu">
              Erste Wartung anlegen
            </a>
          </div>
        </section>
      ) : (
        <div class="stack">
          {
            maintenanceItems.map((item) => (
              <article class="card card--glass card--glow">
                <div class="card__body row row--between">
                  <div class="stack" style="gap: 0.4rem;">
                    <div class="row">
                      <span class="badge badge--accent">{item.statusLabel}</span>
                      <span class="badge">{item.scheduledDateLabel}</span>
                    </div>

                    <h3>{item.title}</h3>
                    <p>{item.objectLabel}</p>
                    <p>{item.noteLabel}</p>
                  </div>

                  <div class="row">
                    <a class="button button--secondary" href={`/app/wartungen/${item.id}`}>
                      Details
                    </a>
                    <a class="button button--ghost" href={`/app/wartungen/${item.id}/bearbeiten`}>
                      Bearbeiten
                    </a>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      )
    }
  </div>
</AppLayout>