---
import AppLayout from "../../../layouts/AppLayout.astro";
import { requireLandlordSession } from "../../../lib/auth/guards";

const session = await requireLandlordSession(Astro);

if (session instanceof Response) {
  return session;
}

const userEmail = Astro.locals.user?.email ?? null;
---

<AppLayout
  title="Wartungen | ImmobilienPro"
  organizationName="Wartungsmanagement"
  userEmail={userEmail}
>
  <div class="stack">
    <header class="section__header">
      <p class="section__eyebrow">Wartungen</p>
      <h2>Technische Vorgänge und Wartungen im Blick</h2>
      <p>
        Organisiere wiederkehrende Aufgaben, offene technische Themen und
        wichtige Prüfprozesse strukturiert.
      </p>
    </header>

    <section class="panel">
      <div class="panel__body stack">
        <div class="row row--between">
          <h3>Statusübersicht</h3>
          <span class="badge badge--accent">Technik</span>
        </div>

        <div class="kpi-grid">
          <article class="kpi-card">
            <div class="kpi-card__label">Geplante Wartungen</div>
            <div class="kpi-card__value">0</div>
          </article>

          <article class="kpi-card">
            <div class="kpi-card__label">Offene Aufgaben</div>
            <div class="kpi-card__value">0</div>
          </article>

          <article class="kpi-card">
            <div class="kpi-card__label">Dringende Themen</div>
            <div class="kpi-card__value">0</div>
          </article>
        </div>
      </div>
    </section>

    <section class="grid-auto">
      <article class="card card--glass">
        <div class="card__body stack">
          <h3>Wartungspläne</h3>
          <p>
            Behalte wiederkehrende Wartungen und Fristen für deine Objekte im
            Blick.
          </p>
        </div>
      </article>

      <article class="card card--glass">
        <div class="card__body stack">
          <h3>Mängel & Folgevorgänge</h3>
          <p>
            Verknüpfe technische Probleme mit Wartungen und priorisiere offene
            Aufgaben.
          </p>
          <div class="row">
            <a href="/app/maengel" class="button button--secondary">
              Zu den Mängeln
            </a>
          </div>
        </div>
      </article>
    </section>
  </div>
</AppLayout>