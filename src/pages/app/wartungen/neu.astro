---
import AppLayout from "../../../layouts/AppLayout.astro";
import { MODULE_KEYS } from "../../../lib/constants/module-keys";

const activeModules = [MODULE_KEYS.HAUSVERWALTUNG];
---

<AppLayout
  title="Neue Wartung | ImmobilienPro"
  organizationName="Musterverwaltung GmbH"
  activeModules={activeModules}
>
  <div class="stack">
    <div class="section__header">
      <span class="section__eyebrow">Wartungen</span>
      <h1>Neue Wartung anlegen</h1>
      <p>
        Plane eine neue Wartung oder Maßnahme für ein Objekt.
      </p>
    </div>

    <section class="card card--glass">
      <div class="card__body stack">
        <form class="stack" id="maintenance-create-form">
          <div class="input-group">
            <label class="input-label" for="title">Titel</label>
            <input id="title" name="title" placeholder="z. B. Heizungswartung" />
          </div>

          <div class="grid-auto">
            <div class="input-group">
              <label class="input-label" for="objectId">Objekt</label>
              <input id="objectId" name="objectId" placeholder="z. B. Musterstraße 12" />
            </div>

            <div class="input-group">
              <label class="input-label" for="scheduledDate">Geplantes Datum</label>
              <input id="scheduledDate" name="scheduledDate" type="date" />
            </div>
          </div>

          <div class="input-group">
            <label class="input-label" for="status">Status</label>
            <select id="status" name="status">
              <option value="offen">Offen</option>
              <option value="geplant">Geplant</option>
              <option value="beauftragt">Beauftragt</option>
              <option value="abgeschlossen">Abgeschlossen</option>
            </select>
          </div>

          <div class="input-group">
            <label class="input-label" for="note">Notiz</label>
            <textarea
              id="note"
              name="note"
              placeholder="Zusätzliche Informationen zur Wartung"
            ></textarea>
          </div>

          <div class="row">
            <button class="button button--primary" type="submit">
              Wartung speichern
            </button>
            <a class="button button--secondary" href="/app/wartungen">
              Abbrechen
            </a>
          </div>

          <p class="form-status" id="maintenance-form-status" aria-live="polite"></p>
        </form>
      </div>
    </section>
  </div>
</AppLayout>

<script>
  const form = document.querySelector("#maintenance-create-form");
  const statusEl = document.querySelector("#maintenance-form-status");

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const formData = new FormData(form);
    const payload = Object.fromEntries(formData.entries());

    try {
      const response = await fetch("/api/maintenance/create", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify(payload)
      });

      const result = await response.json();

      if (!response.ok || !result.success) {
        statusEl.textContent =
          result?.errors?.form ||
          Object.values(result?.errors || {})[0] ||
          "Wartung konnte nicht gespeichert werden.";
        return;
      }

      statusEl.textContent = "Wartung erfolgreich angelegt.";
      form.reset();
    } catch {
      statusEl.textContent = "Beim Speichern ist ein Fehler aufgetreten.";
    }
  });
</script>

<style>
  .form-status {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }
</style>