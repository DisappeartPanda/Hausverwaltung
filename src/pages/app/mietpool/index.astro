---
import AppLayout from "../../../layouts/AppLayout.astro";
import { requireLandlordSession } from "../../../lib/auth/guards";

const session = await requireLandlordSession(Astro);

if (session instanceof Response) {
  return session;
}

const userEmail = Astro.locals.user?.email ?? null;
---

<AppLayout
  title="Mietpool | ImmobilienPro"
  organizationName="Mietpool"
  userEmail={userEmail}
>
  <div class="stack">
    <header class="section__header">
      <p class="section__eyebrow">Mietpool</p>
      <h2>Mietpool-Prozesse zentral steuern</h2>
      <p>
        Verwalte Ausschüttungen, Rücklagen und poolbezogene Strukturen in einer
        klaren und nachvollziehbaren Übersicht.
      </p>
    </header>

    <section class="panel">
      <div class="panel__body stack">
        <div class="row row--between">
          <h3>Poolstatus</h3>
          <span class="badge badge--accent">Poolverwaltung</span>
        </div>

        <div class="kpi-grid">
          <article class="kpi-card">
            <div class="kpi-card__label">Aktive Pools</div>
            <div class="kpi-card__value">0</div>
          </article>

          <article class="kpi-card">
            <div class="kpi-card__label">Auszahlungen</div>
            <div class="kpi-card__value">0</div>
          </article>

          <article class="kpi-card">
            <div class="kpi-card__label">Rücklagen</div>
            <div class="kpi-card__value">0</div>
          </article>
        </div>
      </div>
    </section>

    <section class="grid-auto">
      <article class="card card--glass">
        <div class="card__body stack">
          <h3>Ausschüttungen</h3>
          <p>
            Behalte geplante und bereits ausgeführte Auszahlungen innerhalb des
            Mietpools im Blick.
          </p>
        </div>
      </article>

      <article class="card card--glass">
        <div class="card__body stack">
          <h3>Poolrücklagen</h3>
          <p>
            Organisiere Rücklagen strukturiert und nachvollziehbar für spätere
            Verwendungen.
          </p>
        </div>
      </article>

      <article class="card card--glass">
        <div class="card__body stack">
          <h3>Abrechnungsbezug</h3>
          <p>
            Verbinde Mietpool-Vorgänge mit finanziellen Prozessen und
            Dokumentationen.
          </p>
          <div class="row">
            <a href="/app/abrechnung" class="button button--secondary">
              Zur Abrechnung
            </a>
          </div>
        </div>
      </article>
    </section>
  </div>
</AppLayout>