---
import AppLayout from "../../../layouts/AppLayout.astro";
import { MODULE_KEYS } from "../../../lib/constants/module-keys";
import { getAppContext } from "../../../lib/utils/app-context";
import { getRentalPoolSummaryViewModel } from "../../../lib/domain/rental-pool/rental-pool-service";
import { requireLandlordSession } from "../../../lib/auth/guards";

const activeModules = [MODULE_KEYS.MIETPOOL];

const session = await requireLandlordSession(Astro);

if (session instanceof Response) {
  return session;
}

const appContext = await getAppContext(session);

const rentalPoolSummary = await getRentalPoolSummaryViewModel(
  appContext.organizationId,
);
---

<AppLayout
  title="Mietpool | ImmobilienPro"
  organizationName={appContext.organizationName}
  activeModules={activeModules}
  theme={appContext.theme}
  userEmail={session.email}
>
  <div class="stack">
    <div class="section__header">
      <span class="section__eyebrow">Mietpool</span>
      <h1>Mietpool und Ausschüttungen</h1>
      <p>
        Verfolge Auszahlungsstand, Poolrücklagen und aktuelle Entwicklungen in
        einer Übersicht.
      </p>
    </div>

    <section class="kpi-grid">
      <article class="kpi-card">
        <div class="kpi-card__label">Aktuelle Rücklage</div>
        <div class="kpi-card__value">{rentalPoolSummary.reserveLabel}</div>
      </article>

      <article class="kpi-card">
        <div class="kpi-card__label">Nächste Ausschüttung</div>
        <div class="kpi-card__value">{rentalPoolSummary.nextPayoutDateLabel}</div>
      </article>

      <article class="kpi-card">
        <div class="kpi-card__label">Status</div>
        <div class="kpi-card__value">{rentalPoolSummary.statusLabel}</div>
      </article>
    </section>

    <div class="stack">
      {
        rentalPoolSummary.payouts.map((payout) => (
          <article class="card card--glass card--glow">
            <div class="card__body row row--between">
              <div class="stack" style="gap: 0.4rem;">
                <div class="row">
                  <span class="badge badge--accent">{payout.statusLabel}</span>
                  <span class="badge">{payout.periodLabel}</span>
                </div>

                <h3>{payout.amountLabel}</h3>
                <p>Ausschüttung für den angegebenen Zeitraum</p>
              </div>

              <div class="row">
                <a class="button button--secondary" href={`/app/mietpool/${payout.id}`}>
                  Details
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</AppLayout>