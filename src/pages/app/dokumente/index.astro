---
import AppLayout from "../../../layouts/AppLayout.astro";
import { getUserRole } from "../../../lib/auth/user-role";
import { ROLES } from "../../../lib/constants/roles";
import { ROUTES } from "../../../lib/constants/routes";

const user = Astro.locals.user;
const role = getUserRole(user);

if (!user) {
  return Astro.redirect(ROUTES.AUTH_LOGIN);
}

const userEmail = user.email ?? null;
const organizationName =
  role === ROLES.TENANT ? "Dokumente" : "Dokumentenverwaltung";
---

<AppLayout
  title="Dokumente | ImmobilienPro"
  organizationName={organizationName}
  userEmail={userEmail}
>
  <div class="stack">
    <header class="section__header">
      <p class="section__eyebrow">Dokumente</p>
      <h2>Dokumente sicher und strukturiert verwalten</h2>
      <p>
        Verwalte Verträge, Nachweise, Abrechnungen und weitere Unterlagen
        digital an einem Ort.
      </p>
    </header>

    <section class="panel">
      <div class="panel__body stack">
        <div class="row row--between">
          <h3>Dokumentenübersicht</h3>
          <span class="badge">Ablage</span>
        </div>

        <div class="kpi-grid">
          <article class="kpi-card">
            <div class="kpi-card__label">Gespeicherte Dokumente</div>
            <div class="kpi-card__value">0</div>
          </article>

          <article class="kpi-card">
            <div class="kpi-card__label">Freigegeben</div>
            <div class="kpi-card__value">0</div>
          </article>

          <article class="kpi-card">
            <div class="kpi-card__label">Offene Zuordnungen</div>
            <div class="kpi-card__value">0</div>
          </article>
        </div>
      </div>
    </section>

    <section class="grid-auto">
      <article class="card card--glass card--glow">
        <div class="card__body stack">
          <h3>Verträge & Unterlagen</h3>
          <p>
            Halte Mietverträge, Zusatzvereinbarungen und allgemeine Dokumente
            sauber organisiert.
          </p>
        </div>
      </article>

      <article class="card card--glass card--glow">
        <div class="card__body stack">
          <h3>Freigaben für Mieter</h3>
          <p>
            Steuere, welche Dokumente im Mieterbereich sichtbar sein sollen.
          </p>
          <div class="row">
            <a href=ROUTES.APP_TENANT_HOME class="button button--secondary">
              Mieterbereich ansehen
            </a>
          </div>
        </div>
      </article>

      <article class="card card--glass card--glow">
        <div class="card__body stack">
          <h3>Verknüpfungen</h3>
          <p>
            Weise Dokumente Objekten, Einheiten, Mietern oder Vorgängen
            nachvollziehbar zu.
          </p>
          <div class="row">
            <a href="/app/objekte" class="button button--secondary">
              Zu den Objekten
            </a>
          </div>
        </div>
      </article>
    </section>
  </div>
</AppLayout>