---
import AppLayout from "../../../layouts/AppLayout.astro";
import { requireLandlordSession } from "../../../lib/auth/guards";

const session = await requireLandlordSession(Astro);

if (session instanceof Response) {
  return session;
}

const userEmail = Astro.locals.user?.email ?? null;
---

<AppLayout
  title="Objekte | ImmobilienPro"
  organizationName="Objektverwaltung"
  userEmail={userEmail}
>
  <div class="stack">
    <header class="section__header">
      <p class="section__eyebrow">Objekte</p>
      <h2>Objektbestand im Überblick</h2>
      <p>
        Verwalte Gebäude, Einheiten und zugehörige Stammdaten in einer
        strukturierten Oberfläche.
      </p>
    </header>

    <section class="panel">
      <div class="panel__body stack">
        <div class="row row--between">
          <h3>Bestandsübersicht</h3>
          <span class="badge badge--accent">Verwaltung</span>
        </div>

        <div class="kpi-grid">
          <article class="kpi-card">
            <div class="kpi-card__label">Objekte</div>
            <div class="kpi-card__value">0</div>
          </article>

          <article class="kpi-card">
            <div class="kpi-card__label">Wohneinheiten</div>
            <div class="kpi-card__value">0</div>
          </article>

          <article class="kpi-card">
            <div class="kpi-card__label">Aktive Vorgänge</div>
            <div class="kpi-card__value">0</div>
          </article>
        </div>
      </div>
    </section>

    <section class="grid-auto">
      <article class="card card--glass">
        <div class="card__body stack">
          <h3>Neues Objekt anlegen</h3>
          <p>
            Lege neue Gebäude oder Liegenschaften an und erweitere deinen
            Bestand sauber strukturiert.
          </p>
          <div class="row">
            <a href="/app/wohneinheiten" class="button button--primary">
              Weiter zu Einheiten
            </a>
          </div>
        </div>
      </article>

      <article class="card card--glass">
        <div class="card__body stack">
          <h3>Einheiten verwalten</h3>
          <p>
            Pflege Einheiten, Zuordnungen und Detailinformationen zentral an
            einem Ort.
          </p>
          <div class="row">
            <a href="/app/wohneinheiten" class="button button--secondary">
              Wohneinheiten öffnen
            </a>
          </div>
        </div>
      </article>
    </section>
  </div>
</AppLayout>