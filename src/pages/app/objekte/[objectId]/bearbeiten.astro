---
import AppLayout from "../../../../layouts/AppLayout.astro";
import { MODULE_KEYS } from "../../../../lib/constants/module-keys";
import { getAppContext } from "../../../../lib/utils/app-context";
import { getObjectDetailViewModel } from "../../../../lib/domain/objects/object-detail-service";
import { requireLandlordSession } from "../../../../lib/auth/guards";

const activeModules = [
  MODULE_KEYS.HAUSVERWALTUNG,
  MODULE_KEYS.SONDEREIGENTUM,
];

const session = await requireLandlordSession(Astro);

if (session instanceof Response) {
  return session;
}

const appContext = await getAppContext(session);
const { objectId } = Astro.params;

let objectDetail = null;

if (objectId) {
  try {
    objectDetail = await getObjectDetailViewModel(
      appContext.organizationId ?? "",
      objectId,
    );
  } catch (error) {
    console.error("Fehler beim Laden des Objekts:", error);
  }
}
---

<AppLayout
  title="Objekt bearbeiten | ImmobilienPro"
  organizationName={appContext.organizationName}
  activeModules={activeModules}
  theme={appContext.theme}
  userEmail={session.email}
>
  {
    !objectDetail ? (
      <section class="card card--glass">
        <div class="card__body stack">
          <span class="badge">Nicht gefunden</span>
          <h1>Objekt nicht gefunden</h1>
          <p>Das angeforderte Objekt konnte nicht geladen werden.</p>
          <a class="button button--primary" href="/app/objekte">
            Zurück zur Objektübersicht
          </a>
        </div>
      </section>
    ) : (
      <div class="stack">
        <div class="section__header">
          <span class="section__eyebrow">Objekt bearbeiten</span>
          <h1>{objectDetail.name}</h1>
          <p>Ändere die Stammdaten dieses Objekts.</p>
        </div>

        <section class="card card--glass">
          <div class="card__body stack">
            <form class="stack" id="object-update-form">
              <input type="hidden" name="objectId" value={objectDetail.id} />

              <div class="grid-auto">
                <div class="input-group">
                  <label class="input-label" for="name">Objektname</label>
                  <input id="name" name="name" value={objectDetail.name} />
                </div>

                <div class="input-group">
                  <label class="input-label" for="city">Ort</label>
                  <input id="city" name="city" value={objectDetail.city} />
                </div>
              </div>

              <div class="grid-auto">
                <div class="input-group">
                  <label class="input-label" for="street">Straße</label>
                  <input id="street" name="street" value={objectDetail.street ?? ""} />
                </div>

                <div class="input-group">
                  <label class="input-label" for="postalCode">PLZ</label>
                  <input id="postalCode" name="postalCode" value={objectDetail.postalCode ?? ""} />
                </div>
              </div>

              <div class="row">
                <button class="button button--primary" type="submit">
                  Änderungen speichern
                </button>
                <a class="button button--secondary" href={`/app/objekte/${objectDetail.id}`}>
                  Abbrechen
                </a>
              </div>

              <p id="object-update-status" class="form-status" aria-live="polite"></p>
            </form>
          </div>
        </section>
      </div>
    )
  }
</AppLayout>

<script>
  const form = document.querySelector("#object-update-form");
  const statusEl = document.querySelector("#object-update-status");

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const formData = new FormData(form);
    const payload = Object.fromEntries(formData.entries());

    try {
      const response = await fetch("/api/objects/update", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify(payload)
      });

      const result = await response.json();

      if (!response.ok || !result.success) {
        statusEl.textContent =
          result?.errors?.form ||
          Object.values(result?.errors || {})[0] ||
          "Objekt konnte nicht gespeichert werden.";
        return;
      }

      statusEl.textContent = "Objekt erfolgreich aktualisiert.";
      window.location.href = `/app/objekte/${payload.objectId}`;
    } catch {
      statusEl.textContent = "Beim Speichern ist ein Fehler aufgetreten.";
    }
  });
</script>

<style>
  .form-status {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }
</style>