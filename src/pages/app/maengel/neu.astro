---
import AppLayout from "../../../layouts/AppLayout.astro";
import { MODULE_KEYS } from "../../../lib/constants/module-keys";

const activeModules = [
  MODULE_KEYS.HAUSVERWALTUNG,
  MODULE_KEYS.SONDEREIGENTUM,
];
---

<AppLayout
  title="Neuer Mangel | ImmobilienPro"
  organizationName="Musterverwaltung GmbH"
  activeModules={activeModules}
>
  <div class="stack">
    <div class="section__header">
      <span class="section__eyebrow">Mängel</span>
      <h1>Neuen Mangel erfassen</h1>
      <p>
        Dokumentiere Schäden oder Störungen auf Gebäude- oder Wohneinheitsebene.
      </p>
    </div>

    <section class="card card--glass">
      <div class="card__body stack">
        <form class="stack" id="defect-create-form">
          <div class="input-group">
            <label class="input-label" for="title">Titel</label>
            <input id="title" name="title" placeholder="z. B. Heizung funktioniert nicht" />
          </div>

          <div class="grid-auto">
            <div class="input-group">
              <label class="input-label" for="level">Ebene</label>
              <select id="level" name="level">
                <option value="building">Gebäude</option>
                <option value="unit">Wohneinheit</option>
              </select>
            </div>

            <div class="input-group">
              <label class="input-label" for="status">Status</label>
              <select id="status" name="status">
                <option value="offen">Offen</option>
                <option value="in_bearbeitung">In Bearbeitung</option>
                <option value="geplant">Geplant</option>
                <option value="geschlossen">Geschlossen</option>
              </select>
            </div>
          </div>

          <div class="grid-auto">
            <div class="input-group">
              <label class="input-label" for="objectId">Objekt</label>
              <input id="objectId" name="objectId" placeholder="z. B. Musterstraße 12" />
            </div>

            <div class="input-group">
              <label class="input-label" for="unitId">Wohneinheit</label>
              <input id="unitId" name="unitId" placeholder="z. B. WE 3.2" />
            </div>
          </div>

          <div class="input-group">
            <label class="input-label" for="description">Beschreibung</label>
            <textarea
              id="description"
              name="description"
              placeholder="Beschreibe den Mangel möglichst genau"
            ></textarea>
          </div>

          <div class="row">
            <button class="button button--primary" type="submit">
              Mangel speichern
            </button>
            <a class="button button--secondary" href="/app/maengel">
              Abbrechen
            </a>
          </div>

          <p class="form-status" id="defect-form-status" aria-live="polite"></p>
        </form>
      </div>
    </section>
  </div>
</AppLayout>

<script>
  const form = document.querySelector("#defect-create-form");
  const statusEl = document.querySelector("#defect-form-status");

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const formData = new FormData(form);
    const payload = Object.fromEntries(formData.entries());

    try {
      const response = await fetch("/api/defects/create", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify(payload)
      });

      const result = await response.json();

      if (!response.ok || !result.success) {
        statusEl.textContent =
          result?.errors?.form ||
          Object.values(result?.errors || {})[0] ||
          "Mangel konnte nicht gespeichert werden.";
        return;
      }

      statusEl.textContent = "Mangel erfolgreich angelegt.";
      form.reset();
    } catch {
      statusEl.textContent = "Beim Speichern ist ein Fehler aufgetreten.";
    }
  });
</script>

<style>
  .form-status {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }
</style>