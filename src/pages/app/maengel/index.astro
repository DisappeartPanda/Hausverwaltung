---
import AppLayout from "../../../layouts/AppLayout.astro";
import { getUserRole } from "../../../lib/auth/user-role";
import { ROLES } from "../../../lib/constants/roles";
import { ROUTES } from "../../../lib/constants/routes";

const user = Astro.locals.user;
const role = getUserRole(user);

if (!user) {
  return Astro.redirect(ROUTES.AUTH_LOGIN);
}

const userEmail = user.email ?? null;
const organizationName =
  role === ROLES.TENANT ? "Mieterportal" : "Mängelmanagement";
---

<AppLayout
  title="Mängel | ImmobilienPro"
  organizationName={organizationName}
  userEmail={userEmail}
>
  <div class="stack">
    <header class="section__header">
      <p class="section__eyebrow">Mängel</p>
      <h2>Mängel und Schäden zentral erfassen</h2>
      <p>
        Behalte offene Schäden, Rückmeldungen und Folgevorgänge in einer
        strukturierten Übersicht.
      </p>
    </header>

    <section class="panel">
      <div class="panel__body stack">
        <div class="row row--between">
          <h3>Statusübersicht</h3>
          <span class="badge badge--accent">Vorgänge</span>
        </div>

        <div class="kpi-grid">
          <article class="kpi-card">
            <div class="kpi-card__label">Offen</div>
            <div class="kpi-card__value">0</div>
          </article>

          <article class="kpi-card">
            <div class="kpi-card__label">In Bearbeitung</div>
            <div class="kpi-card__value">0</div>
          </article>

          <article class="kpi-card">
            <div class="kpi-card__label">Abgeschlossen</div>
            <div class="kpi-card__value">0</div>
          </article>
        </div>
      </div>
    </section>

    <section class="grid-auto">
      <article class="card card--glass">
        <div class="card__body stack">
          <h3>Neuen Mangel erfassen</h3>
          <p>
            Dokumentiere neue Schäden, Auffälligkeiten oder technische Probleme
            direkt digital.
          </p>
          <div class="row">
            <a href="/app/wartungen" class="button button--primary">
              Folgeprozesse ansehen
            </a>
          </div>
        </div>
      </article>

      <article class="card card--glass">
        <div class="card__body stack">
          <h3>Bearbeitungsstatus</h3>
          <p>
            Behalte im Blick, welche Themen offen sind und welche bereits
            weitergeleitet wurden.
          </p>
        </div>
      </article>

      <article class="card card--glass">
        <div class="card__body stack">
          <h3>Verknüpfte Bereiche</h3>
          <p>
            Verbinde Mängel mit Einheiten, Dokumenten und technischen
            Folgevorgängen.
          </p>
          <div class="row">
            <a href="/app/dokumente" class="button button--secondary">
              Dokumente öffnen
            </a>
          </div>
        </div>
      </article>
    </section>
  </div>
</AppLayout>