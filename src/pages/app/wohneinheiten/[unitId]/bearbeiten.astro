---
import AppLayout from "../../../../layouts/AppLayout.astro";
import { getAppSession } from "../../../../lib/auth/session";
import { getAppContext } from "../../../../lib/utils/app-context";
import { getObjectListViewModel } from "../../../../lib/domain/objects/object-list-service";
import { getUnitDetailViewModel } from "../../../../lib/domain/units/unit-detail-service";

const session = await getAppSession(Astro);

if (session instanceof Response) {
  return session;
}

const appContext = await getAppContext(session);

if (!appContext.organizationId) {
  throw new Error("Keine organizationId verfügbar.");
}

const unitId = Astro.params.unitId;

if (!unitId) {
  throw new Error("Keine unitId in der Route gefunden.");
}

type ObjectListItem = Awaited<
  ReturnType<typeof getObjectListViewModel>
>[number];

let objects: ObjectListItem[] = [];

try {
  objects = await getObjectListViewModel(appContext.organizationId);
} catch (error) {
  console.error("Fehler beim Laden der Objekte:", error);
}

const unit = await getUnitDetailViewModel(unitId, appContext.organizationId);
---

<AppLayout
  title="Wohneinheit bearbeiten | ImmobilienPro"
  organizationName={appContext.organizationName}
  userEmail={session.email}
>
  <div class="stack">
    <header class="section__header">
      <p class="section__eyebrow">Wohneinheiten</p>
      <h2>Wohneinheit bearbeiten</h2>
      <p>Bearbeite Stammdaten, Status und Objektzuordnung dieser Einheit.</p>
    </header>

    <section class="card card--glass">
      <div class="card__body stack">
        <form id="unit-edit-form" class="stack">
          <input type="hidden" name="unitId" value={unit.id} />

          <div class="input-group">
            <label for="objectId" class="input-label">Objekt</label>
            <select id="objectId" name="objectId" required>
              <option value="">Bitte auswählen</option>
              {
                objects.map((object) => (
                  <option
                    value={object.id}
                    selected={object.id === unit.objectId}
                  >
                    {object.title}
                  </option>
                ))
              }
            </select>
          </div>

          <div class="input-group">
            <label for="title" class="input-label">Bezeichnung</label>
            <input
              id="title"
              name="title"
              type="text"
              value={unit.title ?? ""}
              required
            />
          </div>

          <div class="input-group">
            <label for="status" class="input-label">Status</label>
            <select id="status" name="status">
              <option value="vacant" selected={unit.status === "vacant"}>
                Leerstand
              </option>
              <option value="occupied" selected={unit.status === "occupied"}>
                Vermietet
              </option>
              <option value="reserved" selected={unit.status === "reserved"}>
                Reserviert
              </option>
            </select>
          </div>

          <div class="row">
            <button type="submit" class="button button--primary">
              Änderungen speichern
            </button>
            <a href={`/app/wohneinheiten/${unit.id}`} class="button button--secondary">
              Zurück
            </a>
          </div>
        </form>

        <div id="unit-edit-status" class="panel" hidden>
          <div class="panel__body">
            <p id="unit-edit-status-text"></p>
          </div>
        </div>
      </div>
    </section>
  </div>
</AppLayout>

<script>
  const form = document.getElementById("unit-edit-form") as HTMLFormElement | null;
  const statusWrap = document.getElementById("unit-edit-status") as HTMLElement | null;
  const statusEl = document.getElementById("unit-edit-status-text") as HTMLElement | null;

  if (!form || !statusWrap || !statusEl) {
    throw new Error("Formular oder Status-Elemente nicht gefunden.");
  }

  form.addEventListener("submit", async (event) => {
    event.preventDefault();

    const formData = new FormData(form);

    try {
      const response = await fetch("/api/units/update", {
        method: "POST",
        body: formData,
      });

      const result = await response.json().catch(() => null);

      statusWrap.hidden = false;

      if (!response.ok) {
        statusEl.textContent =
          result?.message ?? "Beim Speichern ist ein Fehler aufgetreten.";
        return;
      }

      statusEl.textContent = "Wohneinheit erfolgreich aktualisiert.";
    } catch (error) {
      console.error(error);
      statusWrap.hidden = false;
      statusEl.textContent = "Beim Speichern ist ein Fehler aufgetreten.";
    }
  });
</script>