---
import AppLayout from "../../../layouts/AppLayout.astro";
import { requireLandlordSession } from "../../../lib/auth/guards";

const session = await requireLandlordSession(Astro);

if (session instanceof Response) {
  return session;
}

const userEmail = Astro.locals.user?.email ?? null;
---

<AppLayout
  title="Wohneinheiten | ImmobilienPro"
  organizationName="Einheitenverwaltung"
  userEmail={userEmail}
>
  <div class="stack">
    <header class="section__header">
      <p class="section__eyebrow">Wohneinheiten</p>
      <h2>Einheiten strukturiert verwalten</h2>
      <p>
        Pflege Wohn- und Nutzungseinheiten mit klarer Zuordnung zu Objekten,
        Mietern und Dokumenten.
      </p>
    </header>

    <section class="panel">
      <div class="panel__body stack">
        <div class="row row--between">
          <h3>Einheitenstatus</h3>
          <span class="badge badge--accent">Bestand</span>
        </div>

        <div class="kpi-grid">
          <article class="kpi-card">
            <div class="kpi-card__label">Einheiten gesamt</div>
            <div class="kpi-card__value">0</div>
          </article>

          <article class="kpi-card">
            <div class="kpi-card__label">Vermietet</div>
            <div class="kpi-card__value">0</div>
          </article>

          <article class="kpi-card">
            <div class="kpi-card__label">Leerstand</div>
            <div class="kpi-card__value">0</div>
          </article>
        </div>
      </div>
    </section>

    <section class="grid-auto">
      <article class="card card--glass card--glow">
        <div class="card__body stack">
          <h3>Einheitenübersicht</h3>
          <p>
            Halte Flächen, Bezeichnungen, Zuordnungen und Status zentral an
            einem Ort fest.
          </p>
        </div>
      </article>

      <article class="card card--glass card--glow">
        <div class="card__body stack">
          <h3>Mieterzuordnung</h3>
          <p>
            Verknüpfe Einheiten mit Mietern, Verträgen und relevanten
            Verwaltungsdaten.
          </p>
          <div class="row">
            <a href="/app/mieter" class="button button--secondary">
              Zu den Mietern
            </a>
          </div>
        </div>
      </article>

      <article class="card card--glass card--glow">
        <div class="card__body stack">
          <h3>Objektbezug</h3>
          <p>
            Ordne Einheiten sauber ihren Gebäuden und Verwaltungsbereichen zu.
          </p>
          <div class="row">
            <a href="/app/objekte" class="button button--secondary">
              Zu den Objekten
            </a>
          </div>
        </div>
      </article>
    </section>
  </div>
</AppLayout>