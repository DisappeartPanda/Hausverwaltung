---
import AppLayout from "../../../layouts/AppLayout.astro";
import { MODULE_KEYS } from "../../../lib/constants/module-keys";
import { getAppContext } from "../../../lib/utils/app-context";
import { getUnitListViewModel } from "../../../lib/domain/units/unit-service";
import { requireLandlordSession } from "../../../lib/auth/guards";

const activeModules = [MODULE_KEYS.SONDEREIGENTUM];

const session = await requireLandlordSession(Astro);

if (session instanceof Response) {
  return session;
}

const appContext = await getAppContext(session);

let units = [];

try {
  units = await getUnitListViewModel(appContext.organizationId);
} catch (error) {
  console.error("Fehler beim Laden der Wohneinheiten:", error);
}
---

<AppLayout
  title="Wohneinheiten | ImmobilienPro"
  organizationName={appContext.organizationName}
  activeModules={activeModules}
  theme={appContext.theme}
  userEmail={session.email}
>
  <div class="stack">
    <div class="row row--between">
      <div class="section__header">
        <span class="section__eyebrow">Wohneinheiten</span>
        <h1>Alle Wohneinheiten im Überblick</h1>
        <p>
          Verwalte Einheiten, Belegung, Leerstand und Mieterzuordnung zentral an
          einem Ort.
        </p>
      </div>

      <a class="button button--primary" href="/app/wohneinheiten/neu">
        Einheit anlegen
      </a>
    </div>

    {
      units.length === 0 ? (
        <section class="card card--glass">
          <div class="card__body stack">
            <span class="badge">Noch keine Wohneinheiten</span>
            <h3>Lege deine erste Wohneinheit an</h3>
            <p>
              Neue Einheiten erscheinen hier automatisch, sobald sie gespeichert wurden.
            </p>
            <a class="button button--primary" href="/app/wohneinheiten/neu">
              Erste Einheit anlegen
            </a>
          </div>
        </section>
      ) : (
        <div class="stack">
          {
            units.map((unit) => (
              <article class="card card--glass card--glow">
                <div class="card__body row row--between">
                  <div class="stack" style="gap: 0.4rem;">
                    <div class="row">
                      <span class="badge badge--accent">{unit.statusLabel}</span>
                      <span class="badge">{unit.objectLabel}</span>
                    </div>

                    <h3>{unit.title}</h3>
                    <p>{unit.tenantLabel}</p>
                  </div>

                  <div class="row">
                    <a class="button button--secondary" href={`/app/wohneinheiten/${unit.id}`}>
                      Details
                    </a>
                    <a class="button button--ghost" href={`/app/wohneinheiten/${unit.id}/bearbeiten`}>
                      Bearbeiten
                    </a>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      )
    }
  </div>
</AppLayout>