---
import AppLayout from "../../../layouts/AppLayout.astro";
import { getAppSession } from "../../../lib/auth/session";
import { getAppContext } from "../../../lib/utils/app-context";
import { getObjectListViewModel, type ObjectListItem } from "../../../lib/domain/objects/object-list-service";

const sessionResult = await getAppSession(Astro);

if (sessionResult instanceof Response) {
  return sessionResult;
}

const session = sessionResult;
const appContext = await getAppContext(session);

if (!appContext.organizationId) {
  throw new Error("Keine organizationId verfügbar.");
}

let objects: ObjectListItem[] = [];

try {
  objects = await getObjectListViewModel(appContext.organizationId);
} catch (error) {
  console.error("Fehler beim Laden der Objekte:", error);
}
---

<AppLayout
  title="Neue Wohneinheit | ImmobilienPro"
  organizationName={appContext.organizationName}
  userEmail={session.email}
>
  <div class="stack">
    <header class="section__header">
      <p class="section__eyebrow">Wohneinheiten</p>
      <h2>Neue Wohneinheit anlegen</h2>
      <p>
        Erfasse eine neue Wohneinheit und ordne sie einem bestehenden Objekt zu.
      </p>
    </header>

    <section class="card card--glass">
      <div class="card__body stack">
        <form id="unit-form" class="stack">
          <div class="input-group">
            <label for="objectId" class="input-label">Objekt</label>
            <select id="objectId" name="objectId" required>
              <option value="">Bitte auswählen</option>
              {
                objects.map((object) => (
                  <option value={object.id}>{object.title}</option>
                ))
              }
            </select>
          </div>

          <div class="input-group">
            <label for="title" class="input-label">Bezeichnung</label>
            <input id="title" name="title" type="text" required />
          </div>

          <div class="input-group">
            <label for="status" class="input-label">Status</label>
            <select id="status" name="status">
              <option value="frei">Leerstand</option>
              <option value="vermietet">Vermietet</option>
              <option value="reserviert">Reserviert</option>
            </select>
          </div>

          <div class="row">
            <button type="submit" class="button button--primary">
              Wohneinheit speichern
            </button>
            <a href="/app/wohneinheiten" class="button button--secondary">
              Abbrechen
            </a>
          </div>
        </form>

        <div id="unit-form-status" class="panel" hidden>
          <div class="panel__body">
            <p id="unit-form-status-text"></p>
          </div>
        </div>
      </div>
    </section>
  </div>
</AppLayout>

<script>
  const form = document.getElementById("unit-form") as HTMLFormElement | null;
  const statusWrap = document.getElementById("unit-form-status") as HTMLElement | null;
  const statusEl = document.getElementById("unit-form-status-text") as HTMLElement | null;

  if (!form || !statusWrap || !statusEl) {
    throw new Error("Formular oder Status-Elemente nicht gefunden.");
  }

  form.addEventListener("submit", async (event) => {
    event.preventDefault();

    const formData = new FormData(form);

    try {
      const response = await fetch("/api/units/create", {
        method: "POST",
        body: formData,
      });

      const result = await response.json().catch(() => null);

      statusWrap.hidden = false;

      if (!response.ok) {
        statusEl.textContent =
          result?.message ?? "Beim Speichern ist ein Fehler aufgetreten.";
        return;
      }

      statusEl.textContent = "Wohneinheit erfolgreich angelegt.";
      form.reset();
    } catch (error) {
      console.error(error);
      statusWrap.hidden = false;
      statusEl.textContent = "Beim Speichern ist ein Fehler aufgetreten.";
    }
  });
</script>