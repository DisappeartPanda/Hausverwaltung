---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Registrieren">
  <div class="min-h-screen flex items-center justify-center bg-gray-50">
    <div class="max-w-md w-full space-y-8 p-8 bg-white rounded-lg shadow-md">
      <h2 class="text-3xl font-bold text-center text-gray-900">Registrieren</h2>
      
      <form id="register-form" class="space-y-6">
        <div>
          <label class="block text-sm font-medium text-gray-700">E-Mail</label>
          <input name="email" type="email" required class="mt-1 block w-full px-3 py-2 border rounded-md" />
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700">Passwort (min. 6 Zeichen)</label>
          <input name="password" type="password" required minlength="6" class="mt-1 block w-full px-3 py-2 border rounded-md" />
        </div>
        
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700">Vorname</label>
            <input name="vorname" type="text" required class="mt-1 block w-full px-3 py-2 border rounded-md" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Nachname</label>
            <input name="nachname" type="text" required class="mt-1 block w-full px-3 py-2 border rounded-md" />
          </div>
        </div>
        
        <button type="submit" id="submit-btn" class="w-full py-2 px-4 bg-blue-600 text-white rounded hover:bg-blue-700 disabled:opacity-50">
          <span id="btn-text">Konto erstellen</span>
          <span id="btn-loading" class="hidden">Wird erstellt...</span>
        </button>
      </form>
      
      <div id="error-message" class="hidden text-red-600 text-center text-sm"></div>
      <div id="success-message" class="hidden text-green-600 text-center text-sm"></div>
      
      <p class="text-center text-sm">
        Bereits registriert? <a href="/login" class="text-blue-600">Anmelden</a>
      </p>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabase';
  
  const form = document.getElementById('register-form');
  const errorMsg = document.getElementById('error-message');
  const successMsg = document.getElementById('success-message');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text');
  const btnLoading = document.getElementById('btn-loading');
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    submitBtn.disabled = true;
    btnText!.classList.add('hidden');
    btnLoading!.classList.remove('hidden');
    errorMsg!.classList.add('hidden');
    successMsg!.classList.add('hidden');
    
    const formData = new FormData(e.target as HTMLFormElement);
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;
    const vorname = formData.get('vorname') as string;
    const nachname = formData.get('nachname') as string;
    
    // 1. User in Auth erstellen
    const { data: authData, error: authError } = await supabase.auth.signUp({
      email,
      password,
    });
    
    if (authError) {
      errorMsg!.textContent = authError.message;
      errorMsg!.classList.remove('hidden');
      submitBtn.disabled = false;
      btnText!.classList.remove('hidden');
      btnLoading!.classList.add('hidden');
      return;
    }
    
    if (authData.user) {
      // 2. Vermieter-Datensatz anlegen
      const { error: dbError } = await supabase
        .from('vermieter')
        .insert({
          user_id: authData.user.id,
          vorname,
          nachname,
          email,
          strasse: '',
          plz: '',
          stadt: ''
        });
      
      if (dbError) {
        errorMsg!.textContent = 'Account erstellt, aber Fehler beim Profil. Bitte kontaktieren Sie uns.';
        errorMsg!.classList.remove('hidden');
        return;
      }
      
      successMsg!.textContent = 'Registrierung erfolgreich! Bitte bestätigen Sie Ihre E-Mail (falls aktiviert) und melden sich an.';
      successMsg!.classList.remove('hidden');
      
      setTimeout(() => {
        window.location.href = '/login';
      }, 3000);
    }
  });
</script>