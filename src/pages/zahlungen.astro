---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Zahlungen">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Mietzahlungen</h1>
    <a href="/zahlungen/neu" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm">
      + Zahlung erfassen
    </a>
  </div>
  
  <!-- Monatsfilter -->
  <div class="mb-6 flex gap-4">
    <input type="month" id="monat-filter" class="px-4 py-2 border rounded-md" />
    <select id="status-filter" class="px-4 py-2 border rounded-md">
      <option value="">Alle Status</option>
      <option value="offen">Offen</option>
      <option value="eingegangen">Eingegangen</option>
      <option value="ueberfaellig">Überfällig</option>
    </select>
  </div>
  
  <div id="loading" class="text-center py-8">Laden...</div>
  
  <div id="zahlungen-liste" class="bg-white rounded-lg shadow overflow-hidden hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Monat</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Mieter</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Betrag</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Aktionen</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200" id="zahlungen-tbody"></tbody>
    </table>
  </div>
</DashboardLayout>

<script>
  import { supabase } from '../lib/supabase';
  
  const loadZahlungen = async () => {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return;
    
    const { data: zahlungen } = await supabase
      .from('mietzahlungen')
      .select(`
        *,
        mietvertraege (
          mieter (vorname, nachname),
          wohneinheiten (bezeichnung)
        )
      `)
      .order('zahlungsmonat', { ascending: false })
      .limit(50);
    
    document.getElementById('loading')!.classList.add('hidden');
    
    if (!zahlungen || zahlungen.length === 0) {
      document.getElementById('zahlungen-liste')!.innerHTML = 
        '<div class="p-8 text-center text-gray-500">Keine Zahlungen vorhanden.</div>';
      document.getElementById('zahlungen-liste')!.classList.remove('hidden');
      return;
    }
    
    renderZahlungen(zahlungen);
    
    // Filter-Handler
    document.getElementById('monat-filter')?.addEventListener('change', filterZahlungen);
    document.getElementById('status-filter')?.addEventListener('change', filterZahlungen);
  };
  
  const renderZahlungen = (zahlungen: any[]) => {
    const tbody = document.getElementById('zahlungen-tbody')!;
    document.getElementById('zahlungen-liste')!.classList.remove('hidden');
    tbody.innerHTML = '';
    
    const statusColors = {
      offen: 'bg-yellow-100 text-yellow-800',
      eingegangen: 'bg-green-100 text-green-800',
      teileingang: 'bg-blue-100 text-blue-800',
      ueberfaellig: 'bg-red-100 text-red-800',
      storniert: 'bg-gray-100 text-gray-800'
    };
    
    zahlungen.forEach(z => {
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
          ${new Date(z.zahlungsmonat).toLocaleDateString('de-DE', {month: 'long', year: 'numeric'})}
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
          ${z.mietvertraege.mieter.nachname}, ${z.mietvertraege.mieter.vorname}
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
          ${z.betrag.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}
        </td>
        <td class="px-6 py-4 whitespace-nowrap">
          <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full ${statusColors[z.status as keyof typeof statusColors]}">
            ${z.status}
          </span>
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
          ${z.status === 'offen' 
            ? `<button onclick="markiereBezahlt('${z.id}')" class="text-green-600 hover:text-green-900">Als bezahlt markieren</button>`
            : `<span class="text-gray-400">-</span>`
          }
        </td>
      `;
      tbody.appendChild(tr);
    });
  };
  
  const filterZahlungen = async () => {
    const monat = (document.getElementById('monat-filter') as HTMLInputElement).value;
    const status = (document.getElementById('status-filter') as HTMLSelectElement).value;
    
    let query = supabase
      .from('mietzahlungen')
      .select(`
        *,
        mietvertraege (
          mieter (vorname, nachname),
          wohneinheiten (bezeichnung)
        )
      `);
    
    if (monat) {
      query = query.gte('zahlungsmonat', `${monat}-01`).lte('zahlungsmonat', `${monat}-31`);
    }
    
    if (status) {
      query = query.eq('status', status);
    }
    
    const { data } = await query.order('zahlungsmonat', { ascending: false });
    renderZahlungen(data || []);
  };
  
  // @ts-ignore
  window.markiereBezahlt = async (id: string) => {
    const heute = new Date().toISOString().split('T')[0];
    
    const { error } = await supabase
      .from('mietzahlungen')
      .update({ 
        status: 'eingegangen',
        zahlungsdatum: heute
      })
      .eq('id', id);
    
    if (!error) {
      loadZahlungen();
    }
  };
  
  loadZahlungen();
</script>