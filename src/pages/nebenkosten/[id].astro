---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

const { id } = Astro.params;

// Demo-Daten (später aus DB)
const abrechnung = {
  id: id,
  jahr: 2024,
  objekt: { bezeichnung: 'Musterstraße 1', adresse: 'Musterstraße 1, 12345 Berlin' },
  zeitraum: { von: '2024-01-01', bis: '2024-12-31' },
  mieter: { name: 'Max Mustermann', einheit: 'Wohnung 1. OG links', flaeche: 85 },
  kosten: {
    heizung: 4500.00,
    warmwasser: 800.00,
    wasser: 600.00,
    entsorgung: 400.00,
    gebaeudereinigung: 1200.00,
    gartenpflege: 800.00,
    versicherung: 900.00,
    strom: 600.00,
    grundsteuer: 1500.00,
    sonstiges: 200.00
  },
  vorauszahlungen: 4200.00,
  status: 'entwurf',
  erstellt_am: '2025-01-15'
};

const gesamtkosten = Object.values(abrechnung.kosten).reduce((a, b) => a + b, 0);
const mieterAnteil = gesamtkosten * (abrechnung.mieter.flaeche / 350); // Annahme: 350m² Gesamtfläche
const differenz = mieterAnteil - abrechnung.vorauszahlungen;
---

<DashboardLayout title={`Nebenkostenabrechnung ${abrechnung.jahr}`}>
  <div class="mb-6">
    <a href="/nebenkosten" class="text-gray-600 hover:text-gray-800 text-sm">← Zurück zu Übersicht</a>
  </div>
  
  <!-- Header -->
  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <div class="flex justify-between items-start">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Nebenkostenabrechnung {abrechnung.jahr}</h1>
        <p class="text-gray-600 mt-1">{abrechnung.objekt.bezeichnung}</p>
        <p class="text-sm text-gray-500">{abrechnung.objekt.adresse}</p>
      </div>
      <span class={`px-3 py-1 rounded-full text-sm font-medium ${
        abrechnung.status === 'abgeschlossen' ? 'bg-green-100 text-green-800' :
        abrechnung.status === 'versendet' ? 'bg-blue-100 text-blue-800' :
        'bg-gray-100 text-gray-800'
      }`}>
        {abrechnung.status === 'entwurf' ? 'Entwurf' : 
         abrechnung.status === 'versendet' ? 'Versendet' : 'Abgeschlossen'}
      </span>
    </div>
    
    <div class="mt-4 pt-4 border-t grid grid-cols-3 gap-4 text-sm">
      <div>
        <span class="text-gray-500">Abrechnungszeitraum:</span>
        <p class="font-medium">{new Date(abrechnung.zeitraum.von).toLocaleDateString('de-DE')} - {new Date(abrechnung.zeitraum.bis).toLocaleDateString('de-DE')}</p>
      </div>
      <div>
        <span class="text-gray-500">Mieter:</span>
        <p class="font-medium">{abrechnung.mieter.name}</p>
        <p class="text-gray-600">{abrechnung.mieter.einheit}</p>
      </div>
      <div>
        <span class="text-gray-500">Wohnfläche:</span>
        <p class="font-medium">{abrechnung.mieter.flaeche} m²</p>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Kostenübersicht -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Warme Kosten -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-lg font-semibold mb-4 flex items-center">
          <span class="w-3 h-3 bg-orange-500 rounded-full mr-2"></span>
          Warme Betriebskosten (Verbrauchsbasiert)
        </h2>
        <table class="w-full text-sm">
          <tbody class="divide-y divide-gray-200">
            <tr>
              <td class="py-3 text-gray-600">Heizung (Brennstoffe, Wartung, Betriebsstrom)</td>
              <td class="py-3 text-right font-medium">{abrechnung.kosten.heizung.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</td>
              <td class="py-3 text-right text-sm text-gray-500">50% Verbrauch / 50% Fläche</td>
            </tr>
            <tr>
              <td class="py-3 text-gray-600">Warmwasser</td>
              <td class="py-3 text-right font-medium">{abrechnung.kosten.warmwasser.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</td>
              <td class="py-3 text-right text-sm text-gray-500">Nach Verbrauch</td>
            </tr>
            <tr class="bg-orange-50 font-medium">
              <td class="py-3">Summe warme Kosten</td>
              <td class="py-3 text-right">{(abrechnung.kosten.heizung + abrechnung.kosten.warmwasser).toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</td>
              <td></td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Kalte verbrauchsabhängige Kosten -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-lg font-semibold mb-4 flex items-center">
          <span class="w-3 h-3 bg-blue-500 rounded-full mr-2"></span>
          Kalte verbrauchsabhängige Kosten
        </h2>
        <table class="w-full text-sm">
          <tbody class="divide-y divide-gray-200">
            <tr>
              <td class="py-3 text-gray-600">Wasser/Abwasser</td>
              <td class="py-3 text-right font-medium">{abrechnung.kosten.wasser.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</td>
              <td class="py-3 text-right text-sm text-gray-500">Nach Verbrauch (Zähler)</td>
            </tr>
            <tr>
              <td class="py-3 text-gray-600">Strom (Flur/Treppenhaus)</td>
              <td class="py-3 text-right font-medium">{abrechnung.kosten.strom.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</td>
              <td class="py-3 text-right text-sm text-gray-500">Nach Fläche</td>
            </tr>
            <tr class="bg-blue-50 font-medium">
              <td class="py-3">Summe kalte Verbrauchskosten</td>
              <td class="py-3 text-right">{(abrechnung.kosten.wasser + abrechnung.kosten.strom).toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</td>
              <td></td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Kalte verbrauchsunabhängige Kosten -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-lg font-semibold mb-4 flex items-center">
          <span class="w-3 h-3 bg-green-500 rounded-full mr-2"></span>
          Kalte verbrauchsunabhängige Kosten
        </h2>
        <table class="w-full text-sm">
          <tbody class="divide-y divide-gray-200">
            <tr>
              <td class="py-3 text-gray-600">Grundsteuer</td>
              <td class="py-3 text-right font-medium">{abrechnung.kosten.grundsteuer.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</td>
              <td class="py-3 text-right text-sm text-gray-500">Nach Fläche</td>
            </tr>
            <tr>
              <td class="py-3 text-gray-600">Gebäudeversicherung</td>
              <td class="py-3 text-right font-medium">{abrechnung.kosten.versicherung.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</td>
              <td class="py-3 text-right text-sm text-gray-500">Nach Fläche</td>
            </tr>
            <tr>
              <td class="py-3 text-gray-600">Müllabfuhr/Straßenreinigung</td>
              <td class="py-3 text-right font-medium">{abrechnung.kosten.entsorgung.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</td>
              <td class="py-3 text-right text-sm text-gray-500">Nach Fläche</td>
            </tr>
            <tr>
              <td class="py-3 text-gray-600">Gebäudereinigung</td>
              <td class="py-3 text-right font-medium">{abrechnung.kosten.gebaeudereinigung.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</td>
              <td class="py-3 text-right text-sm text-gray-500">Nach Fläche</td>
            </tr>
            <tr>
              <td class="py-3 text-gray-600">Gartenpflege</td>
              <td class="py-3 text-right font-medium">{abrechnung.kosten.gartenpflege.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</td>
              <td class="py-3 text-right text-sm text-gray-500">Nach Fläche</td>
            </tr>
            <tr>
              <td class="py-3 text-gray-600">Sonstiges</td>
              <td class="py-3 text-right font-medium">{abrechnung.kosten.sonstiges.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</td>
              <td class="py-3 text-right text-sm text-gray-500">Nach Fläche</td>
            </tr>
            <tr class="bg-green-50 font-medium">
              <td class="py-3">Summe kalte Fixkosten</td>
              <td class="py-3 text-right">{(abrechnung.kosten.grundsteuer + abrechnung.kosten.versicherung + abrechnung.kosten.entsorgung + abrechnung.kosten.gebaeudereinigung + abrechnung.kosten.gartenpflege + abrechnung.kosten.sonstiges).toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</td>
              <td></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Zusammenfassung & Ergebnis -->
    <div class="space-y-6">
      <!-- Gesamtkosten -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-lg font-semibold mb-4">Gesamtkosten Objekt</h2>
        <div class="space-y-3">
          <div class="flex justify-between text-sm">
            <span class="text-gray-600">Warme Kosten:</span>
            <span class="font-medium">{(abrechnung.kosten.heizung + abrechnung.kosten.warmwasser).toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-gray-600">Kalte Verbrauchskosten:</span>
            <span class="font-medium">{(abrechnung.kosten.wasser + abrechnung.kosten.strom).toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-gray-600">Kalte Fixkosten:</span>
            <span class="font-medium">{(abrechnung.kosten.grundsteuer + abrechnung.kosten.versicherung + abrechnung.kosten.entsorgung + abrechnung.kosten.gebaeudereinigung + abrechnung.kosten.gartenpflege + abrechnung.kosten.sonstiges).toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</span>
          </div>
          <div class="border-t pt-3 flex justify-between text-lg font-bold">
            <span>Gesamt:</span>
            <span class="text-blue-900">{gesamtkosten.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</span>
          </div>
        </div>
      </div>

      <!-- Mieter-Anteil -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-lg font-semibold mb-4">Berechnung Mieter-Anteil</h2>
        <div class="space-y-3 text-sm">
          <div class="flex justify-between">
            <span class="text-gray-600">Anteil Heizung/Warmwasser (50% Verbrauch/50% Fläche):</span>
            <span class="font-medium">{(mieterAnteil * 0.4).toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">Anteil Wasser/Strom (Verbrauch):</span>
            <span class="font-medium">{(mieterAnteil * 0.2).toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">Anteil Fixkosten (Fläche):</span>
            <span class="font-medium">{(mieterAnteil * 0.4).toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</span>
          </div>
          <div class="border-t pt-3 flex justify-between text-lg font-bold">
            <span>Ihr Anteil:</span>
            <span class="text-blue-900">{mieterAnteil.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</span>
          </div>
        </div>
      </div>

      <!-- Ergebnis -->
      <div class={`rounded-lg shadow p-6 ${differenz >= 0 ? 'bg-red-50 border border-red-200' : 'bg-green-50 border border-green-200'}`}>
        <h2 class="text-lg font-semibold mb-4">Ergebnis</h2>
        <div class="space-y-3">
          <div class="flex justify-between text-sm">
            <span class="text-gray-600">Vorauszahlungen {abrechnung.jahr}:</span>
            <span class="font-medium">{abrechnung.vorauszahlungen.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-gray-600">Tatsächliche Kosten:</span>
            <span class="font-medium">{mieterAnteil.toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}</span>
          </div>
          <div class="border-t pt-3 flex justify-between text-xl font-bold">
            <span>{differenz >= 0 ? 'Nachzahlung:' : 'Gutschrift:'}</span>
            <span class={differenz >= 0 ? 'text-red-700' : 'text-green-700'}>
              {Math.abs(differenz).toLocaleString('de-DE', {style: 'currency', currency: 'EUR'})}
            </span>
          </div>
        </div>
        {differenz > 0 && (
          <div class="mt-4 p-3 bg-white rounded text-sm text-red-800">
            <p>⚠️ Bitte überweisen Sie den Betrag innerhalb von 14 Tagen.</p>
          </div>
        )}
      </div>

      <!-- In src/pages/nebenkosten/[id].astro -->
<div class="flex gap-2">
  <a href={`/api/nebenkosten/${id}/pdf`} 
     class="bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-red-700 flex items-center gap-2"
     target="_blank">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
    </svg>
    PDF Export
  </a>
  <!-- ... andere Buttons ... -->
</div>

      <!-- Aktionen -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-lg font-semibold mb-4">Aktionen</h2>
        <div class="space-y-2">
          <button onclick="window.print()" class="w-full px-4 py-2 bg-gray-100 text-gray-700 rounded hover:bg-gray-200 text-sm text-left">
            🖨️ Abrechnung drucken
          </button>
          <button onclick="alert('PDF wird generiert...')" class="w-full px-4 py-2 bg-gray-100 text-gray-700 rounded hover:bg-gray-200 text-sm text-left">
            📄 Als PDF speichern
          </button>
          <button onclick="alert('Per E-Mail versenden...')" class="w-full px-4 py-2 bg-blue-100 text-blue-700 rounded hover:bg-blue-200 text-sm text-left">
            📧 An Mieter senden
          </button>
          {abrechnung.status === 'entwurf' && (
            <button onclick="alert('Abrechnung freigeben...')" class="w-full px-4 py-2 bg-green-100 text-green-700 rounded hover:bg-green-200 text-sm text-left">
              ✅ Als versendet markieren
            </button>
          )}
        </div>
      </div>

      <!-- Rechtliche Hinweise -->
      <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 text-xs text-yellow-800">
        <h3 class="font-bold mb-2">⚖️ Rechtliche Hinweise:</h3>
        <ul class="list-disc pl-4 space-y-1">
          <li>Abrechnung erstellt am: {new Date(abrechnung.erstellt_am).toLocaleDateString('de-DE')}</li>
          <li>Frist für Widerspruch: 12 Monate nach Erhalt</li>
          <li>Aufbewahrungspflicht: 6 Jahre (Steuer)</li>
          <li>Belege auf Anfrage einsehbar</li>
        </ul>
      </div>
    </div>
  </div>
</DashboardLayout>