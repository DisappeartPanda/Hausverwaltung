---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { supabase } from '../../lib/supabase/supabase';

const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

// Filter-Parameter
const statusFilter = Astro.url.searchParams.get('status') || 'alle';
const jahrFilter = Astro.url.searchParams.get('jahr') || new Date().getFullYear().toString();

// Objekte laden
const { data: objekte } = await supabase
  .from('objekte')
  .select('id, bezeichnung')
  .eq('vermieter_id', session.user.id);

const objektIds = objekte?.map(o => o.id) || [];

// Abrechnungen mit Summen laden
let query = supabase
  .from('nebenkostenabrechnungen')
  .select(`
    *,
    objekte(bezeichnung, adresse),
    nebenkosten_positionen(kostenart, betrag)
  `)
  .in('objekt_id', objektIds)
  .eq('abrechnungsjahr', parseInt(jahrFilter))
  .order('erstellt_am', { ascending: false });

if (statusFilter !== 'alle') {
  query = query.eq('status', statusFilter);
}

const { data: abrechnungen } = await query;

// Berechne Summen pro Abrechnung
const abrechnungenMitSummen = abrechnungen?.map(a => ({
  ...a,
  gesamtkosten: a.nebenkosten_positionen?.reduce((sum, p) => sum + (p.betrag || 0), 0) || 0
}));

// Statistiken
const { data: offeneAbrechnungen } = await supabase
  .from('nebenkostenabrechnungen')
  .select('id')
  .in('objekt_id', objektIds)
  .eq('status', 'Entwurf');

const verfuegbareJahre = Array.from({length: 5}, (_, i) => new Date().getFullYear() - i);
---

<DashboardLayout title="Nebenkostenabrechnungen">
  <div class="space-y-6">
    <!-- Header -->
    <div class="flex justify-between items-center">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Nebenkostenabrechnungen</h1>
        <p class="text-gray-600">{offeneAbrechnungen?.length || 0} offene Abrechnungen</p>
      </div>
      <a href="/nebenkosten/neu" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
        + Neue Abrechnung
      </a>
    </div>

    <!-- Filter -->
    <div class="bg-white p-4 rounded-lg shadow flex gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Jahr</label>
        <select id="jahrFilter" class="border rounded-lg px-3 py-2" onchange="updateFilter()">
          {verfuegbareJahre.map(jahr => (
            <option value={jahr} selected={jahr.toString() === jahrFilter}>{jahr}</option>
          ))}
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
        <select id="statusFilter" class="border rounded-lg px-3 py-2" onchange="updateFilter()">
          <option value="alle" selected={statusFilter === 'alle'}>Alle</option>
          <option value="Entwurf" selected={statusFilter === 'Entwurf'}>Entwurf</option>
          <option value="Versendet" selected={statusFilter === 'Versendet'}>Versendet</option>
          <option value="Abgeschlossen" selected={statusFilter === 'Abgeschlossen'}>Abgeschlossen</option>
        </select>
      </div>
    </div>

    <!-- Tabelle -->
    <div class="bg-white rounded-lg shadow overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Objekt</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Zeitraum</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Gesamtkosten</th>
            <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Aktionen</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          {abrechnungenMitSummen?.map(a => (
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4">
                <p class="font-medium text-gray-900">{a.objekte.bezeichnung}</p>
                <p class="text-sm text-gray-500">{a.objekte.adresse}</p>
              </td>
              <td class="px-6 py-4 text-sm text-gray-600">
                {new Date(a.zeitraum_von).toLocaleDateString('de-DE')} - {new Date(a.zeitraum_bis).toLocaleDateString('de-DE')}
              </td>
              <td class="px-6 py-4 text-right font-medium">
                {a.gesamtkosten.toLocaleString('de-DE')} €
              </td>
              <td class="px-6 py-4 text-center">
                <span class={`inline-flex px-2 py-1 text-xs font-semibold rounded-full ${
                  a.status === 'Abgeschlossen' ? 'bg-green-100 text-green-800' :
                  a.status === 'Versendet' ? 'bg-blue-100 text-blue-800' :
                  'bg-gray-100 text-gray-800'
                }`}>
                  {a.status}
                </span>
              </td>
              <td class="px-6 py-4 text-right space-x-2">
                <a href={`/nebenkosten/${a.id}`} class="text-blue-600 hover:text-blue-900">Details</a>
                {a.status === 'Entwurf' && (
                  <a href={`/nebenkosten/${a.id}/bearbeiten`} class="text-gray-600 hover:text-gray-900">Bearbeiten</a>
                )}
              </td>
            </tr>
          ))}
          {(!abrechnungenMitSummen || abrechnungenMitSummen.length === 0) && (
            <tr>
              <td colspan="5" class="px-6 py-8 text-center text-gray-500">
                Keine Abrechnungen für {jahrFilter} gefunden
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </div>

  <script>
    function updateFilter() {
      const jahr = document.getElementById('jahrFilter').value;
      const status = document.getElementById('statusFilter').value;
      window.location.href = `/nebenkosten?jahr=${jahr}&status=${status}`;
    }
  </script>
</DashboardLayout>