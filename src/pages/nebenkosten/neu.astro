---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { supabase } from '../../lib/supabase/supabase';

const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

const { data: objekte } = await supabase
  .from('objekte')
  .select('id, bezeichnung, adresse, wohneinheiten(id, bezeichnung, wohnflaeche_m2)')
  .eq('vermieter_id', session.user.id);

const kostenarten = [
  { id: 'heizung', name: 'Heizung', warm: true, defaultVerteilung: 'verbrauch' },
  { id: 'warmwasser', name: 'Warmwasser', warm: true, defaultVerteilung: 'verbrauch' },
  { id: 'wasser', name: 'Wasser (Kalt)', warm: false, defaultVerteilung: 'verbrauch' },
  { id: 'entsorgung', name: 'Entsorgung', warm: false, defaultVerteilung: 'flaeche' },
  { id: 'gebaeudereinigung', name: 'Gebäudereinigung', warm: false, defaultVerteilung: 'flaeche' },
  { id: 'gartenpflege', name: 'Gartenpflege', warm: false, defaultVerteilung: 'flaeche' },
  { id: 'versicherung', name: 'Versicherung', warm: false, defaultVerteilung: 'flaeche' },
  { id: 'strom', name: 'Strom (Flur)', warm: false, defaultVerteilung: 'flaeche' },
  { id: 'grundsteuer', name: 'Grundsteuer', warm: false, defaultVerteilung: 'flaeche' },
  { id: 'sonstiges', name: 'Sonstiges', warm: false, defaultVerteilung: 'flaeche' },
];

const aktuellesJahr = new Date().getFullYear();
const letztesJahr = aktuellesJahr - 1;
---

<DashboardLayout title="Neue Nebenkostenabrechnung">
  <div class="max-w-4xl mx-auto">
    <h1 class="text-2xl font-bold text-gray-900 mb-2">Neue Nebenkostenabrechnung</h1>
    <p class="text-gray-600 mb-6">Abrechnungsjahr {letztesJahr} (01.01.{letztesJahr} - 31.12.{letztesJahr})</p>

    <form action="/api/nebenkosten/neu" method="POST" class="space-y-6" id="nebenkostenForm">
      <input type="hidden" name="abrechnungsjahr" value={letztesJahr} />
      <input type="hidden" name="zeitraum_von" value={`${letztesJahr}-01-01`} />
      <input type="hidden" name="zeitraum_bis" value={`${letztesJahr}-12-31`} />

      <!-- Objekt -->
      <div class="bg-white rounded-lg shadow p-6">
        <label class="block text-sm font-medium text-gray-700 mb-1">Objekt *</label>
        <select name="objekt_id" id="objektSelect" required class="w-full border rounded-lg px-3 py-2">
          <option value="">Bitte wählen...</option>
          {objekte?.map(o => (
            <option value={o.id} data-wohnflaeche={o.wohneinheiten?.reduce((sum, w) => sum + (w.wohnflaeche_m2 || 0), 0)}>
              {o.bezeichnung} - {o.adresse} ({o.wohneinheiten?.length || 0} WE)
            </option>
          ))}
        </select>
      </div>

      <!-- Kostenpositionen -->
      <div class="bg-white rounded-lg shadow p-6">
        <div class="flex justify-between items-center mb-4">
          <h2 class="font-semibold text-gray-900">Kostenpositionen</h2>
          <div class="text-sm text-gray-600">
            Gesamtkosten: <span id="gesamtsumme" class="font-bold text-lg">0,00 €</span>
          </div>
        </div>

        <div class="space-y-3" id="kostenContainer">
          {kostenarten.map((k, index) => (
            <div class="grid grid-cols-12 gap-3 items-center p-3 bg-gray-50 rounded-lg kosten-zeile" data-warm={k.warm}>
              <div class="col-span-3">
                <span class="font-medium text-sm">{k.name}</span>
                {k.warm && <span class="text-xs text-orange-600 ml-1">(warm)</span>}
              </div>
              <div class="col-span-3">
                <input type="number" 
                       name={`positionen[${index}][betrag]`} 
                       step="0.01" 
                       min="0" 
                       placeholder="0,00"
                       class="w-full border rounded px-3 py-2 betrag-input"
                       data-kostenart={k.name}
                       oninput="berechneSumme()" />
              </div>
              <div class="col-span-3">
                <select name={`positionen[${index}][verteilung]`} class="w-full border rounded px-3 py-2 text-sm">
                  <option value="flaeche" selected={k.defaultVerteilung === 'flaeche'}>nach Fläche</option>
                  <option value="verbrauch" selected={k.defaultVerteilung === 'verbrauch'}>nach Verbrauch</option>
                  <option value="anteil">Anteilig (%)</option>
                  <option value="fix">Fix</option>
                </select>
              </div>
              <div class="col-span-2">
                <input type="number" 
                       name={`positionen[${index}][anteil]`} 
                       placeholder="%" 
                       min="0" 
                       max="100"
                       class="w-full border rounded px-3 py-2 text-sm anteil-input hidden" />
              </div>
              <input type="hidden" name={`positionen[${index}][kostenart]`} value={k.name} />
            </div>
          ))}
        </div>
      </div>

      <!-- Hinweise -->
      <div class="bg-blue-50 border-l-4 border-blue-500 p-4 rounded">
        <h3 class="font-medium text-blue-900 mb-2">ℹ️ Rechtliche Hinweise</h3>
        <ul class="text-sm text-blue-800 space-y-1">
          <li>• Abrechnungsfrist: 12 Monate nach Ende des Abrechnungsjahres (§ 556 BGB)</li>
          <li>• Heizkosten: 50-70% nach Verbrauch, Rest nach Wohnfläche (HeizkostenV)</li>
          <li>• Widerspruchsfrist: 12 Monate nach Zugang der Abrechnung</li>
        </ul>
      </div>

      <!-- Buttons -->
      <div class="flex gap-4">
        <a href="/nebenkosten" class="flex-1 bg-gray-100 text-gray-700 py-3 rounded-lg text-center hover:bg-gray-200">Abbrechen</a>
        <button type="submit" class="flex-1 bg-blue-600 text-white py-3 rounded-lg hover:bg-blue-700 font-medium">
          Abrechnung erstellen
        </button>
      </div>
    </form>
  </div>

  <script>
    function berechneSumme() {
      const inputs = document.querySelectorAll('.betrag-input');
      let summe = 0;
      inputs.forEach(input => {
        summe += parseFloat(input.value) || 0;
      });
      document.getElementById('gesamtsumme').textContent = summe.toLocaleString('de-DE', {minimumFractionDigits: 2}) + ' €';
    }

    // Zeige/verstecke Anteil-Feld basierend auf Verteilung
    document.querySelectorAll('select[name*="[verteilung]"]').forEach(select => {
      select.addEventListener('change', (e) => {
        const anteilInput = e.target.closest('.kosten-zeile').querySelector('.anteil-input');
        if (e.target.value === 'anteil') {
          anteilInput.classList.remove('hidden');
          anteilInput.required = true;
        } else {
          anteilInput.classList.add('hidden');
          anteilInput.required = false;
          anteilInput.value = '';
        }
      });
    });
  </script>
</DashboardLayout>