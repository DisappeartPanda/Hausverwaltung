---
type ActionTone = 'primary' | 'success' | 'warning' | 'danger' | 'neutral';

export type NextAction = {
  title: string;
  desc?: string;
  href: string;
  tone?: ActionTone;
  icon?: string; // emoji ok
};

const { actions = [] } = Astro.props as { actions: NextAction[] };

const toneClass = (t: ActionTone) => {
  switch (t) {
    case 'primary': return 'tone-primary';
    case 'success': return 'tone-success';
    case 'warning': return 'tone-warning';
    case 'danger':  return 'tone-danger';
    default:        return 'tone-neutral';
  }
};
---

{actions.length > 0 && (
  <section class="nba" aria-label="Nächste Schritte">
    <div class="nba-head">
      <h2>Next Steps</h2>
      <p>1-Klick Aktionen, die dein Portfolio sofort verbessern.</p>
    </div>

    <div class="nba-grid">
      {actions.map((a) => (
        <a class={`nba-card ${toneClass(a.tone ?? 'neutral')}`} href={a.href}>
          <div class="nba-top">
            <div class="nba-icon" aria-hidden="true">{a.icon ?? '✨'}</div>
            <div class="nba-title">{a.title}</div>
          </div>
          {a.desc && <div class="nba-desc">{a.desc}</div>}
          <div class="nba-cta">
            <span>Öffnen</span>
            <span aria-hidden="true">→</span>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .nba{
    display:flex;
    flex-direction:column;
    gap: 10px;
  }

  .nba-head h2{
    margin:0;
    font-size: 1.05rem;
    font-weight: 950;
    letter-spacing: -0.01em;
    color: rgba(255,255,255,0.96);
  }
  .nba-head p{
    margin: 4px 0 0;
    color: var(--gray-400);
    font-weight: 650;
    font-size: 0.9rem;
    line-height: 1.35;
  }

  .nba-grid{
    display:grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(0.6rem, 1vw, 0.9rem);
  }

  .nba-card{
    display:flex;
    flex-direction:column;
    gap: 8px;
    padding: clamp(0.75rem, 1.1vw, 0.95rem);
    border-radius: 1.1rem;
    text-decoration:none;
    border: 2px solid var(--dark-lighter);
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(18px);
    transition: transform .18s ease, background .18s ease, border-color .18s ease, box-shadow .18s ease;
  }
  .nba-card:hover{
    transform: translateY(-2px);
    background: rgba(255,255,255,0.08);
    border-color: rgba(134,239,172,0.40);
    box-shadow: 0 20px 60px rgba(0,0,0,0.35);
  }

  .nba-top{
    display:flex;
    align-items:center;
    gap: 10px;
  }
  .nba-icon{
    width: 34px;
    height: 34px;
    border-radius: 12px;
    display:grid;
    place-items:center;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.10);
  }
  .nba-title{
    font-weight: 950;
    color: rgba(255,255,255,0.95);
    letter-spacing: -0.01em;
    line-height: 1.15;
  }

  .nba-desc{
    color: var(--gray-400);
    font-weight: 650;
    font-size: 0.88rem;
    line-height: 1.35;
  }

  .nba-cta{
    margin-top: 2px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    color: rgba(255,255,255,0.84);
    font-weight: 900;
    font-size: 0.92rem;
  }

  /* tones */
  .tone-primary{ border-color: rgba(34,197,94,0.28); }
  .tone-success{ border-color: rgba(134,239,172,0.22); }
  .tone-warning{ border-color: rgba(253,224,71,0.18); }
  .tone-danger{  border-color: rgba(239,68,68,0.20); }
  .tone-neutral{ border-color: var(--dark-lighter); }

  @media (max-width: 560px){
    .nba-grid{ grid-template-columns: 1fr; }
  }
</style>