---
interface Props {
  href: string;
  icon: 'building' | 'users' | 'credit-card' | 'tool' | 'file-text' | 'settings';
  label: string;
}

const { href, icon, label } = Astro.props;

const icons: Record<string, string> = {
  building: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1"/></svg>`,
  users: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a4 4 0 00-4-4h-1M9 20H4v-2a4 4 0 014-4h1m4-4a4 4 0 11-8 0 4 4 0 018 0zm10 4a4 4 0 10-4-4"/></svg>`,
  'credit-card': `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2 8h20M4 6h16a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V8a2 2 0 012-2z"/></svg>`,
  tool: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.7 6.3a1 1 0 00-1.4 0l-7 7a1 1 0 000 1.4l2 2a1 1 0 001.4 0l7-7a1 1 0 000-1.4l-2-2zM7 21h10"/></svg>`,
  'file-text': `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 2v6h6M8 13h8M8 17h8M8 9h3"/></svg>`,
  settings: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15a3 3 0 110-6 3 3 0 010 6z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.4 15a7.97 7.97 0 00.1-1 7.97 7.97 0 00-.1-1l2-1.5-2-3.5-2.3 1a8.2 8.2 0 00-1.7-1L13 2h-2L9.6 6a8.2 8.2 0 00-1.7 1L5.6 6 3.6 9.5 5.6 11a7.97 7.97 0 00-.1 1 7.97 7.97 0 00.1 1l-2 1.5 2 3.5 2.3-1a8.2 8.2 0 001.7 1L11 22h2l1.4-4a8.2 8.2 0 001.7-1l2.3 1 2-3.5-2-1.5z"/></svg>`,
};
---

<a class="ql" href={href} aria-label={label}>
  <span class="icon"><Fragment set:html={icons[icon]} /></span>
  <span class="label">{label}</span>
</a>

<style>
  .ql{
    /* ✅ füllt die Grid-Zelle */
    height: 100%;
    min-height: 56px;

    display: flex;
    align-items: center;
    gap: 12px;

    padding: 0 14px;

    background: rgba(255,255,255,0.05);
    border: 2px solid var(--dark-lighter);
    border-radius: 1rem;
    text-decoration: none;

    transition: border-color .2s ease, background .2s ease, box-shadow .2s ease;
  }

  .ql:hover{
    border-color: var(--primary);
    background: rgba(255,255,255,0.075);
    box-shadow: 0 10px 24px rgba(0,0,0,0.25);
  }

  .icon{
    width: 38px;
    height: 38px;
    border-radius: 12px;
    display: grid;
    place-items: center;
    background: rgba(134,239,172,0.10);
    flex: 0 0 auto;
  }

  .icon :global(svg){
    width: 20px;
    height: 20px;
    color: var(--primary);
  }

  .label{
    font-size: 0.95rem;
    font-weight: 650;
    color: var(--white);
    line-height: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>