---
import type { DashboardStats } from '../../lib/dashboard/dashboardStats';

interface Props {
  stats: DashboardStats;
}

const { stats } = Astro.props;
const { score, scoreFarbe, scoreText, scoreSubtext } = stats;

const s = Math.max(0, Math.min(100, score));

// Gauge angle (0..100 => 180..0 on scale)
const angleDeg = 180 - s * 1.8;

// Needle points UP at 0°, so map to gauge angle:
const needleRotate = 90 - angleDeg;

// Use pathLength=100 so dash math is exact and independent of actual path length
const dashOffset = 100 - s;

// ticks
const minor = Array.from({ length: 21 }, (_, i) => i * 5);
const major = [0, 25, 50, 75, 100];

function polar(cx: number, cy: number, r: number, deg: number) {
  const rad = (deg * Math.PI) / 180;
  return { x: cx + r * Math.cos(rad), y: cy - r * Math.sin(rad) };
}
---

<div class="tacho-card">
  <div class="tacho-center">
    <div class="tacho-wrapper">
      <svg class="tacho" viewBox="0 0 200 110" preserveAspectRatio="xMidYMid meet" aria-label="Zustands-Tacho">
        <defs>
          <linearGradient id="trackGrad" x1="20" y1="100" x2="180" y2="20" gradientUnits="userSpaceOnUse">
            <stop offset="0" stop-color="#0f1512" stop-opacity="1" />
            <stop offset="1" stop-color="#1a2420" stop-opacity="1" />
          </linearGradient>

          <linearGradient id="fillGrad" x1="20" y1="100" x2="180" y2="20" gradientUnits="userSpaceOnUse">
            <stop offset="0" stop-color={scoreFarbe} stop-opacity="0.75" />
            <stop offset="0.55" stop-color={scoreFarbe} stop-opacity="1" />
            <stop offset="1" stop-color={scoreFarbe} stop-opacity="0.85" />
          </linearGradient>

          <!-- softer, smaller glow -->
          <filter id="softGlow" x="-35%" y="-35%" width="170%" height="170%">
            <feGaussianBlur stdDeviation="2.2" result="blur" />
            <feMerge>
              <feMergeNode in="blur" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>

          <filter id="needleShadow" x="-40%" y="-40%" width="180%" height="180%">
            <feDropShadow dx="0" dy="2" stdDeviation="2.4" flood-color="#000" flood-opacity="0.55" />
          </filter>

          <radialGradient id="centerMetal" cx="50%" cy="45%" r="60%">
            <stop offset="0" stop-color="#e8ecea" stop-opacity="0.95" />
            <stop offset="0.35" stop-color="#9aa3a0" stop-opacity="0.95" />
            <stop offset="1" stop-color="#2a312e" stop-opacity="1" />
          </radialGradient>
        </defs>

        <!-- Arc path (symmetric + level) -->
        <!-- pathLength=100 makes dasharray/dashoffset exact -->
        <path
          d="M 20 100 A 80 80 0 0 1 180 100"
          pathLength="100"
          fill="none"
          stroke="url(#trackGrad)"
          stroke-width="16"
          stroke-linecap="round"
          opacity="0.95"
        />

        <!-- Progress glow (reduced so it doesn't look "full") -->
        <path
          d="M 20 100 A 80 80 0 0 1 180 100"
          pathLength="100"
          fill="none"
          stroke={scoreFarbe}
          stroke-width="18"
          stroke-linecap="round"
          stroke-dasharray="100"
          stroke-dashoffset={dashOffset}
          opacity="0.18"
          filter="url(#softGlow)"
        />

        <!-- Progress main -->
        <path
          d="M 20 100 A 80 80 0 0 1 180 100"
          pathLength="100"
          fill="none"
          stroke="url(#fillGrad)"
          stroke-width="14"
          stroke-linecap="round"
          stroke-dasharray="100"
          stroke-dashoffset={dashOffset}
          class="tacho-fill"
          filter="url(#softGlow)"
        />

        <!-- ticks -->
        <g class="ticks">
          {minor.map((val) => {
            const i = val / 5;              // 0..20
            const ang = 180 - i * 9;        // 180..0
            const isMajor = major.includes(val);
            const r1 = isMajor ? 66 : 71;
            const r2 = 80;
            const p1 = polar(100, 100, r1, ang);
            const p2 = polar(100, 100, r2, ang);
            return (
              <line
                x1={p1.x}
                y1={p1.y}
                x2={p2.x}
                y2={p2.y}
                stroke={isMajor ? '#d7e0dd' : '#7b878d'}
                stroke-width={isMajor ? 2.4 : 1.25}
                stroke-linecap="round"
                opacity={isMajor ? 0.9 : 0.55}
              />
            );
          })}
        </g>

        <!-- labels -->
        <g class="labels">
          {major.map((val) => {
            const i = val / 25;           // 0..4
            const ang = 180 - i * 45;
            const p = polar(100, 100, 56, ang);
            return (
              <text
                x={p.x}
                y={p.y}
                text-anchor="middle"
                dominant-baseline="central"
                font-size="9"
                fill="#cbd5e1"
                opacity="0.92"
              >
                {val}
              </text>
            );
          })}
        </g>

        <!-- needle (now correct) -->
        <g transform={`rotate(${needleRotate}, 100, 100)`} filter="url(#needleShadow)">
          <path d="M 100 100 L 98 35 Q 100 22 102 35 L 100 100 Z" fill={scoreFarbe} opacity="0.95" />
          <path d="M 100 100 L 99.2 38 Q 100 28 100.8 38 L 100 100 Z" fill="#fff" opacity="0.16" />
        </g>

        <!-- center cap -->
        <circle cx="100" cy="100" r="10" fill="url(#centerMetal)" opacity="0.95" />
        <circle cx="100" cy="100" r="5" fill="#0b0f0d" opacity="0.8" />
      </svg>

      <div class="tacho-text" style={`--accent:${scoreFarbe}`}>
        <div class="score">{s}%</div>
        <div class="status">{scoreText}</div>
        <div class="subtext">{scoreSubtext}</div>
      </div>
    </div>
  </div>
</div>

<style>
.tacho-card{
  width:100%;
  border-radius:1.5rem;
  padding:1.5rem;
  background: linear-gradient(180deg, rgba(14,18,16,0.85), rgba(10,14,12,0.9));
  border:1px solid rgba(255,255,255,0.08);
  box-shadow: 0 25px 60px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.05);
  backdrop-filter: blur(12px);
}

.tacho-center{display:flex;justify-content:center;align-items:center;}

.tacho-wrapper{
  position:relative;
  width:min(820px, 100%);
  aspect-ratio:200 / 110;   /* <-- wieder „waagerecht“ wie klassischer Halbkreis */
  isolation:isolate;
}

.tacho{width:100%;height:100%;display:block;}

.tacho-fill{
  transition: stroke-dashoffset 1s cubic-bezier(.2,.9,.2,1);
}

.tacho-text{
  position:absolute;
  left:50%;
  bottom:16%;
  transform:translateX(-50%);
  text-align:center;
  width:max-content;
  padding: 10px 16px;
  border-radius: 999px;
  background: rgba(0,0,0,0.35);
  border: 1px solid rgba(255,255,255,0.10);
  backdrop-filter: blur(10px);
  box-shadow: 0 15px 40px rgba(0,0,0,0.45), inset 0 1px 0 rgba(255,255,255,0.06);
  z-index:5;
  pointer-events:none;
}

.score{
  font-size:3.1rem;
  font-weight:900;
  line-height:1;
  margin:0;
  color: var(--accent);
  text-shadow: 0 0 18px color-mix(in srgb, var(--accent) 55%, transparent), 0 6px 18px rgba(0,0,0,0.55);
}

.status{
  margin-top:2px;
  font-size:1.05rem;
  font-weight:800;
  color: rgba(255,255,255,0.95);
  text-shadow: 0 2px 14px rgba(0,0,0,0.55);
}

.subtext{
  margin-top:2px;
  font-size:0.88rem;
  font-weight:700;
  color: rgba(255,255,255,0.72);
}

@media (max-width:768px){
  .tacho-card{padding:1rem;}
  .tacho-wrapper{width:min(560px, 100%);}
  .score{font-size:2.6rem;}
}
</style>