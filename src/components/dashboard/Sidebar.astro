---
import QuickLink from './QuickLink.astro';
import { getQuickLinks } from '../../lib/dashboard/quickLinks';
import type { ResolvedDashboardMode } from '../../lib/dashboard/dashboardModes';

const { einheiten, mode } = Astro.props as {
  einheiten: number;
  mode: ResolvedDashboardMode;
};

const links = getQuickLinks(einheiten, mode);
---

<div class="side" data-mode={mode}>
  <nav
    class="list"
    aria-label="Schnellzugriff"
    style={`--rows:${links.length};`}
  >
    {links.map((link) => (
      <QuickLink {...link} />
    ))}
  </nav>
</div>

<style>
  .side{
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(20px);
    border: 2px solid var(--dark-lighter);
    border-radius: 1.5rem;

    padding: clamp(0.75rem, 1.2vw, 1.1rem);
    height: 100%;
    box-sizing: border-box;

    display: flex;
    flex-direction: column;
  }

  /* ✅ 100% Höhe wird genutzt: jede Zeile ist 1fr */
  .list{
    margin-top: 0;
    display: grid;

    /* 6 Links => 6 gleich hohe Reihen */
    grid-template-rows: repeat(var(--rows), 1fr);

    /* gleichmäßiger Abstand, aber nicht riesig */
    gap: clamp(.55rem, 1vh, .9rem);

    /* wichtig: füllt die komplette Sidebar */
    height: 100%;
    min-height: 0;
  }

  /* Auf sehr kleinen Screens darf es zweispaltig werden */
  @media (max-width: 900px){
    .list{
      grid-template-columns: 1fr 1fr;
      grid-template-rows: none;
      grid-auto-rows: 1fr;
    }
  }
</style>