---
---

<section class="ai-chat" id="ai">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">KI-Assistent</h2>
            <p class="section-subtitle">Stellen Sie Ihre Fragen rund um die Uhr. Unser KI-Assistent hilft Ihnen sofort weiter.</p>
        </div>

        <div class="chat-container">
            <div class="chat-header">
                <div class="chat-header-left">
                    <div class="chat-avatar">🤖</div>
                    <div class="chat-header-info">
                        <h4>ImmobilienPro KI</h4>
                        <span class="chat-status">Online</span>
                    </div>
                </div>
                <span class="chat-badge">Beta</span>
            </div>

            <div class="chat-body">
                <div class="chat-message">
                    <div class="chat-message-avatar">🤖</div>
                    <div class="chat-message-content">
                        <p>Hallo! Ich bin Ihr KI-Assistent für die Hausverwaltung. Wie kann ich Ihnen heute helfen?</p>
                        <span class="chat-time">11:39</span>
                    </div>
                </div>
            </div>

            <div class="chat-suggestions">
                <p class="chat-suggestions-title">Häufige Fragen:</p>
                <div class="chat-suggestion-tags">
                    <button class="chat-suggestion">Wie melde ich einen Mangel?</button>
                    <button class="chat-suggestion">Wann kommt die Nebenkostenabrechnung?</button>
                    <button class="chat-suggestion">Wie kann ich meine Miete ändern?</button>
                    <button class="chat-suggestion">Was ist in der Kaltmiete enthalten?</button>
                    <button class="chat-suggestion">Wie kündige ich meinen Mietvertrag?</button>
                </div>
            </div>
        </div>
    </div>
</section>

<script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.chat-suggestion').forEach(btn => {
            btn.addEventListener('click', function() {
                const chatBody = document.querySelector('.chat-body');
                const userMessage = document.createElement('div');
                userMessage.className = 'chat-message';
                userMessage.style.flexDirection = 'row-reverse';
                userMessage.innerHTML = `
                    <div class="chat-message-avatar" style="background: var(--dark-light);">👤</div>
                    <div class="chat-message-content" style="background: var(--primary); color: white; border-bottom-left-radius: 1rem; border-bottom-right-radius: 0.25rem;">
                        <p style="color: white;">${this.textContent}</p>
                        <span class="chat-time" style="color: rgba(255,255,255,0.7);">Jetzt</span>
                    </div>
                `;
                chatBody.appendChild(userMessage);
                
                setTimeout(() => {
                    const aiMessage = document.createElement('div');
                    aiMessage.className = 'chat-message';
                    aiMessage.innerHTML = `
                        <div class="chat-message-avatar">🤖</div>
                        <div class="chat-message-content">
                            <p>Ich habe Ihre Anfrage erhalten. Ein Mitarbeiter wird sich in Kürze bei Ihnen melden.</p>
                            <span class="chat-time">Jetzt</span>
                        </div>
                    `;
                    chatBody.appendChild(aiMessage);
                    chatBody.scrollTop = chatBody.scrollHeight;
                }, 1000);
                
                chatBody.scrollTop = chatBody.scrollHeight;
            });
        });
    });
</script>

<style>
    .ai-chat {
        padding: 6rem 0;
        background: var(--white);
    }

    .chat-container {
        max-width: 800px;
        margin: 0 auto;
        background: var(--white);
        border-radius: 1rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        border: 1px solid var(--gray-200);
        overflow: hidden;
    }

    .chat-header {
        background: var(--dark);
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .chat-header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .chat-avatar {
        width: 40px;
        height: 40px;
        background: var(--primary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--white);
        font-size: 1.25rem;
    }

    .chat-header-info h4 {
        color: var(--white);
        font-weight: 600;
    }

    .chat-status {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--success);
        font-size: 0.875rem;
    }

    .chat-status::before {
        content: '';
        width: 8px;
        height: 8px;
        background: var(--success);
        border-radius: 50%;
    }

    .chat-badge {
        background: rgba(245, 158, 11, 0.2);
        color: var(--primary);
        padding: 0.25rem 0.75rem;
        border-radius: 1rem;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .chat-body {
        padding: 1.5rem;
        min-height: 300px;
    }

    .chat-message {
        display: flex;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .chat-message-avatar {
        width: 40px;
        height: 40px;
        background: var(--primary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--white);
        flex-shrink: 0;
    }

    .chat-message-content {
        background: var(--gray-100);
        padding: 1rem 1.25rem;
        border-radius: 1rem;
        border-bottom-left-radius: 0.25rem;
        max-width: 80%;
    }

    .chat-message-content p {
        color: var(--dark);
        line-height: 1.5;
    }

    .chat-time {
        font-size: 0.75rem;
        color: var(--gray-400);
        margin-top: 0.5rem;
    }

    .chat-suggestions {
        padding: 0 1.5rem 1.5rem;
    }

    .chat-suggestions-title {
        font-size: 0.875rem;
        color: var(--gray-600);
        margin-bottom: 0.75rem;
    }

    .chat-suggestion-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .chat-suggestion {
        padding: 0.625rem 1rem;
        background: var(--gray-100);
        border: 1px solid var(--gray-200);
        border-radius: 2rem;
        font-size: 0.875rem;
        color: var(--gray-600);
        cursor: pointer;
        transition: all 0.3s;
    }

    .chat-suggestion:hover {
        background: var(--primary);
        color: var(--white);
        border-color: var(--primary);
    }
</style>