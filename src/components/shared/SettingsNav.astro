---
interface Props {
  currentPath?: string;
}

const { currentPath = "/settings" } = Astro.props;

const items = [
  { label: "Übersicht", href: "/settings" },
  { label: "Konto", href: "/settings/konto" },
  { label: "Organisation", href: "/settings/organisation" },
  { label: "Design", href: "/settings/design" },
  { label: "Module", href: "/settings/module" },
  { label: "Abrechnung", href: "/settings/abrechnung" },
  { label: "Benachrichtigungen", href: "/settings/benachrichtigungen" },
];

function isActive(path: string, href: string) {
  if (href === "/settings") return path === "/settings";
  return path === href || path.startsWith(`${href}/`);
}
---

<nav class="settings-nav" aria-label="Einstellungen Navigation">
  {
    items.map((item) => (
      <a
        href={item.href}
        class:list={[
          "settings-nav__link",
          isActive(currentPath, item.href) && "settings-nav__link--active",
        ]}
      >
        {item.label}
      </a>
    ))
  }
</nav>

<style>
  .settings-nav {
    display: grid;
    gap: var(--space-2);
    align-content: start;
  }

  .settings-nav__link {
    display: flex;
    align-items: center;
    min-height: 2.75rem;
    padding: 0.75rem 0.95rem;
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    color: var(--text-muted);
  }

  .settings-nav__link:hover {
    color: var(--text);
    background: rgba(255, 255, 255, 0.03);
    border-color: var(--border);
  }

  .settings-nav__link--active {
    color: var(--text);
    background: rgba(57, 224, 122, 0.1);
    border-color: var(--border-accent-soft);
    box-shadow: var(--shadow-glow-sm);
  }
</style>