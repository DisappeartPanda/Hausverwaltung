---
import type { ModuleKey } from "../../lib/constants/module-keys";
import UserMenu from "./UserMenu.astro";

interface Props {
  organizationName?: string;
  activeModules?: ModuleKey[];
  userEmail?: string | null;
}

const {
  organizationName = "Musterverwaltung GmbH",
  activeModules = [],
  userEmail = "demo@immobilienpro.de",
} = Astro.props;
---

<header class="app-topbar">
  <div class="app-topbar__inner">
    <div>
      <div class="app-topbar__label">Organisation</div>
      <div class="app-topbar__title">{organizationName}</div>
    </div>

    <div class="app-topbar__actions">
      <div class="app-topbar__badges">
        {
          activeModules.map((module) => (
            <span class="badge badge--accent">{module}</span>
          ))
        }
      </div>

      <UserMenu email={userEmail} />
    </div>
  </div>
</header>

<style>
  .app-topbar {
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid var(--border);
    background: rgba(11, 18, 32, 0.72);
    backdrop-filter: blur(var(--blur-md));
    -webkit-backdrop-filter: blur(var(--blur-md));
  }

  .app-topbar__inner {
    min-height: var(--topbar-height);
    padding: 0 var(--space-8);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .app-topbar__label {
    color: var(--text-soft);
    font-size: var(--text-sm);
  }

  .app-topbar__title {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
  }

  .app-topbar__actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .app-topbar__badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  @media (max-width: 960px) {
    .app-topbar__inner {
      padding: var(--space-4) var(--space-5);
      align-items: flex-start;
      justify-content: flex-start;
      flex-direction: column;
    }

    .app-topbar__actions {
      width: 100%;
      justify-content: space-between;
    }
  }
</style>