---
import HeroCard from './HeroCard.astro';
import Stats from './Stats.astro';

// Aus Cookie oder Query-Parameter lesen (für Demo)
const cookieRole = Astro.cookies.get('userRole')?.value;
const urlRole = Astro.url.searchParams.get('role') as 'guest' | 'tenant' | 'landlord' | null;

// Priorität: URL-Parameter > Cookie > Default
const userRole: 'guest' | 'tenant' | 'landlord' = urlRole || cookieRole || 'guest';
---

<section class="hero">
    <div class="hero-bg"></div>
    <div class="container">
        <div class="hero-content">
            <div class="hero-left">
                <div class="hero-badge">
                    <span>💬</span>
                    <span>Mit KI-Assistent 24/7 für Sie da</span>
                </div>
                <h1 class="hero-title">
                    {userRole === 'guest' && 'Professionelle '}
                    {userRole === 'landlord' && 'Willkommen zurück, '}
                    {userRole === 'tenant' && 'Willkommen zurück, '}
                    <span>
                        {userRole === 'guest' && 'Hausverwaltung'}
                        {userRole === 'landlord' && 'Vermieter'}
                        {userRole === 'tenant' && 'Mieter'}
                    </span>
                    {userRole === 'guest' && ' mit KI-Unterstützung'}
                </h1>
                <p class="hero-desc">
                    {userRole === 'guest' && 'Wir verwalten Ihre Immobilien effizient und digital. Unser KI-Assistent beantwortet Fragen rund um die Uhr – für Eigentümer und Mieter.'}
                    {userRole === 'landlord' && 'Verwalten Sie Ihre Immobilien digital und effizient. Alle Abrechnungen, Mieter und Wartungen auf einen Blick.'}
                    {userRole === 'tenant' && 'Ihr persönlicher Mieterbereich – Mängel melden, Dokumente einsehen und direkt mit der Verwaltung kommunizieren.'}
                </p>
                
                {userRole === 'guest' && (
                    <div class="hero-features">
                        <div class="hero-feature">
                            <div class="hero-feature-icon">✓</div>
                            <span>Digitale Mietverwaltung</span>
                        </div>
                        <div class="hero-feature">
                            <div class="hero-feature-icon">✓</div>
                            <span>24/7 KI-Support</span>
                        </div>
                        <div class="hero-feature">
                            <div class="hero-feature-icon">✓</div>
                            <span>Automatische Abrechnungen</span>
                        </div>
                        <div class="hero-feature">
                            <div class="hero-feature-icon">✓</div>
                            <span>Instandhaltungsmanagement</span>
                        </div>
                    </div>
                )}

                <div class="hero-buttons">
                    {userRole === 'guest' ? (
                        <>
                            <a href="/register" class="btn btn-primary">
                                <span>🚀</span>
                                <span>Jetzt registrieren</span>
                            </a>
                            <a href="/login" class="btn btn-outline">
                                Anmelden
                            </a>
                        </>
                    ) : (
                        <>
                            <a href="/dashboard" class="btn btn-primary">
                                <span>📊</span>
                                <span>Zum Dashboard</span>
                            </a>
                            <button onclick="logout()" class="btn btn-outline">
                                Abmelden
                            </button>
                        </>
                    )}
                </div>
            </div>

            <HeroCard userRole={userRole} />
        </div>
    </div>
</section>

<Stats />

<script is:inline>
    function switchTab(role) {
        const ownerServices = document.getElementById('owner-services');
        const tenantServices = document.getElementById('tenant-services');
        const tabs = document.querySelectorAll('.role-tab');
        
        if (!ownerServices || !tenantServices) return;
        
        if (role === 'owner') {
            ownerServices.style.display = 'flex';
            tenantServices.style.display = 'none';
            tabs[0]?.classList.add('active');
            tabs[1]?.classList.remove('active');
        } else {
            ownerServices.style.display = 'none';
            tenantServices.style.display = 'flex';
            tabs[0]?.classList.remove('active');
            tabs[1]?.classList.add('active');
        }
    }
    
    window.switchTab = switchTab;

    function logout() {
        document.cookie = 'userRole=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
        localStorage.removeItem('user');
        window.location.href = '/';
    }
    
    window.logout = logout;
</script>

<style>
    .hero {
        min-height: 100vh;
        background: linear-gradient(135deg, var(--dark) 0%, var(--dark-light) 100%);
        position: relative;
        display: flex;
        align-items: center;
        padding: 8rem 0 4rem;
        overflow: hidden;
    }

    .hero::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><rect fill="none" stroke="rgba(255,255,255,0.03)" stroke-width="0.5" x="0" y="0" width="100" height="100"/></svg>');
        background-size: 50px 50px;
        opacity: 0.5;
    }

    .hero-bg {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url('https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=1920&q=80') center/cover;
        opacity: 0.15;
    }

    .hero-content {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }

    .hero-left {
        color: var(--white);
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(245, 158, 11, 0.2);
        color: var(--primary);
        padding: 0.5rem 1rem;
        border-radius: 2rem;
        font-size: 0.875rem;
        margin-bottom: 1.5rem;
        border: 1px solid rgba(245, 158, 11, 0.3);
    }

    .hero-title {
        font-size: 3.5rem;
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 1.5rem;
    }

    .hero-title span {
        color: var(--primary);
    }

    .hero-desc {
        font-size: 1.25rem;
        color: var(--gray-400);
        margin-bottom: 2rem;
        max-width: 500px;
    }

    .hero-features {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 2.5rem;
    }

    .hero-feature {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: var(--gray-200);
        font-size: 0.9375rem;
    }

    .hero-feature-icon {
        width: 24px;
        height: 24px;
        background: var(--primary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--dark);
        font-size: 0.75rem;
        flex-shrink: 0;
    }

    .hero-buttons {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    @media (max-width: 1024px) {
        .hero-content {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
    }

    @media (max-width: 768px) {
        .hero-title {
            font-size: 2.5rem;
        }

        .hero-features {
            grid-template-columns: 1fr;
        }
    }
</style>