---
interface Props {
    userRole?: 'guest' | 'tenant' | 'landlord';
}

const { userRole = 'guest' } = Astro.props;

// Services basierend auf Rolle filtern
const ownerServices = [
    { icon: '📄', title: 'Abrechnungen einsehen', desc: 'Nebenkosten- & Heizkostenabrechnung' },
    { icon: '🔧', title: 'Instandhaltung', desc: 'Wartung & Reparaturen verwalten' },
    { icon: '📈', title: 'Mieteinnahmen', desc: 'Übersicht & Auszahlungen' },
    { icon: '🏠', title: 'Objektübersicht', desc: 'Alle Immobilien auf einen Blick' },
    { icon: '👥', title: 'Mieter verwalten', desc: 'Verträge & Kommunikation' },
];

const tenantServices = [
    { icon: '📄', title: 'Mietvertrag', desc: 'Vertragsdetails & Dokumente' },
    { icon: '🔧', title: 'Mangel melden', desc: 'Reparaturanfrage stellen' },
    { icon: '💬', title: 'Nachricht senden', desc: 'Direkt mit Verwaltung kontaktieren' },
    { icon: '💰', title: 'Mietzahlungen', desc: 'Zahlungsübersicht & Quittungen' },
    { icon: '📊', title: 'Nebenkosten', desc: 'Abrechnungen einsehen' },
];

let displayServices: typeof ownerServices = [];
let activeTab = 'owner';

if (userRole === 'landlord') {
    displayServices = ownerServices;
    activeTab = 'owner';
} else if (userRole === 'tenant') {
    displayServices = tenantServices;
    activeTab = 'tenant';
} else {
    displayServices = [...ownerServices.slice(0, 3), ...tenantServices.slice(0, 3)];
}
---

<div class="hero-card" data-role={userRole}>
    <h3 class="hero-card-title">
        {userRole === 'guest' && 'Womit können wir Ihnen helfen?'}
        {userRole === 'landlord' && 'Ihre Vermieter-Übersicht'}
        {userRole === 'tenant' && 'Ihre Mieter-Übersicht'}
    </h3>
    
    {userRole === 'guest' && (
        <div class="role-tabs">
            <button class="role-tab active" onclick="switchTab('owner')">
                <span>🏢</span>
                <span>Eigentümer</span>
            </button>
            <button class="role-tab" onclick="switchTab('tenant')">
                <span>🔑</span>
                <span>Mieter</span>
            </button>
        </div>
    )}

    {userRole === 'guest' ? (
        <>
            <div class="service-list" id="owner-services">
                {ownerServices.slice(0, 3).map((service) => (
                    <div class="service-item">
                        <div class="service-icon">{service.icon}</div>
                        <div class="service-content">
                            <h4>{service.title}</h4>
                            <p>{service.desc}</p>
                        </div>
                    </div>
                ))}
            </div>
            <div class="service-list" id="tenant-services" style="display: none;">
                {tenantServices.slice(0, 3).map((service) => (
                    <div class="service-item">
                        <div class="service-icon">{service.icon}</div>
                        <div class="service-content">
                            <h4>{service.title}</h4>
                            <p>{service.desc}</p>
                        </div>
                    </div>
                ))}
            </div>
            <div class="demo-badge">
                <span>👁️</span>
                <span>Demo-Ansicht – <a href="/login">Jetzt einloggen</a> für alle Features</span>
            </div>
        </>
    ) : (
        <div class="service-list">
            {displayServices.map((service) => (
                <a href="#" class="service-item">
                    <div class="service-icon">{service.icon}</div>
                    <div class="service-content">
                        <h4>{service.title}</h4>
                        <p>{service.desc}</p>
                    </div>
                </a>
            ))}
        </div>
    )}

    <div class="ai-banner">
        <div class="ai-banner-icon">🤖</div>
        <div class="ai-banner-content">
            <h4>KI-Assistent verfügbar</h4>
            <p>
                {userRole === 'guest' 
                    ? 'Stellen Sie Fragen – rund um die Uhr!' 
                    : 'Persönlicher Support für Sie – 24/7!'}
            </p>
        </div>
    </div>
</div>

<style>
    .hero-card {
        background: var(--white);
        border-radius: 1rem;
        padding: 2rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .hero-card-title {
        font-size: 1.25rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        color: var(--dark);
    }

    .role-tabs {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
        background: var(--gray-100);
        padding: 0.25rem;
        border-radius: 0.5rem;
    }

    .role-tab {
        flex: 1;
        padding: 0.75rem;
        border: none;
        background: transparent;
        border-radius: 0.375rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        color: var(--gray-600);
    }

    .role-tab.active {
        background: var(--dark);
        color: var(--white);
    }

    .service-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .service-item {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding: 1rem;
        border-radius: 0.5rem;
        transition: all 0.3s;
        cursor: pointer;
        text-decoration: none;
    }

    .service-item:hover {
        background: var(--gray-100);
    }

    .service-icon {
        width: 48px;
        height: 48px;
        background: rgba(245, 158, 11, 0.1);
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
        font-size: 1.25rem;
        flex-shrink: 0;
    }

    .service-content h4 {
        font-weight: 600;
        color: var(--dark);
        margin-bottom: 0.25rem;
    }

    .service-content p {
        font-size: 0.875rem;
        color: var(--gray-600);
    }

    .demo-badge {
        margin-top: 1rem;
        padding: 0.75rem 1rem;
        background: var(--gray-100);
        border-radius: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.875rem;
        color: var(--gray-600);
    }

    .demo-badge a {
        color: var(--primary);
        font-weight: 600;
        text-decoration: none;
    }

    .ai-banner {
        margin-top: 1.5rem;
        padding: 1rem;
        background: rgba(245, 158, 11, 0.1);
        border: 1px solid rgba(245, 158, 11, 0.2);
        border-radius: 0.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .ai-banner-icon {
        width: 40px;
        height: 40px;
        background: var(--primary);
        border-radius: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--white);
        flex-shrink: 0;
    }

    .ai-banner-content h4 {
        font-weight: 600;
        color: var(--dark);
        font-size: 0.9375rem;
    }

    .ai-banner-content p {
        font-size: 0.875rem;
        color: var(--gray-600);
    }
</style>