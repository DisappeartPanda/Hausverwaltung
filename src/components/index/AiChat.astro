---
import type { UserRole } from '../../lib/supabase/role';
import { normalizeRole } from '../../lib/supabase/role';

const role: UserRole = normalizeRole(Astro.cookies.get('userRole')?.value);

const suggestionsByRole: Record<UserRole, string[]> = {
  guest: [
    'Wie melde ich einen Mangel?',
    'Was ist in der Kaltmiete enthalten?',
    'Wie kündige ich meinen Mietvertrag?',
    'Wie funktioniert ImmobilienPro?',
    'Kann ich Dokumente digital abrufen?'
  ],
  tenant: [
    'Wie melde ich einen Mangel?',
    'Wann kommt die Nebenkostenabrechnung?',
    'Wo finde ich meine Dokumente?',
    'Wie ändere ich meine Bankverbindung?',
    'Wie kündige ich meinen Mietvertrag?'
  ],
  landlord: [
    'Wie bearbeite ich einen Mangel?',
    'Wie erstelle ich eine Nebenkostenabrechnung?',
    'Wie setze ich eine Mieterhöhung korrekt um?',
    'Wie lade ich Dokumente hoch?',
    'Wie kommuniziere ich mit Mietern?'
  ],
};

const suggestions = suggestionsByRole[role];
---

<section class="ai-chat" id="ai" data-role={role}>
  <div class="container">
    <div class="section-header">
    </div>

    <div class="chat-container">
      <div class="chat-header">
        <div class="chat-header-left">
          <div class="chat-avatar">🤖</div>
          <div class="chat-header-info">
            <h4>ImmobilienPro KI</h4>
            <span class="chat-status">Online</span>
          </div>
        </div>
        <span class="chat-badge">Beta</span>
      </div>

      <div class="chat-body" aria-live="polite">
        <div class="chat-message is-ai">
          <div class="chat-message-avatar">🤖</div>
          <div class="chat-message-content">
            <p>
              Hallo! Ich bin Ihr KI-Assistent. (Rolle: <strong style="color: rgba(34,197,94,.95)">{role}</strong>)
              Wie kann ich helfen?
            </p>
            <span class="chat-time">Jetzt</span>
          </div>
        </div>
      </div>

      <div class="chat-suggestions">
        <p class="chat-suggestions-title">Häufige Fragen:</p>
        <div class="chat-suggestion-tags">
          {suggestions.map((s) => (
            <button class="chat-suggestion" type="button">{s}</button>
          ))}
        </div>
      </div>

      <form class="chat-input" autocomplete="off">
        <input
          class="chat-input-field"
          name="message"
          type="text"
          placeholder="Schreiben Sie eine Nachricht…"
          aria-label="Nachricht eingeben"
        />
        <button class="chat-send" type="submit" aria-label="Senden">➤</button>
      </form>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const root = document.querySelector('.ai-chat');
    if (!root) return;

    const role = root.getAttribute('data-role') || 'guest';

    const chat = root.querySelector('.chat-container');
    const chatBody = root.querySelector('.chat-body');
    const form = root.querySelector('.chat-input');
    const input = root.querySelector('.chat-input-field');
    const suggestions = root.querySelectorAll('.chat-suggestion');
    const sendBtn = root.querySelector('.chat-send');

    const nowLabel = () => {
      const d = new Date();
      return d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    };

    const scrollToBottom = (smooth = true) => {
      chatBody.scrollTo({ top: chatBody.scrollHeight, behavior: smooth ? 'smooth' : 'auto' });
    };

    const addMessage = ({ text, who }) => {
  const wrap = document.createElement('div');
  wrap.classList.add('chat-message');
  wrap.classList.add(who === 'user' ? 'is-user' : 'is-ai');

  const avatar = document.createElement('div');
  avatar.classList.add('chat-message-avatar');
  avatar.textContent = who === 'user' ? '👤' : '🤖';

  const content = document.createElement('div');
  content.classList.add('chat-message-content');

  const p = document.createElement('p');
  p.textContent = text;

  const time = document.createElement('span');
  time.classList.add('chat-time');
  time.textContent = who === 'user' ? 'Jetzt' : nowLabel();

  content.appendChild(p);
  content.appendChild(time);

  wrap.appendChild(avatar);
  wrap.appendChild(content);

  chatBody.appendChild(wrap);
  scrollToBottom();
  return wrap;
};

const addTyping = () => {
  const wrap = document.createElement('div');
  wrap.classList.add('chat-message', 'is-ai', 'is-typing');

  const avatar = document.createElement('div');
  avatar.classList.add('chat-message-avatar');
  avatar.textContent = '🤖';

  const content = document.createElement('div');
  content.classList.add('chat-message-content', 'chat-typing');

  content.innerHTML = `<span class="dot"></span><span class="dot"></span><span class="dot"></span>`;

  wrap.appendChild(avatar);
  wrap.appendChild(content);

  chatBody.appendChild(wrap);
  scrollToBottom();
  return wrap;
};

    const setBusy = (busy) => {
      input.disabled = busy;
      sendBtn.disabled = busy;
      if (busy) chat.classList.add('is-busy');
      else chat.classList.remove('is-busy');
    };

    const callApi = async (message) => {
      const res = await fetch('/api/ai', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message, role })
      });

      const data = await res.json().catch(() => null);
      if (!res.ok || !data || data.ok !== true) {
        const err = (data && data.error) ? data.error : 'Serverfehler.';
        throw new Error(err);
      }
      return data.reply;
    };

    const send = async (text) => {
      const cleaned = (text || '').trim();
      if (!cleaned) return;

      addMessage({ text: cleaned, who: 'user' });
      input.value = '';

      const typing = addTyping();
      setBusy(true);

      try {
        const reply = await callApi(cleaned);
        typing.remove();
        addMessage({ text: reply, who: 'ai' });
      } catch (e) {
        typing.remove();
        addMessage({ text: `⚠️ ${e.message || 'Unerwarteter Fehler.'}`, who: 'ai' });
      } finally {
        setBusy(false);
        input.focus();
        scrollToBottom();
      }
    };

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      send(input.value);
    });

    suggestions.forEach((btn) => {
      btn.addEventListener('click', () => {
        send(btn.textContent);
      });
    });

    scrollToBottom(false);
  });
</script>

<style is:global>
 /* =========================================================
   AI CHAT – IMMOBILIENPRO (SCOPED + CONSISTENT)
   - unabhängig vom globalen Light-Theme
   - alle Bubbles identisch (wie Default)
   - AI links, User rechts
   ========================================================= */

.ai-chat{
  padding: 6rem 0;
  background:
    radial-gradient(900px 600px at 20% 20%, rgba(34,197,94,.10), transparent 60%),
    radial-gradient(900px 600px at 80% 40%, rgba(34,197,94,.06), transparent 55%),
    var(--dark);
  color: rgba(255,255,255,.92);
}

/* Überschreibt globale Section-Header (Light Theme) */
.ai-chat .section-title{
  color: rgba(255,255,255,.96);
  text-shadow: 0 0 16px rgba(34,197,94,.10);
}
.ai-chat .section-subtitle{
  color: rgba(255,255,255,.70);
}

/* Container bleibt wie global, aber Chat eigener Look */
.ai-chat .container{
  position: relative;
}

/* GLASS CONTAINER */
.ai-chat .chat-container{
  max-width: 860px;
  margin: 0 auto;
  border-radius: 1.25rem;
  overflow: hidden;

  background: rgba(255,255,255,.055);
  border: 1px solid rgba(34,197,94,.22);

  box-shadow:
    0 30px 60px rgba(0,0,0,.55),
    0 0 0 1px rgba(255,255,255,.03) inset,
    0 0 40px rgba(34,197,94,.18);

  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
}

/* HEADER */
.ai-chat .chat-header{
  background: linear-gradient(180deg, rgba(16,24,20,.95), rgba(10,14,12,.80));
  padding: 1.25rem 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid rgba(34,197,94,.18);
}

.ai-chat .chat-header-left{
  display: flex;
  align-items: center;
  gap: 1rem;
}

.ai-chat .chat-avatar{
  width: 44px;
  height: 44px;
  border-radius: 50%;
  display: grid;
  place-items: center;

  background: rgba(34,197,94,.18);
  border: 1px solid rgba(34,197,94,.45);

  box-shadow:
    0 0 18px rgba(34,197,94,.35),
    0 0 40px rgba(34,197,94,.15);

  color: #fff;
  font-size: 1.3rem;
}

.ai-chat .chat-header-info h4{
  margin: 0;
  color: rgba(255,255,255,.97);
  font-weight: 700;
  letter-spacing: .3px;
  text-shadow: 0 0 14px rgba(34,197,94,.12);
}

.ai-chat .chat-status{
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  color: rgba(34,197,94,.98);
  font-size: .875rem;
}

.ai-chat .chat-status::before{
  content: '';
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: rgba(34,197,94,.95);
  box-shadow: 0 0 12px rgba(34,197,94,.85);
}

.ai-chat .chat-badge{
  background: rgba(34,197,94,.18);
  color: rgba(34,197,94,.95);
  border: 1px solid rgba(34,197,94,.35);
  padding: .35rem .9rem;
  border-radius: 999px;
  font-size: .75rem;
  font-weight: 700;
  letter-spacing: .4px;
  box-shadow: 0 0 20px rgba(34,197,94,.15);
}

/* BODY */
.ai-chat .chat-body{
  padding: 1.5rem;
  min-height: 320px;
  max-height: 440px;
  overflow: auto;

  background: transparent;
  color: rgba(255,255,255,.92);
}

/* Prevent global dimming inside chat */
.ai-chat .chat-body,
.ai-chat .chat-body *{
  opacity: 1 !important;
  filter: none !important;
}

.ai-chat .chat-body::-webkit-scrollbar{ width: 10px; }
.ai-chat .chat-body::-webkit-scrollbar-thumb{
  background: rgba(34,197,94,.25);
  border-radius: 999px;
}

/* ===============================
   CHAT STRUCTURE + DEFAULT BUBBLES
   (AI left, User right)
================================ */

/* Chat list */
.ai-chat .chat-body{
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* Row wrapper */
.ai-chat .chat-message{
  display: flex;
  align-items: flex-end;
  gap: 12px;
  width: 100%;
}

/* Row wrapper */
.ai-chat .chat-message{
  display: flex;
  align-items: flex-end;
  gap: 12px;
  width: 100%;
}

/* AI left */
.ai-chat .chat-message.is-ai{
  justify-content: flex-start;
  flex-direction: row;
}

/* USER right (wichtig: ANDOCKEN + Abstand links) */
.ai-chat .chat-message.is-user{
  justify-content: flex-end;     /* dockt nach rechts */
  flex-direction: row-reverse;   /* Avatar rechts */
}

/* Optional: damit die Bubble wirklich rechts bleibt */
.ai-chat .chat-message.is-user .chat-message-content{
  margin-left: auto;
}

/* Optional: AI-Bubble bleibt links */
.ai-chat .chat-message.is-ai .chat-message-content{
  margin-right: auto;
}

/* Avatar */
.ai-chat .chat-message-avatar{
  width: 38px;
  height: 38px;
  border-radius: 999px;
  display: grid;
  place-items: center;
  flex-shrink: 0;

  background: rgba(34,197,94,.14);
  border: 1px solid rgba(34,197,94,.35);
  color: #fff;

  box-shadow: 0 0 16px rgba(34,197,94,.20);
}

/* Bubble = exakt “Default Card” Feeling (deutlich sichtbar) */
.ai-chat .chat-message-content{
  max-width: min(640px, 78%);
  padding: 14px 16px;

  border-radius: 14px;
  border: 1px solid rgba(255,255,255,.14);

  /* stärkere Card-Fläche wie im Screenshot bei Default */
  background: rgba(255,255,255,.10);
  color: rgba(255,255,255,.95);

  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);

  box-shadow:
    0 10px 26px rgba(0,0,0,.35),
    0 0 22px rgba(34,197,94,.10);

  text-shadow: 0 0 10px rgba(34,197,94,.06);
}

/* Text */
.ai-chat .chat-message-content p{
  margin: 0;
  font-weight: 600;
  line-height: 1.55;
}

/* Time */
.ai-chat .chat-time{
  display: inline-block;
  margin-top: 8px;
  font-size: 12px;
  color: rgba(255,255,255,.70);
}

/* TYPING bubble uses same bubble */
.ai-chat .chat-message-content.chat-typing{
  display: inline-flex;
  gap: 6px;
  align-items: center;
  padding: 12px 14px;
}

.ai-chat .chat-typing .dot{
  width: 7px;
  height: 7px;
  border-radius: 999px;
  background: rgba(34,197,94,.85);
  box-shadow: 0 0 10px rgba(34,197,94,.70);
  animation: typingBounce 1.1s infinite ease-in-out;
}

.ai-chat .chat-typing .dot:nth-child(2){ animation-delay: .15s; }
.ai-chat .chat-typing .dot:nth-child(3){ animation-delay: .3s; }

@keyframes typingBounce{
  0%,100%{ transform: translateY(0); opacity: .6; }
  50%{ transform: translateY(-4px); opacity: 1; }
}

/* SUGGESTIONS */
.ai-chat .chat-suggestions{
  padding: .5rem 1.5rem 1.2rem;
}

.ai-chat .chat-suggestions-title{
  font-size: .9rem;
  color: rgba(255,255,255,.85);
  font-weight: 600;
  margin: 0 0 .7rem 0;
}

.ai-chat .chat-suggestion-tags{
  display: flex;
  flex-wrap: wrap;
  gap: .6rem;
}

.ai-chat .chat-suggestion{
  padding: .65rem 1rem;
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.16);
  border-radius: 999px;
  font-size: .875rem;
  color: rgba(255,255,255,.88);
  cursor: pointer;
  transition: all .2s ease;
}

.ai-chat .chat-suggestion:hover{
  transform: translateY(-2px);
  border-color: rgba(34,197,94,.55);
  background: rgba(34,197,94,.16);
  box-shadow: 0 0 25px rgba(34,197,94,.25);
  color: #fff;
}

/* INPUT */
.ai-chat .chat-input{
  display: flex;
  gap: .8rem;
  padding: 1.2rem 1.5rem 1.5rem;
  border-top: 1px solid rgba(34,197,94,.18);
  background: linear-gradient(180deg, rgba(0,0,0,0), rgba(0,0,0,.25));
}

.ai-chat .chat-input-field{
  flex: 1;
  height: 48px;
  border-radius: 999px;
  padding: 0 1.2rem;

  background: rgba(255,255,255,.07);
  border: 1px solid rgba(255,255,255,.18);

  color: #fff;
  font-size: .95rem;

  outline: none;
  transition: all .2s ease;
}

.ai-chat .chat-input-field::placeholder{
  color: rgba(255,255,255,.6);
}

.ai-chat .chat-input-field:focus{
  border-color: rgba(34,197,94,.55);
  box-shadow:
    0 0 0 4px rgba(34,197,94,.15),
    0 0 30px rgba(34,197,94,.25);
}

.ai-chat .chat-send{
  width: 48px;
  height: 48px;
  border-radius: 999px;

  border: 1px solid rgba(34,197,94,.55);
  background: rgba(34,197,94,.22);

  color: #fff;
  cursor: pointer;

  transition: all .2s ease;
  box-shadow: 0 0 25px rgba(34,197,94,.25);
}

.ai-chat .chat-send:hover{
  transform: translateY(-2px);
  background: rgba(34,197,94,.32);
  box-shadow: 0 0 35px rgba(34,197,94,.35);
}

.ai-chat .chat-send:disabled{
  opacity: .55;
  cursor: not-allowed;
  transform: none;
}

/* RESPONSIVE */
@media (max-width: 640px){
  .ai-chat .chat-message-content{ max-width: 85%; }
  .ai-chat .chat-body{ max-height: 480px; }
}
</style>