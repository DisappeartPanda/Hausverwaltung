---
type Socials = { phone?: string; email?: string; linkedin?: string };

interface Props {
  name: string;
  role: string;
  description: string;
  image: string;
  socials?: Socials;
}

const { name, role, description, image, socials } = Astro.props;
---

<div class="team-card">
  <div class="img-wrap">
    <img src={image} alt={name} loading="lazy" />
  </div>

  <div class="content">
    <h3 class="name">{name}</h3>
    <div class="badge">{role}</div>
    <p class="desc">{description}</p>

    {socials && (
      <div class="social">
        {socials.phone && <a href={socials.phone} aria-label="Telefon">📞</a>}
        {socials.email && <a href={socials.email} aria-label="E-Mail">✉️</a>}
        {socials.linkedin && <a href={socials.linkedin} aria-label="LinkedIn">💼</a>}
      </div>
    )}
  </div>
</div>

<style>
  .team-card{
    height: 100%;
    border-radius: 1.25rem;
    overflow: hidden;
    border: 2px solid rgba(255,255,255,0.10);
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(16px);
    box-shadow: 0 12px 35px rgba(0,0,0,0.35);
    transition: all .25s ease;
  }

  .team-card:hover{
    border-color: rgba(134,239,172,0.35);
    background: rgba(255,255,255,0.06);
    transform: translateY(-2px);
  }

  .img-wrap{
    aspect-ratio: 16/10;
    background: rgba(0,0,0,0.25);
  }

  .img-wrap img{
    width: 100%;
    height: 100%;
    object-fit: cover;
    display:block;
    filter: saturate(1.05) contrast(1.05);
  }

  .content{
    padding: 1.1rem 1.1rem 1.25rem;
    text-align: left;
  }

  .name{
    margin: 0 0 .5rem;
    color: var(--white);
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: -0.01em;
  }

  .badge{
    display: inline-flex;
    align-items: center;
    padding: .35rem .75rem;
    border-radius: 999px;
    font-size: .8rem;
    font-weight: 700;
    background: rgba(134,239,172,0.10);
    border: 1px solid rgba(134,239,172,0.25);
    color: rgba(134,239,172,0.95);
    margin-bottom: .75rem;
  }

  .desc{
    margin: 0;
    color: rgba(255,255,255,0.72);
    font-size: .92rem;
    line-height: 1.45;
    min-height: 2.8em;
  }

  .social{
    display:flex;
    gap: .6rem;
    margin-top: 1rem;
  }

  .social a{
    width: 38px;
    height: 38px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(0,0,0,0.25);
    display:flex;
    align-items:center;
    justify-content:center;
    text-decoration:none;
    color: rgba(255,255,255,0.80);
    transition: all .2s ease;
  }

  .social a:hover{
    border-color: rgba(134,239,172,0.55);
    color: rgba(134,239,172,0.95);
    transform: translateY(-1px);
  }
</style>