---
// Server-seitig: Prüfe ob User eingeloggt ist
const userRole = Astro.cookies.get('userRole')?.value;
const isLoggedIn = !!userRole;
const isLandlord = userRole === 'landlord';
const isTenant = userRole === 'tenant';
---

<nav class="nav" id="navbar">
  <div class="container nav-container">
    <a href="/" class="logo" aria-label="ImmobilienPro Startseite">
      <div class="logo-icon" aria-hidden="true">🏢</div>
      <div class="logo-text">
        <span class="logo-title">ImmobilienPro</span>
        <span class="logo-subtitle">HAUSVERWALTUNG</span>
      </div>
    </a>

    <ul class="nav-links" id="nav-links">
      <li><a href="/#ai">KI-Assistent</a></li>
      <li><a href="/#services">Leistungen</a></li>

      {isLoggedIn && (
        <>
          {isLandlord && (
            <>
              <li><a href="/dashboard">Dashboard</a></li>
              <li><a href="/objekte">Objekte</a></li>
            </>
          )}
          {isTenant && (
            <>
              <li><a href="/mieter-portal">Mein Mietvertrag</a></li>
              <li><a href="/zahlungen">Zahlungen</a></li>
            </>
          )}
        </>
      )}

      <li><a href="/#kontakt">Kontakt</a></li>
    </ul>

    <div class="nav-actions">
      {isLoggedIn ? (
        <div class="user-menu">
          <button class="user-btn" id="user-btn" type="button" aria-haspopup="menu" aria-expanded="false">
            <span class="user-name">{isLandlord ? 'Vermieter' : 'Mieter'}</span>
            <svg class="dropdown-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>

          <div class="dropdown-menu" id="dropdown-menu" role="menu">
            <a role="menuitem" href={isLandlord ? '/profil' : '/mieter-portal'}>
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
              Profil
            </a>

            <a role="menuitem" href="/einstellungen">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              Einstellungen
            </a>

            <hr class="dropdown-divider" />

            <button class="logout-btn" id="logout-btn" type="button" role="menuitem">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
              </svg>
              Abmelden
            </button>
          </div>
        </div>
      ) : (
        <div class="auth-buttons">
          <a href="/login" class="nav-login">Anmelden</a>
          <a href="/registrieren" class="nav-register">Registrieren</a>
        </div>
      )}

      <button class="mobile-menu-btn" id="mobile-menu-btn" type="button" aria-label="Menü öffnen">
        <span class="hamburger" aria-hidden="true"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu">
    <ul class="mobile-nav-links">
      <li><a href="/#ai">KI-Assistent</a></li>
      <li><a href="/#services">Leistungen</a></li>

      {isLoggedIn && (
        <>
          {isLandlord && (
            <>
              <li><a href="/dashboard">Dashboard</a></li>
              <li><a href="/objekte">Objekte</a></li>
            </>
          )}
          {isTenant && <li><a href="/mieter-portal">Mein Portal</a></li>}
        </>
      )}

      <li><a href="/#contact">Kontakt</a></li>

      {!isLoggedIn && (
        <li class="mobile-auth">
          <a href="/login" class="mobile-login">Anmelden</a>
          <a href="/registrieren" class="mobile-register">Registrieren</a>
        </li>
      )}
    </ul>
  </div>
</nav>

<style>
  :root { --nav-height: 72px; }

  .nav{
    position: fixed;
    top:0; left:0; right:0;
    height: var(--nav-height);
    z-index: 1000;

    background: rgba(10, 10, 10, 0.62);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    transition: background .25s ease, box-shadow .25s ease;
  }

  .nav.scrolled{
    background: rgba(10, 10, 10, 0.72);
    box-shadow: 0 10px 40px rgba(0,0,0,0.35);
  }

  .nav-container{
    display:flex;
    align-items:center;
    justify-content:space-between;
    height:100%;
    max-width: 1400px;
    margin:0 auto;
    padding: 0 2rem;
  }

  /* Logo */
  .logo{
    display:flex;
    align-items:center;
    gap:.75rem;
    text-decoration:none;
    transition: transform .2s ease;
  }
  .logo:hover{ transform: scale(1.01); }

  .logo-icon{
    width:42px; height:42px;
    border-radius: .9rem;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:1.5rem;

    background: rgba(134,239,172,0.12);
    border: 1px solid rgba(134,239,172,0.25);
    box-shadow: 0 18px 45px rgba(0,0,0,0.35);
  }

  .logo-text{ display:flex; flex-direction:column; }
  .logo-title{
    font-weight: 800;
    font-size: 1.25rem;
    color: var(--white);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  .logo-subtitle{
    font-size: .7rem;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: .15em;
    font-weight: 600;
  }

  /* Links */
  .nav-links{
    display:flex;
    gap: 2rem;
    list-style:none;
    margin:0;
    padding:0;
  }

  .nav-links a{
    position:relative;
    text-decoration:none;
    font-weight: 650;
    font-size: .95rem;
    padding: .5rem 0;
    color: rgba(255,255,255,0.78);
    transition: color .2s ease, opacity .2s ease;
    opacity: .92;
  }

  .nav-links a:hover{
    opacity: 1;
    color: var(--white);
  }

  .nav-links a::after{
    content:'';
    position:absolute;
    bottom:0; left:0;
    width:0;
    height:2px;
    background: var(--primary);
    transition: width .25s ease;
  }
  .nav-links a:hover::after{ width:100%; }

  /* Actions */
  .nav-actions{ display:flex; align-items:center; gap: 1rem; }

  .auth-buttons{ display:flex; gap:.75rem; }

  .nav-login,
  .nav-register{
    display:flex;
    align-items:center;
    gap:.5rem;
    padding: .6rem 1.25rem;
    border-radius: .75rem;
    text-decoration:none;
    font-weight: 800;
    font-size: .875rem;
    transition: all .2s ease;
    border: 1px solid rgba(255,255,255,0.10);
  }

  .nav-login{
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.92);
  }
  .nav-login:hover{
    background: rgba(255,255,255,0.08);
    border-color: rgba(134,239,172,0.30);
    color: var(--white);
  }

  .nav-register{
    background: var(--primary);
    color: var(--dark);
    border-color: rgba(134,239,172,0.50);
  }
  .nav-register:hover{
    transform: translateY(-1px);
    box-shadow: 0 12px 30px rgba(134,239,172,0.18);
  }

  /* User Menu */
  .user-menu{ position:relative; }

  .user-btn{
    display:flex;
    align-items:center;
    gap:.5rem;
    padding: .55rem 1rem;
    border-radius: 999px;
    cursor:pointer;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.10);
    color: rgba(255,255,255,0.92);
    transition: all .2s ease;
    font-size: .875rem;
    font-weight: 800;
  }
  .user-btn:hover{
    background: rgba(255,255,255,0.08);
    border-color: rgba(134,239,172,0.30);
    color: var(--white);
  }

  .user-avatar{ font-size:1.15rem; }
  .user-name{ display:none; }
  @media (min-width:1024px){ .user-name{ display:inline; } }

  .dropdown-icon{ width:1rem; height:1rem; transition: transform .2s ease; }
  .user-menu.open .dropdown-icon{ transform: rotate(180deg); }

  .dropdown-menu{
    position:absolute;
    top: calc(100% + .6rem);
    right:0;
    min-width: 220px;
    padding: .5rem;
    border-radius: 1rem;
    background: rgba(10,10,10,0.72);
    border: 1px solid rgba(255,255,255,0.10);
    backdrop-filter: blur(18px);
    box-shadow: 0 18px 55px rgba(0,0,0,0.45);
    opacity:0;
    visibility:hidden;
    transform: translateY(-10px);
    transition: all .2s ease;
    z-index: 1001;
  }

  .user-menu.open .dropdown-menu{
    opacity:1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-menu a,
  .dropdown-menu button{
    display:flex;
    align-items:center;
    gap:.75rem;
    width:100%;
    padding: .75rem 1rem;
    border-radius: .75rem;
    text-decoration:none;
    font-size:.9rem;
    font-weight: 650;
    color: rgba(255,255,255,0.86);
    border: 1px solid transparent;
    background:none;
    cursor:pointer;
    text-align:left;
    transition: background .15s ease, border-color .15s ease, color .15s ease;
  }

  .dropdown-menu a:hover,
  .dropdown-menu button:hover{
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.10);
    color: var(--white);
  }

  .dropdown-menu svg{
    width:1.2rem;
    height:1.2rem;
    opacity:.9;
  }

  .dropdown-divider{
    margin:.5rem;
    border:none;
    border-top: 1px solid rgba(255,255,255,0.10);
  }

  .logout-btn{ color: var(--error) !important; }
  .logout-btn svg{ color: var(--error) !important; }

  /* Mobile Menu Button */
  .mobile-menu-btn{
    display:none;
    width:40px; height:40px;
    background:none;
    border:none;
    cursor:pointer;
    padding:0;
    position:relative;
  }

  .hamburger{
    display:block;
    width:24px;
    height:2px;
    background: rgba(255,255,255,0.9);
    position:absolute;
    left:8px;
    top:50%;
    transform: translateY(-50%);
    transition: all .2s ease;
  }

  .hamburger::before,
  .hamburger::after{
    content:'';
    position:absolute;
    width:24px;
    height:2px;
    background: rgba(255,255,255,0.9);
    transition: all .2s ease;
  }
  .hamburger::before{ top:-7px; }
  .hamburger::after{ top:7px; }

  .mobile-menu-btn.active .hamburger{ background: transparent; }
  .mobile-menu-btn.active .hamburger::before{ top:0; transform: rotate(45deg); }
  .mobile-menu-btn.active .hamburger::after{ top:0; transform: rotate(-45deg); }

  /* Mobile Menu */
  .mobile-menu{
    display:none;
    position:absolute;
    top: var(--nav-height);
    left:0; right:0;
    padding: 1.25rem;

    background: rgba(10,10,10,0.80);
    border-bottom: 1px solid rgba(255,255,255,0.10);
    backdrop-filter: blur(18px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.45);
  }
  .mobile-menu.active{ display:block; }

  .mobile-nav-links{
    list-style:none;
    padding:0; margin:0;
    display:flex;
    flex-direction:column;
    gap:.5rem;
  }

  .mobile-nav-links a{
    display:block;
    padding: .95rem 1rem;
    text-decoration:none;
    font-weight: 700;
    border-radius: .75rem;
    color: rgba(255,255,255,0.86);
    transition: all .15s ease;
  }

  .mobile-nav-links a:hover{
    background: rgba(255,255,255,0.06);
    color: var(--white);
  }

  .mobile-auth{
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255,255,255,0.10);
    display:flex;
    flex-direction:column;
    gap:.75rem;
  }

  .mobile-login,
  .mobile-register{
    display:block;
    padding: 1rem;
    text-align:center;
    border-radius: .75rem;
    text-decoration:none;
    font-weight: 800;
  }

  .mobile-login{
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.92);
    border: 1px solid rgba(255,255,255,0.10);
  }

  .mobile-register{
    background: var(--primary);
    color: var(--dark);
    border: 1px solid rgba(134,239,172,0.45);
  }

  @media (max-width:1024px){
    .nav-links{ display:none; }
    .mobile-menu-btn{ display:block; }
    .auth-buttons{ display:none; }
    .user-name{ display:none; }
  }

  @media (max-width:640px){
    .nav-container{ padding: 0 1rem; }
    .logo-title{ font-size: 1.1rem; }
    .logo-subtitle{ display:none; }
  }
</style>

<script>
  // Scroll-Effekt
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) navbar?.classList.add('scrolled');
    else navbar?.classList.remove('scrolled');
  });

  // User Dropdown
  const userBtn = document.getElementById('user-btn');
  const userMenu = userBtn?.closest('.user-menu');

  userBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    userMenu?.classList.toggle('open');
    userBtn.setAttribute('aria-expanded', userMenu?.classList.contains('open') ? 'true' : 'false');
  });

  document.addEventListener('click', () => {
    userMenu?.classList.remove('open');
    userBtn?.setAttribute('aria-expanded', 'false');
  });

  // Logout
  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    try {
      const res = await fetch('/api/logout', { method: 'POST' });
      if (res.ok) window.location.href = '/';
    } catch (err) {
      console.error('Logout fehlgeschlagen:', err);
    }
  });

  // Mobile Menu
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileBtn?.addEventListener('click', () => {
    mobileBtn.classList.toggle('active');
    mobileMenu?.classList.toggle('active');
  });

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileBtn?.classList.remove('active');
      mobileMenu?.classList.remove('active');
    });
  });
</script>