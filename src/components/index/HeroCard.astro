---
interface Props {
  userRole?: 'guest' | 'tenant' | 'landlord';
}

const { userRole = 'guest' } = Astro.props;

const ownerServices = [
  { icon: '📄', title: 'Abrechnungen einsehen', desc: 'Nebenkosten- & Heizkostenabrechnung' },
  { icon: '🔧', title: 'Instandhaltung', desc: 'Wartung & Reparaturen verwalten' },
  { icon: '📈', title: 'Mieteinnahmen', desc: 'Übersicht & Auszahlungen' },
  { icon: '🏠', title: 'Objektübersicht', desc: 'Alle Immobilien auf einen Blick' },
  { icon: '👥', title: 'Mieter verwalten', desc: 'Verträge & Kommunikation' },
];

const tenantServices = [
  { icon: '📄', title: 'Mietvertrag', desc: 'Vertragsdetails & Dokumente' },
  { icon: '🔧', title: 'Mangel melden', desc: 'Reparaturanfrage stellen' },
  { icon: '💬', title: 'Nachricht senden', desc: 'Direkt mit Verwaltung kontaktieren' },
  { icon: '💰', title: 'Mietzahlungen', desc: 'Zahlungsübersicht & Quittungen' },
  { icon: '📊', title: 'Nebenkosten', desc: 'Abrechnungen einsehen' },
];

let displayServices: typeof ownerServices = [];

if (userRole === 'landlord') {
  displayServices = ownerServices;
} else if (userRole === 'tenant') {
  displayServices = tenantServices;
} else {
  displayServices = [...ownerServices.slice(0, 3), ...tenantServices.slice(0, 3)];
}
---

<div class="card" data-role={userRole}>
  <div class="head">
    <h3 class="title">
      {userRole === 'guest' && 'Womit können wir Ihnen helfen?'}
      {userRole === 'landlord' && 'Ihre Vermieter-Übersicht'}
      {userRole === 'tenant' && 'Ihre Mieter-Übersicht'}
    </h3>

    <p class="sub">
      {userRole === 'guest' && 'Wechseln Sie die Ansicht und entdecken Sie Features.'}
      {userRole === 'landlord' && 'Schnellzugriff auf Ihre wichtigsten Bereiche.'}
      {userRole === 'tenant' && 'Alles Wichtige rund um Ihre Wohnung.'}
    </p>
  </div>

  {userRole === 'guest' && (
    <div class="tabs" role="tablist" aria-label="Rollen-Auswahl">
      <button class="tab active role-tab" type="button" onclick="switchTab('owner')" role="tab" aria-selected="true">
        <span aria-hidden="true">🏢</span>
        <span>Eigentümer</span>
      </button>
      <button class="tab role-tab" type="button" onclick="switchTab('tenant')" role="tab" aria-selected="false">
        <span aria-hidden="true">🔑</span>
        <span>Mieter</span>
      </button>
    </div>
  )}

  {userRole === 'guest' ? (
    <>
      <div class="list" id="owner-services">
        {ownerServices.slice(0, 3).map((service) => (
          <div class="item">
            <div class="ico" aria-hidden="true">{service.icon}</div>
            <div class="txt">
              <h4>{service.title}</h4>
              <p>{service.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="list" id="tenant-services" style="display:none;">
        {tenantServices.slice(0, 3).map((service) => (
          <div class="item">
            <div class="ico" aria-hidden="true">{service.icon}</div>
            <div class="txt">
              <h4>{service.title}</h4>
              <p>{service.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="notice">
        <span class="notice-dot" aria-hidden="true"></span>
        <span>
          Demo-Ansicht – <a href="/login">Jetzt einloggen</a> für alle Features
        </span>
      </div>
    </>
  ) : (
    <div class="list">
      {displayServices.map((service) => (
        <a href="#" class="item item-link">
          <div class="ico" aria-hidden="true">{service.icon}</div>
          <div class="txt">
            <h4>{service.title}</h4>
            <p>{service.desc}</p>
          </div>
          <span class="chev" aria-hidden="true">→</span>
        </a>
      ))}
    </div>
  )}

  <div class="ai">
    <div class="ai-ico" aria-hidden="true">🤖</div>
    <div class="ai-txt">
      <h4>KI-Assistent verfügbar</h4>
      <p>
        {userRole === 'guest'
          ? 'Stellen Sie Fragen – rund um die Uhr!'
          : 'Persönlicher Support für Sie – 24/7!'}
      </p>
    </div>
  </div>
</div>

<style>
  .card{
    background: rgba(255,255,255,0.05);
    border: 2px solid var(--dark-lighter);
    border-radius: 1.5rem;
    padding: clamp(1.25rem, 2.2vw, 1.75rem);
    backdrop-filter: blur(20px);
    box-shadow: 0 25px 60px rgba(0,0,0,0.45);
  }

  .head{ margin-bottom: 1rem; }
  .title{
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--white);
    margin: 0;
    letter-spacing: -0.01em;
  }
  .sub{
    margin-top: .35rem;
    color: rgba(255,255,255,0.68);
    font-size: .9rem;
    line-height: 1.4;
  }

  /* Tabs (Guest) */
  .tabs{
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .6rem;
    margin: 1rem 0 1rem;
  }

  .tab{
    border-radius: 1rem;
    padding: .75rem .9rem;
    border: 2px solid rgba(255,255,255,0.10);
    background: rgba(255,255,255,0.04);
    color: rgba(255,255,255,0.82);
    cursor: pointer;
    transition: all .2s ease;
    display:flex;
    align-items:center;
    justify-content:center;
    gap:.5rem;
    font-weight: 800;
    font-size: .9rem;
  }

  .tab:hover{
    background: rgba(255,255,255,0.06);
    border-color: rgba(134,239,172,0.25);
    transform: translateY(-1px);
  }

  .tab.active{
    background: rgba(134,239,172,0.14);
    border-color: rgba(134,239,172,0.35);
    color: var(--white);
    box-shadow: 0 10px 35px rgba(134,239,172,0.10);
  }

  /* Services */
  .list{
    display:flex;
    flex-direction:column;
    gap: .75rem;
  }

  .item{
    display:flex;
    align-items:flex-start;
    gap: .9rem;
    padding: .9rem 1rem;
    border-radius: 1.1rem;
    border: 1px solid rgba(255,255,255,0.10);
    background: rgba(255,255,255,0.04);
    transition: all .2s ease;
    text-decoration: none;
  }

  .item:hover{
    background: rgba(255,255,255,0.06);
    border-color: rgba(134,239,172,0.22);
    transform: translateY(-1px);
  }

  .ico{
    width: 44px;
    height: 44px;
    border-radius: 1rem;
    display:flex;
    align-items:center;
    justify-content:center;
    flex: 0 0 auto;

    background: rgba(134,239,172,0.12);
    border: 1px solid rgba(134,239,172,0.20);
    color: var(--primary);
    font-size: 1.2rem;
  }

  .txt h4{
    margin: 0;
    font-weight: 800;
    color: rgba(255,255,255,0.92);
    font-size: .95rem;
  }
  .txt p{
    margin-top: .2rem;
    margin-bottom: 0;
    color: rgba(255,255,255,0.64);
    font-size: .85rem;
    line-height: 1.35;
  }

  .item-link{ cursor: pointer; }
  .chev{
    margin-left: auto;
    color: rgba(255,255,255,0.55);
    font-weight: 900;
  }

  /* Demo Notice */
  .notice{
    margin-top: .9rem;
    display:flex;
    align-items:center;
    gap: .65rem;
    padding: .75rem .9rem;
    border-radius: 1rem;

    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.10);
    color: rgba(255,255,255,0.70);
    font-size: .85rem;
  }

  .notice a{
    color: var(--primary);
    font-weight: 800;
    text-decoration: none;
  }
  .notice a:hover{ text-decoration: underline; }

  .notice-dot{
    width: .55rem;
    height: .55rem;
    border-radius: 999px;
    background: var(--primary);
    box-shadow: 0 0 0 4px rgba(134,239,172,0.14);
    flex: 0 0 auto;
  }

  /* AI Banner */
  .ai{
    margin-top: 1rem;
    display:flex;
    align-items:center;
    gap: .9rem;

    padding: .95rem 1rem;
    border-radius: 1.1rem;
    background: rgba(134,239,172,0.10);
    border: 1px solid rgba(134,239,172,0.22);
  }

  .ai-ico{
    width: 42px;
    height: 42px;
    border-radius: 1rem;
    display:flex;
    align-items:center;
    justify-content:center;

    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    color: var(--white);
  }

  .ai-txt h4{
    margin: 0;
    font-weight: 900;
    color: var(--white);
    font-size: .95rem;
  }

  .ai-txt p{
    margin: .2rem 0 0;
    color: rgba(255,255,255,0.70);
    font-size: .85rem;
    line-height: 1.35;
  }
</style>