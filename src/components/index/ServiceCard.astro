---
interface Props {
  icon: string;
  title: string;
  description: string;
  features: string[];
  featured?: boolean;
  isNew?: boolean;
}

const { icon, title, description, features, featured = false, isNew = false } = Astro.props;
---

<article class={`service-card ${featured ? 'featured' : ''}`}>
  <header class="top">
    <div class="icon" aria-hidden="true">{icon}</div>

    <div class="heading">
      <h3 class="title">
        {title}
        {isNew && <span class="new-badge">Neu</span>}
      </h3>
      <p class="desc">{description}</p>
    </div>
  </header>

  <ul class="feature-list">
    {features.map((feature) => (
      <li class="feature">{feature}</li>
    ))}
  </ul>

  {featured && <div class="glow" aria-hidden="true"></div>}
</article>

<style>
.service-card{
  position: relative;
  overflow: hidden;

  background: rgba(255,255,255,0.06);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 1.5rem;

  padding: 1.75rem;
  transition: all .25s ease;
  box-shadow: 0 18px 40px rgba(0,0,0,0.30);
}

.service-card:hover{
  border-color: rgba(134,239,172,0.45);
  background: rgba(255,255,255,0.08);
  transform: translateY(-3px);
}

/* FEATURED stärker */
.service-card.featured{
  border: 1px solid rgba(134,239,172,0.55);
  background: linear-gradient(
    135deg,
    rgba(134,239,172,0.08),
    rgba(255,255,255,0.06)
  );
}

/* ICON */
.icon{
  width: 56px;
  height: 56px;
  border-radius: 1rem;
  display:flex;
  align-items:center;
  justify-content:center;

  background: rgba(134,239,172,0.15);
  border: 1px solid rgba(134,239,172,0.25);
  color: var(--primary);

  font-size: 1.35rem;
}

/* TITLE heller + grüner Akzent */
.title{
  margin: 0 0 .5rem 0;
  font-size: 1.2rem;
  font-weight: 900;
  letter-spacing: -0.01em;
  color: #ffffff;
}

.service-card.featured .title{
  color: var(--primary);
}

/* DESCRIPTION deutlich heller */
.desc{
  margin: 0 0 1.25rem 0;
  color: rgba(255,255,255,0.85);
  font-size: 0.97rem;
  line-height: 1.6;
}

/* FEATURES */
.feature-list{
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  gap: .8rem;
}

.feature{
  display:flex;
  align-items:flex-start;
  gap: .7rem;

  color: #ffffff;               /* <<< jetzt richtig hell */
  font-size: .95rem;
  font-weight: 500;
  line-height: 1.4;
}

.feature::before{
  content: '✓';
  width: 22px;
  height: 22px;
  border-radius: 999px;

  display:flex;
  align-items:center;
  justify-content:center;

  background: rgba(134,239,172,0.18);
  border: 1px solid rgba(134,239,172,0.35);
  color: var(--primary);

  font-size: .75rem;
  font-weight: 900;
  flex: 0 0 auto;
  margin-top: 2px;
}

/* NEW BADGE */
.new-badge{
  display:inline-flex;
  align-items:center;
  padding: .25rem .6rem;
  border-radius: 999px;

  font-size: .7rem;
  font-weight: 900;

  background: rgba(134,239,172,0.18);
  color: var(--primary);
  border: 1px solid rgba(134,239,172,0.35);
}
</style>