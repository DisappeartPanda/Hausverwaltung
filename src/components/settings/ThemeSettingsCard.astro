---
import { THEMES } from "../../lib/themes/theme-definitions";
---

<section class="panel">
  <div class="panel__body stack">
    <div class="section__header">
      <span class="section__eyebrow">Design</span>
      <h2>Wähle dein Theme</h2>
      <p>
        Das Theme wird lokal gespeichert und direkt auf die Oberfläche angewendet.
      </p>
    </div>

    <div class="grid-auto">
      {
        THEMES.map((theme) => (
          <article class="card card--glass card--glow theme-card" data-theme-card={theme.key}>
            <div class="card__body stack">
              <span class="badge badge--accent">{theme.label}</span>
              <h3>{theme.label}</h3>
              <p>{theme.description}</p>

              <div class="theme-preview" data-theme-preview={theme.key}>
                <div class="theme-preview__top"></div>
                <div class="theme-preview__body">
                  <div class="theme-preview__card"></div>
                  <div class="theme-preview__card"></div>
                </div>
              </div>

              <button
                class="button button--primary js-theme-button"
                type="button"
                data-theme-value={theme.key}
              >
                Theme auswählen
              </button>
            </div>
          </article>
        ))
      }
    </div>

    <p class="theme-status" id="theme-status" aria-live="polite"></p>
  </div>
</section>

<script>
  const STORAGE_KEY = "immobilienpro-theme";
  const buttons = document.querySelectorAll(".js-theme-button");
  const statusEl = document.querySelector("#theme-status");

  async function saveTheme(theme) {
    try {
      await fetch("/api/settings/theme", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ theme })
      });
    } catch {
      // bewusst still, local fallback reicht erstmal
    }
  }

  function setActiveTheme(theme) {
    document.documentElement.setAttribute("data-theme", theme);
    localStorage.setItem(STORAGE_KEY, theme);

    if (statusEl) {
      statusEl.textContent = `Aktives Theme: ${theme}`;
    }
  }

  buttons.forEach((button) => {
    button.addEventListener("click", async () => {
      const theme = button.dataset.themeValue;
      if (!theme) return;

      setActiveTheme(theme);
      await saveTheme(theme);
    });
  });
</script>

<style>
  .theme-preview {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    min-height: 9rem;
    background: var(--surface);
  }

  .theme-preview__top {
    height: 2rem;
    border-bottom: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.04);
  }

  .theme-preview__body {
    padding: var(--space-4);
    display: grid;
    gap: var(--space-3);
  }

  .theme-preview__card {
    height: 2rem;
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.08);
  }

  .theme-status {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }
</style>